onds):\n            if idx1 >= idx2: continue\n            shared = set([i1,j1]) & set([i2,j2])\n            if len(shared) == 1:\n                shared_atom = shared.pop()\n                a = positions[i1 if i1 != shared_atom else j1] - positions[shared_atom]\n                b = positions[i2 if i2 != shared_atom else j2] - positions[shared_atom]\n                cos_angle = np.dot(a, b) / (np.linalg.norm(a) * np.linalg.norm(b) + 1e-8)\n                cos_angle = np.clip(cos_angle, -1, 1)\n                angle = np.arccos(cos_angle)\n                edge_index.append([idx1, idx2])\n                edge_index.append([idx2, idx1])\n                edge_attr.extend([[angle], [angle]])\n    \n    edge_index = torch.tensor(edge_index, dtype=torch.long).t().contiguous() if edge_index else torch.zeros((2,0), dtype=torch.long)\n    edge_attr = torch.tensor(edge_attr, dtype=torch.float) if edge_attr else torch.zeros((0,1), dtype=torch.float)\n    \n    y = torch.tensor([target_value], dtype=torch.float)\n    u = torch.tensor([[structure.volume / len(positions), 1, structure.lattice.volume]], dtype=torch.float)\n    \n    return Data(x=x, edge_index=edge_index, edge_attr=edge_attr, y=y, u=u)","metadata":{"execution":{"iopub.status.busy":"2025-11-15T18:39:38.550528Z","iopub.execute_input":"2025-11-15T18:39:38.551035Z","iopub.status.idle":"2025-11-15T18:39:38.558773Z","shell.execute_reply.started":"2025-11-15T18:39:38.551011Z","shell.execute_reply":"2025-11-15T18:39:38.558131Z"}}},{"cell_type":"markdown","source":"## Convert crystal structure to atom graph (nodes=atoms, edges=distances)","metadata":{}},{"cell_type":"markdown","source":"def structure_to_graph2(structure, target_value, df_features):\n    structure = structure.copy()\n    structure.make_supercell([3, 3, 3])\n    \n    node_features = []\n    atomic_numbers = []\n    \n    for site in structure.sites:\n        symbol = site.specie.symbol\n        atomic_numbers.append(site.specie.Z)\n        \n        # فقط فی