])\n        if not lattice or len(lattice) != 3:\n            print(f\"⛔ Skipping {file} - invalid lattice structure\")\n            continue\n\n        # طول بردارهای شبکه\n        a = np.linalg.norm(lattice[0])\n        b = np.linalg.norm(lattice[1])\n        c = np.linalg.norm(lattice[2])\n\n        # --- استخراج reciprocal_lattice ---\n        reciprocal_lattice = data.get('reciprocal_lattice', [])\n        if not reciprocal_lattice or len(reciprocal_lattice) != 3:\n            print(f\"⛔ Skipping {file} - invalid reciprocal_lattice structure\")\n            continue\n\n        # طول بردارهای شبکه متقابل\n        a_star = np.linalg.norm(reciprocal_lattice[0])\n        b_star = np.linalg.norm(reciprocal_lattice[1])\n        c_star = np.linalg.norm(reciprocal_lattice[2])\n\n        # ذخیره داده‌ها در یک دیکشنری\n        data_row = {\n            'file': file,\n            'num_atoms': num_atoms,\n            'avg_mass': avg_mass,\n            'a': a,\n            'b': b,\n            'c': c,\n            'a_star': a_star,\n            'b_star': b_star,\n            'c_star': c_star\n        }\n        data_list.append(data_row)\n\n    except Exception as e:\n        print(f\"⚠️ Error in file {file}: {e}\")\n\n# تبدیل داده‌ها به دیتافریم\ndf = pd.DataFrame(data_list)\n\n# --- تحلیل آماری اولیه ---\nprint(\"\\n=== تحلیل آماری اولیه ===\")\nprint(df.describe())\n\n# --- بررسی داده‌های گمشده ---\nprint(\"\\n=== داده‌های گمشده ===\")\nprint(df.isnull().sum())\n\n# --- نرمال‌سازی داده‌ها برای همبستگی ---\n# انتخاب ستون‌های عددی برای محاسبه همبستگی\nnumeric_cols = ['num_atoms', 'avg_mass', 'a', 'b', 'c', 'a_star', 'b_star', 'c_star']\ndf_numeric = df[numeric_cols]\n\n# نرمال‌سازی داده‌ها\nscaler = StandardScaler()\ndf_scaled = pd.DataFrame(scaler.fit_transform(df_numeric), columns=df_numeric.columns)\n\n# --- محاسبه ماتریس همبستگی ---\nprint(\"\\n=== ماتریس همبستگی ===\")\ncorrelation_matrix = df_scaled.corr()\nprint(correlation_matrix)\n\n# --- رسم ماتریس همبستگی با hea