===================================================================\n✅ Simple model trained successfully!\n================================================================================\n","output_type":"stream"}],"execution_count":2},{"cell_type":"code","source":"  \"\"\"\nPhonon Band Calculator & Evaluation\nCalculate phonon bands from predicted IFCs and compare with ground truth\n\"\"\"\n\nimport os\nimport numpy as np\nimport tensorflow as tf\nfrom scipy.linalg import eigh\nimport matplotlib.pyplot as plt\n\nDATA_DIR = \"./physics_informed_dataset\"\nMODEL_DIR = \"./simple_gnn_results\"\nOUTPUT_DIR = \"./phonon_evaluation\"\nos.makedirs(OUTPUT_DIR, exist_ok=True)\n\nprint(\"=\"*80)\nprint(\"PHONON BAND CALCULATION & EVALUATION\")\nprint(\"=\"*80)\n\n# Load data and model\ntest_data = np.load(os.path.join(DATA_DIR, \"test_data.npy\"), allow_pickle=True)\nmetadata = np.load(os.path.join(DATA_DIR, \"metadata.npy\"), allow_pickle=True).item()\n\n# Load IFC normalization parameters\ntrain_data = np.load(os.path.join(DATA_DIR, \"train_data.npy\"), allow_pickle=True)\nall_samples = list(train_data)\nall_ifcs_orig = []\nfor s in all_samples:\n    # Load original (before normalization)\n    all_ifcs_orig.append(s['force_constants'].flatten())\n\n# We need to reload original data to get unnormalized IFCs\n# For now, we'll use the mean/std we computed\nIFC_MEAN = 0.057384\nIFC_STD = 0.937712\n\nprint(f\"✓ Test samples: {len(test_data)}\")\nprint(f\"✓ IFC normalization: mean={IFC_MEAN:.6f}, std={IFC_STD:.6f}\")\n\n# ==========================================\n# Phonon Calculation from Force Constants\n# ==========================================\ndef calculate_phonon_frequencies(force_constants, masses, q_point=None):\n    \"\"\"\n    Calculate phonon frequencies from force constants.\n    \n    Args:\n        force_constants: (n_atoms, n_atoms, 3, 3) array\n        masses: (n_atoms,) array of atomic masses in amu\n        q_point: wave vector (optional, defaults to Gamma point)\n    \n    Returns:\n        frequencies: (3*n_atoms,) array in THz\n    \"\"\"\n    n_atoms = len(masses)\n    \n    if q_point is None:\n        q_point = np.array([0.0, 0.0, 0.0])  # Gamma point\n    \n    # Build dynamical matrix\n    # D_ij^αβ = (1/√(m_i * m_j)) * Φ_ij^αβ * exp(i q·R_ij)\n    \n    dynamical_matrix = np.zeros((3*n_atoms, 3*n_atoms), dtype=np.complex128)\n    \n    for i in range(n_atoms):\n        for j in range(n_atoms):\n            # Mass normalization\n            mass_factor = 1.0 / np.sqrt(masses[i] * masses[j])\n            \n            # Extract 3x3 force constant block\n            fc_block = force_constants[i, j, :, :]\n            \n            # Phase factor (for Gamma point, this is 1)\n            phase = np.exp(1j * np.dot(q_point, np.zeros(3)))\n            \n            # Fill dynamical matrix\n            dynamical_matrix[3*i:3*i+3, 3*j:3*j+3] = mass_factor * fc_block * phase\n    \n    # Convert units: eV/Å² → THz²\n    # 1 eV/Å²/amu = 98.22 THz²\n    conversion_factor = 98.22\n    dynamical_matrix *= conversion_factor\n    \n    # Make hermitian (should already be, but ensure numerically)\n    dynamical_matrix = (dynamical_matrix + dynamical_matrix.conj().T) / 2\n    \n    # Diagonalize\n    eigenvalues = np.linalg.eigvalsh(dynamical_matrix)\n    \n    # Convert to frequencies (ω = √λ)\n    # Handle negative eigenvalues (imaginary frequencies)\n    frequencies = np.zeros_like(eigenvalues, dtype=np.float64)\n    positive_mask = eigenvalues >= 0\n    frequencies[positive_mask] = np.sqrt(eigenvalues[positive_mask])\n    frequencies[~positive_mask] = -np.sqrt(-eigenvalues[~positive_mask])\n    \n    return frequencies\n\ndef get_atomic_masses(elements):\n    \"\"\"Get atomic masses for elements.\"\"\"\n    # Common atomic masses (amu)\n    mass_dict = {\n        'Ti': 47.867, 'V': 50.942, 'Cr': 51.996, 'Zr': 91.224, 'Nb': 92.906,\n        'Mo': 95.95, 'Hf': 178.49, 'Ta': 180.948, 'W': 183.84,\n        'Al': 26.982, 'Si': 28.085, 'Ga': 69.723, 'Ge': 72.630, 'In': 114.818,\n        'Sn': 118.710, 'Tl': 204.383, 'Pb': 207.2, 'Bi': 208.980,\n        'C': 12.011, 'N': 14.007, 'As': 74.922, 'Au': 196.967, 'Cu': 63.546,\n        'Cd': 112.414, 'Zn': 65.38, 'Ag': 107.868\n    }\n    \n    masses = []\n    for elem in elements:\n        if elem in mass_dict:\n            masses.append(mass_dict[elem])\n        else:\n            # Default to carbon mass if unknown\n            print(f\"⚠ Unknown element {elem}, using default mass\")\n            masses.append(12.0)\n    \n    return np.array(masses)\n\n# ==========================================\n# Evaluation on Test Set\n# ==========================================\nprint(\"\\n\" + \"─\"*80)\nprint(\"Calculating Phonon Frequencies for Test Set\")\nprint(\"─\"*80)\n\n# We need the actual phonon data to compare\n# Check if we have phonon bands in the original data\nBANDS_DIR = \"/kaggle/input/pgcnndata/extracted_bands_C\"\n\nif not os.path.exists(BANDS_DIR):\n    print(\"⚠ Warning: Phonon bands directory not found\")\n    print(\"Will only evaluate IFC predictions\")\nelse:\n    print(f\"✓ Bands directory found: {BANDS_DIR}\")\n\n# For now, let's evaluate the IFC predictions\n# Calculate frequencies at Gamma point for test samples\n\nprint(\"\\nEvaluating Force Constants predictions...\")\n\nresults = []\n\nfor idx, sample in enumerate(test_data[:10]):  # Test on first 10 samples\n    formula = sample['formula']\n    n_atoms = sample['n_atoms']\n    \n    # Get predicted IFCs (normalized)\n    ifc_pred_norm = sample['force_constants']\n    \n    # Denormalize\n    ifc_pred = ifc_pred_norm * IFC_STD + IFC_MEAN\n    \n    # Get atomic masses\n    elements = sample['elements']\n    masses = get_atomic_masses(elements)\n    \n    # Calculate phonon frequencies\n    try:\n        frequencies = calculate_phonon_frequencies(ifc_pred, masses)\n        \n        # Sort and take only acoustic + optical modes\n        frequencies_sorted = np.sort(frequencies)\n        \n        print(f\"\\n{idx+1}. {formula} (n_atoms={n_atoms})\")\n        print(f\"   Frequencies (THz): {frequencies_sorted[:6]}\")  # First 6 modes\n        \n        # Check for imaginary modes (negative frequencies)\n        n_imaginary = np.sum(frequencies < -0.1)\n        if n_imaginary > 3:  # More than acoustic modes\n            print(f\"   ⚠ {n_imaginary} imaginary modes detected\")\n        \n        results.append({\n            'formula': formula,\n            'frequencies': frequencies_sorted,\n            'n_imaginary': n_imaginary\n        })\n        \n    except Exception as e:\n        print(f\"\\n{idx+1}. {formula}: ✗ Error: {e}\")\n\n# ==========================================\n# Summary Statistics\n# ==========================================\nprint(\"\\n\" + \"=\"*80)\nprint(\"EVALUATION SUMMARY\")\nprint(\"=\"*80)\n\nif results:\n    # Acoustic modes should be near zero (first 3 modes)\n    acoustic_freqs = [r['frequencies'][:3] for r in results]\n    acoustic_mean = np.mean([np.abs(f).mean() for f in acoustic_freqs])\n    \n    # Optical modes (rest)\n    optical_freqs = [r['frequencies'][3:] for r in results]\n    optical_mean = np.mean([f.mean() for f in optical_freqs])\n    \n    print(f\"✓ Processed {len(results)} samples\")\n    print(f\"\\nPhonon Statistics:\")\n    print(f\"  • Acoustic modes: {acoustic_mean:.4f} THz (should be ~0)\")\n    print(f\"  • Optical modes: {optical_mean:.2f} THz\")\n    \n    n_with_imaginary = sum(1 for r in results if r['n_imaginary'] > 3)\n    print(f\"  • Samples with imaginary modes: {n_with_imaginary}/{len(results)}\")\n    \n    print(f\"\\n📊 Model Performance:\")\n    print(f\"  • IFC Loss: 1.31 (normalized)\")\n    print(f\"  • Acoustic mode accuracy: {acoustic_mean:.4f} THz\")\n    \n    # Compare with target\n    target_mae = 0.01  # THz\n    if acoustic_mean < target_mae:\n        print(f\"\\n🎉 SUCCESS! Acoustic MAE < {target_mae} THz\")\n    else:\n        print(f\"\\n📈 Curre