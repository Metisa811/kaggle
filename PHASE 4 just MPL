             n_qpoints = len(data['phonon'])\n                n_bands = len(data['phonon'][0]['band'])\n                max_atoms = max(max_atoms, n_atoms)\n                max_bands = max(max_bands, n_bands)\n                max_qpoints = max(max_qpoints, n_qpoints)\n            except:\n                continue\n\n    print(f\"ШӯШҜШ§Ъ©Ш«Шұ Ш§ШӘЩ…вҖҢЩҮШ§: {max_atoms}, ШӯШҜШ§Ъ©Ш«Шұ ШЁШ§ЩҶШҜвҖҢЩҮШ§: {max_bands}, ШӯШҜШ§Ъ©Ш«Шұ ЩҶЩӮШ§Ш· q: {max_qpoints}\")\n\n    for file in os.listdir(folder_path):\n        if file.endswith(\".yaml\"):\n            try:\n                with open(os.path.join(folder_path, file), 'r') as f:\n                    data = yaml.safe_load(f)\n\n                if 'points' not in data or 'lattice' not in data or 'reciprocal_lattice' not in data or 'phonon' not in data:\n                    skipped += 1\n                    continue\n\n                # ЩҲЫҢЪҳЪҜЫҢвҖҢЩҮШ§ЫҢ Ш§ШӘЩ…вҖҢЩҮШ§: [x, y, z, Ш¬ШұЩ…]\n                atom_features = [pt['coordinates'] + [pt['mass']] for pt in data['points']]\n                atom_features = np.array(atom_features)\n                atom_features = np.pad(atom_features, ((0, max_atoms - atom_features.shape[0]), (0, 0)), 'constant')\n\n                lattice = np.array(data['lattice']).flatten()\n                reciprocal = np.array(data['reciprocal_lattice']).flatten()\n\n                # Ш§Ш¶Ш§ЩҒЩҮ Ъ©ШұШҜЩҶ Щ…Ш®ШӘШөШ§ШӘ q-points ШЁЩҮ ЩҲЫҢЪҳЪҜЫҢвҖҢЩҮШ§\n                qpoints = [qp['q-position'] for qp in data['phonon']]\n                qpoints = np.array(qpoints)\n                qpoints = np.pad(qpoints, ((0, max_qpoints - qpoints.shape[0]), (0, 0)), 'constant')\n\n                feature_tensor = np.concatenate([\n                    atom_features.flatten(),\n                    lattice,\n                    reciprocal,\n                    qpoints.flatten()\n                ])\n\n                # ЩҒШұЪ©Ш§ЩҶШівҖҢЩҮШ§\n                frequencies = []\n                for qpoint in data['phonon']:\n                    bands = [b['frequency'] for b in qpoint.get('band', [])]\n                    frequencies.append(bands)\n                frequencies = np.array(frequencies)\n                frequencies = np.pad(frequencies, ((0, max_qpoints - frequencies.shape[0]), (0, max_bands - frequencies.shape[1])), 'constant')\n\n                X.append(feature_tensor)\n                y.append(frequencies)\n\n            except Exception as e:\n                print(f\"Ш®Ш·Ш§ ШҜШұ ЩҒШ§ЫҢЩ„ {file}: {e}\")\n                skipped += 1\n\n    print(f\"вң… ШЁШ§ШұЪҜШ°Ш§ШұЫҢ ШҙШҜЩҮ: {len(X)}, ШұШҜ ШҙШҜЩҮ: {skipped}\")\n    return np.array(X), np.array(y), max_atoms\n\ndef prepare_input(points, lattice, reciprocal, max_atoms, max_qpoints):\n    atom_features = [pt['coordinates'] + [pt['mass']] for pt in points]\n    atom_features = np.array(atom_features)\n    atom_features = np.pad(atom_features, ((0, max_atoms - atom_features.shape[0]), (0, 0)), 'constant')\n    lattice_flat = np.array(lattice).flatten()\n    reciprocal_flat = np.array(reciprocal).flatten()\n    # ЩҒШұШ¶ Щ…ЫҢвҖҢЪ©ЩҶЫҢЩ… qpoints ШЁШұШ§ЫҢ ЩҶЩ…ЩҲЩҶЩҮ Ш¬ШҜЫҢШҜ ШөЩҒШұ Ш§ШіШӘ (ШҜШұ ШөЩҲШұШӘ ЩҲШ¬ЩҲШҜ Ш§Ш·Щ„Ш§Ш№Ш§ШӘ ЩҲШ§ЩӮШ№ЫҢ Ш¬Ш§ЫҢЪҜШІЫҢЩҶ ШҙЩҲШҜ)\n    qpoints = np.zeros((max_qpoints, 3))\n    return np.concatenate([atom_features.flatten(), lattice_flat, reciprocal_flat, qpoints.flatten()]).reshape(1, -1)\n\ndef build_cnn_model(input_shape, output_shape):\n    num_qpoints = 357  # ШӘШ№ШҜШ§ШҜ ЩӮЫҢШ§ШіЫҢвҖҢЩҮШ§\n    model = tf.keras.Sequential([\n        tf.keras.layers.Input(shape=input_shape),\n        tf.keras.layers.Reshape((input_shape[0], 1)),\n        tf.keras.layers.Conv1D(1 * num_qpoints, kernel_size=3, activation='relu', padding='same'),  # 357 ЩҒЫҢЩ„ШӘШұ\n        tf.keras.layers.Conv1D(int(0.5 * num_qpoints), kernel_size=3, activation='relu', padding='same'),  # 178 ЩҒЫҢЩ„ШӘШұ\n        tf.keras.layers.MaxPooling1D(pool_size=2),\n        tf.keras.layers.Flatten(),\n        tf.keras.layers.Dense(1 * num_qpoints, activation='relu', kernel_regularizer=tf.keras.regularizers.l2(0.005)),  # 357 ЩҶЩҲШұЩҲЩҶ\n        tf.keras.layers.Dropout(0.3),\n        tf.keras.layers.Dense(np.prod(output_shape), activation='linear')\n    ])\n    return model\n\n# ШӘШ§ШЁШ№ error_loss (ЩҲШІЩҶвҖҢШҜШ§Шұ ШЁШұШ§ЫҢ ЩҒШұЪ©Ш§ЩҶШівҖҢЩҮШ§ЫҢ ШЁШ§Щ„Ш§)\ndef error_loss(y_true, y_pred):\n    weights = tf.where(y_true > 15.0, 2.0, 1.0)  # ЩҲШІЩҶ 2 ШЁШұШ§ЫҢ ЩҒШұЪ©Ш§ЩҶШівҖҢЩҮШ§ЫҢ > 15 THz\n    return tf.reduce_mean(tf.square(weights * (y_pred - y_true)))\n\n# ШӘШ§ШЁШ№ physics_loss (ЩӮЩҲШ§ЩҶЫҢЩҶ ЩҒЫҢШІЫҢЪ©ЫҢ)\ndef physics_loss(y_pred):\n    # Ш¬ШұЫҢЩ…ЩҮ ШЁШұШ§ЫҢ ЩҒШұЪ©Ш§ЩҶШівҖҢЩҮШ§ЫҢ Щ…ЩҶЩҒЫҢ (Пү вүҘ 0)\n    negative_penalty = tf.reduce_mean(tf.square(tf.minimum(y_pred, 0)))\n    \n    # ШӘЩӮШұЫҢШЁ ШіШ§ШҜЩҮ ШЁШұШ§ЫҢ Ш§Щ…ЩҲШ§Ш¬ ШЁЩ„ЩҲШ®: ШіШ§ШІЪҜШ§ШұЫҢ ШЁШ§ ШӘЩӮШ§ШұЩҶ ЩӮЫҢШ§ШіЫҢ (Ш¬ШұЫҢЩ…ЩҮ ШӘШәЫҢЫҢШұШ§ШӘ ЩҶШ§ЪҜЩҮШ§ЩҶЫҢ)\n    diff_penalty = tf.reduce_mean(tf.square(y_pred[:, 1:] - y_pred[:, :-1]))  # ШӘЩҒШ§ЩҲШӘ Щ…ШӘЩҲШ§Щ„ЫҢ\n    return negative_penalty + 0.1 * diff_penalty  # ЩҲШІЩҶ 0.1 ШЁШұШ§ЫҢ Ш¬ШұЫҢЩ…ЩҮ ШӘЩҒШ§ЩҲШӘ\n\n# ШӘШ§ШЁШ№ loss ШӘШұЪ©ЫҢШЁЫҢ\ndef combined_loss(y_true, y_pred):\n    return error_loss(y_true, y_pred) + 1.0 * physics_loss(y_pred)\n\n# Щ…ШіЫҢШұ ШҜШ§ШҜЩҮвҖҢЩҮШ§\nfolder = \"/kaggle/input/yaml-phonopy-data/extracted_bands_C\"\nX, y, max_atoms = parse_yaml_files(folder)\n\n# ЩҶШұЩ… Ъ©ШұШҜЩҶ ЩҒШұЪ©Ш§ЩҶШівҖҢЩҮШ§ ШЁШ§ sigma Ъ©Щ…ШӘШұ\ny_smoothed = gaussian_filter1d(y, sigma=0.5, axis=1)\n\n# ЩҶШұЩ…Ш§Щ„вҖҢШіШ§ШІЫҢ X\nscaler_X = MinMaxScaler()\nX_normalized = scaler_X.fit_transform(X)\n\n# ЩҶШұЩ…Ш§Щ„вҖҢШіШ§ШІЫҢ y ШЁШ§ MinMaxScaler\nnum_samples, num_qpoints, num_bands = y_smoothed.shape\ny_flat = y_smoothed.reshape(num_samples, -1)\nscaler_y = MinMaxScaler()\ny_normalized = scaler_y.fit_transform(y_flat).reshape(num_samples, num_qpoints, num_bands)\n\n# ШӘЩӮШіЫҢЩ… ШҜШ§ШҜЩҮвҖҢЩҮШ§\nX_train, X_test, y_train, y_test = train_test_split(X_normalized, y_normalized, test_size=0.2, random_state=42)\n\n# ШӘШ№ШұЫҢЩҒ EarlyStopping\nearly_stopping = tf.keras.callbacks.EarlyStopping(monitor='val_loss', patience=50, restore_best_weights=True)\n\n# ШіШ§Ш®ШӘ ЩҲ Ъ©Ш§Щ…ЩҫШ§ЫҢЩ„ Щ…ШҜЩ„\nmodel = build_cnn_model((X.shape[1],), y.shape[1:])\nmodel.compile(optimizer=tf.keras.optimizers.Adam(learning_rate=0.0003), \n              loss=combined_loss, \n              metrics=['mae'])\n\n# ШӘЩҶШёЫҢЩ…Ш§ШӘ Ш¬ШҜЫҢШҜ ШЁШұШ§ЫҢ ШўЩ…ЩҲШІШҙ\nhistory = model.fit(X_train, y_train.reshape(len(y_train), -1),\n                    validation_split=0.1, epochs=200, batch_size=16, verbose=1,\n                    callbacks=[early_stopping, tf.keras.callbacks.ReduceLROnPlateau(monitor='val_loss', factor=0.9, patience=5, min_lr=1e-6)])\n\n# ЩҫЫҢШҙвҖҢШЁЫҢЩҶЫҢ ШұЩҲЫҢ Щ…Ш¬Щ…ЩҲШ№ЩҮ ШӘШіШӘ\ny_test_pred_normalized = model.predict(X_test).reshape(y_test.shape)\ny_test_pred = scaler_y.inverse_transform(y_test_pred_normalized.reshape(len(y_test), -1)).reshape(y_test.shape)\ny_test_original = scaler_y.inverse_transform(y_test.reshape(len(y_test), -1)).reshape(y_test.shape)\n\n# Щ…ШӯШ§ШіШЁЩҮ Ш§Щ…ШӘЫҢШ§ШІ RВІ\nr2_scores = [r2_score(y_test_original[i].flatten(), y_test_pred[i].flatten()) for i in range(len(y_test))]\naverage_r2 = np.mean(r2_scores)\nprint(f\"Щ…ЫҢШ§ЩҶЪҜЫҢЩҶ RВІ ШҜШұ Щ…Ш¬Щ…ЩҲШ№ЩҮ ШӘШіШӘ: {average_r2:.4f}\")\n\n# Ш°Ш®ЫҢШұЩҮ Щ„ЫҢШіШӘ RВІ\nnp.save('r2_list.npy', r2_scores)\n\n# ШұШіЩ… ЩҶЩ…ЩҲЩҶЩҮ (Щ…ЩӮШ§ЫҢШіЩҮ ЩҲШ§ЩӮШ№ЫҢ ЩҲ ЩҫЫҢШҙвҖҢШЁЫҢЩҶЫҢвҖҢШҙШҜЩҮ ШЁШұШ§ЫҢ ЩҶЩ…ЩҲЩҶЩҮ 0 Ш§ШІ Щ…Ш¬Щ…ЩҲШ№ЩҮ ШӘШіШӘ)\ndef plot_sample_prediction(y_true, y_pred, sample_idx=0):\n    plt.figure(figsize=(12, 6))\n    for band in range(num_bands):\n        plt.plot(y_true[sample_idx, :, band], label=f'True Band {band}', linestyle='-', alpha=0.7)\n        plt.plot(y_pred[sample_idx, :, band], label=f'Predicted Band {band}', linestyle='--', alpha=0.7)\n    plt.axhline(y=17.0, color='r', linestyle=':', label='17 THz Target')\n    plt.xlabel('Q-point Index')\n    plt.ylabel('Frequency (THz)')\n    plt.title('Actual vs Predicted Frequencies for Sample 0 (Test Set)')\n    plt.legend()\n    plt.grid(True)\n    plt.savefig('actual_vs_predicted_sample0_cnn.png')\n    plt.close()\n\n# ШұШіЩ… ШЁШұШ§ЫҢ ЩҶЩ…ЩҲЩҶЩҮ 0 Ш§ШІ Щ…Ш¬Щ…ЩҲШ№ЩҮ ШӘШіШӘ\nplot_sample_prediction(y_test_original, y_test_pred)\n\n# ШұШіЩ… ШӘШ§ШұЫҢШ®ЪҶЩҮ ШўЩ…ЩҲШІШҙ\nplt.figure(figsize=(8, 6))\nplt.plot(history.history['loss'], label='Training Loss')\nplt.plot(history.history['val_loss'], label='Validation Loss')\nplt.xlabel('Epoch')\nplt.ylabel('Loss')\nplt.title('Training and Validation Loss')\nplt.legend()\nplt.grid(True)\nplt.savefig('training_loss_cnn.png')\nplt.close()\n\n# ШўЩ…Ш§ШҜЩҮвҖҢШіШ§ШІЫҢ ЩҲШұЩҲШҜЫҢ ШЁШұШ§ЫҢ Щ…Ш§ШҜЩҮ Ш¬ШҜЫҢШҜ\nsample_points = [\n    {'coordinates': [0.666666666666664, 0.333333333333336, 0.573789318806853], 'mass': 51.996100},\n    {'coordinates': [0.666666666666664, 0.333333333333336, 0.926210681193147], 'mass': 51.996100},\n    {'coordinates': [0.333333333333336, 0.666666666666664, 0.073789318806853], 'mass': 51.996100},\n    {'coordinates': [0.333333333333336, 0.666666666666664, 0.426210681193147], 'mass': 51.996100},\n    {'coordinates': [0.333333333333336, 0.666666666666664, 0.750000000000000], 'mass': 196.966569},\n    {'coordinates': [0.000000000000000, 0.000000000000000, 0.500000000000000], 'mass': 14.006700},\n    {'coordinates': [0.000000000000000, 0.000000000000000, 0.000000000000000], 'mass': 14.006700}\n]\nsample_lattice = [[2.932123524309962, 0.0, 0.0], [-1.466061762154982, 2.539293459086388, 0.0], [0.0, 0.0, 12.890073431300316]]\nsample_reciprocal = [[0.34104975, 0.19690517, 0.0], [0.0, 0.39381033, 0.0], [0.0, 0.0, 0.07757908]]\n\nx_new_raw = prepare_input(sample_points, sample_lattice, sample_reciprocal, max_atoms, num_qpoints)\nx_new_normalized = scaler_X.transform(x_new_raw)\npredicted_normalized = model.predict(x_new_normalized).reshape(y.shape[1:])\npredicted = scaler_y.inverse_transform(predicted_normalized.reshape(1, -1)).reshape(y.shape[1:])\n\n# ШұШіЩ… ШіШ§Ш®ШӘШ§Шұ ШЁШ§ЩҶШҜ ЩҒЩҲЩҶЩҲЩҶЫҢ ЩҫЫ