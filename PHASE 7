41e-01\nEpoch 289 | Train Loss: 4.113968e-02 | Val Loss: 9.696359e-02\nEpoch 290 | Train Loss: 4.042365e-02 | Val Loss: 1.170553e-01\nEpoch 291 | Train Loss: 3.771973e-02 | Val Loss: 1.042107e-01\nEpoch 292 | Train Loss: 3.777685e-02 | Val Loss: 9.861310e-02\nEpoch 293 | Train Loss: 3.395254e-02 | Val Loss: 9.747001e-02\nEpoch 294 | Train Loss: 3.393487e-02 | Val Loss: 9.860003e-02\nEpoch 295 | Train Loss: 3.528101e-02 | Val Loss: 9.670670e-02\nEpoch 296 | Train Loss: 3.155137e-02 | Val Loss: 9.741806e-02\nEpoch 297 | Train Loss: 3.421579e-02 | Val Loss: 1.022497e-01\nEpoch 298 | Train Loss: 3.358569e-02 | Val Loss: 1.096324e-01\nEpoch 299 | Train Loss: 3.223201e-02 | Val Loss: 9.746721e-02\nEpoch 300 | Train Loss: 3.259705e-02 | Val Loss: 9.961957e-02\nLoading best model from /kaggle/working/best_gnn_model.weights.h5 for evaluation.\n","output_type":"stream"},{"name":"stderr","text":"WARNING: All log messages before absl::InitializeLog() is called are written to STDERR\nI0000 00:00:1757676299.954915      95 service.cc:148] XLA service 0x305ec1f0 initialized for platform CUDA (this does not guarantee that XLA will be used). Devices:\nI0000 00:00:1757676299.955843      95 service.cc:156]   StreamExecutor device (0): Tesla P100-PCIE-16GB, Compute Capability 6.0\nI0000 00:00:1757676300.119733      95 cuda_dnn.cc:529] Loaded cuDNN version 90300\n","output_type":"stream"},{"name":"stdout","text":"\u001b[1m1/5\u001b[0m \u001b[32m━━━━\u001b[0m\u001b[37m━━━━━━━━━━━━━━━━\u001b[0m \u001b[1m4s\u001b[0m 1s/step","output_type":"stream"},{"name":"stderr","text":"I0000 00:00:1757676300.608138      95 device_compiler.h:188] Compiled cluster using XLA!  This line is logged at most once for the lifetime of the process.\n","output_type":"stream"},{"name":"stdout","text":"\u001b[1m5/5\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m2s\u001b[0m 231ms/step\n\n--- GNN R2 Score Analysis ---\nMean R2: 0.9824, Median R2: 0.9936, Std Dev: 0.0240\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 1200x700 with 1 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":1},{"cell_type":"markdown","source":"### the GNN model worked well.","metadata":{}},{"cell_type":"markdown","source":"## top code with chart and more ditails","metadata":{}},{"cell_type":"code","source":"import os\nimport numpy as np\nimport tensorflow as tf\nfrom sklearn.metrics import r2_score\nimport matplotlib.pyplot as plt\nfrom scipy.signal import savgol_filter\n\n# -----------------------\n# مسیرها و تنظیمات\n# -----------------------\ndata_dir = \"/kaggle/input/gnn-dataset-1\"\nout_dir = \"/kaggle/working/new_genrate\"\nos.makedirs(out_dir, exist_ok=True)\n\n# -----------------------\n# بارگذاری داده‌های گرافی\n# -----------------------\nprint(\"Loading GNN dataset...\")\ntrain_nodes = np.load(os.path.join(data_dir, \"train_nodes.npy\"))\ntrain_edge_idx = np.load(os.path.join(data_dir, \"train_edge_idx.npy\"))\ntrain_edge_attr = np.load(os.path.join(data_dir, \"train_edge_attr.npy\"))\ny_train = np.load(os.path.join(data_dir, \"train_y_gnn.npy\"))\n\nval_nodes = np.load(os.path.join(data_dir, \"val_nodes.npy\"))\nval_edge_idx = np.load(os.path.join(data_dir, \"val_edge_idx.npy\"))\nval_edge_attr = np.load(os.path.join(data_dir, \"val_edge_attr.npy\"))\ny_val = np.load(os.path.join(data_dir, \"val_y_gnn.npy\"))\n\ntest_nodes = np.load(os.path.join(data_dir, \"test_nodes.npy\"))\ntest_edge_idx = np.load(os.path.join(data_dir, \"test_edge_idx.npy\"))\ntest_edge_attr = np.load(os.path.join(data_dir, \"test_edge_attr.npy\"))\ny_test = np.load(os.path.join(data_dir, \"test_y_gnn.npy\"))\n\nscaler_y_mean = np.load(os.path.join(data_dir, \"scaler_y_mean_gnn.npy\"))\nscaler_y_std = np.load(os.path.join(data_dir, \"scaler_y_std_gnn.npy\"))\nprint(\"Dataset loaded.\")\n\n# -----------------------\n# ابعاد و هایپرپارامترها\n# -----------------------\nBATCH_SIZE = 16\nEPOCHS = 300\nLR = 5e-4\nLAMBDA_SMOOTH = 5.0 # Increased smoothness penalty\nPATIENCE = 40\n_, max_nodes, node_dim = train_nodes.shape\n_, max_qpoints, max_bands = y_train.shape\noutput_flat_dim = max_qpoints * max_bands\n\n# -----------------------\n# پیاده‌سازی لایه GNN (Message Passing)\n# -----------------------\nclass MessagePassingLayer(tf.keras.layers.Layer):\n    def __init__(self, units, **kwargs):\n        super().__init__(**kwargs)\n        self.units = units\n        self.mlp_message = tf.keras.Sequential([\n            tf.keras.layers.Dense(units, activation='relu'),\n            tf.keras.layers.Dense(units)\n        ])\n        self.mlp_update = tf.keras.Sequential([\n            tf.keras.layers.Dense(units, activation='relu'),\n            tf.keras.layers.Dense(units)\n        ])\n        self.norm = tf.keras.layers.LayerNormalization()\n\n    def call(self, inputs):\n        node_features, edge_indices, edge_attributes = inputs\n        batch_size = tf.shape(node_features)[0]\n        num_nodes = tf.shape(node_features)[1]\n        \n        sender_indices = edge_indices[:, :, 0]\n        receiver_indices = edge_indices[:, :, 1]\n        sender_features = tf.gather(node_features, sender_indices, batch_dims=1)\n        \n        messages_in = tf.concat([sender_features, edge_attributes], axis=-1)\n        messages = self.mlp_message(messages_in)\n        \n        batch_offsets = tf.range(batch_size) * num_nodes\n        batch_offsets_reshaped = tf.reshape(batch_offsets, [batch_size, 1])\n        receiver_indices_offset = receiver_indices + batch_offsets_reshaped\n        messages_flat = tf.reshape(messages, [-1, self.units])\n        receiver_indices_flat = tf.reshape(receiver_indices_offset, [-1])\n        \n        aggregated_messages_flat = tf.math.unsorted_segment_sum(\n            data=messages_flat,\n            segment_ids=receiver_indices_flat,\n            num_segments=batch_size * num_nodes\n        )\n        \n        aggregated_messages = tf.reshape(aggregated_messages_flat, [batch_size, num_nodes, self.units])\n        update_input = tf.concat([node_features, aggregated_messages], axis=-1)\n        updated_features = self.mlp_update(update_input)\n        \n        return self.norm(node_features + updated_features)\n\n# -----------------------\n# ساخت مدل کامل GNN\n# -----------------------\ndef build_gnn_model():\n    node_input = tf.keras.layers.Input(shape=(max_nodes, node_dim), name=\"node_features\")\n    edge_idx_input = tf.keras.layers.Input(shape=(None, 2), dtype=tf.int32, name=\"edge_indices\")\n    edge_attr_input = tf.keras.layers.Input(shape=(None, 1), name=\"edge_attributes\")\n    \n    x = tf.keras.layers.Dense(128, activation='relu')(node_input)\n    x = MessagePassingLayer(128)([x, edge_idx_input, edge_attr_input])\n    x = MessagePassingLayer(128)([x, edge_idx_input, edge_attr_input])\n    x = MessagePassingLayer(128)([x, edge_idx_input, edge_attr_input])\n    \n    graph_embedding = tf.keras.layers.GlobalAveragePooling1D()(x)\n    \n    y = tf.keras.layers.Dense(512, activation='relu')(graph_embedding)\n    y = tf.keras.layers.Dropout(0.2)(y)\n    y = tf.keras.layers.Dense(output_flat_dim)(y)\n    \n    return tf.keras.Model(inputs=[node_input, edge_idx_input, edge_attr_input], outputs=y)\n\nmodel = build_gnn_model()\nmodel.summary()\n\n# -----------------------\n# توابع آموزش و ارزیابی\n# -----------------------\nmse = tf.keras.losses.MeanSquaredError()\noptimizer = tf.keras.optimizers.Adam(learning_rate=LR)\nsmoothness_loss_from_reshaped = lambda y: tf.reduce_mean(tf.square(y[:, 2:, :] - 2.0 * y[:, 1:-1, :] + y[:, :-2, :]))\n\n@tf.function\ndef train_step(inputs, y_batch):\n    with tf.GradientTape() as tape:\n        pred_flat = model(inputs, training=True)\n        loss_mse = mse(tf.reshape(y_batch, (tf.shape(y_batch)[0], -1)), pred_flat)\n        pred_reshaped = tf.reshape(pred_flat, (-1, max_qpoints, max_bands))\n        loss_smooth = smoothness_loss_from_reshaped(pred_reshaped)\n        loss = loss_mse + LAMBDA_SMOOTH * loss_smooth\n    grads = tape.gradient(loss, model.trainable_variables)\n    optimizer.apply_gradients(zip(grads, model.trainable_variables))\n    return loss\n\n@tf.function\ndef val_step(inputs, y_batch):\n    pred_flat = model(inputs, training=False)\n    loss_mse = mse(tf.reshape(y_batch, (tf.shape(y_batch)[0], -1)), pred_flat)\n    pred_reshaped = tf.reshape(pred_flat, (-1, max_qpoints, max_bands))\n    loss_smooth = smoothness_loss_from_reshaped(pred_reshaped)\n    return loss_mse + LAMBDA_SMOOTH * loss_smooth\n\n# -----------------------\n# حلقه آموزش\n# -----------------------\ntrain_dataset = tf.data.Dataset.from_tensor_slices(((train_nodes, train_edge_idx, train_edge_attr), y_train)).batch(BATCH_SIZE).shuffle(100)\nval_dataset = tf.data.Dataset.from_tensor_slices(((val_nodes, val_edge_idx, val_edge_attr), y_val)).batch(BATCH_SIZE)\n\nbest_val = np.inf\npatience_counter = 0\nhistory = {'train_loss': [], 'val_loss': []}\nbest_model_path = os.path.join(out_dir, \"best_gnn_model.weights.h5\")\n\nfor epoch in range(1, EPOCHS + 1):\n    train_losses = [train_step(xb, yb).numpy() for xb, yb in train_dataset]\n    val_losses = [val_step(xb, yb).numpy() for xb, yb in val_dataset]\n    train_loss_epoch = np.mean(train_losses)\n    val_loss_epoch = np.mean(val_losses)\n    history['train_loss'].append(train_loss_epoch)\n    history['val_loss'].append(val_loss_epoch)\n    print(f\"Epoch {epoch:03d} | Train Loss: {train_loss_epoch:.6e} | Val Loss: {val_loss_epoch:.6e}\")\n    if val_loss_epoch < best_val:\n        best_val = val_loss_epoch\n        patience_counter = 0\n        model.save_weights(best_model_path)\n    else:\n        patience_counter += 1\n        if patience_counter >= PATIENCE:\n            print(\"Early stopping triggered.\")\n            break\n\n# ---------- رسم نمودار تاریخچه آموزش (برای بررسی Overfitting) ----------\nplt.figure(figsize=(10, 6))\nplt.plot(history['train_loss'], label='Training Loss')\nplt.plot(history['val_loss'], label='Validation Loss')\nplt.title('Training and Validation Loss History')\nplt.xlabel('Epoch')\nplt.ylabel('Loss')\nplt.legend()\nplt.grid(True)\nplt.savefig(os.path.join(out_dir, \"loss_history_gnn.png\"))\nplt.show()\n\n# -----------------------\n# ارزیابی نهایی و پس‌پردازش\n# -----------------------\nprint(f\"\\nLoading best model from {best_model_path} for evaluation.\")\nmodel.load_weights(best_model_path)\ntest_inputs = [test_nodes, test_edge_idx, test_edge_attr]\ny_pred_flat = model.predict(test_inputs, batch_size=BATCH_SIZE)\ny_pred_rescaled = (y_pred_flat * scaler_y_std + scaler_y_mean).reshape(-1, max_qpoints, max_bands)\ny_test_rescaled = (y_test.reshape(len(y_test), -1) * scaler_y_std + scaler_y_mean).reshape(-1, max_qpoints, max_bands)\n\n# Post-processing with Savitzky-Golay filter\ny_pred_final = np.copy(y_pred_rescaled)\nfor i in range(len(y_pred_final)):\n    for b in range(max_bands):\n        # Apply filter only if the band has enough points\n        if max_qpoints > 11:\n            y_pred_final[i, :, b] = savgol_filter(y_pred_rescaled[i, :, b], 11, 3)\n\n# -----------------------\n# تحلیل جامع R²\n# -----------------------\nr2_scores = np.array([r2_score(y_test_rescaled[i].flatten(), y_pred_final[i].flatten()) for i in range(len(y_test_rescaled))])\nprint(\"\\n--- R2 Score Analysis (Overall per Sample) ---\")\nprint(f\"Mean R2: {np.mean(r2_scores):.4f}, Median R2: {np.median(r2_scores):.4f}, Std Dev: {np.std(r2_scores):.4f}\")\n\n# تابع کمکی برای رسم نمودار مقایسه\ndef plot_band_comparison(sample_idx, y_true_all, y_pred_all, r2_score_val, title_prefix, filename):\n    plt.figure(figsize=(12, 7))\n    colors = plt.cm.viridis(np.linspace(0, 1, y_true_all.shape[2]))\n    true_sample = y_true_all[sample_idx]\n    pred_sample = y_pred_all[sample_idx]\n    for b in range(true_sample.shape[1]):\n        plt.plot(true_sample[:, b], color=colors[b], linestyle='-', linewidth=2.5, label=f'True B{b+1}' if b < 2 else None)\n        plt.plot(pred_sample[:, b], color=colors[b], linestyle='--', linewidth=2.5, label=f'Pred B{b+1}' if b < 2 else None)\n    plt.title(f\"{title_prefix} (Sample {sample_idx}, R² = {r2_score_val:.3f})\")\n    plt.xlabel(\"Q-point index\"); plt.ylabel(\"Frequency (THz)\"); plt.grid(True)\n    from matplotlib.lines import Line2D\n    legend_elements = [Line2D([0], [0], color='black', lw=2, linestyle='-', label='True'),\n                       Line2D([0], [0], color='black', lw=2, linestyle='--', label='Predicted')]\n    plt.legend(handles=legend_elements)\n    plt.savefig(filename)\n    plt.show()\n\n# رسم بهترین و بدترین پیش‌بینی\nbest_idx = np.argmax(r2_scores)\nworst_idx = np.argmin(r2_scores)\nprint(f\"Plotting best case (Sample {best_idx}, R²={r2_scores[best_idx]:.3f}) and worst case (Sample {worst_idx}, R²={r2_scores[worst_idx]:.3f}).\")\nplot_band_comparison(best_idx, y_test_rescaled, y_pred_final, r2_scores[best_idx], \"Best Prediction\", os.path.join(out_dir, \"best_prediction_gnn.png\"))\nplot_band_comparison(worst_idx, y_test_rescaled, y_pred_final, r2_scores[worst_idx], \"Worst Prediction\", os.path.join(out_dir, \"worst_prediction_gnn.png\"))\n\n# تحلیل R² به تفکیک هر باند\nprint(\"\\n--- R2 Score Analysis (Per Individual Band) ---\")\nr2_per_band = [[] for _ in range(max_bands)]\nfor i in range(len(y_test_rescaled)):\n    for b in range(max_bands):\n        if np.std(y_test_rescaled[i, :, b]) > 1e-6:\n            score = r2_score(y_test_rescaled[i, :, b], y_pred_final[i, :, b])\n            r2_per_band[b].append(score)\n\nmean_r2_per_band = [np.mean(scores) if len(scores) > 0 else -1 for scores in r2_per_band]\nmedian_r2_per_band = [np.median(scores) if len(scores) > 0 else -1 for scores in r2_per_band]\nfor b in range(max_bands):\n    print(f\"Band {b+1:02d} | Mean R²: {mean_r2_per_band[b]:.4f} | Median R²: {median_r2_per_band[b]:.4f}\")\n\n# رسم نمودار جعبه‌ای برای توزیع R² هر باند\nplt.figure(figsize=(15, 8))\nbox = plt.boxplot(r2_per_band, vert=True, patch_artist=True, labels=[f'B{i+1}' for i in range(max_bands)])\ncolors = plt.cm.viridis(np.linspace(0, 1, max_bands))\nfor patch, color in zip(box['boxes'], colors):\n    patch.set_facecolor(color)\n    patch.set_alpha(0.6)\nplt.title('Distribution of R² Scores for Each Phonon Band')\nplt.ylabel('R² Score')\nplt.xlabel('Band Index')\nplt.grid(axis='y', linestyle='--')\nplt.axhline(y=0, color='r', linestyle='--')\nplt.ylim(-1, 1.1) # Set y-axis limits for better visualization\nplt.savefig(os.path.join(out_dir, \"r2_per_band_distribution.png\"))\nplt.show()\n\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-09-12T11:55:01.902434Z","iopub.execute_input":"2025-09-12T11:55:01.903008Z","iopub.status.idle":"2025-09-12T11:56:08.261075Z","shell.execute_reply.started":"2025-09-12T11:55:01.902984Z","shell.execute_reply":"2025-09-12T11:56:08.260379Z"}},"outputs":[{"name":"stdout","text":"Loading GNN dataset...\nDataset loaded.\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"\u001b[1mModel: \"functional_6\"\u001b[0m\n","text/html":"<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\">Model: \"functional_6\"</span>\n</pre>\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"┏━━━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━┓\n┃\u001b[1m \u001b[0m\u001b[1mLayer (type)       \u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1mOutput Shape     \u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1m   Param #\u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1mConnected to     \u001b[0m\u001b[1m \u001b[0m┃\n┡━━━━━━━━━━━━━━━━━━━━━╇━━━━━━━━━━━━━━━━━━━╇━━━━━━━━━━━━╇━━━━━━━━━━━━━━━━━━━┩\n│ node_features       │ (\u001b[38;5;45mNone\u001b[0m, \u001b[38;5;34m8\u001b[0m, \u001b[38;5;34m35\u001b[0m)     │          \u001b[38;5;34m0\u001b[0m │ -                 │\n│ (\u001b[38;5;33mInputLayer\u001b[0m)        │           