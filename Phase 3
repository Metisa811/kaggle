nfrom torch_geometric.nn import GCNConv\nfrom torch_geometric.data import Data, Batch\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.preprocessing import StandardScaler\nfrom sklearn.metrics import r2_score\nimport matplotlib.pyplot as plt\nfrom scipy.ndimage import gaussian_filter1d\n\n# تابع تبدیل داده‌ها به گراف\ndef parse_yaml_to_graph(folder_path):\n    graphs, y = [], []\n    skipped = 0\n    max_atoms = 0\n    max_bands = 0\n    max_qpoints = 0\n\n    # یافتن حداکثر اندازه‌ها\n    for file in os.listdir(folder_path):\n        if file.endswith(\".yaml\"):\n            try:\n                with open(os.path.join(folder_path, file), 'r') as f:\n                    data = yaml.safe_load(f)\n                n_atoms = len(data['points'])\n                n_qpoints = len(data['phonon'])\n                n_bands = len(data['phonon'][0]['band'])\n                max_atoms = max(max_atoms, n_atoms)\n                max_bands = max(max_bands, n_bands)\n                max_qpoints = max(max_qpoints, n_qpoints)\n            except:\n                continue\n\n    print(f\"حداکثر اتم‌ها: {max_atoms}, حداکثر باند‌ها: {max_bands}, حداکثر نقاط q: {max_qpoints}\")\n\n    for file in os.listdir(folder_path):\n        if file.endswith(\".yaml\"):\n            try:\n                with open(os.path.join(folder_path, file), 'r') as f:\n                    data = yaml.safe_load(f)\n\n                if 'points' not in data or 'lattice' not in data or 'reciprocal_lattice' not in data or 'phonon' not in data:\n                    skipped += 1\n                    continue\n\n                # ویژگی‌های اتم‌ها: [x, y, z, جرم]\n                atom_features = [pt['coordinates'] + [pt['mass']] for pt in data['points']]\n                atom_features = np.array(atom_features)\n                atom_features = np.pad(atom_features, ((0, max_atoms - atom_features.shape[0]), (0, 0)), 'constant')\n                node_features = torch.tensor(atom_features, dtype=torch.float)\n\n                # ساخت یال‌ها (همسایگی ساده بر اساس اندیس)\n                edge_index = []\n                for i in range(len(data['points'])):\n                    for j in range(i + 1, len(data['points'])):\n                        edge_index.append([i, j])\n                        edge_index.append([j, i])\n                edge_index = torch.tensor(edge_index, dtype=torch.long).t()\n\n                # فرکانس‌ها\n                frequencies = []\n                for qpoint in data['phonon']:\n                    bands = [b['frequency'] for b in qpoint.get('band', [])]\n                    frequencies.append(bands)\n                frequencies = np.array(frequencies)\n                frequencies = np.pad(frequencies, ((0, max_qpoints - frequencies.shape[0]), (0, max_bands - frequencies.shape[1])), 'constant')\n                y_flat = frequencies.reshape(-1)\n\n                graph = Data(x=node_features, edge_index=edge_index, y=torch.tensor(y_flat, dtype=torch.float))\n                graphs.append(graph)\n                y.append(frequencies)\n\n            except Exception as e:\n                print(f\"خطا در فایل {file}: {e}\")\n                skipped += 1\n\n    print(f\"✅ بارگذاری شده: {len(graphs)}, رد شده: {skipped}\")\n    if len(graphs) == 0:\n        raise ValueError(\"هیچ داده‌ای بارگذاری نشد! لطفاً مسیر داده‌ها یا ساختار فایل‌ها را بررسی کنید.\")\n    return graphs, y, max_atoms, max_qpoints, max_bands\n\n# تعریف مدل GNN\nclass PhononGNN(torch.nn.Module):\n    def __init__(self, num_node_features, hidden_channels, num_frequencies):\n        super(PhononGNN, self).__init__()\n        self.conv1 = GCNConv(num_node_features, hidden_channels)\n        self.conv2 = GCNConv(hidden_channels, hidden_channels)\n        self.fc1 = torch.nn.Linear(hidden_channels, hidden_channels // 2)\n        self.fc2 = torch.nn.Linear(hidden_channels // 2, num_frequencies)\n\n    def forward(self, data):\n        x, edge_index = data.x, data.edge_index\n        x = self.conv1(x, edge_index)\n        x = F.relu(x)\n        x = self.conv2(x, edge_index)\n        x = F.relu(x)\n        x = torch.mean(x, dim=0)  # global pooling\n        x = self.fc1(x)\n        x = F.relu(x)\n        x = self.fc2(x)\n        return x\n\n# تابع آماده‌سازی داده برای پیش‌بینی\ndef prepare_input_graph(points, lattice, reciprocal, max_atoms):\n    atom_features = [pt['coordinates'] + [pt['mass']] for pt in points]\n    atom_features = np.array(atom_features)\n    atom_features = np.pad(atom_features, ((0, max_atoms - atom_features.shape[0]), (0, 0)), 'constant')\n    node_features = torch.tensor(atom_features, dtype=torch.float)\n    \n    edge_index = []\n    for i in range(len(points)):\n        for j in range(i + 1, len(points)):\n            edge_index.append([i, j])\n            edge_index.append([j, i])\n    edge_index = torch.tensor(edge_index, dtype=torch.long).t()\n    \n    return Data(x=node_features, edge_index=edge_index)\n\n# تابع آموزش مدل\ndef train_model(model, train_data, train_labels, epochs=1000):\n    optimizer = torch.optim.Adam(model.parameters(), lr=0.001)\n    criterion = torch.nn.MSELoss()\n    early_stopping = torch.optim.lr_scheduler.ReduceLROnPlateau(optimizer, mode='min', factor=0.5, patience=5, min_lr=1e-6)\n    losses = []\n\n    model.train()\n    for epoch in range(epochs):\n        total_loss = 0\n        for data, label in zip(train_data, train_labels):\n            optimizer.zero_grad()\n            out = model(data)\n            loss = criterion(out, label)\n            loss.backward()\n            optimizer.step()\n            total_loss += loss.item()\n        avg_loss = total_loss / len(train_data)\n        losses.append(avg_loss)\n        if epoch % 50 == 0:\n            print(f'Epoch {epoch}, Loss: {avg_loss:.4f}')\n        early_stopping.step(avg_loss)\n        if early_stopping.num_bad_epochs >= early_stopping.patience:\n            print(f\"Early stopping at epoch {epoch}\")\n            break\n    \n    return losses\n\n# مسیر داده‌ها\nfolder = \"/kaggle/input/yaml-phonopy-data/extracted_bands_C\"\ngraphs, y, max_atoms, max_qpoints, max_bands = parse_yaml_to_graph(folder)\n\n# نرم کردن فرکانس‌ها\ny_smoothed = np.array([gaussian_filter1d(y_i, sigma=1, axis=0) for y_i in y])\nif y_smoothed.size == 0:\n    raise ValueError(\"آرایه y_smoothed خالی است! احتمالاً داده‌ها به درستی بارگذاری نشده‌اند.\")\ny_flat = y_smoothed.reshape(len(y_smoothed), -1)\n\n# نرمال‌سازی\nscaler_X = StandardScaler()\nscaler_y = StandardScaler()\n\n# تبدیل گراف‌ها به تانسور برای نرمال‌سازی ویژگی‌ها\nnode_features_all = torch.cat([g.x for g in graphs], dim=0)\nX_normalized = scaler_X.fit_transform(node_features_all.numpy())\nfor i, graph in enumerate(graphs):\n    graphs[i].x = torch.tensor(X_normalized[i * max_atoms:(i + 1) * max_atoms], dtype=torch.float)\n\ny_normalized = scaler_y.fit_transform(y_flat).reshape(len(y), max_qpoints, max_bands)\ntrain_graphs, test_graphs, train_labels, test_labels = train_test_split(graphs, y_normalized, test_size=0.2, random_state=42)\n\n# آماده‌سازی داده‌ها برای مدل\ntrain_labels_flat = [torch.tensor(y.reshape(-1), dtype=torch.float) for y in train_labels]\ntest_labels_flat = [torch.tensor(y.reshape(-1), dtype=torch.float) for y in test_labels]\n\n# ساخت و آموزش مدل\nmodel = PhononGNN(num_node_features=4, hidden_channels=64, num_frequencies=max_qpoints * max_bands)\nlosses = train_model(model, train_graphs, train_labels_flat)\n\n# پیش‌بینی\nmodel.eval()\nwith torch.no_grad():\n    test_predictions = [model(g) for g in test_graphs]\n    test_predictions = torch.stack(test_predictions).numpy()\n    test_labels = np.array([y.numpy() for y in test_labels_flat])\n\n# معکوس کردن نرمال‌سازی\ntest_predictions = scaler_y.inverse_transform(test_predictions)\ntest_labels = scaler_y.inverse_transform(test_labels)\n\n# محاسبه R²\nr2_scores = [r2_score(test_labels[i].flatten(), test_predictions[i].flatten()) for i in range(len(test_labels))]\naverage_r2 = np.mean(r2_scores)\nprint(f\"میانگین R² در مجموعه تست: {average_r2:.4f}\")\n\n# ذخیره R²\nnp.save('r2_list.npy', r2_scores)\n\n# پیش‌بینی برای ماده جدید\nsample_points = [\n    {'coordinates': [0.666666666666664, 0.333333333333336, 0.573789318806853], 'mass': 51.996100},\n    {'coordinates': [0.666666666666664, 0.333333333333336, 0.926210681193147], 'mass': 51.996100},\n    {'coordinates': [0.333333333333336, 0.666666666666664, 0.073789318806853], 'mass': 51.996100},\n    {'coordinates': [0.333333333333336, 0.666666666666664, 0.426210681193147], 'mass': 51.996100},\n    {'coordinates': [0.333333333333336, 0.666666666666664, 0.750000000000000], 'mass': 196.966569},\n    {'coordinates': [0.000000000000000, 0.000000000000000, 0.500000000000000], 'mass': 14.006700},\n    {'coordinates': [0.000000000000000, 0.000000000000000, 0.000000000000000], 'mass': 14.006700}\n]\nsample_lattice = [[2.932123524309962, 0.0, 0.0], [-1.466061762154982, 2.539293459086388, 0.0], [0.0, 0.0, 12.890073431300316]]\nsample_reciprocal = [[0.34104975, 0.19690517, 0.0], [0.0, 0.39381033, 0.0], [0.0, 0.0, 0.07757908]]\n\nnew_graph = prepare_input_graph(sample_points, sample_lattice, sample_reciprocal, max_atoms)\nnew_graph.x = torch.tensor(scaler_X.transform(new_graph.x.numpy()), dtype=torch.float)\nwith torch.no_grad():\n    predicted_normalized = model(new_graph).numpy()\n    predicted = scaler_y.inverse_transform(predicted_normalized.reshape(1, -1)).reshape(max_qpoints, max_bands)\n\n# رسم ساختار باند فونونی پیش‌بینی‌شده\nplt.figure(figsize=(10, 6))\nfor i in range(predicted.shape[1]):\n    plt.plot(predicted[:, i])\nplt.title(\"Predicted Phonon Band Structure\")\nplt.xlabel(\"Q-point index\")\nplt.ylabel(\"Frequency (THz)\")\nplt.grid(True)\nplt.savefig('predicted_phonon_bands.png')\nplt.show()\n\n#میانگین R² در مجموعه تست: 0.8984\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-05-27T07:59:12.736606Z","iopub.execute_input":"2025-05-27T07:59:12.737018Z","iopub.status.idle":"2025-05-27