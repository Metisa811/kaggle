 146 - train_loss: 3.423961e-02  val_loss: 8.824405e-02\nEpoch 147 - train_loss: 3.323353e-02  val_loss: 8.791851e-02\nEpoch 148 - train_loss: 3.009012e-02  val_loss: 8.783385e-02\nEpoch 149 - train_loss: 3.150717e-02  val_loss: 8.663646e-02\nEpoch 150 - train_loss: 3.116977e-02  val_loss: 8.699773e-02\nEpoch 151 - train_loss: 3.128126e-02  val_loss: 8.698739e-02\nEpoch 152 - train_loss: 3.101521e-02  val_loss: 8.606912e-02\nEpoch 153 - train_loss: 2.972211e-02  val_loss: 8.610170e-02\nEpoch 154 - train_loss: 3.035292e-02  val_loss: 8.592091e-02\nEpoch 155 - train_loss: 2.981072e-02  val_loss: 8.793064e-02\nEpoch 156 - train_loss: 2.903134e-02  val_loss: 8.721310e-02\nEpoch 157 - train_loss: 2.918352e-02  val_loss: 8.636487e-02\nEpoch 158 - train_loss: 3.144869e-02  val_loss: 8.624335e-02\nEpoch 159 - train_loss: 3.020802e-02  val_loss: 8.690243e-02\nEpoch 160 - train_loss: 2.932981e-02  val_loss: 8.814592e-02\nEpoch 161 - train_loss: 3.099981e-02  val_loss: 8.800791e-02\nEpoch 162 - train_loss: 2.978738e-02  val_loss: 8.697911e-02\nEpoch 163 - train_loss: 3.006635e-02  val_loss: 8.513176e-02\nEpoch 164 - train_loss: 3.063059e-02  val_loss: 8.840741e-02\nEpoch 165 - train_loss: 3.051676e-02  val_loss: 8.613375e-02\nEpoch 166 - train_loss: 3.003004e-02  val_loss: 8.511292e-02\nEpoch 167 - train_loss: 2.722411e-02  val_loss: 8.888765e-02\nEarly stopping after 167 epochs (no improvement for 30 epochs).\n\u001b[1m2/2\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m0s\u001b[0m 148ms/step\nMean R2: 0.9843025250350625\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 1000x600 with 1 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"Saved weights: /kaggle/working/best_model_light.ckpt\nSaved R2 list: /kaggle/working/r2_list_light.npy\n","output_type":"stream"}],"execution_count":1},{"cell_type":"code","source":"# prepare_physics_meta.py\n# ایجاد ابر‌دادهٔ فیزیکی برای ترم‌های Physics-Guided Loss\n# خروجی: چند npy که با ترتیب نمونه‌ها در YAML (سورت‌شده) هم‌راستا هستند.\n# - phys_valid_mask.npy        (N,)\n# - phys_gamma_idx.npy         (N,)\n# - phys_dk_steps.npy          (N, S)\n# - phys_C_acoustic.npy        (N, 3)   میانگین شیب 3 شاخهٔ آکوستیک نزدیک Γ\n# - filelist.npy               (N,)      نام فایل‌های YAML به همان ترتیب\n\nimport os\nimport yaml\nimport numpy as np\n\n# ------ پارامترها ------\nyaml_folder = \"/kaggle/input/pgcnndata/extracted_bands_C\"  # مسیر YAML\nout_dir     = \"/kaggle/working\"\nS_STEPS     = 3     # چند قدم بعد از Γ برای تخمین شیب\nGAMMA_TOL   = 1e-8  # آستانه برای شناسایی q≈0\n\nos.makedirs(out_dir, exist_ok=True)\n\n# لیست فایل‌ها (سورت‌شده)\nyaml_files = [f for f in os.listdir(yaml_folder) if f.endswith(\".yaml\")]\nyaml_files.sort()\n\nN = len(yaml_files)\nvalid_mask   = np.zeros((N,), dtype=bool)\ngamma_idx    = np.full((N,), -1, dtype=int)\ndk_steps     = np.zeros((N, S_STEPS), dtype=float)\nC_acoustic   = np.zeros((N, 3), dtype=float)  # میانگین شیب 3 شاخهٔ آکوستیک\n\ndef _is_gamma(q):\n    return np.linalg.norm(q) < GAMMA_TOL\n\ndef _safe_freqs(ph):\n    # ph: dict with 'band' list of dicts\n    bands = ph.get('band', [])\n    freqs = [b.get('frequency', 0.0) for b in bands]\n    return np.array(freqs, dtype=float)\n\nfor i, fname in enumerate(yaml_files):\n    path = os.path.join(yaml_folder, fname)\n    try:\n        with open(path, \"r\") as f:\n            data = yaml.safe_load(f)\n        phonon = data.get(\"phonon\", [])\n        if not phonon or len(phonon) < S_STEPS + 1:\n            continue\n\n        # q-points & frequencies (واقعی)\n        q_list = []\n        f_list = []\n        for ph in phonon:\n            q = ph.get(\"q-position\", None)\n            if q is None:\n                # بعضی فایل‌ها از کلید 'q-position' با فاصله/داش متفاوت استفاده می‌کنند\n                # تلاش برای نام‌های رایج دیگر\n                for k in [\"q-position\", \"q_position\", \"q\"]:\n                    if k in ph:\n                        q = ph[k]\n                        break\n            if q is None:\n                q = [0.0, 0.0, 0.0]  # fallback\n            q_list.append(np.array(q, dtype=float))\n            f_list.append(_safe_freqs(ph))\n\n        q_arr = np.vstack(q_list)                     # (Q, 3)\n        f_arr = np.vstack(f_list)                     # (Q, bands)\n        Q, B  = f_arr.shape\n        if B < 3:\n            continue\n\n        # پیدا کردن ایندکس Γ که بعدش حداقل S_STEPS نقطه وجود داشته باشد\n        g_candidates = [idx for idx in range(Q - S_STEPS) if _is_gamma(q_arr[idx])]\n        if not g_candidates:\n            continue\n        g = g_candidates[0]\n\n        # شاخه‌های آکوستیکی: 3 شاخهٔ اول (فرض استاندارد مرتب‌سازی)\n        # شیب‌ها: (f[q+1] - f[q]) / ||Δk|| برای قدم‌های 1..S\n        dk = []\n        slopes_per_step = []\n        for s in range(1, S_STEPS + 1):\n            dq = q_arr[g + s] - q_arr[g + s - 1]\n            dk_s = float(np.linalg.norm(dq))\n            if dk_s < 1e-12:\n                dk_s = 1e-12\n            df = f_arr[g + s, :3] - f_arr[g + s - 1, :3]  # سه شاخهٔ اول\n            slopes_per_step.append(df / dk_s)             # (3,)\n            dk.append(dk_s)\n        slopes_per_step = np.stack(slopes_per_step, axis=0)  # (S, 3)\n        dk = np.array(dk, dtype=float)                       # (S,)\n\n        C_mean = np.mean(slopes_per_step, axis=0)            # (3,)\n\n        valid_mask[i] = True\n        gamma_idx[i]  = g\n        dk_steps[i]   = dk\n        C_acoustic[i] = C_mean\n\n    except Exception as e:\n        print(f\"[WARN] skip {fname}: {e}\")\n        continue\n\n# ذخیره\nnp.save(os.path.join(out_dir, \"phys_valid_mask.npy\"), valid_mask)\nnp.save(os.path.join(out_dir, \"phys_gamma_idx.npy\"), gamma_idx)\nnp.save(os.path.join(out_dir, \"phys_dk_steps.npy\"), dk_steps)\nnp.save(os.path.join(out_dir, \"phys_C_acoustic.npy\"), C_acoustic)\nnp.save(os.path.join(out_dir, \"filelist.npy\"), np.array(yaml_files, dtype=object))\n\nprint(f\"Physics meta saved to {out_dir}\")\nprint(f\"usable samples: {valid_mask.sum()} / {N}\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-08-16T10:44:41.909255Z","iopub.execute_input":"2025-08-16T10:44:41.909623Z","iopub.status.idle":"2025-08-16T10:44:41.957518Z","shell.execute_reply.started":"2025-08-16T10:44:41.909597Z","shell.execute_reply":"2025-08-16T10:44:41.956307Z"}},"outputs":[{"name":"stdout","text":"Physics meta saved to /kaggle/working\nusable samples: 0 / 0\n","output_type":"stream"}],"execution_count":1},{"cell_type":"code","source":"# train_pgcnn_style.py\n# مدل سبک + Physics-Guided Loss (Γ-zero + nonnegativity + slope-match) + smoothness\n# ورودی: آرایه‌های آماده (X,y,scalers) + فایل‌های فیزیکی تهیه‌شده توسط prepare_physics_meta.py\n\nimport os\nimport numpy as np\nimport tensorflow as tf\nfrom sklearn.metrics import r2_score\nimport matplotlib.pyplot as plt\nfrom scipy.signal import savgol_filter\n\n# ---------- مسیرها ----------\ndata_dir_np = \"/kaggle/input/fanal-dataset\"          # پوشهٔ npyهای X,y,scalers\nyaml_meta_dir = \"/kaggle/working\"                        # همان out_dir از prepare_physics_meta.py\nout_dir = \"/kaggle/working\"\nos.makedirs(out_dir, exist_ok=True)\n\n# ---------- mixed precision ----------\nfrom tensorflow.keras import mixed_precision\ntry:\n    mixed_precision.set_global_policy('mixed_float16')\n    print(\"Mixed precision policy set to:\", mixed_precision.global_policy())\nexcept Exception as e:\n    print(\"Mixed precision unavailable:\", e)\n\n# ---------- بارگذاری داده‌ها ----------\nX_train = np.load(os.path.join(data_dir_np, \"train_x.npy\"))\nX_val   = np.load(os.path.join(data_dir_np, \"val_x.npy\"))\nX_test  = np.load(os.path.join(data_dir_np, \"test_x.npy\"))\ny_train = np.load(os.path.join(data_dir_np, \"train_y.npy\"))\ny_val   = np.load(os.path.join(data_dir_np, \"val_y.npy\"))\ny_test  = np.load(os.path.join(data_dir_np, \"test_y.npy\"))\n\nscaler_y_mean = np.load(os.path.join(data_dir_np, \"scaler_y_mean.npy\"))\nscaler_y_std  = np.load(os.path.join(data_dir_np, \"scaler_y_std.npy\"))\n\n# ابعاد\nnum_samples, max_qpoints, max_bands = y_train.shape\noutput_flat_dim = int(max_qpoints * max_bands)\n\n# ---------- بارگذاری متادیتای فیزیکی ----------\n# فرض: ترتیب نمونه‌ها در npy با ترتیب YAML (سورت‌شده) یکی است.\n# اگر دیتاست را به شیوهٔ دیگری ساخته‌ای، باید آرایه‌های فیزیکی را به همان ترتیب ایندکس‌گذاری کنی.\nphys_valid_mask = np.load(os.path.join(yaml_meta_dir, \"phys_valid_mask.npy\"))\nphys_gamma_idx  = np.load(os.path.join(yaml_meta_dir, \"phys_gamma_idx.npy\"))\nphys_dk_steps   = np.load(os.path.join(yaml_meta_dir, \"phys_dk_steps.npy\"))      # (N, S)\nphys_C_acoustic = np.load(os.path.join(yaml_meta_dir, \"phys_C_acoustic.npy\"))    # (N, 3)\n\n# به حداقل طول مشترک برش می‌زنیم تا mismatch‌های احتمالی از بین برود\nN_all = min(len(phys_valid_mask), len(X_train) + len(X_val) + len(X_test))\nphys_valid_mask = phys_valid_mask[:N_all]\nphys_gamma_idx  = phys_gamma_idx[:N_all]\nphys_dk_steps   = phys_dk_steps[:N_all]\nphys_C_acoustic = phys_C_acoustic[:N_all]\n\n# دیتاست npy را هم به N_all برش می‌دهیم (اگر لازم شد)\ndef clip_to_N(arr, N):\n    return arr[:N]\n\n# بازترکیب X,y به یک آرایه‌ی کامل و سپس برش‌های train/val/test را بر اساس طول‌های فعلی می‌سازیم\nn_tr, n_va, n_te = len(X_train), len(X_val), len(X_test)\nX_all = np.concatenate([X_train, X_val, X_test], axis=0)\ny_all = np.concatenate([y_train, y_val, y_test], axis=0)\n\nX_all = clip_to_N(X_all, N_all)\ny_all = clip_to_N(y_all, N_all)\n\n# دوباره تقسیم به train/val/test با نسبت‌های قبلی\nX_train = X_all[:n_tr]\ny_train = y_all[:n_tr]\nX_val   = X_all[n_tr:n_tr+n_va]\ny_val   = y_all[n_tr:n_tr+n_va]\nX_test  = X_all[n_tr+n_va:n_tr+n_va+n_te]\ny_test  = y_all[n_tr+n_va:n_tr+n_va+n_te]\n\n# متادیتای فیزیکی را نیز به همین برش‌ها تقسیم می‌کنیم\nphys_valid_train = phys_valid_mask[:n_tr]\nphys_valid_val   = phys_valid_mask[n_tr:n_tr+n_va]\nphys_valid_test  = phys_valid_mask[n_tr+n_va:n_tr+n_va+n_te]\n\nphys_gamma_train = phys_gamma_idx[:n_tr]\nphys_gamma_val   = phys_gamma_idx[n_tr:n_tr+n_va]\nphys_gamma_test  = phys_gamma_idx[n_tr+n_va:n_tr+n_va+n_te]\n\nphys_dk_train = phys_dk_steps[:n_tr]\nphys_dk_val   = phys_dk_steps[n_tr:n_tr+n_va]\nphys_dk_test  = phys_dk_steps[n_tr+n_va:n_tr+n_va+n_te]\n\nphys_C_train = phys_C_acoustic[:n_tr]\nphys_C_val   = phys_C_acoustic[n_tr:n_tr+n_va]\nphys_C_test  = phys_C_acoustic[n_tr+n_va:n_tr+n_va+n_te]\n\n# ---------- ابزارها ----------\ndef inverse_transform_y_flat(y_norm_flat):\n    # y_norm_flat: (batch, Q*B)\n    y_mean = tf.constant(scaler_y_mean.reshape(1, -1), dtype=tf.float32)\n    y_std  = tf.constant(scaler_y_std.reshape(1, -1), dtype=tf.float32)\n    return y_norm_flat * y_std + y_mean\n\ndef smoothness_loss_from_reshaped(y_pred_reshaped):\n    # y_pred_reshaped: (batch, Q, B) - در فضای فیزیکی (THz)\n    d2 = y_pred_reshaped[:, 2:, :] - 2.0 * y_pred_reshaped[:, 1:-1, :] + y_pred_reshaped[:, :-2, :]\n    return tf.reduce_mean(tf.square(d2))\n\n# ---------- مدل ----------\ndef swish(x): return tf.nn.swish(x)\n\ndef residual_dense_block(x, units, dropout_rate=0.03, use_bn=False):\n    sc = x\n    if int(sc.shape[-1]) != units:\n        sc = tf.keras.layers.Dense(units, activation=None, dtype='float32')(sc)\n    x = tf.keras.layers.Dense(units, activation=swish, dtype='float32')(x)\n    if use_bn: x = tf.keras.layers.BatchNormalization()(x)\n    x = tf.keras.layers.Dropout(dropout_rate)(x)\n    x = tf.keras.layers.Add()([sc, x])\n    x = tf.keras.layers.Activation(swish)(x)\n    return x\n\ndef build_model_light(input_dim, output_dim):\n    inp = tf.keras.layers.Input(shape=(input_dim,), name=\"input\")\n    x = tf.keras.layers.Dense(256, activation=swish, dtype='float32')(inp)\n    x = residual_dense_block(x, 256, dropout_rate=0.03, use_bn=False)\n    x = residual_dense_block(x, 128, dropout_rate=0.02, use_bn=False)\n    x = tf.keras.layers.Dense(256, activation=swish, dtype='float32')(x)\n    x = tf.keras.layers.Dropout(0.15)(x)\n    out = tf.keras.layers.Dense(output_dim, activation='linear', dtype='float32', name=\"out\")(x)\n    return tf.keras.Model(inputs=inp, outputs=out)\n\n# ---------- هایپرپارامترها ----------\nBATCH_SIZE     = 64\nEPOCHS         = 300\nLR             = 3e-4\nLAMBDA_SMOOTH  = 1e-2\n\n# ضرایب ترم‌های فیزیکی (قابل تیون)\nLAMBDA_GAMMA0  = 5e-3   # پنالتی برای غیرصفر بودن 3 شاخه آکوستیک در Γ\nLAMBDA_NONNEG  = 5e-3   # پنالتی برای فرکانس‌های منفی\nLAMBDA_SLOPE   = 5e-2   # تطبیق شیب نزدیک Γ با C_acoustic\n\n# ---------- ساخت tf.data که متادیتا را هم تحویل بدهد ----------\ndef make_dataset(X, y, valid, gamma_idx, dk_steps, C_acoustic, batch_size, shuffle):\n    X = X.astype(np.float32)\n    y_flat = y.reshape(len(y), -1).astype(np.float32)\n    valid = valid.astype(np.float32)\n    gamma_idx = gamma_idx.astype(np.int32)\n    dk_steps  = dk_steps.astype(np.float32)         # (N, S)\n    C_acoustic = C_acoustic.astype(np.float32)      # (N, 3)\n\n    ds = tf.data.Dataset.from_tensor_slices((X, y_flat, valid, gamma_idx, dk_steps, C_acoustic))\n    if shuffle:\n        ds = ds.shuffle(buffer_size=min(10000, len(X)))\n    ds = ds.batch(batch_size, drop_remainder=False).prefetch(tf.data.AUTOTUNE)\n    return ds\n\ntrain_ds = make_dataset(X_train, y_train, phys_valid_train, phys_gamma_train, phys_dk_train, phys_C_train, BATCH_SIZE, True)\nval_ds   = make_dataset(X_val,   y_val,   phys_valid_val,   phys_gamma_val,   phys_dk_val,   phys_C_val,   BATCH_SIZE, False)\n\n# ---------- مدل و اپتیمایزر ----------\ninput_dim = X_train.shape[1]\nmodel = build_model_light(input_dim, output_flat_dim)\nmodel.summary()\nmse = tf.keras.losses.MeanSquaredError()\noptimizer = tf.keras.optimizers.Adam(learning_rate=LR)\n\n# ---------- Physics-Guided loss ----------\n@tf.function\ndef pg_loss(y_true_flat, y_pred_flat, valid_mask, gamma_idx, dk_steps, C_acoustic):\n    \"\"\"\n    همه‌چیز در فضای فیزیکی (THz) محاسبه می‌شود.\n    \"\"\"\n    # denormalize\n    y_true_phys_flat = inverse_transform_y_flat(y_true_flat)\n    y_pred_phys_flat = inverse_transform_y_flat(y_pred_flat)\n\n    # reshape به (batch, Q, B)\n    Q = tf.constant(max_qpoints, dtype=tf.int32)\n    B = tf.constant(max_bands, dtype=tf.int32)\n    y_pred_phys = tf.reshape(y_pred_phys_flat, (-1, Q, B))\n    y_true_phys = tf.reshape(y_true_phys_flat, (-1, Q, B))\n\n    # 1) Data term (MSE)\n    loss_data = mse(y_true_phys_flat, y_pred_phys_flat)\n\n    # 2) Smoothness term\n    loss_smooth = smoothness_loss_from_reshaped(y_pred_phys)\n\n    # 3) Γ-zero (سه شاخهٔ اول در Γ باید نزدیک صفر باشند)\n    # gather y_pred[:, gamma_idx, :3]\n    batch_size = tf.shape(y_pred_phys)[0]\n    idx = tf.stack([tf.range(batch_size, dtype=gamma_idx.dtype), gamma_idx], axis=1)  # (batch, 2)\n    y_gamma = tf.gather_nd(y_pred_phys[:, :, :3], idx)  # (batch, 3)\n    loss_gamma0 = tf.reduce_mean(tf.square(y_gamma) * valid_mask[:, None])\n\n    # 4) non-negativity (فرکانس‌های منفی جریمه شوند)\n    neg_part = tf.nn.relu(-y_pred_phys)  # (batch, Q, B)\n    loss_nonneg = tf.reduce_mean(tf.square(neg_part))\n\n    # 5) slope-match نزدیک Γ برای 3 شاخهٔ آکوستیک\n    # ساخت اندیس‌های گام‌های بعد از Γ: gamma_idx + [1..S]\n    S = tf.shape(dk_steps)[1]\n    step_offsets = tf.range(1, S + 1, dtype=gamma_idx.dtype)[None, :]     # (1, S)\n    idx_steps = gamma_idx[:, None] + step_offsets                          # (batch, S)\n\n    # gather y_pred در این ایندکس‌ها برای همهٔ باندها، سپس فقط [:, :, :3]\n    # شکل خروجی gather با batch_dims=1 ، (batch, S, B)\n    y_steps = tf.gather(y_pred_phys, idx_steps, batch_dims=1)[:, :, :3]    # (batch, S, 3)\n\n    # y_gamma را به شکل (batch, 1, 3) بسط بده\n    y_gamma_exp = y_gamma[:, None, :]                                      # (batch, 1, 3)\n\n    # df / dk برای هر step\n    dk = dk_steps[:, :, None] + 1e-12                                      # (batch, S, 1)\n    slopes_pred = (y_steps - y_gamma_exp) / dk                             # (batch, S, 3)\n    slopes_pred_mean = tf.reduce_mean(slopes_pred, axis=1)                 # (batch, 3)\n\n    # C_acoustic: (batch, 3)\n    slope_err = slopes_pred_mean - C_acoustic\n    loss_slope = tf.reduce_mean(tf.square(slope_err) * valid_mask[:, None])\n\n    # total\n    total = loss_data + LAMBDA_SMOOTH * loss_smooth \\\n                      + LAMBDA_GAMMA0 * loss_gamma0 \\\n                      + LAMBDA_NONNEG * loss_nonneg \\\n                      + LAMBDA_SLOPE  * loss_slope\n    return total, loss_data, loss_smooth, loss_gamma0, loss_nonneg, loss_slope\n\n# ---------- حلقهٔ آموزش ----------\n@tf.function\ndef train_step(xb, yb, vb, gb, dkb, Cb):\n    with tf.GradientTape() as tape:\n        pred = model(xb, training=True)\n        loss_all = pg_loss(yb, pred, vb, gb, dkb, Cb)\n        total = loss_all[0]\n    grads = tape.gradient(total, model.trainable_variables)\n    optimizer.apply_gradients(zip(grads, model.trainable_variables))\n    return loss_all\n\n@tf.function\ndef val_step(xb, yb, vb, gb, dkb, Cb):\n    pred = model(xb, training=False)\n    return pg_loss(yb, pred, vb, gb, dkb, Cb)\n\nbest_val = np.inf\npatience = 30\nno_improve = 0\nhistory = {\"loss\": [], \"val_loss\": []}\n\nfor epoch in range(1, EPOCHS + 1):\n    # train\n    tr_losses = []\n    for xb, yb, vb, gb, dkb, Cb in train_ds:\n        loss_all = train_step(xb, yb, vb, gb, dkb, Cb)\n        tr_losses.append(loss_all[0].numpy())\n    train_loss = float(np.mean(tr_losses))\n\n    # val\n    va_losses = []\n    for xb, yb, vb, gb, dkb, Cb in val_ds:\n        loss_all = val_step(xb, yb, vb, gb, dkb, Cb)\n        va_losses.append(loss_all[0].numpy())\n    val_loss = float(np.mean(va_losses))\n\n    history[\"loss\"].append(train_loss)\n    history[\"val_loss\"].append(val_loss)\n    print(f\"Epoch {epoch:03d} | Train: {train_loss:.6e} | Val: {val_loss:.6e}\")\n\n    if val_loss < best_val - 1e-10:\n        best_val = val_loss\n        no_improve = 0\n        model.save_weights(os.path.join(out_dir, \"best_model_phys.weights.h5\"))\n    else:\n        no_improve += 1\n        if no_improve >= patience:\n            print(\"Early stopping.\")\n            break\n\n# ---------- ارزیابی ----------\nmodel.load_weights(os.path.join(out_dir, \"best_model_phys.weights.h5\"))\n\nBATCH_EVAL = BATCH_SIZE\ny_test_flat = y_test.reshape(len(y_test), -1).astype(np.float32)\ny_pred_flat = model.predict(X_test.astype(np.float32), batch_size=BATCH_EVAL)\n\n# denormalize برای محاسبهٔ R2\ny_pred = (y_pred_flat * scaler_y_std + scaler_y_mean).reshape(-1, max_qpoints, max_bands)\ny_true = (y_test_flat * scaler_y_std + scaler_y_mean).reshape(-1, max_qpoints, max_bands)\n\nr2_scores = [r2_score(y_true[i].ravel(), y_pred[i].ravel()) for i in range(len(y_true))]\nprint(\"Test mean R²:\", np.mean(r2_scores))\nnp.save(os.path.join(out_dir, \"r2_list_phys.npy\"), np.array(r2_scores))\n\n# ---------- رسم نمونه ----------\nsample_idx = 0\npred_sample = y_pred[sample_idx]\nwindow_length = 7 if max_qpoints >= 7 else (max_qpoints//2*2+1)\npolyorder = 3\ntry:\n    pred_smooth = np.copy(pred_sample)\n    for b in range(pred_sample.shape[1]):\n        pred_smooth[:, b] = savgol_filter(pred_sample[:, b], window_length=window_length, polyorder=polyorder, mode='interp')\nexcept Exception:\n    from scipy.ndimage import gaussian_filter1d\n    pred_smooth = gaussian_filter1d(pred_sample, sigma=0.6, axis=0)\n\nplt.figure(figsize=(10,6))\nfor b in range(pred_sample.shape[1]):\n    plt.plot(pred_sample[:, b], alpha=0.35)\n    plt.plot(pred_smooth[:, b], linewidth=1.4)\nplt.title(\"Predicted phonon bands (before & after smoothing)\")\nplt.xlabel(\"Q-point\"); plt.ylabel(\"Frequency (THz)\"); plt.grid(True)\nplt.savefig(os.path.join(out_dir, \"pred_phys_before_after_smooth.png\"))\nplt.show()\n\n# ---------- نمودار تاریخچه ----------\nplt.figure(figsize=(10,6))\nplt.plot(history[\"loss\"], label=\"Training Loss\")\nplt.plot(history[\"val_loss\"], label=\"Validation Loss\")\nplt.title(\"Training & Validation Loss (with Physics)\")\nplt.xlabel(\"Epoch\"); plt.ylabel(\"Loss\"); plt.grid(True); plt.legend()\nplt.savefig(os.path.join(out_dir, \"training_loss_phys.png\"))\nplt.show()\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-08-16T10:49:46.056061Z","iopub.execute_input":"2025-08-16T10:49:46.056537Z","iopub.status.idle":"2025-08-16T10:49:46.162926Z","shell.execute_reply.started":"2025-08-16T10:49:46.056513Z","shell.execute_reply":"2025-08-16T10:49:46.161636Z"}},"outputs":[{"name":"stdout","text":"Mixed precision policy set to: <DTypePolicy \"mixed_float16\">\n","output_type":"stream"},{"traceback":["\u001b[0;31m---------------------------------------------------------------------------\u001b[0m","\u001b[0;31mValueError\u001b[0m                                Traceback (most recent call last)","\u001b[0;32m/tmp/ipykernel_35/2651696601.py\u001b[0m in \u001b[0;36m<cell line: 0>\u001b[0;34m()\u001b[0m\n\u001b[1;32m    153\u001b[0m     \u001b[0;32mreturn\u001b[0m \u001b[0mds\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m    154\u001b[0m \u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0;32m--> 155\u001b[0;31m \u001b[0mtrain_ds\u001b[0m \u001b[0;34m=\u001b[0m \u001b[0mmake_dataset\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mX_train\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0my_train\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0mphys_valid_train\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0mphys_gamma_train\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0mphys_dk_train\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0mphys_C_train\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0mBATCH_SIZE\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0;32mTrue\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0m\u001b[1;32m    156\u001b[0m \u001b[0mval_ds\u001b[0m   \u001b[0;34m=\u001b[0m \u001b[0mmake_dataset\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mX_val\u001b[0m\u001b[0;34m,\u001b[0m   \u001b[0my_val\u001b[0m\u001b[0;34m,\u001b[0m   \u001b[0mphys_valid_val\u001b[0m\u001b[0;34m,\u001b[0m   \u001b[0mphys_gamma_val\u001b[0m\u001b[0;34m,\u001b[0m   \u001b[0mphys_dk_val\u001b[0m\u001b[0;34m,\u001b[0m   \u001b[0mphys_C_val\u001b[0m\u001b[0;34m,\u001b[0m   \u001b[0mBATCH_SIZE\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0;32mFalse\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m    157\u001b[0m \u001b[0;34m\u001b[0m\u001b[0m\n","\u001b[0;32m/tmp/ipykernel_35/2651696601.py\u001b[0m in \u001b[0;36mmake_dataset\u001b[0;34m(X, y, valid, gamma_idx, dk_steps, C_acoustic, batch_size, shuffle)\u001b[0m\n\u001b[1;32m    141\u001b[0m \u001b[0;32mdef\u001b[0m \u001b[0mmake_dataset\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mX\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0my\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0mvalid\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0mgamma_idx\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0mdk_steps\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0mC_acoustic\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0mbatch_size\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0mshuffle\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m:\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m    142\u001b[0m     \u001b[0mX\u001b[0m \u001b[0;34m=\u001b[0m \u001b[0mX\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mastype\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mnp\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mfloat32\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0;32m--> 143\u001b[0;31m     \u001b[0my_flat\u001b[0m \u001b[0;34m=\u001b[0m \u001b[0my\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mreshape\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mlen\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0my\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0;34m-\u001b[0m\u001b[0;36m1\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mastype\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mnp\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mfloat32\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0m\u001b[1;32m    144\u001b[0m     \u001b[0mvalid\u001b[0m \u001b[0;34m=\u001b[0m \u001b[0mvalid\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mastype\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mnp\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mfloat32\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m    145\u001b[0m     \u001b[0mgamma_idx\u001b[0m \u001b[0;34m=\u001b[0m \u001b[0mgamma_idx\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mastype\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mnp\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mint32\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n","\u001b[0;31mValueError\u001b[0m: cannot reshape array of size 0 into shape (0,newaxis)"],"ename":"ValueError","evalue":"cannot reshape array of size 0 into shape (0,newaxis)","output_type":"error"}],"execution_count":5},{"cell_type":"code","source":"# =========================================================\n# بخش A) ساخت دیتاست گرافی از POSCAR + YAML + اکسل اتمی → ذخیره npy\n# =========================================================\n\nimport os\nimport glob\nimport math\nimport yaml\nimport pickle\nimport numpy as np\nimport pandas as pd\nfrom tqdm import tqdm\nfrom pymatgen.io.vasp import Poscar\n# ساختار/مواد\nfrom pymatgen.core import Structure\nfrom pymatgen.core.periodic_table import Element\n\n# نرمال‌سازی\nfrom sklearn.preprocessing import StandardScaler\n\n# -----------------------\n# مسیرها (برحسب فولدرهای خودت تنظیم کن)\n# -----------------------\nPOSCAR_DIR   = \"/kaggle/input/pgcnndata/all_poscar/all_poscar\"          # فولدری که POSCAR ها داخلشه\nYAML_DIR     = \"/kaggle/input/pgcnndata/extracted_bands_C/extracted_bands_C\"     # فولدری که band.yaml یا yaml های فرکانس داخلشه\nATOMIC_XLSX  = \"/kaggle/input/npy-phonon-phase7/feature_data_edited.xlsx\"  # اکسل ویژگی‌های اتمی\nOUTPUT_DIR   = \"/kaggle/working/graph_dataset\"  # خروجی‌ها اینجا ذخیره می‌شن\n\nos.makedirs(OUTPUT_DIR, exist_ok=True)\n\n# -----------------------\n# تنظیمات گراف\n# -----------------------\nCUTOFF = 5.0         # آنگستروم؛ همسایه‌ها در این فاصله\nMAX_NB = 24          # حداکثر تعداد همسایه برای هر اتم (برای کنترل اندازه)\nANGLE_HIST_BINS = 8  # تعداد بین‌های هیستوگرام cos(theta) برای آمارهای زاویه‌ای\n\n# -----------------------\n# خواندن اکسل ویژگی‌های اتمی و ساخت نگاشت عنصر→بردار فیچر\n# انتظار: ستون 'element' + بقیه ستون‌ها ویژگی‌ها\n# -----------------------\natomic_df = pd.read_excel(ATOMIC_XLSX)\natomic_df.columns = [str(c).strip() for c in atomic_df.columns]\nassert 'symbol' in atomic_df.columns, \"ستون 'symbol' باید در اکسل باشد.\"\nfeature_cols = [c for c in atomic_df.columns if c != 'symbol']\n\nfeat_mat = atomic_df[feature_cols].values.astype(float)\n# نرمال‌سازی اولیه روی فیچرهای اتمی (بهتر برای تعمیم)\natom_feat_scaler = StandardScaler()\nfeat_mat_norm = atom_feat_scaler.fit_transform(feat_mat)\n\n# نگاشت نام عنصر به اندیس در جدول و سپس به بردار نرمال‌شده\nelem_to_vec = {row['symbol']: feat_mat_norm[i] for i, row in atomic_df.iterrows()}\n\ndef element_vector(symbol: str) -> np.ndarray:\n    # اگر عنصری نبود، با صفرها پر می‌کنیم (یا می‌تونی assert بگذاری)\n    return elem_to_vec.get(symbol, np.zeros((feat_mat_norm.shape[1],), dtype=float))\n\n# -----------------------\n# کمکی: استخراج برچسب y از YAML (مثلاً band.yaml از phonopy)\n# انتظار: yaml شامل لیست فرکانس‌ها روی qpoints باشد\n# نتیجه: y به شکل یک بردار 1D با طول ثابت بین ساختارها (فرض مسیر و sampling برابر است)\n# -----------------------\ndef load_label_from_yaml(yaml_path: str) -> np.ndarray:\n    with open(yaml_path, 'r') as f:\n        data = yaml.safe_load(f)\n    # این بخش وابسته به ساختار فایل YAML است. برای band.yaml معمولاً:\n    # data['phonon'][i]['band'][j]['frequency']\n    # ما همه فرکانس‌ها را به صورت یک بردار فلت در می‌آوریم.\n    phonon = data.get('phonon', [])\n    freqs = []\n    for q in phonon:\n        bands = q.get('band', [])\n        for b in bands:\n            f = b.get('frequency', None)\n            if f is not None:\n                freqs.append(float(f))\n    return np.array(freqs, dtype=float)\n\n# -----------------------\n# کمکی: ساخت گراف از ساختار pymatgen\n# خروجی: dict شامل x (نود فیچر), edge_index, edge_attr, pos, u (گلوبال فیچر)\n# + y (برچسب)\n# -----------------------\ndef build_graph_from_structure(struct: Structure,\n                               y_vec: np.ndarray,\n                               cutoff=CUTOFF,\n                               max_nb=MAX_NB) -> dict:\n    # مختصات کارتزین و المان‌ها\n    cart_coords = np.array([s.coords for s in struct.sites], dtype=float)   # (N, 3)\n    species = [s.specie.symbol for s in struct.sites]                       # طول N\n\n    N = len(species)\n\n    # --- نود فیچر از اکسل ---\n    x_nodes = np.stack([element_vector(sym) for sym in species], axis=0)    # (N, F_atom)\n\n    # --- همسایه‌ها بر اساس cutoff ---\n    # از خود pymatgen استفاده می‌کنیم\n    # همسایه‌ها شامل (سایت همسایه، فاصله، تصویر) هستند\n    # برای کنترل اندازه، نهایتاً max_nb را نگه می‌داریم\n    neighbors_list = [[] for _ in range(N)]\n    for i in range(N):\n        neighs = struct.get_neighbors(struct[i], cutoff)\n        # sort by distance\n        neighs_sorted = sorted(neighs, key=lambda nn: nn[1])\n        # محدودکردن\n        neighs_sorted = neighs_sorted[:max_nb]\n        neighbors_list[i] = neighs_sorted\n\n    # --- edge_index و edge_attr (فاصله و بردار جهت) ---\n    edge_src, edge_dst = [], []\n    edge_feat = []   # [dx, dy, dz, dist]\n    for i in range(N):\n        ri = cart_coords[i]\n        for nn in neighbors_list[i]:\n            j = nn[0].index\n            rj = nn[0].coords\n            vec = rj - ri\n            dist = np.linalg.norm(vec)\n            if dist <= 1e-12:\n                continue\n            unit = vec / dist\n            edge_src.append(i)\n            edge_dst.append(j)\n            edge_feat.append([unit[0], unit[1], unit[2], dist])\n\n    edge_index = np.array([edge_src, edge_dst], dtype=np.int64)\n    edge_attr  = np.array(edge_feat, dtype=float)  # (E, 4)\n\n    # --- ویژگی زاویه‌ای: آمار زاویه‌ها حول هر نود ---\n    # برای هر نود i، برای همه جفت همسایه‌های (j,k) زاویه بین (j-i) و (k-i) را حساب می‌کنیم\n    # سپس روی cos(theta) آمار می‌گیریم و به فیچر نود append می‌کنیم.\n    def angle_stats_for_node(i):\n        neighs = neighbors_list[i]\n        if len(neighs) < 2:\n            # بدون زاویه قابل تعریف\n            num_stats = 4 + ANGLE_HIST_BINS  # mean, std, min, max + hist\n            return np.zeros((num_stats,), dtype=float)\n\n        vecs = []\n        for nn in neighs:\n            rj = nn[0].coords\n            v = rj - cart_coords[i]\n            n = np.linalg.norm(v)\n            if n > 1e-12:\n                vecs.append(v / n)\n        if len(vecs) < 2:\n            num_stats = 4 + ANGLE_HIST_BINS\n            return np.zeros((num_stats,), dtype=float)\n\n        cos_list = []\n        for a in range(len(vecs)):\n            for b in range(a+1, len(vecs)):\n                ca = np.dot(vecs[a], vecs[b])\n                # محدود کردن به بازه [-1,1] برای پایداری عددی\n                ca = max(-1.0, min(1.0, float(ca)))\n                cos_list.append(ca)\n\n        cos_arr = np.array(cos_list, dtype=float)\n        mean_c = float(np.mean(cos_arr))\n        std_c  = float(np.std(cos_arr))\n        min_c  = float(np.min(cos_arr))\n        max_c  = float(np.max(cos_arr))\n        hist, _ = np.histogram(cos_arr, bins=ANGLE_HIST_BINS, range=(-1.0, 1.0), density=True)\n        stats = np.concatenate([[mean_c, std_c, min_c, max_c], hist.astype(float)], axis=0)\n        return stats\n\n    angle_stats = np.stack([angle_stats_for_node(i) for i in range(N)], axis=0)  # (N, 4+bins)\n    x = np.concatenate([x_nodes, angle_stats], axis=1)  # نود فیچر نهایی (نود+زاویه)\n\n    # --- گلوبال فیچر u ---\n    # چند ویژگی فیزیکی ساده + آمار روی نود فیچرها\n    volume = float(struct.volume)\n    density = float(struct.density) if struct.density is not None else 0.0\n    num_atoms = float(N)\n    num_species = float(len(set(species)))\n\n    x_mean = x.mean(axis=0)\n    x_std  = x.std(axis=0)\n    x_min  = x.min(axis=0)\n    x_max  = x.max(axis=0)\n    # برای جلوگیری از طول خیلی زیاد، فقط آمار کلی از آمارها (میانگین‌شان)\n    u_stats = np.array([x_mean.mean(), x_std.mean(), x_min.mean(), x_max.mean()], dtype=float)\n\n    # میانگین فاصله همسایه‌ها (روی edge_attr[:, -1])\n    avg_dist = float(edge_attr[:, -1].mean()) if edge_attr.shape[0] > 0 else 0.0\n\n    u = np.array([volume, density, num_atoms, num_species, avg_dist] + u_stats.tolist(), dtype=float)\n\n    sample = dict(\n        x=x.astype(np.float32),                 # (N, F_node)\n        edge_index=edge_index.astype(np.int64), # (2, E)\n        edge_attr=edge_attr.astype(np.float32), # (E, 4)\n        pos=cart_coords.astype(np.float32),     # (N, 3)\n        u=u.astype(np.float32),                 # (F_global,)\n        y=y_vec.astype(np.float32)              # (T,) بردار فرکانس‌ها\n    )\n    return sample\n\n# -----------------------\n# پیمایش فایل‌ها: فرض می‌کنیم برای هر POSCAR یک YAML هم‌نام وجود دارد\n# مثال: POSCARs/ABC/POSCAR  ↔  phonons/ABC/band.yaml\n# اگر نام‌گذاری‌تان فرق دارد، این نگاشت را متناسب کنید.\n# -----------------------\nposcar_paths = sorted(glob.glob(os.path.join(POSCAR_DIR, \"*.psc\")))\nassert len(poscar_paths) > 0, \"هیچ فایل .psc پیدا نشد. مسیر POSCAR_DIR را چک کن.\"\n\n\nsamples = []\ny_lengths = []\n\nfor poscar_path in tqdm(poscar_paths, desc=\"Building graphs\"):\n    # حدس مسیر YAML: همان فولدر نسبی، فایل band.yaml\n    rel = os.path.relpath(os.path.dirname(poscar_path), POSCAR_DIR)\n    yaml_guess = os.path.join(YAML_DIR, rel, \"band.yaml\")\n    if not os.path.isfile(yaml_guess):\n        # اگر نام دیگری دارید، اینجا تطبیق دهید\n        # نوبتی یک yaml در همان فولدر برمی‌داریم\n        candidates = glob.glob(os.path.join(YAML_DIR, rel, \"*.yaml\"))\n        if len(candidates) == 0:\n            print(f\"⚠️ YAML not found for {poscar_path}. skipping.\")\n            continue\n        yaml_guess = candidates[0]\n\n    \n\n    struct = Poscar.from_file(poscar_path).structure\n\n    y_vec = load_label_from_yaml(yaml_guess)\n    y_lengths.append(len(y_vec))\n\n    samples.append((struct, y_vec))\n\n# اطمینان از یکسان بودن طول y در همه نمونه‌ها\nif len(set(y_lengths)) != 1:\n    # می‌تونیم کوتاه‌ترین طول را مبنا بگیریم یا رد کنیم. اینجا کوتاه‌ترین را مبنا می‌گذاریم.\n    min_len = int(min(y_lengths))\n    print(f\"ℹ️ طول y بین نمونه‌ها متفاوت است. همه به طول {min_len} بریده می‌شوند.\")\nelse:\n    min_len = y_lengths[0]\n\ndataset = []\nfor struct, y_vec in tqdm(samples, desc=\"Assembling samples\"):\n    y_use = y_vec[:min_len].copy()\n    sample = build_graph_from_structure(struct, y_use, cutoff=CUTOFF, max_nb=MAX_NB)\n    dataset.append(sample)\n\n# -----------------------\n# نرمال‌سازی نود/یال/گلوبال و برچسب‌ها (اختیاری ولی توصیه می‌شود)\n# اسکالرها ذخیره می‌شوند\n# -----------------------\n# چون طول نود/یال در نمونه‌ها متفاوته، همه را ردیفی می‌چینیم و اسکالر فیت می‌کنیم\nall_x = np.concatenate([s['x'] for s in dataset], axis=0)\nall_e = np.concatenate([s['edge_attr'] for s in dataset if s['edge_attr'].shape[0] > 0], axis=0) if any(s['edge_attr'].shape[0] > 0 for s in dataset) else np.zeros((1,4),dtype=float)\nall_u = np.stack([s['u'] for s in dataset], axis=0)\nall_y = np.stack([s['y'] for s in dataset], axis=0)\n\nscaler_x = StandardScaler().fit(all_x)\nscaler_e = StandardScaler().fit(all_e)\nscaler_u = StandardScaler().fit(all_u)\nscaler_y = StandardScaler().fit(all_y)\n\nfor s in dataset:\n    s['x'] = scaler_x.transform(s['x']).astype(np.float32)\n    if s['edge_attr'].shape[0] > 0:\n        s['edge_attr'] = scaler_e.transform(s['edge_attr']).astype(np.float32)\n    s['u'] = scaler_u.transform(s['u'][None, :]).astype(np.float32)[0]\n    s['y'] = scaler_y.transform(s['y'][None, :]).astype(np.float32)[0]\n\n# -----------------------\n# ذخیره به صورت NPY (pickled dict list) + اسکالرها\n# -----------------------\nDATA_NPY = os.path.join(OUTPUT_DIR, \"graph_dataset.npy\")\nnp.save(DATA_NPY, np.array(dataset, dtype=object), allow_pickle=True)\n\nwith open(os.path.join(OUTPUT_DIR, \"scaler_x.pkl\"), \"wb\") as f:\n    pickle.dump(scaler_x, f)\nwith open(os.path.join(OUTPUT_DIR, \"scaler_e.pkl\"), \"wb\") as f:\n    pickle.dump(scaler_e, f)\nwith open(os.path.join(OUTPUT_DIR, \"scaler_u.pkl\"), \"wb\") as f:\n    pickle.dump(scaler_u, f)\nwith open(os.path.join(OUTPUT_DIR, \"scaler_y.pkl\"), \"wb\") as f:\n    pickle.dump(scaler_y, f)\n\nprint(f\"✅ Dataset saved to: {DATA_NPY}\")\nprint(\"✅ Scalers saved (scaler_x/e/u/y.pkl)\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-08-24T17:34:33.392356Z","iopub.execute_input":"2025-08-24T17:34:33.39261Z","iopub.status.idle":"2025-08-24T17:41:29.85394Z","shell.execute_reply.started":"2025-08-24T17:34:33.392592Z","shell.execute_reply":"2025-08-24T17:41:29.853224Z"}},"outputs":[{"name":"stderr","text":"Building graphs: 100%|██████████| 374/374 [06:51<00:00,  1.10s/it]\nAssembling samples: 100%|██████████| 374/374 [00:03<00:00, 93.86it/s]\n","output_type":"stream"},{"name":"stdout","text":"✅ Dataset saved to: /kaggle/working/graph_dataset/graph_dataset.npy\n✅ Scalers saved (scaler_x/e/u/y.pkl)\n","output_type":"stream"}],"execution_count":10},{"cell_type":"code","source":"","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# =========================================================\n# بخش B) مدل GNN با PyTorch Geometric برای پیش‌بینی فرکانس‌ها\n# =========================================================\n\nimport os\nimport math\nimport numpy as np\nimport pickle\nfrom tqdm import tqdm\nimport matplotlib.pyplot as plt\n\nimport torch\nimport torch.nn as nn\nimport torch.nn.functional as F\nfrom torch_geometric.nn import GCNConv, global_mean_pool\n\n# نصب PyTorch Geometric اگر لازم بود (در کگل معمولاً نیاز میشه)\ntry:\n    import torch_geometric\n    from torch_geometric.data import Data, Dataset, DataLoader\n    from torch_geometric.nn import GINEConv, global_mean_pool\nexcept Exception as e:\n    print(\"PyTorch Geometric not found. Trying to install...\")\n    # در کگل ممکنه لازم باشه نسخه‌های سازگار نصب کنید؛\n    # اگر اینترنت بسته است، این بخش را حذف کنید و محیطی که pyg دارد استفاده کنید.\n    !pip -q install torch-geometric torch-scatter torch-sparse torch-cluster -f https://data.pyg.org/whl/torch-2.3.0+cu121.html\n    import torch_geometric\n    from torch_geometric.data import Data, Dataset, DataLoader\n    from torch_geometric.nn import GINEConv, global_mean_pool\n\n# -----------------------\n# مسیرها\n# -----------------------\nDATA_NPY = \"/kaggle/working/graph_dataset/graph_dataset.npy\"     # خروجی بخش A\nSCALER_Y = \"/kaggle/working/graph_dataset/scaler_y.pkl\"          # برای برگشت به مقیاس واقعی اگر خواستی\n\n# -----------------------\n# Dataset کلاس\n# -----------------------\nclass NPGraphDataset(Dataset):\n    def __init__(self, npy_path):\n        super().__init__()\n        self.samples = np.load(npy_path, allow_pickle=True)\n        # ثابت بودن طول y\n        self.y_len = self.samples[0]['y'].shape[0]\n\n    def len(self):\n        return len(self.samples)\n\n    def get(self, idx):\n        s = self.samples[idx].item() if isinstance(self.samples[idx], np.ndarray) else self.samples[idx]\n        x = torch.tensor(s['x'], dtype=torch.float32)                       # (N, Fx)\n        edge_index = torch.tensor(s['edge_index'], dtype=torch.long)        # (2, E)\n        edge_attr = torch.tensor(s['edge_attr'], dtype=torch.float32)       # (E, Fe)\n        pos = torch.tensor(s['pos'], dtype=torch.float32)                   # (N, 3)\n        u = torch.tensor(s['u'], dtype=torch.float32)                       # (Fu,)\n        y = torch.tensor(s['y'], dtype=torch.float32)                       # (T,)\n\n        data = Data(x=x, edge_index=edge_index, edge_attr=edge_attr, pos=pos, y=y)\n        data.u = u\n        return data\n\n# -----------------------\n# واگذاری train/val split\n# -----------------------\nfull_ds = NPGraphDataset(DATA_NPY)\nn_total = len(full_ds)\nn_val = max(1, int(0.2 * n_total))\nn_train = n_total - n_val\n\ngenerator = torch.Generator().manual_seed(42)\ntrain_ds, val_ds = torch.utils.data.random_split(full_ds, [n_train, n_val], generator=generator)\n\nbatch_size = 16\ntrain_loader = DataLoader(train_ds, batch_size=batch_size, shuffle=True)\nval_loader   = DataLoader(val_ds,   batch_size=batch_size, shuffle=False)\n\ndevice = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n\n# -----------------------\n# مدل: GINEConv با edge_attr + الحاق u (گلوبال) به رپ. گراف\n# -----------------------\ndef mlp(channels):\n    layers = []\n    for i in range(len(channels)-1):\n        layers += [nn.Linear(channels[i], channels[i+1]), nn.ReLU()]\n    return nn.Sequential(*layers)\n\nclass GraphRegressor(nn.Module):\n    def __init__(self, in_dim, u_dim, hidden_dim, out_dim, num_layers=3):\n        super().__init__()\n\n        # لیست از کانولوشن‌های گراف\n        self.convs = nn.ModuleList()\n        self.convs.append(GCNConv(in_dim, hidden_dim))\n        for _ in range(num_layers - 1):\n            self.convs.append(GCNConv(hidden_dim, hidden_dim))\n\n        # اکتیویشن\n        self.relu = nn.ReLU()\n\n        # هد شبکه (برای ترکیب ویژگی گراف + ویژگی‌های کلی u)\n        self.head = nn.Sequential(\n            nn.Linear(hidden_dim + u_dim, 128),\n            nn.ReLU(),\n            nn.Linear(128, out_dim)\n        )\n\n    def forward(self, data):\n        x, edge_index, batch = data.x, data.edge_index, data.batch\n        u = data.u  # ویژگی‌های کلی (global features)\n\n        # عبور از لایه‌های GCN\n        for conv in self.convs:\n            x = self.relu(conv(x, edge_index))\n\n        # پولینگ روی نودها → گراف رپرزنتیشن\n        g = global_mean_pool(x, batch)\n\n        # هماهنگ‌سازی ابعاد u\n        if u.dim() == 1:\n            u = u.unsqueeze(0).repeat(g.size(0), 1)\n\n        # کانکات و پاس به هد\n        gu = torch.cat([g, u], dim=-1)\n        return self.head(gu)\n\n\n\n\n# کشف ابعاد\nsample0 = dataset[0]\nin_node = sample0.x.shape[1]\nin_global = sample0.u.shape[1]   # داینامیک\nout_dim = sample0.y.shape[0]\n\nmodel = GraphRegressor(\n    in_dim=in_node,\n    u_dim=in_global,\n    hidden_dim=128,\n    out_dim=out_dim,\n    num_layers=3\n).to(device)\n\noptimizer = torch.optim.Adam(model.parameters(), lr=1e-3, weight_decay=1e-5)\nloss_fn = nn.MSELoss()\n\n# اگر scaler_y خواستی برای برگرداندن به مقیاس واقعی\nwith open(SCALER_Y, \"rb\") as f:\n    scaler_y = pickle.load(f)\n\n# -----------------------\n# آموزش\n# -----------------------\nepochs = 50\ntrain_losses, val_losses = [], []\n\n\ndef train_one_epoch(loader, model, optimizer, loss_fn, device):\n    model.train()\n    total_loss = 0\n    for batch in loader:\n        batch = batch.to(device)\n        optimizer.zero_grad()\n        pred = model(batch)\n        loss = loss_fn(pred, batch.y)\n        loss.backward()\n        optimizer.step()\n        total_loss += loss.item() * batch.num_graphs\n    return total_loss / len(loader.dataset)\n\n\ndef evaluate(loader, model, loss_fn, device):\n    model.eval()\n    total_loss = 0\n    with torch.no_grad():\n        for batch in loader:\n            batch = batch.to(device)\n            pred = model(batch)\n            loss = loss_fn(pred, batch.y)\n            total_loss += loss.item() * batch.num_graphs\n    return total_loss / len(loader.dataset)\n\n\n# اجرای آموزش\nnum_epochs = 50\nfor epoch in range(1, num_epochs+1):\n    train_loss = train_one_epoch(train_loader, model, optimizer, loss_fn, device)\n    val_loss = evaluate(val_loader, model, loss_fn, device)\n    print(f\"Epoch {epoch:03d}: Train Loss = {train_loss:.4f}, Val Loss = {val_loss:.4f}\")\n\n\nprint(\"✅ Training finished.\")\n\n# -----------------------\n# نمودار loss ها\n# -----------------------\nplt.figure(figsize=(7,5))\npl