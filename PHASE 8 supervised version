 epoch: 11.\n\u001b[1m2/2\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m2s\u001b[0m 982ms/step\nTest mean R²: 0.8990\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 1000x600 with 1 Axes>","image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"<Figure size 1000x600 with 1 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"Min val loss at epoch 11: 6.750787e-01\nLast val loss: 9.345374e+00 | Last train loss: 4.711775e-01 | Gap: 8.874197e+00\nModel likely overfitting: validation loss increased after an early minimum.\nSaved weights: /kaggle/working/best_model_light.weights.h5\nSaved R2 list: /kaggle/working/r2_list_light.npy\nSaved history: /kaggle/working/history.npy\n","output_type":"stream"}],"execution_count":5},{"cell_type":"code","source":"# ===========================================\n# CNN + BiLSTM Phonon Model (sequence output)\n# ===========================================\nimport os\nimport numpy as np\nimport tensorflow as tf\nimport matplotlib.pyplot as plt\nfrom sklearn.metrics import r2_score\nfrom scipy.signal import savgol_filter\nfrom tensorflow.keras import mixed_precision\nfrom tensorflow.keras.callbacks import EarlyStopping, ReduceLROnPlateau, ModelCheckpoint\n\n# -------- Paths --------\ndata_dir = \"/kaggle/input/fanal-dataset\"   # <--- change if needed\nout_dir  = \"/kaggle/working\"\nos.makedirs(out_dir, exist_ok=True)\n\n# -------- Mixed precision (safe on GPU) --------\ntry:\n    mixed_precision.set_global_policy('mixed_float16')\n    print(\"Mixed precision:\", mixed_precision.global_policy())\nexcept Exception as e:\n    print(\"Mixed precision unavailable:\", e)\n\n# -------- Load arrays --------\nX_train = np.load(os.path.join(data_dir, \"train_x.npy\"))\nX_val   = np.load(os.path.join(data_dir, \"val_x.npy\"))\nX_test  = np.load(os.path.join(data_dir, \"test_x.npy\"))\ny_train = np.load(os.path.join(data_dir, \"train_y.npy\"))  # shape: (N, Q, B) normalized\ny_val   = np.load(os.path.join(data_dir, \"val_y.npy\"))\ny_test  = np.load(os.path.join(data_dir, \"test_y.npy\"))\n\nscaler_y_mean = np.load(os.path.join(data_dir, \"scaler_y_mean.npy\"))  # shape: (Q*B,)\nscaler_y_std  = np.load(os.path.join(data_dir, \"scaler_y_std.npy\"))\nscaler_X_mean = np.load(os.path.join(data_dir, \"scaler_X_mean.npy\"))\nscaler_X_std  = np.load(os.path.join(data_dir, \"scaler_X_std.npy\"))\n\nnum_samples, max_qpoints, max_bands = y_train.shape\ninput_dim = X_train.shape[1]\nprint(f\"X: {X_train.shape} | y: {y_train.shape} (Q={max_qpoints}, B={max_bands})\")\n\n# -------- Inverse transform for y (flat <-> (Q,B)) --------\ndef inverse_transform_y(y_norm):  # y_norm: (N, Q, B)\n    flat = y_norm.reshape(len(y_norm), -1)\n    y = (flat * scaler_y_std + scaler_y_mean).reshape(-1, max_qpoints, max_bands)\n    return y\n\n# -------- Loss: smoothness along Q --------\ndef smoothness_loss_seq(y_pred):  # y_pred: (batch, Q, B)\n    d2 = y_pred[:, 2:, :] - 2.0 * y_pred[:, 1:-1, :] + y_pred[:, :-2, :]\n    return tf.reduce_mean(tf.square(d2))\n\nLAMBDA_SMOOTH = 0.05  # tuneable\n\ndef custom_loss(y_true, y_pred):\n    mse = tf.keras.losses.MeanSquaredError()(y_true, y_pred)\n    loss_s = smoothness_loss_seq(y_pred)\n    return mse + LAMBDA_SMOOTH * loss_s\n\n# -------- Data augmentation on X --------\nAUG_NOISE_STD = 0.003   # small, scale-aware\nscaler_X_std_tensor = tf.constant(scaler_X_std.astype(np.float32))\n\n@tf.function\ndef augment_xy(x, y):\n    noise = tf.random.normal(tf.shape(x), mean=0.0,\n                             stddev=AUG_NOISE_STD * scaler_X_std_tensor,\n                             dtype=tf.float32)\n    x_aug = x + noise\n    # clamp within +-3 sigma around the current x (keeps it realistic)\n    x_aug = tf.clip_by_value(x_aug, x - 3.0 * scaler_X_std_tensor, x + 3.0 * scaler_X_std_tensor)\n    return x_aug, y\n\ndef make_dataset(X, y, batch, shuffle=True, augment=False):\n    X = X.astype(np.float32)\n    y = y.astype(np.float32)   # keep as (N, Q, B)\n    ds = tf.data.Dataset.from_tensor_slices((X, y))\n    if shuffle:\n        ds = ds.shuffle(min(10000, len(X)))\n    if augment:\n        ds = ds.map(augment_xy, num_parallel_calls=tf.data.AUTOTUNE)\n    ds = ds.batch(batch, drop_remainder=False).prefetch(tf.data.AUTOTUNE)\n    return ds\n\n# -------- Model: Dense -> Repeat(Q) -> Conv1D -> BiLSTM -> TimeDistributed --------\ndef swish(x): return tf.nn.swish(x)\n\ndef temporal_res_block(x, filters, kernel_size=5, rate=0.1, use_bn=True):\n    s = x\n    x = tf.keras.layers.Conv1D(filters, kernel_size, padding='same', activation=None, dtype='float32',\n                               kernel_regularizer=tf.keras.regularizers.l2(1e-6))(x)\n    if use_bn: x = tf.keras.layers.BatchNormalization()(x)\n    x = tf.keras.layers.Activation(swish)(x)\n    x = tf.keras.layers.Dropout(rate)(x)\n    # projection if needed\n    if int(s.shape[-1]) != filters:\n        s = tf.keras.layers.Conv1D(filters, 1, padding='same', activation=None, dtype='float32')(s)\n    x = tf.keras.layers.Add()([x, s])\n    x = tf.keras.layers.Activation(swish)(x)\n    return x\n\ndef build_sequence_model(input_dim, Q, B):\n    inp = tf.keras.layers.Input(shape=(input_dim,), name=\"X_in\")\n\n    # Global conditioning from X\n    x = tf.keras.layers.Dense(512, activation=swish, dtype='float32')(inp)\n    x = tf.keras.layers.BatchNormalization()(x)\n    x = tf.keras.layers.Dropout(0.15)(x)\n\n    x = tf.keras.layers.Dense(512, activation=swish, dtype='float32')(x)\n    x = tf.keras.layers.BatchNormalization()(x)\n    x = tf.keras.layers.Dropout(0.10)(x)\n\n    # Project to temporal seed and repeat over Q\n    x = tf.keras.layers.Dense(Q * 128, activation=swish, dtype='float32')(x)\n    x = tf.keras.layers.Reshape((Q, 128))(x)\n\n    # Temporal CNN + Residuals\n    x = tf.keras.layers.Conv1D(128, 7, padding='same', activation=swish, dtype='float32')(x)\n    x = tf.keras.layers.BatchNormalization()(x)\n    x = tf.keras.layers.Dropout(0.10)(x)\n\n    x = temporal_res_block(x, 128, kernel_size=5, rate=0.10)\n    x = temporal_res_block(x, 128, kernel_size=5, rate=0.10)\n\n    # BiLSTM for long-range dependencies across Q\n    x = tf.keras.layers.Bidirectional(\n        tf.keras.layers.LSTM(128, return_sequences=True, dtype='float32')\n    )(x)\n    x = tf.keras.layers.Dropout(0.10)(x)\n\n    # Head\n    x = tf.keras.layers.TimeDistributed(tf.keras.layers.Dense(256, activation=swish, dtype='float32'))(x)\n    x = tf.keras.layers.TimeDistributed(tf.keras.layers.Dense(128, activation=swish, dtype='float32'))(x)\n    out = tf.keras.layers.TimeDistributed(tf.keras.layers.Dense(B, activation='linear', dtype='float32'), name=\"y_seq\")(x)\n\n    model = tf.keras.Model(inputs=inp, outputs=out)\n    return model\n\n# -------- Hyperparams --------\nBATCH_SIZE   = 64\nEPOCHS       = 400\nBASE_LR      = 2e-4\nPATIENCE     = 40\n\ntrain_ds = make_dataset(X_train, y_train, BATCH_SIZE, shuffle=True,  augment=True)\nval_ds   = make_dataset(X_val,   y_val,   BATCH_SIZE, shuffle=False, augment=False)\n\nmodel = build_sequence_model(input_dim, max_qpoints, max_bands)\nmodel.summary()\n\noptimizer = tf.keras.optimizers.Adam(learning_rate=BASE_LR, clipnorm=1.0)\n\nmodel.compile(optimizer=optimizer, loss=custom_loss)\n\nckpt_path = os.path.join(out_dir, \"best_seq_model.weights.h5\")\ncallbacks = [\n    ModelCheckpoint(ckpt_path, monitor=\"val_loss\", save_best_only=True, save_weights_only=True, verbose=1),\n    EarlyStopping(monitor=\"val_loss\", patience=PATIENCE, restore_best_weights=True, verbose=1),\n    ReduceLROnPlateau(monitor=\"val_loss\", factor=0.3, patience=12, min_lr=1e-6, verbose=1),\n]\n\nhistory = model.fit(train_ds, validation_data=val_ds, epochs=EPOCHS, callbacks=callbacks, verbose=1)\n\n# -------- Save history --------\nnp.save(os.path.join(out_dir, \"history.npy\"), history.history)\n\n# -------- Evaluate on test --------\n# Optionally: Test-Time Augmentation (average several noisy passes on X_test)\ndef predict_tta(model, X, n_passes=3):\n    X = X.astype(np.float32)\n    preds = []\n    for _ in range(n_passes):\n        noise = np.random.normal(0.0, AUG_NOISE_STD * scaler_X_std, size=X.shape).astype(np.float32)\n        Xn = X + noise\n        preds.append(model.predict(Xn, batch_size=BATCH_SIZE, verbose=0))\n    return np.mean(preds, axis=0)\n\ny_pred_norm = predict_tta(model, X_test, n_passes=3)  # shape (N, Q, B)\ny_pred      = inverse_transform_y(y_pred_norm)\ny_true      = inverse_transform_y(y_test)\n\nr2_list = [r2_score(y_true[i].ravel(), y_pred[i].ravel()) for i in range(len(y_true))]\nprint(f\"Test mean R²: {np.mean(r2_list):.4f}\")\nnp.save(os.path.join(out_dir, \"r2_list_seq.npy\"), np.array(r2_list))\n\n# -------- Plot one sample (with Savitzky–Golay smoothing) --------\nsample_idx = 0\npred_sample = y_pred[sample_idx]          # (Q, B)\nwindow_length = 7 if max_qpoints >= 7 else (max_qpoints//2*2+1)\npolyorder = 3\ntry:\n    pred_smooth = np.copy(pred_sample)\n    for b in range(pred_sample.shape[1]):\n        pred_smooth[:, b] = savgol_filter(pred_sample[:, b], window_length=window_length, polyorder=polyorder, mode='interp')\nexcept Exception:\n    from scipy.ndimage import gaussian_filter1d\n    pred_smooth = gaussian_filter1d(pred_sample, sigma=0.6, axis=0)\n\nplt.figure(figsize=(10,6))\nfor b in range(pred_sample.shape[1]):\n    plt.plot(pred_sample[:, b], alpha=0.35)\n    plt.plot(pred_smooth[:, b], linewidth=1.4)\nplt.title(\"Predicted phonon bands (one sample): raw & smoothed\")\nplt.xlabel(\"Q-point\")\nplt.ylabel(\"Frequency (THz)\")\nplt.grid(True)\nplt.tight_layout()\nplt.savefig(os.path.join(out_dir, \"seq_pred_one_sample.png\"))\nplt.show()\n\n# -------- Plot training curves + quick overfitting check (English) --------\nhist = history.history\nplt.figure(figsize=(9,6))\nplt.plot(hist['loss'], label='Train Loss')\nplt.plot(hist['val_loss'], label='Val Loss')\nplt.xlabel('Epoch'); plt.ylabel('Loss'); plt.title('Training vs Validation Loss')\nplt.legend(); plt.grid(True); plt.tight_layout()\nplt.savefig(os.path.join(out_dir, \"seq_training_loss.png\"))\nplt.show()\n\nmin_val = float(np.min(hist['val_loss']))\nmin_ep  = int(np.argmin(hist['val_loss'])) + 1\nlast_val, last_train = float(hist['val_loss'][-1]), float(hist['loss'][-1])\nprint(f\"Min val loss at epoch {min_ep}: {min_val:.6e}\")\nprint(f\"Last val loss: {last_val:.6e} | Last train loss: {last_train:.6e} | Gap: {last_val - last_train:.6e}\")\nif last_val > min_val * 1.25 and min_ep < len(hist['val_loss']) * 0.6:\n    print(\"Model likely overfitting: validation loss increased after an early minimum.\")\nelse:\n    print(\"No strong overfitting indications.\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-08-16T08:03:25.691471Z","iopub.execute_input":"2025-08-16T08:03:25.692196Z","iopub.status.idle":"2025-08-16T08:12:36.782604Z","shell.execute_reply.started":"2025-08-16T08:03:25.692166Z","shell.execute_reply":"2025-08-16T08:12:36.781838Z"}},"outputs":[{"name":"stdout","text":"Mixed precision: <DTypePolicy \"mixed_float16\">\nX: (228, 330) | y: (228, 357, 24) (Q=357, B=24)\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"\u001b[1mModel: \"functional_2\"\u001b[0m\n","text/html":"<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\">Model: \"functional_2\"</span>\n</pre>\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"┏━━━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━┓\n┃\u001b[1m \u001b[0m\u001b[1mLayer (type)       \u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1mOutput Shape     \u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1m   Param #\u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1mConnected to     \u001b[0m\u001b[1m \u001b[0m┃\n┡━━━━━━━━━━━━━━━━━━━━━╇━━━