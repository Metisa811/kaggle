Dataset, DataLoader\nfrom sklearn.model_selection import train_test_split\nimport matplotlib.pyplot as plt\nfrom sklearn.metrics import mean_squared_error, mean_absolute_error, r2_score\n\n# --------------------------\n# Step 1: Parse YAML files\n# --------------------------\ndef parse_yaml_files(folder_path):\n    X, y = [], []\n    skipped = 0\n    max_atoms = 0\n    max_bands = 0\n    max_qpoints = 0\n\n    # First pass to find max sizes\n    for file in os.listdir(folder_path):\n        if file.endswith(\".yaml\"):\n            try:\n                with open(os.path.join(folder_path, file), 'r') as f:\n                    data = yaml.safe_load(f)\n                n_atoms = len(data['points'])\n                n_qpoints = len(data['phonon'])\n                n_bands = len(data['phonon'][0]['band'])\n                max_atoms = max(max_atoms, n_atoms)\n                max_bands = max(max_bands, n_bands)\n                max_qpoints = max(max_qpoints, n_qpoints)\n            except:\n                continue\n\n    for file in os.listdir(folder_path):\n        if file.endswith(\".yaml\"):\n            try:\n                with open(os.path.join(folder_path, file), 'r') as f:\n                    data = yaml.safe_load(f)\n                if 'points' not in data or 'lattice' not in data or 'reciprocal_lattice' not in data or 'phonon' not in data:\n                    skipped += 1\n                    continue\n\n                atom_features = [pt['coordinates'] + [pt['mass']] for pt in data['points']]\n                atom_features = np.array(atom_features)\n                atom_features = np.pad(atom_features, ((0, max_atoms - atom_features.shape[0]), (0, 0)), 'constant')\n\n                lattice = np.array(data['lattice']).flatten()\n                reciprocal = np.array(data['reciprocal_lattice']).flatten()\n\n                feature_tensor = np.concatenate([atom_features.flatten(), lattice, reciprocal])\n\n                frequencies = []\n                for qpoint in data['phonon']:\n                    bands = [b['frequency'] for b in qpoint.get('band', [])]\n                    frequencies.append(bands)\n                frequencies = np.array(frequencies)\n                frequencies = np.pad(frequencies, ((0, max_qpoints - frequencies.shape[0]), (0, max_bands - frequencies.shape[1])), 'constant')\n\n                X.append(feature_tensor)\n                y.append(frequencies)\n\n            except Exception as e:\n                skipped += 1\n\n    return np.array(X), np.array(y), max_atoms\n\n# --------------------------\n# Step 2: PyTorch Dataset\n# --------------------------\nclass PhononDataset(Dataset):\n    def __init__(self, X, y):\n        self.X = torch.tensor(X, dtype=torch.float32)\n        self.y = torch.tensor(y.reshape(len(y), -1), dtype=torch.float32)\n\n    def __len__(self):\n        return len(self.X)\n\n    def __getitem__(self, idx):\n        return self.X[idx], self.y[idx]\n\n# --------------------------\n# Step 3: CNN Model\n# --------------------------\nclass CNNModel(nn.Module):\n    def __init__(self, input_length, output_length):\n        super(CNNModel, self).__init__()\n        self.conv1 = nn.Conv1d(1, 64, kernel_size=3, padding=1)\n        self.conv2 = nn.Conv1d(64, 64, kernel_size=3, padding=1)\n        self.pool1 = nn.MaxPool1d(2)\n\n        self.conv3 = nn.Conv1d(64, 128, kernel_size=3, padding=1)\n        self.conv4 = nn.Conv1d(128, 128, kernel_size=3, padding=1)\n        self.pool2 = nn.MaxPool1d(2)\n\n        self.conv5 = nn.Conv1d(128, 256, kernel_size=3, padding=1)\n        self.conv6 = nn.Conv1d(256, 256, kernel_size=3, padding=1)\n        self.pool3 = nn.AdaptiveMaxPool1d(1)\n\n        self.fc1 = nn.Linear(256, 4096)\n        self.fc2 = nn.Linear(4096, 2048)\n        self.fc3 = nn.Linear(2048, output_length)\n\n    def forward(self, x):\n        x = x.unsqueeze(1)\n        x = F.relu(self.conv1(x))\n        x = self.pool1(F.relu(self.conv2(x)))\n        x = self.pool2(F.r