n\n# -----------------------\n# توابع کمکی (بدون تغییر از اسکریپت قبل)\n# -----------------------\ndef _normalize_cols(cols):\n    normed = []\n    for c in cols:\n        c2 = str(c).strip()\n        c2 = re.sub(r\"\\s+\", \"_\", c2)\n        c2 = c2.replace(\"-\", \"_\").replace(\"/\", \"_\").replace(\".\", \"_\")\n        normed.append(c2.lower())\n    return normed\n\ndef _guess_symbol_col(df):\n    candidates = [\"symbol\", \"element\", \"species\", \"label\", \"name\", \"atomic_symbol\"]\n    for c in df.columns:\n        if c in candidates:\n            return c\n    raise ValueError(\"Element symbol column (symbol/element/...) not found in Excel.\")\n\ndef _read_excel_features(excel_path):\n    df = pd.read_excel(excel_path)\n    df.columns = _normalize_cols(df.columns)\n    sym_col = _guess_symbol_col(df)\n    feature_cols = [c for c in df.columns if c not in [sym_col] and 'atomic_weight' not in c]\n    elem_features = {str(r[sym_col]).strip(): r[feature_cols].astype(float).fillna(0.0).values for _, r in df.iterrows()}\n    return elem_features, feature_cols\n\ndef find_neighbors(atom_coords, lattice_matrix, cutoff):\n    \"\"\"\n    Finds atomic neighbors within a cutoff radius, handling periodic boundary conditions.\n    This is a simplified implementation for environments without libraries like pymatgen.\n    \"\"\"\n    n_atoms = len(atom_coords)\n    edge_index = []\n    edge_attr = []\n\n    # Consider a 3x3x3 supercell to find periodic neighbors\n    for i in range(n_atoms):\n        for j in range(n_atoms):\n            for dx in [-1, 0, 1]:\n                for dy in [-1, 0, 1]:\n                    for dz in [-1, 0, 1]:\n                        # Don't connect an atom to itself in the central cell\n                        if i == j and dx == 0 and dy == 0 and dz == 0:\n                            continue\n\n                        # Calculate vector in fractional coords, considering periodic image\n                        disp_frac = atom_coords[j] - atom_coords[i] + [dx, dy, dz]\n                        \n                        # Convert to cartesian coordinates\n                        disp_cart = np.dot(disp_frac, lattice_matrix)\n                        dist = np.linalg.norm(disp_cart)\n\n                        if dist < cutoff:\n                            edge_index.append([i, j])\n                            edge_attr.append([dist]) # Edge attribute is the distance\n                            \n    return np.array(edge_index, dtype=np.int32), np.array(edge_attr, dtype=np.float32)\n\n\n# -----------------------\n# گام 1: خواندن ویژگی‌های عناصر از اکسل\n# -----------------------\nelem_features, excel_feature_cols = _read_excel_features(excel_path)\nprint(f\"[Excel] Loaded {len(excel_feature_cols)} features for each element.\")\n\n# -----------------------\n# گام 2: استخراج داده‌های گراف از YAML\n# -----------------------\nNEIGHBOR_CUTOFF = 5.0 # Cutoff radius in Angstroms to define neighbors\nall_node_features, all_edge_indices, all_edge_attrs, all_ys = [], [], [], []\nmax_nodes, max_edges = 0, 0\nyaml_files = [f for f in os.listdir(yaml_folder) if f.endswith(\".yaml\")]\n\nprint(\"Processing YAML files to build graphs...\")\nfor file in tqdm(yaml_files):\n    try:\n        with open(os.path.join(yaml_folder, file), \"r\") as f:\n            data = yaml.safe_load(f)\n        if not all(k in data for k in [\"points\", \"lattice\", \"phonon\"]):\n            continue\n\n        # --- Node Features ---\n        node_features = []\n        atom_coords_frac = []\n        for pt in data[\"points\"]:\n            sym = pt.get(\"symbol\", \"H\") # Fallback to H if symbol is missing\n            node_features.append(elem_features.get(sym, np.zeros(len(excel_feature_cols))))\n            atom_coords_frac.append(pt.get(\"coordinates\", [0, 0, 0]))\n        \n        node_features = np.array(node_features, dtype=np.float32)\n        atom_coords_frac = np.array(atom_coords_frac, dtype=np.float32)\n        lattice_matrix = np.array(data[\"lattice\"], dtype=np.float32)\n\n        # --- Edges and Edge Attributes ---\n        edge_index, edge_attr = find_neighbors(atom_coords_frac, lattice_matrix, NEIGHBOR_CUTOFF)\n\n        if len(node_features) == 0 or len(edge_index) == 0:\n            continue # Skip graphs with no nodes or edges\n\n        # --- Target (y) ---\n        freqs = [[b.get(\"frequency\", 0.0) for b in qpt.get(\"band\", [])] for qpt in data[\"phonon\"]]\n        \n        all_node_features.append(node_features)\n        all_edge_indices.append(edge_index)\n        all_edge_attrs.append(edge_attr)\n        all_ys.append(np.array(freqs, dtype=np.float32))\n\n        # Update max dimensions for padding\n        max_nodes = max(max_nodes, node_features.shape[0])\n        max_edges = max(max_edges, edge_index.shape[0])\n\n    except Exception as e:\n        print(f\"[PARSE] Skipping {file}: {e}\")\n\n# Find max dimensions for y padding\nmax_qpoints = max(y.shape[0] for y in all_ys if y.ndim == 2)\nmax_bands = max(y.shape[1] for y in all_ys if y.ndim == 2)\nprint(f\"Max nodes: {max_nodes}, Max edges: {max_edges}, Max Q-points: {max_qpoints}, Max bands: {max_bands}\")\n\n# -----------------------\n# گام 3: Padding و ایجاد دیتاست نهایی\n# -----------------------\nprint(\"Padding data to uniform tensor shapes...\")\nX_nodes, X_edge_idx, X_edge_attr, Y = [], [], [], []\nnode_dim = len(excel_feature_cols)\n\nfor i in range(len(all_ys)):\n    # Pad nodes\n    num_nodes = all_node_features[i].shape[0]\n    padded_nodes = np.pad(all_node_features[i], ((0, max_nodes - num_nodes), (0, 0)), 'constant')\n    \n    # Pad edges\n    num_edges = all_edge_indices[i].shape[0]\n    padded_edge_idx = np.pad(all_edge_indices[i], ((0, max_edges - num_edges), (0, 0)), 'constant')\n    padded_edge_attr = np.pad(all_edge_attrs[i], ((0, max_edges - num_edges), (0, 0)), 'constant')\n\n    # Pad target y\n    y = all_ys[i]\n    padded_y = np.zeros((max_qpoints, max_bands), dtype=np.float32)\n    shape = y.shape\n    if len(shape) == 2:\n        padded_y[:shape[0], :shape[1]] = y\n\n    X_nodes.append(padded_nodes)\n    X_edge_idx.append(padded_edge_idx)\n    X_edge_attr.append(padded_edge_attr)\n    Y.append(padded_y)\n\nX_nodes = np.array(X_nodes, dtype=np.float32)\nX_edge_idx = np.array(X_edge_idx, dtype=np.int32)\nX_edge_attr = np.array(X_edge_attr, dtype=np.float32)\nY = np.array(Y, dtype=np.float32)\n\nprint(f\"Final dataset shapes:\")\nprint(f\"Nodes: {X_nodes.shape}, Edge Indices: {X_edge_idx.shape}, Edge Attrs: {X_edge_attr.shape}, Target: {Y.shape}\")\n\n# -----------------------\n# گام 4: نرمال‌سازی و تقسیم داده‌ها\n# -----------------------\n# Node features\nscaler_nodes = StandardScaler()\nX_nodes_flat = X_nodes.reshape(-1, node_dim)\nX_nodes_norm_flat = scaler_nodes.fit_transform(X_nodes_flat)\nX_nodes = X_nodes_norm_flat.reshape(X_nodes.shape)\n\n# Edge attributes (distances)\nscaler_edges = StandardScaler()\nX_edge_attr_flat = X_edge_attr.reshape(-1, 1)\nX_edge_attr_norm_flat = scaler_edges.fit_transform(X_edge_attr_flat)\nX_edge_attr = X_edge_attr_norm_flat.reshape(X_edge_attr.shape)\n\n# Target (y)\nscaler_y = StandardScaler()\ny_flat = Y.reshape(Y.shape[0], -1)\ny_norm_flat = scaler_y.fit_transform(y_flat)\nY_norm = y_norm_flat.reshape(Y.shape)\n\n# Split\nindices = np.arange(X_nodes.shape[0])\ntrain_idx, test_idx = train_test_split(indices, test_size=0.2, random_state=42)\ntrain_idx, val_idx = train_test_split(train_idx, test_size=0.2, random_state=42)\n\n# -----------------------\n# گام 5: ذخیره خروجی‌ها\n# -----------------------\nnp.save(os.path.join(out_dir, \"train_nodes.npy\"), X_nodes[train_idx])\nnp.save(os.path.join(out_dir, \"train_edge_idx.npy\"), X_edge_idx[train_idx])\nnp.save(os.path.join(out_dir, \"train_edge_attr.npy\"), X_edge_attr[train_idx])\nnp.save(os.path.join(out_dir, \"train_y_gnn.npy\"), Y_norm[train_idx])\n\nnp.save(os.path.join(out_dir, \"val_nodes.npy\"), X_nodes[val_idx])\nnp.save(os.path.join(out_dir, \"val_edge_idx.npy\"), X_edge_idx[val_idx])\nnp.save(os.path.join(out_dir, \"val_edge_attr.npy\"), X_edge_attr[val_idx])\nnp.save(os.path.join(out_dir, \"val_y_gnn.npy\"), Y_norm[val_idx])\n\nnp.save(os.path.join(out_dir, \"test_nodes.npy\"), X_nodes[test_idx])\nnp.save(os.path.join(out_dir, \"test_edge_idx.npy\"), X_edge_idx[test_idx])\nnp.save(os.path.join(out_dir, \"test_edge_attr.npy\"), X_edge_attr[test_idx])\nnp.save(os.path.join(out_dir, \"test_y_gnn.npy\"), Y_norm[test_idx])\n# Save scalers\nnp.save(os.path.join(out_dir, \"scaler_nodes_mean.npy\"), scaler_nodes.mean_)\nnp.save(os.path.join(out_dir, \"scaler_nodes_scale.npy\"), scaler_nodes.scale_)\nnp.save(os.path.join(out_dir, \"scaler_edges_mean.npy\"), scaler_edges.mean_)\nnp.save(os.path.join(out_dir, \"scaler_edges_scale.npy\"), scaler_edges.scale_)\nnp.save(os.path.join(out_dir, \"scaler_y_mean_gnn.npy\"), scaler_y.mean_)\nnp.save(os.path.join(out_dir, \"scaler_y_std_gnn.npy\"), scaler_y.scale_)\n\nprint(\"\\n[DONE] GNN dataset saved successfully.\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-09-10T16:04:38.850971Z","iopub.execute_input":"2025-09-10T16:04:38.851416Z","iopub.status.idle":"2025-09-10T16:19:53.975528Z","shell.execute_reply.started":"2025-09-10T16:04:38.851383Z","shell.execute_reply":"2025-09-10T16:19:53.974566Z"}},"outputs":[{"name":"stdout","text":"[Excel] Loaded 35 features for each element.\nProcessing YAML files to build graphs...\n","output_type":"stream"},{"name":"stderr","text":"100%|██████████| 358/358 [15:13<00:00,  2.55s/it] \n","output_type":"stream"},{"name":"stdout","text":"Max nodes: 8, Max edges: 356, Max Q-points: 357, Max bands: 24\nPadding data to uniform tensor shapes...\nFinal dataset shapes:\nNodes: (358, 8, 35), Edge Indices: (358, 356, 2), Edge Attrs: (358, 356, 1), Target: (358, 357, 24)\n\n[DONE] GNN dataset saved successfully.\n","output_type":"stream"}],"execution_count":6},{"cell_type":"markdown","source":"## GNN model structure","metadata":{}},{"cell_type":"code","source":"import os\nimport numpy as np\nimport tensorflow as tf\nfrom sklearn.metrics import r2_score\nimport matplotlib.pyplot as plt\nfrom scipy.signal import savgol_filter\n\n# -----------------------\n# مسیرها و تنظیمات\n# -----------------------\ndata_dir = \"/kaggle/input/gnn-dataset-1\"\nout_dir = \"/kaggle/working\"\nos.makedirs(out_dir, exist_ok=True)\n\n# -----------------------\n# بارگذاری داده‌های گرافی\n# -----------------------\nprint(\"Loading GNN dataset...\")\ntrain_nodes = np.load(os.path.join(data_dir, \"train_nodes.npy\"))\ntrain_edge_idx = np.load(os.path.join(data_dir, \"train_edge_idx.npy\"))\ntrain_edge_attr = np.load(os.path.join(data_dir, \"train_edge_attr.npy\"))\ny_train = np.load(os.path.join(data_dir, \"train_y_gnn.npy\"))\n\nval_nodes = np.load(os.path.join(data_dir, \"val_nodes.npy\"))\nval_edge_idx = np.load(os.path.join(data_dir, \"val_edge_idx.npy\"))\nval_edge_attr = np.load(os.path.join(data_dir, \"val_edge_attr.npy\"))\ny_val = np.load(os.path.join(data_dir, \"val_y_gnn.npy\"))\n\ntest_nodes = np.load(os.path.join(data_dir, \"test_nodes.npy\"))\ntest_edge_idx = np.load(os.path.join(data_dir, \"test_edge_idx.npy\"))\ntest_edge_attr = np.load(os.path.join(data_dir, \"test_edge_attr.npy\"))\ny_test = np.load(os.path.join(data_dir, \"test_y_gnn.npy\"))\n\nscaler_y_mean = np.load(os.path.join(data_dir, \"scaler_y_mean_gnn.npy\"))\nscaler_y_std = np.load(os.path.join(data_dir, \"scaler_y_std_gnn.npy\"))\nprint(\"Dataset loaded.\")\n\n# -----------------------\n# ابعاد و هایپرپارامترها\n# -----------------------\nBATCH_SIZE = 16 # GNNs are more memory intensive, so a smaller batch size is often needed\nEPOCHS = 300\nLR = 5e-4\nLAMBDA_SMOOTH = 2.0\nPATIENCE = 40\n_, max_nodes, node_dim = train_nodes.shape\n_, max_qpoints, max_bands = y_train.shape\noutput_flat_dim = max_qpoints * max_bands\n\n# -----------------------\n# پیاده‌سازی لایه GNN (Message Passing)\n# -----------------------\nclass MessagePassingLayer(tf.keras.layers.Layer):\n    def __init__(self, units, **kwargs):\n        super().__init__(**kwargs)\n        self.units = units\n        # MLP for transforming messages\n        self.mlp_message = tf.keras.Sequential([\n            tf.keras.layers.Dense(units, activation='relu', name=\"mlp_msg_1\"),\n            tf.keras.layers.Dense(units, name=\"mlp_msg_2\")\n        ], name=\"mlp_message\")\n        # MLP for updating node states\n        self.mlp_update = tf.keras.Sequential([\n            tf.keras.layers.Dense(units, activation='relu', name=\"mlp_update_1\"),\n            tf.keras.layers.Dense(units, name=\"mlp_update_2\")\n        ], name=\"mlp_update\")\n        self.norm = tf.keras.layers.LayerNormalization()\n\n    def call(self, inputs):\n        node_features, edge_indices, edge_attributes = inputs\n        \n        batch_size = tf.shape(node_features)[0]\n        num_nodes = tf.shape(node_features)[1]\n\n        # Prepare messages\n        sender_indices = edge_indices[:, :, 0]\n        receiver_indices = edge_indices[:, :, 1]\n        \n        sender_features = tf.gather(node_features, sender_indices, batch_dims=1)\n        \n        # Combine sender features and edge attributes to form messages\n        messages_in = tf.concat([sender_features, edge_attributes], axis=-1)\n        messages = self.mlp_message(messages_in)\n        \n        # --- BATCH-AWARE AGGREGATION ---\n        # Create batch offsets for indices so that each graph's indices are unique.\n        batch_offsets = tf.range(batch_size) * num_nodes\n        batch_offsets_reshaped = tf.reshape(batch_offsets, [batch_size, 1])\n        \n        # Apply offsets to receiver indices\n        receiver_indices_offset = receiver_indices + batch_offsets_reshaped\n\n        # Flatten tensors for segment_sum\n        messages_flat = tf.reshape(messages, [-1, self.units])\n        receiver_indices_flat = tf.reshape(receiver_indices_offset, [-1])\n        \n        # Perform aggregation on the flattened, offset data\n        aggregated_messages_flat = tf.math.unsorted_segment_sum(\n            data=messages_flat,\n            segment_ids=receiver_indices_flat,\n            num_segments=batch_size * num_nodes\n        )\n        \n        # Reshape aggregated messages back to batch format\n        aggregated_messages = tf.reshape(aggregated_messages_flat, [batch_size, num_nodes, self.units])\n        \n        # Update node features by concatenating old features with aggregated messages\n        update_input = tf.concat([node_features, aggregated_messages], axis=-1)\n        updated_features = self.mlp_update(update_input)\n        \n        # Residual connection and normalization\n        return self.norm(node_features + updated_features)\n\n# -----------------------\n# ساخت مدل کامل GNN\n# -----------------------\ndef build_gnn_model():\n    node_input = tf.keras.layers.Input(shape=(max_nodes, node_dim), name=\"node_features\")\n    edge_idx_input = tf.keras.layers.Input(shape=(None, 2), dtype=tf.int32, name=\"edge_indices\")\n    edge_attr_input = tf.keras.layers.Input(shape=(None, 1), name=\"edge_attributes\")\n\n    # Initial projection\n    x = tf.keras.layers.Dense(128, activation='relu')(node_input)\n\n    # Stack of GNN layers\n    x = MessagePassingLayer(128)([x, edge_idx_input, edge_attr_input])\n    x = MessagePassingLayer(128)([x, edge_idx_input, edge_attr_input])\n    x = MessagePassingLayer(128)([x, edge_idx_input, edge_attr_input])\n    \n    # **FIX**: Replaced tf.reduce_mean with the Keras equivalent layer.\n    # This is the \"Readout\" phase, which aggregates node features into a single graph vector.\n    graph_embedding = tf.keras.layers.GlobalAveragePooling1D()(x)\n\n    # Final MLP for prediction\n    y = tf.keras.layers.Dense(512, activation='relu')(graph_embedding)\n    y = tf.keras.layers.Dropout(0.2)(y)\n    y = tf.keras.layers.Dense(output_flat_dim)(y)\n\n    return tf.keras.Model(inputs=[node_input, edge_idx_input, edge_attr_input], outputs=y)\n\nmodel = build_gnn_model()\nmodel.summary()\n\n# -----------------------\n# توابع آموزش و ارزیابی\n# -----------------------\nmse = tf.keras.losses.MeanSquaredError()\noptimizer = tf.keras.optimizers.Adam(learning_rate=LR)\nsmoothness_loss_from_reshaped = lambda y: tf.reduce_mean(tf.square(y[:, 2:, :] - 2.0 * y[:, 1:-1, :] + y[:, :-2, :]))\n\n@tf.function\ndef train_step(inputs, y_batch):\n    with tf.GradientTape() as tape:\n        pred_flat = model(inputs, training=True)\n        loss_mse = mse(tf.reshape(y_batch, (tf.shape(y_batch)[0], -1)), pred_flat)\n        pred_reshaped = tf.reshape(pred_flat, (-1, max_qpoints, max_bands))\n        loss_smooth = smoothness_loss_from_reshaped(pred_reshaped)\n        loss = loss_mse + LAMBDA_SMOOTH * loss_smooth\n    \n    grads = tape.gradient(loss, model.trainable_variables)\n    optimizer.apply_gradients(zip(grads, model.trainable_variables))\n    return loss\n\n@tf.function\ndef val_step(inputs, y_batch):\n    pred_flat = model(inputs, training=False)\n    loss_mse = mse(tf.reshape(y_batch, (tf.shape(y_batch)[0], -1)), pred_flat)\n    pred_reshaped = tf.reshape(pred_flat, (-1, max_qpoints, max_bands))\n    loss_smooth = smoothness_loss_from_reshaped(pred_reshaped)\n    return loss_mse + LAMBDA_SMOOTH * loss_smooth\n\n# -----------------------\n# حلقه آموزش\n# -----------------------\ntrain_dataset = tf.data.Dataset.from_tensor_slices(((train_nodes, train_edge_idx, train_edge_attr), y_train)).batch(BATCH_SIZE).shuffle(100)\nval_dataset = tf.data.Dataset.from_tensor_slices(((val_nodes, val_edge_idx, val_edge_attr), y_val)).batch(BATCH_SIZE)\n\nbest_val = np.inf\npatience_counter = 0\nhistory = {'train_loss': [], 'val_loss': []}\nbest_model_path = os.path.join(out_dir, \"best_gnn_model.weights.h5\")\n\nfor epoch in range(1, EPOCHS + 1):\n    train_losses = [train_step(xb, yb).numpy() for xb, yb in train_dataset]\n    val_losses = [val_step(xb, yb).numpy() for xb, yb in val_dataset]\n    train_loss_epoch = np.mean(train_losses)\n    val_loss_epoch = np.mean(val_losses)\n    history['train_loss'].append(train_loss_epoch)\n    history['val_loss'].append(val_loss_epoch)\n    print(f\"Epoch {epoch:03d} | Train Loss: {train_loss_epoch:.6e} | Val Loss: {val_loss_epoch:.6e}\")\n    if val_loss_epoch < best_val:\n        best_val = val_loss_epoch\n        patience_counter = 0\n        model.save_weights(best_model_path)\n    else:\n        patience_counter += 1\n        if patience_counter >= PATIENCE:\n            print(\"Early stopping triggered.\")\n            break\n\n# -----------------------\n# ارزیابی و رسم نتایج (مشابه قبل)\n# -----------------------\nprint(f\"Loading best model from {best_model_path} for evaluation.\")\nmodel.load_weights(best_model_path)\ntest_inputs = [test_nodes, test_edge_idx, test_edge_attr]\ny_pred_flat = model.predict(test_inputs, batch_size=BATCH_SIZE)\ny_pred_rescaled = (y_pred_flat * scaler_y_std + scaler_y_mean).reshape(-1, max_qpoints, max_bands)\ny_test_rescaled = (y_test.reshape(len(y_test), -1) * scaler_y_std + scaler_y_mean).reshape(-1, max_qpoints, max_bands)\n\n# Post-processing filter\ny_pred_final = np.copy(y_pred_rescaled)\nfor i in range(len(y_pred_final)):\n    for b in range(max_bands):\n        y_pred_final[i, :, b] = savgol_filter(y_pred_rescaled[i, :, b], 11, 3)\n\nr2_scores = np.array([r2_score(y_test_rescaled[i].flatten(), y_pred_final[i].flatten()) for i in range(len(y_test_rescaled))])\n\nprint(\"\\n--- GNN R2 Score Analysis ---\")\nprint(f\"Mean R2: {np.mean(r2_scores):.4f}, Median R2: {np.median(r2_scores):.4f}, Std Dev: {np.std(r2_scores):.4f}\")\n\n# Plotting (identical to previous script)\nsample_idx = np.random.randint(0, len(y_test_rescaled))\nplt.figure(figsize=(12, 7))\ncolors = plt.cm.viridis(np.linspace(0, 1, max_bands))\nfor b in range(max_bands):\n    plt.plot(y_test_rescaled[sample_idx, :, b], color=colors[b], linestyle='-', linewidth=2.5, label=f'True Band {b+1}' if b < 3 else \"\")\n    plt.plot(y_pred_f