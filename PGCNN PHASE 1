{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.11.11","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"gpu","dataSources":[{"sourceType":"datasetVersion","sourceId":12765449},{"sourceType":"datasetVersion","sourceId":12764155},{"sourceType":"datasetVersion","sourceId":12838831},{"sourceType":"datasetVersion","sourceId":12081217}],"dockerImageVersionId":31040,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":true}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"code","source":"# بخش اول: وارد کردن کتابخانه‌های لازم\nimport os\nimport yaml\nimport numpy as np\nimport tensorflow as tf\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.preprocessing import StandardScaler\nfrom sklearn.metrics import r2_score\nimport matplotlib.pyplot as plt\nfrom tqdm import tqdm  # برای نمایش نوار پیشرفت\n\n# --- وارد کردن کتابخانه Phonopy ---\n# مطمئن شوید که phonopy نصب است: pip install phonopy\nimport phonopy\n\n# مسیرهای اصلی داده‌ها (نسخه اصلاح‌شده برای پوشه‌های جدا)\n# لطفاً این مسیرها را با آدرس دقیق پوشه‌های خود جایگزین کنید\nYAML_FOLDER = \"/kaggle/input/pgcnndata/extracted_bands_C/extracted_bands_C\"\nPSC_FOLDER = \"/kaggle/input/pgcnndata/all_poscar/all_poscar\"\nFC_FOLDER = \"/kaggle/input/pgcnndata/extracted_force_constant_All/extracted_force_constant_C\"\n#======================================================================\n# بخش دوم: آماده‌سازی داده‌ها و تابع هزینه فیزیکی\n#======================================================================\n\n# فقط این تابع را با نسخه زیر جایگزین کنید\n\n# فقط این تابع را با نسخه زیر جایگزین کنید\n\ndef parse_and_load_data_with_physics(yaml_folder, psc_folder, fc_folder):\n    \"\"\"\n    نسخه نهایی: این تابع ماتریس ابرسلول را به phonopy.load می‌دهد تا\n    ناهماهنگی بین سلول اولیه و فایل FORCE_CONSTANTS حل شود.\n    \"\"\"\n    dataset = []\n    skipped = 0\n    max_atoms = 0\n    max_bands = 0\n    max_qpoints = 0\n\n    # یافتن حداکثر اندازه‌ها\n    yaml_files = [f for f in os.listdir(yaml_folder) if f.endswith(\".yaml\")]\n    for file in yaml_files:\n        try:\n            with open(os.path.join(yaml_folder, file), 'r') as f:\n                data = yaml.safe_load(f)\n            max_atoms = max(max_atoms, len(data['points']))\n            max_bands = max(max_bands, len(data['phonon'][0]['band']))\n            max_qpoints = max(max_qpoints, len(data['phonon']))\n        except:\n            continue\n    print(f\"✅ شناسایی ابعاد: حداکثر اتم‌ها: {max_atoms}, حداکثر باند‌ها: {max_bands}, حداکثر نقاط q: {max_qpoints}\")\n\n    # ##########################################################################\n    # ##  تغییر کلیدی: ماتریس ابرسلول خود را در اینجا تعریف کنید  ##\n    # ##########################################################################\n    # این ماتریس باید با چیزی که در محاسبات اولیه استفاده کرده‌اید، یکسان باشد.\n    # به عنوان مثال، برای یک ابرسلول 3x3x1:\n    SUPERCELL_MATRIX = [[3, 0, 0], [0, 3, 0], [0, 0, 1]] \n    # اگر از ابعاد دیگری استفاده کرده‌اید، این ماتریس را اصلاح کنید.\n    # ##########################################################################\n\n    # بارگذاری داده‌ها\n    for file in tqdm(yaml_files, desc=\"بارگذاری داده‌ها و اشیاء فونوپی\"):\n        basename = file.replace('.yaml', '')\n        try:\n            fc_path = os.path.join(fc_folder, f\"{basename}.fc\")\n            psc_path = os.path.join(psc_folder, f\"{basename}.psc\")\n\n            if not os.path.exists(psc_path) or not os.path.exists(fc_path):\n                skipped += 1\n                continue\n            \n            # --- تغییر کلیدی در فراخوانی phonopy.load ---\n            phonon_obj = phonopy.load(\n                unitcell_filename=psc_path,\n                force_constants_filename=fc_path,\n                supercell_matrix=SUPERCELL_MATRIX,  # <<<< این خط اضافه شده است\n                is_nac=False\n            )\n\n            with open(os.path.join(yaml_folder, file), 'r') as f:\n                data = yaml.safe_load(f)\n\n            # استخراج ویژگی‌ها (بدون تغییر)\n            atom_features = [pt['coordinates'] + [pt['mass']] for pt in data['points']]\n            atom_features = np.pad(np.array(atom_features), ((0, max_atoms - len(atom_features)), (0, 0)), 'constant')\n            lattice = np.array(data['lattice']).flatten()\n            reciprocal = np.array(data['reciprocal_lattice']).flatten()\n            feature_vector = np.concatenate([atom_features.flatten(), lattice, reciprocal])\n            \n            # استخراج فرکانس‌ها و بردارهای q (بدون تغییر)\n            frequencies, qpoints = [], []\n            for qp in data['phonon']:\n                qpoints.append(qp['q-position'])\n                frequencies.append([b['frequency'] for b in qp.get('band', [])])\n            frequencies = np.pad(np.array(frequencies), ((0, max_qpoints - len(frequencies)), (0, max_bands - len(frequencies[0]))), 'constant')\n            qpoints = np.pad(np.array(qpoints), ((0, max_qpoints - len(qpoints)), (0, 0)), 'constant')\n\n            dataset.append({\n                'X': feature_vector,\n                'y': frequencies,\n                'qpoints': qpoints,\n                'phonopy_obj': phonon_obj\n            })\n\n        except Exception as e:\n            print(f\"      ❌❌❌ یک خطا در حین پردازش فایل {file} رخ داد: {e} ❌❌❌\")\n            skipped += 1\n\n    print(f\"\\n✅ بارگذاری کامل شد: {len(dataset)} نمونه, {skipped} فایل رد شده\")\n    return dataset, max_atoms, max_qpoints, max_bands\n\ndef calculate_physics_loss_for_sample(y_pred, phonopy_obj, qpoints):\n    \"\"\"\n    تابع هزینه فیزیکی برای یک نمونه.\n    این تابع با NumPy کار می‌کند و باید با tf.py_function در گراف تنسورفلو استفاده شود.\n    \"\"\"\n    total_loss = 0.0\n    num_calculations = 0\n    \n    # y_pred شکل (n_qpoints, n_bands) دارد\n    \n    for i, q in enumerate(qpoints):\n        # اگر q یک بردار پدینگ (صفر) است، از آن بگذرید\n        if np.all(q == 0) and i > 0: # از نقطه گاما در i=0 نپر\n             continue\n\n        # محاسبه فرکانس‌های واقعی از فونوپی\n        _, true_frequencies = phonopy_obj.get_frequencies(q)\n        predicted_frequencies = sorted(y_pred[i]) # مرتب‌سازی برای مقایسه صحیح\n\n        # محاسبه خطای مربعات میانگین\n        total_loss += np.mean((true_frequencies - predicted_frequencies)**2)\n        num_calculations += 1\n    \n    return total_loss / num_calculations if num_calculations > 0 else 0.0\n\n#======================================================================\n# بخش سوم: ساخت مدل و حلقه آموزش سفارشی\n#======================================================================\n\n# مدل CNN شما (بدون تغییر)\ndef build_cnn_model(input_shape, output_shape):\n    model = tf.keras.Sequential([\n        tf.keras.layers.Input(shape=input_shape),\n        tf.keras.layers.Reshape((input_shape[0], 1)),\n        tf.keras.layers.Conv1D(16, kernel_size=3, activation='relu', padding='same'),\n        tf.keras.layers.MaxPooling1D(pool_size=2),\n        tf.keras.layers.Conv1D(32, kernel_size=3, activation='relu', padding='same'),\n        tf.keras.layers.MaxPooling1D(pool_size=2),\n        tf.keras.layers.Conv1D(64, kernel_size=3, activation='relu', padding='same'),\n        tf.keras.layers.MaxPooling1D(pool_size=2),\n        tf.keras.layers.Flatten(),\n        tf.keras.layers.Dense(512, activation='relu', kernel_regularizer=tf.keras.regularizers.l2(0.005)),\n        tf.keras.layers.Dense(np.prod(output_shape), activation='linear'),\n        tf.keras.layers.Reshape(output_shape) # لایه Reshape برای مطابقت با خروجی\n    ])\n    return model\n\n\n\n# 1. بارگذاری داده‌ها با استفاده از تابع اصلاح‌شده\nfull_dataset, max_atoms, max_qpoints, max_bands = parse_and_load_data_with_physics(\n    YAML_FOLDER, \n    PSC_FOLDER, \n    FC_FOLDER\n)\n\n# 2. آماده‌سازی X و y برای نرمال‌سازی و تقسیم‌بندی\nX = np.array([d['X'] for d in full_dataset])\ny = np.array([d['y'] for d in full_dataset])\n\nscaler_X = StandardScaler()\nX_normalized = scaler_X.fit_transform(X)\n\nnum_samples, num_qpoints, num_bands = y.shape\ny_flat = y.reshape(num_samples, -1)\nscaler_y = StandardScaler()\ny_normalized = scaler_y.fit_transform(y_flat).reshape(num_samples, num_qpoints, num_bands)\n\n# ساخت دیتاست نهایی برای آموزش\n# ما نمی‌توانیم اشیاء فونوپی را مستقیم به train_test_split بدهیم\nindices = np.arange(len(full_dataset))\ntrain_indices, test_indices = train_test_split(indices, test_size=0.2, random_state=42)\n\n# 3. ساخت مدل\ninput_shape = (X.shape[1],)\noutput_shape = (num_qpoints, num_bands)\nmodel = build_cnn_model(input_shape, output_shape)\n\n# 4. تعریف بهینه‌ساز و تابع هزینه استاندارد\noptimizer = tf.keras.optimizers.Adam(learning_rate=0.0001)\nmse_loss_fn = tf.keras.losses.MeanSquaredError()\n\n# 5. حلقه آموزش سفارشی\nepochs = 100 # برای مثال\nbatch_size = 16\nphysics_loss_weight = 0.5 # هایپرپارامتر: میزان اهمیت لاس فیزیکی\n\nfor epoch in range(epochs):\n    print(f\"\\nEpoch {epoch + 1}/{epochs}\")\n    epoch_total_loss = 0\n    \n    # داده‌های آموزش را به صورت بچ بچ جدا می‌کنیم\n    for i in tqdm(range(0, len(train_indices), batch_size), desc=\"Training\"):\n        batch_indices = train_indices[i:i+batch_size]\n        \n        # استخراج داده‌های مورد نیاز برای بچ فعلی\n        X_batch = tf.convert_to_tensor(X_normalized[batch_indices], dtype=tf.float32)\n        y_true_batch = tf.convert_to_tensor(y_normalized[batch_indices], dtype=tf.float32)\n        batch_samples = [full_dataset[j] for j in batch_indices]\n\n        with tf.GradientTape() as tape:\n            # پیش‌بینی مدل\n            y_pred_batch_normalized = model(X_batch, training=True)\n\n            # محاسبه لاس استاندارد (MSE)\n            standard_loss = mse_loss_fn(y_true_batch, y_pred_batch_normalized)\n            \n            # محاسبه لاس فیزیکی برای هر نمونه در بچ\n            physics_loss = 0.0\n            for j, sample in enumerate(batch_samples):\n                # بازگرداندن پیش‌بینی به مقیاس اصلی\n                y_pred_sample_flat = tf.reshape(y_pred_batch_normalized[j], (1, -1))\n                y_pred_sample_unscaled = scaler_y.inverse_transform(y_pred_sample_flat.numpy())\n                y_pred_sample_unscaled = y_pred_sample_unscaled.reshape(output_shape)\n\n                # ... (داخل حلقه for j, sample in enumerate(batch_samples):)\n                \n                # --- بلوک کد اصلاح شده ---\n                # اشیاء پایتونی را که تنسور نیستند، جدا می‌کنیم\n                phonopy_object = sample['phonopy_obj']\n                q_points = sample['qpoints']\n                \n                # یک تابع موقت با lambda می‌سازیم که اشیاء پایتونی را در خود \"به خاطر می‌سپارد\"\n                # این تابع جدید فقط یک ورودی (آرایه NumPy) خواهد داشت\n                loss_func = lambda y_pred_numpy: calculate_physics_loss_for_sample(y_pred_numpy, phonopy_object, q_points)\n                \n                # حالا tf.py_function را فقط با ورودی عددی (که قابل تبدیل به تنسور است) فراخوانی می‌کنیم\n                p_loss = tf.py_function(\n                    func=loss_func,\n                    inp=[y_pred_sample_unscaled], # حالا فقط آرایه عددی را به عنوان ورودی پاس می‌دهیم\n                    Tout=tf.float32\n                )\n                physics_loss += p_loss\n                # --- پایان بلوک اصلاح شده ---\n            \n            physics_loss /= len(batch_samples) # میانگین لاس فیزیکی در بچ\n\n            # ترکیب دو لاس\n            total_loss = standard_loss + physics_loss_weight * physics_loss\n\n        # محاسبه و اعمال گرادیان‌ها\n        grads = tape.gradient(total_loss, model.trainable_variables)\n        optimizer.apply_gradients(zip(grads, model.trainable_variables))\n        \n        epoch_total_loss += total_loss\n    \n    print(f\"میانگین Loss در این Ep