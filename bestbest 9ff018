پیام با مکانیزم Attention (مشابه ترنسفورمر).\n    این لایه تصمیم می‌گیرد کدام همسایه‌ها اطلاعات مهم‌تری دارند.\n    \"\"\"\n    def __init__(self, hidden_dim):\n        super().__init__()\n        # شبکه تشخیص اهمیت (Attention Network)\n        self.attention_mlp = nn.Sequential(\n            nn.Linear(3 * hidden_dim, hidden_dim),\n            nn.LeakyReLU(0.2),\n            nn.Linear(hidden_dim, 1) # خروجی: یک عدد (امتیاز اهمیت)\n        )\n        \n        # شبکه پردازش پیام\n        self.msg_mlp = nn.Sequential(\n            nn.Linear(hidden_dim, hidden_dim),\n            nn.SiLU(),\n            nn.Linear(hidden_dim, hidden_dim)\n        )\n\n    def forward(self, x, edge_index, edge_attr):\n        source, target = edge_index\n        \n        # اطلاعات گره مبدا و مقصد\n        x_i = x[source]\n        x_j = x[target]\n        \n        # 1. محاسبه امتیاز توجه (Attention Score)\n        # ترکیب ویژگی‌های مبدا + مقصد + یال\n        attn_input = torch.cat([x_i, x_j, edge_attr], dim=1)\n        attn_score = self.attention_mlp(attn_input)\n        \n        # نرمال‌سازی امتیازها (Softmax) -> مجموع توجه‌ها باید ۱ شود\n        attn_weights = softmax(attn_score, target, num_nodes=x.size(0))\n        \n        # 2. ساخت پیام\n        # پیام = اطلاعات همسایه * ویژگی یال\n        msg = x_i * edge_attr\n        \n        # 3. اعمال وزن توجه\n        weighted_msg = msg * attn_weights\n        \n        # 4. جمع‌آوری پیام‌ها در گره مقصد\n        out = torch.zeros_like(x)\n        out.index_add_(0, target, weighted_msg)\n        \n        return self.msg_mlp(out)\n\n# Cell 9: Initialize Expert 2 (Deep & Narrow)\n\nclass DualGraphGNN_Deep(nn.Module):\n    def __init__(self, n_atom_features, n_bond_features=6, hidden_dim=64, k=32):\n        super().__init__()\n        self.k = k\n        \n        print(f\"🏗️ Building Expert 2 (Deep & Narrow)...\")\n        print(f\"   Hidden Dim: {hidden_dim} (Narrow)\")\n        print(f\"   Layers: 6 (Seeing long-range interactions)\")\n        \n        # --- Bond Graph ---\n        self.bond_embed = nn.Sequential(\n            nn.Linear(n_bond_features, hidden_dim),\n            nn.LayerNorm(hidden_dim),\n            nn.Mish() # اکتیویشن جدید و مدرن برای تنوع\n        )\n        self.bond_edge_embed = nn.Linear(1, hidden_dim)\n        \n        # ۶ لایه عمیق برای گراف پیوند\n        self.bond_layers = nn.ModuleList([CustomMessagePassing(hidden_dim) for _ in range(6)])\n        \n        # --- Atom Graph ---\n        self.atom_embed = nn.Sequential(\n            nn.Linear(n_atom_features + k, hidden_dim), \n            nn.LayerNorm(hidden_dim),\n            nn.Mish()\n        )\n        self.atom_edge_embed = nn.Linear(1, hidden_dim)\n        \n        # ۶ لایه عمیق برای گراف اتم\n        self.atom_layers = nn.ModuleList([CustomMessagePassing(hidden_dim) for _ in range(6)])\n        \n        self.register_buffer('W', torch.randn(n_atom_features, k) * 0.5)\n        self.register_buffer('b', torch.rand(k) * 2 * np.pi)\n\n        # --- Head ---\n        final_dim = (2 * hidden_dim) + (2 * hidden_dim) + 32\n        self.global_mlp = nn.Sequential(nn.Linear(3, 32), nn.Mish())\n        \n        self.head = nn.Sequential(\n            nn.Linear(final_dim, 256),\n            nn.Mish(),\n            nn.Dropout(0.15),\n            nn.Linear(256, 128),\n            nn.Mish(),\n            nn.Linear(128, 1)\n        )\n\n    def forward(self, bond_data, atom_data):\n        # Bond Path\n        x_b = self.bond_embed(bond_data.x)\n        e_b = self.bond_edge_embed(bond_data.edge_attr)\n        for layer in self.bond_layers:\n            residual = x_b\n            x_b = layer(x_b, bond_data.edge_index, e_b)\n            x_b = x_b + residual\n        pool_b = torch.cat([global_mean_pool(x_b, bond_data.batch), global_max_pool(x_b, bond_data.batch)], dim=1)\n\n        # Atom Path\n        sketch = torch.cos(atom_data.x @ self.W + self.b)\n        x_a = self.atom_embed(torch.cat([atom_data.x, sketch], dim=1))\n        e_a = self.atom_edge_embed(atom_data.edge_attr)\n        for layer in self.atom_layers:\n            residual = x_a\n            x_a = layer(x_a, atom_data.edge_index, e_a)\n            x_a = x_a + residual\n        pool_a = torch.cat([global_mean_pool(x_a, atom_data.batch), global_max_pool(x_a, atom_data.batch)], dim=1)\n        \n        # Fusion\n        g_info = self.global_mlp(bond_data.u)\n        return self.head(torch.cat([pool_b, pool_a, g_info], dim=1))\n\n# ساخت مدل Expert 2\nmodel_exp2 = DualGraphGNN_Deep(\n    n_atom_features=n_atom_features,\n    n_bond_features=6, \n    hidden_dim=64,     # باریک\n    k=32\n).to(device)\n\n# بهینه‌ساز متفاوت (RMSprop) برای پیدا کردن مسیرهای جدید در گرادیان\noptimizer = optim.RMSprop(model_exp2.parameters(), lr=0.0005, weight_decay=1e-5)\ncriterion = nn.L1Loss()\nscheduler = optim.lr_scheduler.ReduceLROnPlateau(optimizer, mode='min', factor=0.5, patience=10, verbose=True)\n\nprint(\"✅ Expert 2 (Deep Specialist) Initialized with RMSprop & Mish!\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-12-06T18:25:42.324608Z","iopub.execute_input":"2025-12-06T18:25:42.324898Z","iopub.status.idle":"2025-12-06T18:25:42.356171Z","shell.execute_reply.started":"2025-12-06T18:25:42.324876Z","shell.execute_reply":"2025-12-06T18:25:42.355426Z"}},"outputs":[{"name":"stdout","text":"🏗️ Building Expert 2 (Deep & Narrow)...\n   Hidden Dim: 64 (Narrow)\n   Layers: 6 (Seeing long-range interactions)\n✅ Expert 2 (Deep Specialist) Initialized with RMSprop & Mish!\n","output_type":"stream"}],"execution_count":24},{"cell_type":"code","source":"# Cell 7: Data Loaders & Model Instantiation\nfrom torch_geometric.nn import global_mean_pool, global_max_pool\n\n# 1. کلاس مدیریت دسته‌های دوتایی (Dual Graph Batching)\nclass DualGraphCollater:\n    def __init__(self, device):\n        self.device = device\n\n    def __call__(self, batch):\n        # batch ورودی لیستی از تاپل‌هاست: [(bond_graph, atom_graph), ...]\n        # ما باید