e < 0.005: ['melting_point', 'covalent_radius_pyykko', 'magp_density', 'dipole_polarizability', 'boiling_point']\nFeatures with permutation importance mean < 0.005: ['magp_column', 'pymg_electronegativity', 'lattice_constant', 'magp_unfilled_f', 'ionization_energy', 'dipole_polarizability_unc', 'imat_electron_affinity', 'specific_heat', 'evaporation_heat', 'mendeleev_number', 'en_allen', 'magp_unfilled_d', 'magp_electronegativity', 'imat_ionization_energy', 'atomic_radius_rahm', 'magp_covalent_radius', 'magp_t_boil', 'imat_electronegativity', 'covalent_radius_pyykko', 'melting_point', 'dipole_polarizability', 'magp_density', 'boiling_point']\nCandidate features to DROP (intersection): ['boiling_point', 'covalent_radius_pyykko', 'dipole_polarizability', 'magp_density', 'melting_point']\nSaved plots into feature_analysis_plots/all_plots.pdf\nSaved CSVs into feature_analysis_plots\n","output_type":"stream"}],"execution_count":11},{"cell_type":"code","source":"","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# Augmention code edit by deepseek","metadata":{}},{"cell_type":"code","source":"\"\"\"\nنسخه تصحیح شده - حذف پارامترهای غیرضروری برای model.fit\n\"\"\"\n\nimport os\nimport numpy as np\nimport tensorflow as tf\nfrom sklearn.metrics import r2_score\nimport matplotlib.pyplot as plt\nfrom scipy.signal import savgol_filter\nfrom tensorflow.keras import mixed_precision\nimport json\nfrom typing import Generator, Tuple\n\n# ---------- تنظیمات اولیه ----------\ndata_dir = \"/kaggle/input/npy-phonon-phase7\"\nout_dir = \"/kaggle/working\"\nos.makedirs(out_dir, exist_ok=True)\n\n# فعال‌سازی mixed precision\ntry:\n    mixed_precision.set_global_policy('mixed_float16')\n    print(\"Mixed precision policy set to:\", mixed_precision.global_policy())\nexcept Exception as e:\n    print(\"Mixed precision unavailable:\", e)\n\n# ---------- کلاس Data Generator برای مدیریت حافظه ----------\nclass PhononDataGenerator(tf.keras.utils.Sequence):\n    def __init__(self, X: np.ndarray, y: np.ndarray, batch_size: int = 32, \n                 shuffle: bool = True, augment: bool = False,\n                 scaler_X_mean: np.ndarray = None, scaler_X_std: np.ndarray = None,\n                 scaler_y_mean: np.ndarray = None, scaler_y_std: np.ndarray = None, **kwargs): # <--- ۱. **kwargs اضافه شد\n        \n        super().__init__(**kwargs) # <--- ۲. این خط برای فراخوانی سازنده کلاس پدر اضافه شد\n        \n        self.X = X\n        self.y = y\n        self.batch_size = batch_size\n        self.shuffle = shuffle\n        self.augment = augment\n        self.scaler_X_mean = scaler_X_mean\n        self.scaler_X_std = scaler_X_std\n        self.scaler_y_mean = scaler_y_mean\n        self.scaler_y_std = scaler_y_std\n        self.indices = np.arange(len(X))\n        self.on_epoch_end()\n        \n        # پارامترهای Augmentation\n        self.augment_prob = 0.5\n        self.noise_std = 0.01\n        \n    def __len__(self):\n        return int(np.ceil(len(self.X) / self.batch_size))\n    \n    def __getitem__(self, index):\n        batch_indices = self.indices[index*self.batch_size:(index+1)*self.batch_size]\n        X_batch = self.X[batch_indices].astype(np.float32)\n        y_batch = self.y[batch_indices].astype(np.float32)\n        \n        # اعمال Augmentation\n        if self.augment:\n            X_batch, y_batch = self._apply_augmentation(X_batch, y_batch)\n            \n        return X_batch, y_batch.reshape(len(y_batch), -1)\n    \n    def on_epoch_end(self):\n        if self.shuffle:\n            np.random.shuffle(self.indices)\n    \n    def _apply_augmentation(self, X_batch: np.ndarray, y_batch: np.ndarray) -> Tuple[np.ndarray, np.ndarray]:\n        \"\"\"اعمال augmentation بر اساس تقارن و نویز\"\"\"\n        batch_size = len(X_batch)\n        \n        for i in range(batch_size):\n            if np.random.random() < self.augment_prob:\n                # افزودن نویز گوسی\n                X_batch[i] += np.random.normal(0, self.noise_std, X_batch[i].shape)\n                \n            if np.random.random() < self.augment_prob:\n                # جابجایی کوچک در فرکانس‌ها (شبیه‌سازی اثر دمای مختلف)\n                freq_shift = np.random.normal(0, 0.02)\n                y_batch[i] += freq_shift\n                \n        return X_batch, y_batch\n\n# ---------- توابع کمکی ----------\ndef swish(x):\n    return tf.nn.swish(x)\n\ndef inverse_transform_y_flat(y_norm_flat, scaler_y_mean, scaler_y_std, max_qpoints, max_bands):\n    return (y_norm_flat * scaler_y_std + scaler_y_mean).reshape(-1, max_qpoints, max_bands)\n\ndef smoothness_loss_from_reshaped(y_pred_reshaped):\n    d2 = y_pred_reshaped[:, 2:, :] - 2.0 * y_pred_reshaped[:, 1:-1, :] + y_pred_reshaped[:, :-2, :]\n    return tf.reduce_mean(tf.square(d2))\n\n# ---------- ساخت مدل سبک‌تر ----------\ndef build_model_optimized(input_dim: int, output_dim: int):\n    \"\"\"مدل بهینه‌شده با regularization و normalization\"\"\"\n    inp = tf.keras.layers.Input(shape=(input_dim,), name=\"input\")\n    \n    # Block 1\n    x = tf.keras.layers.Dense(256, activation=swish, \n                             kernel_regularizer=tf.keras.regularizers.l2(1e-4))(inp)\n    x = tf.keras.layers.BatchNormalization()(x)\n    x = tf.keras.layers.Dropout(0.2)(x)\n    \n    # Block 2\n    x = tf.keras.layers.Dense(128, activation=swish,\n                             kernel_regularizer=tf.keras.regularizers.l2(1e-4))(x)\n    x = tf.keras.layers.BatchNormalization()(x)\n    x = tf.keras.layers.Dropout(0.2)(x)\n    \n    # Block 3\n    x = tf.keras.layers.Dense(64, activation=swish,\n                             kernel_regularizer=tf.keras.regularizers.l2(1e-4))(x)\n    x = tf.keras.layers.BatchNormalization()(x)\n    \n    # Output\n    out = tf.keras.layers.Dense(output_dim, activation='linear', \n                               kernel_regularizer=tf.keras.regularizers.l2(1e-4))(x)\n    \n    model = tf.keras.Model(inputs=inp, outputs=out)\n    return model\n\n# ---------- بارگذاری داده‌ها ----------\nprint(\"Loading data...\")\nX_train = np.load(os.path.join(data_dir, \"train_x_editedfeature.npy\"))\nX_val = np.load(os.path.join(data_dir, \"val_x_editedfeature.npy\"))\nX_test = np.load(os.path.join(data_dir, \"test_x_editedfeature.npy\"))\ny_train = np.load(os.path.join(data_dir, \"train_y_editedfeature.npy\"))\ny_val = np.load(os.path.join(data_dir, \"val_y_editedfeature.npy\"))\ny_test = np.load(os.path.join(data_dir, \"test_y_editedfeature.npy\"))\n\nscaler_y_mean = np.load(os.path.join(data_dir, \"scaler_y_mean_editedfeature.npy\"))\nscaler_y_std = np.load(os.path.join(data_dir, \"scaler_y_std_editedfeature.npy\"))\nscaler_X_mean = np.load(os.path.join(data_dir, \"scaler_X_mean_editedfeature.npy\"))\nscaler_X_std = np.load(os.path.join(data_dir, \"scaler_X_std_editedfeature.npy\"))\n\n# پارامترهای خروجی\nnum_samples, max_qpoints, max_bands = y_train.shape\noutput_flat_dim = int(max_qpoints * max_bands)\n\n# ---------- ایجاد Data Generators ----------\nbatch_size = 32\ntrain_gen = PhononDataGenerator(X_train, y_train, batch_size=batch_size, \n                               shuffle=True, augment=True,\n                               scaler_X_mean=scaler_X_mean, scaler_X_std=scaler_X_std,\n                               scaler_y_mean=scaler_y_mean, scaler_y_std=scaler_y_std)\n\nval_gen = PhononDataGenerator(X_val, y_val, batch_size=batch_size, \n                             shuffle=False, augment=False,\n                             scaler_X_mean=scaler_X_mean, scaler_X_std=scaler_X_std,\n                             scaler_y_mean=scaler_y_mean, scaler_y_std=scaler_y_std)\n\n# ---------- ساخت و کامپایل مدل ----------\nprint(\"Building model...\")\nmodel = build_model_optimized(X_train.shape[1], output_flat_dim)\nmodel.summary()\n\n# تنظیمات آموزش\ninitial_lr = 3e-4\nlambda_smooth = 0.1\nepochs = 200\npatience = 30\n\n# Optimizer با learning rate scheduler\nlr_schedule = tf.keras.optimizers.schedules.ExponentialDecay(\n    initial_lr, decay_steps=1000, decay_rate=0.9, staircase=True)\n# به جای یک برنامه زمان‌بندی، یک عدد ثابت بدهید\noptimizer = tf.keras.optimizers.Adam(learning_rate=0.001)\n\n# Loss function ترکیبی\ndef combined_loss(y_true, y_pred):\n    mse_loss = tf.keras.losses.MeanSquaredError()(y_true, y_pred)\n\n    # محاسبه smoothness loss\n    y_pred_reshaped = tf.reshape(y_pred, (-1, max_qpoints, max_bands))\n    smooth_loss = smoothness_loss_from_reshaped(y_pred_reshaped)\n    \n    return mse_loss + lambda_smooth * smooth_loss\n\nmodel.compile(optimizer=optimizer, loss=combined_loss, metrics=['mse'])\n\n# ---------- Callbacks ----------\ncallbacks = [\n    tf.keras.callbacks.EarlyStopping(\n        monitor='val_loss',\n        patience=patience,\n        restore_best_weights=True,\n        verbose=1\n    ),\n    tf.keras.callbacks.ReduceLROnPlateau(\n        monitor='val_loss',\n        factor=0.5,\n        patience=10,\n        min_lr=1e-6,\n        verbose=1\n    ),\n    tf.keras.callbacks.ModelCheckpoint(\n        os.path.join(out_dir, 'best_model_augmented.weights.h5'),\n        monitor='val_loss',\n        save_best_only=True,\n        save_weights_only=True,\n        verbose=1\n    ),\n    tf.keras.callbacks.CSVLogger(\n        os.path.join(out_dir, 'training_log.csv'),\n        append=True\n    )\n]\n\n# ---------- آموزش مدل ----------\nprint(\"Starting training...\")\nhistory = model.fit(\n    train_gen,\n    epochs=epochs,\n    validation_data=val_gen,\n    callbacks=callbacks,\n    verbose=1\n    # حذف workers و use_multiprocessing چون در این نسخه مشکل ایجاد می‌کنند\n)\n\n# ---------- ارزیابی مدل ----------\nprint(\"Evaluating model...\")\ntest_gen = PhononDataGenerator(X_test, y_test, batch_size=batch_size, \n                              shuffle=False, augment=False)\n\n# پیش‌بینی\ny_pred_flat = model.predict(test_gen, verbose=1)\ny_pred = inverse_transform_y_flat(y_pred_flat, scaler_y_mean, scaler_y_std, max_qpoints, max_bands)\ny_test_true = inverse_transform_y_flat(y_test.reshape(len(y_test), -1), \n                                      scaler_y_mean, scaler_y_std, max_qpoints, max_bands)\n\n# محاسبه R²\nr2_scores = [r2_score(y_test_true[i].flatten(), y_pred[i].flatten()) \n             for i in range(len(y_test_true))]\nmean_r2 = np.mean(r2_scores)\nstd_r2 = np.std(r2_scores)\n\nprint(f\"Test R² Score: {mean_r2:.4f} ± {std_r2:.4f}\")\n\n# ذخیره نتایج\nnp.save(os.path.join(out_dir, \"r2_scores_augmented.npy\"), np.array(r2_scores))\nnp.save(os.path.join(out_dir, \"y_pred_augmented.npy\"), y_pred)\nnp.save(os.path.join(out_dir, \"y_true_augmented.npy\"), y_test_true)\n\n# ---------- نمودارهای حرفه‌ای ----------\ndef create_professional_plots():\n    \"\"\"ایجاد نمودارهای حرفه‌ای\"\"\"\n    \n    # 1. نمودار Training/Validation Loss\n    plt.figure(figsize=(15, 12))\n    \n    plt.subplot(2, 2, 1)\n    plt.plot(history.history['loss'], label='Training Loss', linewidth=2, alpha=0.8)\n    plt.plot(history.history['val_loss'], label='Validation Loss', linewidth=2, alpha=0.8)\n    plt.xlabel('Epochs')\n    plt.ylabel('Loss')\n    plt.title('Training and Validation Loss')\n    plt.legend()\n    plt.grid(True, alpha=0.3)\n    plt.yscale('log')\n    \n    # 2. نمودار R² Distribution\n    plt.subplot(2, 2, 2)\n    plt.hist(r2_scores, bins=30, alpha=0.7, color='skyblue', edgecolor='black')\n    plt.axvline(mean_r2, color='red', linestyle='--', linewidth=2, label=f'Mean R²: {mean_r2:.4f}')\n    plt.xlabel('R² Score')\n    plt.ylabel('Frequency')\n    plt.title('Distribution of R² Scores')\n    plt.legend()\n    plt.grid(True, alpha=0.3)\n    \n    # 3. نمودار Phonon Bands (همانند تصویر شما)\n    plt.subplot(2, 2, 3)\n    sample_idx = 0  # نمونه اول برای نمایش\n    \n    # ایجاد colormap حرفه‌ای\n    colors = plt.cm.viridis(np.linspace(0, 1, max_bands))\n    \n    for b in range(max_bands):\n        plt.plot(y_test_true[sample_idx, :, b], color=colors[b], linewidth=2.5, \n                label=f'True Band {b+1}', alpha=0.8)\n        plt.plot(y_pred[sample_idx, :, b], color=colors[b], linewidth=1.5, \n                linestyle='--', label=f'Pred Band {b+1}', alpha=0.8)\n    \n    plt.xlabel('Q-point Index')\n    plt.ylabel('Frequency (THz)')\n    plt.title('Phonon Band Structure - True vs Predicted')\n    plt.legend(bbox_to_anchor=(1.05, 1), loc='upper left')\n    plt.grid(True, alpha=0.3)\n    \n    # 4. نمودار Error Analysis\n    plt.subplot(2, 2, 4)\n    errors = np.abs(y_test_true - y_pred).mean(axis=(1, 2))\n    plt.scatter(range(len(errors)), errors, alpha=0.6, s=50)\n    plt.axhline(np.mean(errors), color='red', linestyle='--', linewidth=2, \n               label=f'Mean Error: {np.mean(errors):.4f}')\n    plt.xlabel('Sample Index')\n    plt.ylabel('Mean Absolute Error')\n    plt.title('Error Distribution Across Samples')\n    plt.legend()\n    plt.grid(True, alpha=0.3)\n    \n    plt.tight_layout()\n    plt.savefig(os.path.join(out_dir, 'professional_analysis.png'), dpi=300, bbox_inches='tight')\n    plt.show()\n    \n    # 5. نمودار حرفه‌ای جداگانه برای Phonon Bands\n    plt.figure(figsize=(14, 8))\n    \n    # ایجاد پس‌زمینه گرادیان\n    ax = plt.gca()\n    ax.set_facecolor('#f8f9fa')\n    \n    # رسم نوارهای فونونی با استایل حرفه‌ای\n    for b in range(max_bands):\n        plt.plot(y_test_true[sample_idx, :, b], color='navy', linewidth=3, \n                label='True' if b == 0 else \"\", alpha=0.9)\n        plt.plot(y_pred[sample_idx, :, b], color='crimson', linewidth=2, \n                linestyle='--', label='Predicted' if b == 0 else \"\", alpha=0.9)\n    \n    plt.xlabel('Q-point Path', fontsize=14, fontweight='bold')\n    plt.ylabel('Frequency (THz)', fontsize=14, fontweight='bold')\n    plt.title('Phonon Dispersion Relations\\nTrue vs Predicted', \n              fontsize=16, fontweight='bold', pad=20)\n    plt.legend(fontsize=12, frameon=True, fancybox=True, shadow=True)\n    plt.grid(True, alpha=0.4, linestyle='-', linewidth=0.5)\n    \n    # اضافه کردن جعبه اطلاعات\n    textstr = f'Mean R²: {mean_r2:.4f}\\nMean MAE: {mean_mae:.4f}\\nSamples: {len(y_test_true)}'\n    props = dict(boxstyle='round', facecolor='wheat', alpha=0.8)\n    plt.text(0.02, 0.98, textstr, transform=plt.gca().transAxes, fontsize=10,\n             verticalalignment='top', bbox=props)\n    \n    plt.tight_layout()\n    plt.savefig(os.path.join(out_dir, 'professional_phonon_bands.png'), \n                dpi=350, bbox_inches='tight', facecolor='white')\n    plt.show()\n\ncreate_professional_plots()\n\n# ---------- ذخیره نتایج پیشرفته ----------\nadvanced_results = {\n    'final_r2_score': float(mean_r2),\n    'r2_std': float(std_r2),\n    'mean_mae': float(mean_mae),\n    'mean_mse': float(mean_mse),\n    'best_val_loss': float(min(history.history['val_loss'])),\n    'final_train_loss': float(history.history['loss'][-1]),\n    'epochs_trained': len(history.history['loss']),\n    'learning_rate': float(initial_lr),\n    'augmentation_used': True,\n    'model_parameters': model.count_params(),\n    'r2_scores': [float(score) for score in r2_scores]\n}\n\nwith open(os.path.join(out_dir, 'advanced_results.json'), 'w') as f:\n    json.dump(advanced_results, f, indent=2)\n\n# ذخیره پیش‌بینی‌ها\nnp.save(os.path.join(out_dir, \"advanced_r2_scores.npy\"), np.array(r2_scores))\nnp.save(os.path.join(out_dir, \"advanced_y_pred.npy\"), y_pred)\nnp.save(os.path.join(out_dir, \"advanced_y_true.npy\"), y_test_true)\n\nprint(\"Advanced training completed successfully!\")\nprint(f\"Best model saved to: {os.path.join(out_dir, 'best_advanced_model.weights.h5')}\")\nprint(f\"Professional plots saved to: {out_dir}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-08-22T10:03:19.838242Z","iopub.execute_input":"2025-08-22T10:03:19.838622Z","execution_failed":"2025-08-22T11:07:48.194Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"","metadata":{}},{"cell_type":"code","source":"","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"\"\"\"\nنسخه تصحیح شده با رفع خطای Learning Rate\n\"\"\"\n\nimport os\nimport numpy as np\nimport tensorflow as tf\nfrom sklearn.metrics import r2_score\nimport matplotlib.pyplot as plt\nfrom scipy.signal import savgol_filter\nimport json\nimport seaborn as sns\n\n# تنظیمات زیبایی نمودارها\nplt.rcParams['figure.figsize'] = [12, 8]\nplt.rcParams['font.size'] = 12\nplt.rcParams['axes.grid'] = True\nplt.rcParams['grid.alpha'] = 0.3\nsns.set_palette(\"husl\")\n\n# ---------- تنظیمات اولیه ----------\ndata_dir = \"/kaggle/input/npy-phonon-phase7\"\nout_dir = \"/kaggle/working\"\nos.makedirs(out_dir, exist_ok=True)\n\n# ---------- کلاس Data Generator پیشرفته ----------\nclass AdvancedPhononDataGenerator(tf.keras.utils.Sequence):\n    def __init__(self, X: np.ndarray, y: np.ndarray, batch_size: int = 32, \n                 shuffle: bool = True, augment: bool = False, mode: str = 'train'):\n        self.X = X\n        self.y = y\n        self.batch_size = batch_size\n        self.shuffle = shuffle\n        self.augment = augment\n        self.mode = mode\n        self.indices = np.arange(len(X))\n        self.on_epoch_end()\n        \n        # پارامترهای Augmentation پیشرفته\n        self.augment_prob = 0.7 if mode == 'train' else 0.0\n        self.noise_std = 0.015\n        self.freq_shift_std = 0.03\n        self.mixup_alpha = 0.2\n        \n    def __len__(self):\n        return int(np.ceil(len(self.X) / self.batch_size))\n    \n    def __getitem__(self, index):\n        batch_indices = self.indices[index*self.batch_size:(index+1)*self.batch_size]\n        X_batch = self.X[batch_indices].astype(np.float32)\n        y_batch = self.y[batch_indices].astype(np.float32)\n        \n        # اعمال Augmentation پیشرفته\n        if self.augment:\n            X_batch, y_batch = self._apply_advanced_augmentation(X_batch, y_batch)\n            \n        return X_batch, y_batch.reshape(len(y_batch), -1)\n    \n    def on_epoch_end(self):\n        if self.shuffle:\n            np.random.shuffle(self.indices)\n    \n    def _apply_advanced_augmentation(self, X_batch, y_batch):\n        \"\"\"Augmentation پیشرفته با Mixup و CutMix\"\"\"\n        batch_size = len(X_batch)\n        \n        # Mixup Augmentation\n        if np.random.random() < 0.4:\n            lam = np.random.beta(self.mixup_alpha, self.mixup_alpha)\n            indices = np.random.permutation(batch_size)\n            X_batch = lam * X_batch + (1 - lam) * X_batch[indices]\n            y_batch = lam * y_batch + (1 - lam) * y_batch[indices]\n        \n        # Additive noise\n        for i in range(batch_size):\n            if np.random.random() < self.augment_prob:\n                noise = np.random.normal(0, self.noise_std, X_batch[i].shape)\n                X_batch[i] += noise * (1 + 0.1 * np.random.random())\n                \n            if np.random.random() < self.augment_prob:\n                freq_shift = np.random.normal(0, self.freq_shift_std)\n                y_batch[i] += freq_shift * (1 + 0.2 * np.random.random())\n                \n        return X_batch, y_batch\n\n# ---------- توابع کمکی ----------\ndef swish(x):\n    return tf.nn.swish(x)\n\ndef inverse_transform_y_flat(y_norm_flat, scaler_y_mean, scaler_y_std, max_qpoints, max_bands):\n    return (y_norm_flat * scaler_y_std + scaler_y_mean).reshape(-1, max_qpoints, max_bands)\n\ndef smoothness_loss_from_reshaped(y_pred_reshaped):\n    d2 = y_pred_reshaped[:, 2:, :] - 2.0 * y_pred_reshaped[:, 1:-1, :] + y_pred_reshaped[:, :-2, :]\n    return tf.reduce_mean(tf.square(d2))\n\n# ---------- ساخت مدل پیشرفته ----------\ndef build_advanced_model(input_dim: int, output_dim: int):\n    \"\"\"مدل پیشرفته با معماری بهبود یافته\"\"\"\n    inp = tf.keras.layers.Input(shape=(input_dim,), name=\"input\")\n    \n    # Block 1 - Wider\n    x = tf.keras.layers.Dense(512, activation=swish, \n                             kernel_regularizer=tf.keras.regularizers.l2(1e-5))(inp)\n    x = tf.keras.layers.BatchNormalization()(x)\n    x = tf.keras.layers.Dropout(0.15)(x)\n    \n    # Block 2\n    x = tf.keras.layers.Dense(256, activation=swish,\n                             kernel_regularizer=tf.keras.regularizers.l2(1e-5))(x)\n    x = tf.keras.layers.BatchNormalization()(x)\n    x = tf.keras.layers.Dropout(0.15)(x)\n    \n    # Block 3\n    x = tf.keras.layers.Dense(128, activation=swish,\n                             kernel_regularizer=tf.keras.regularizers.l2(1e-5))(x)\n    x = tf.keras.layers.BatchNormalization()(x)\n    x = tf.keras.layers.Dropout(0.1)(x)\n    \n    # Block 4\n    x = tf.keras.layers.Dense(64, activation=swish,\n                             kernel_regularizer=tf.keras.regularizers.l2(1e-5))(x)\n    x = tf.keras.layers.BatchNormalization()(x)\n    \n    # Output\n    out = tf.keras.layers.Dense(output_dim, activation='linear', \n                               kernel_regularizer=tf.keras.regularizers.l2(1e-5))(x)\n    \n    model = tf.keras.Model(inputs=inp, outputs=out)\n    return model\n\n# ---------- بارگذاری داده‌ها ----------\nprint(\"Loading data...\")\nX_train = np.load(os.path.join(data_dir, \"train_x_editedfeature.npy\"))\nX_val = np.load(os.path.join(data_dir, \"val_x_editedfeature.npy\"))\nX_test = np.load(os.path.join(data_dir, \"test_x_editedfeature.npy\"))\ny_train = np.load(os.path.join(data_dir, \"train_y_editedfeature.npy\"))\ny_val = np.load(os.path.join(data_dir, \"val_y_editedfeature.npy\"))\ny_test = np.load(os.path.join(data_dir, \"test_y_editedfeature.npy\"))\n\nscaler_y_mean = np.load(os.path.join(data_dir, \"scaler_y_mean_editedfeature.npy\"))\nscaler_y_std = np.load(os.path.join(data_dir, \"scaler_y_std_editedfeature.npy\"))\nscaler_X_mean = np.load(os.path.join(data_dir, \"scaler_X_mean_editedfeature.npy\"))\nscaler_X_std = np.load(os.path.join(data_dir, \"scaler_X_std_editedfeature.npy\"))\n\n# پارامترهای خروجی\nnum_samples, max_qpoints, max_bands = y_train.shape\noutput_flat_dim = int(max_qpoints * max_bands)\n\n# ---------- ایجاد Data Generators پیشرفته ----------\nbatch_size = 16\ntrain_gen = AdvancedPhononDataGenerator(X_train, y_train, batch_size=batch_size, \n                                       shuffle=True, augment=True, mode='train')\n\nval_gen = AdvancedPhononDataGenerator(X_val, y_val, batch_size=batch_size, \n                                     shuffle=False, augment=False, mode='val')\n\n# ---------- ساخت و کامپایل مدل پیشرفته ----------\nprint(\"Building advanced model...\")\nmodel = build_advanced_model(X_train.shape[1], output_flat_dim)\nmodel.summary()\n\n# تنظیمات آموزش پیشرفته\ninitial_lr = 1e-4\nlambda_smooth = 0.1\nepochs = 200\npatience = 30\n\n# استفاده از Adam معمولی به جای AdamW برای جلوگیری از خطا\noptimizer = tf.keras.optimizers.Adam(learning_rate=initial_lr)\n\n# Loss function ترکیبی پیشرفته\ndef advanced_combined_loss(y_true, y_pred):\n    mse_loss = tf.keras.losses.MSE(y_true, y_pred)\n    \n    # محاسبه smoothness loss با وزن کمتر\n    y_pred_reshaped = tf.reshape(y_pred, (-1, max_qpoints, max_bands))\n    smooth_loss = smoothness_loss_from_reshaped(y_pred_reshaped)\n    \n    return mse_loss + lambda_smooth * smooth_loss\n\nmodel.compile(optimizer=optimizer, loss=advanced_combined_loss, \n              metrics=['mse', 'mae'])\n\n# ---------- Callbacks پیشرفته ----------\ncallbacks = [\n    tf.keras.callbacks.EarlyStopping(\n        monitor='val_loss',\n        patience=patience,\n        restore_best_weights=True,\n        verbose=1,\n        min_delta=1e-6\n    ),\n    tf.keras.callbacks.ReduceLROnPlateau(\n        monitor='val_loss',\n        factor=0.5,\n        patience=15,\n        min_lr=1e-7,\n        verbose=1\n    ),\n    tf.keras.callbacks.ModelCheckpoint(\n        os.path.join(out_dir, 'best_advanced_model.weights.h5'),\n        monitor='val_loss',\n        save_best_only=True,\n        save_weights_only=True,\n        verbose=1\n    ),\n    tf.keras.callbacks.CSVLogger(\n        os.path.join(out_dir, 'advanced_training_log.csv'),\n        append=True\n    ),\n    tf.keras.callbacks.TerminateOnNaN()\n]\n\n# ---------- آموزش مدل ----------\nprint(\"Starting advanced training...\")\nhistory = model.fit(\n    train_gen,\n    epochs=epochs,\n    validation_data=val_gen,\n    callbacks=callbacks,\n    verbose=1\n)\n\n# ---------- ارزیابی پیشرفته ----------\nprint(\"Advanced evaluation...\")\ntest_gen = AdvancedPhononDataGenerator(X_test, y_test, batch_size=batch_size, \n                                      shuffle=False, augment=False, mode='test')\n\n# پیش‌بینی\ny_pred_flat = model.predict(test_gen, verbose=1)\ny_pred = inverse_transform_y_flat(y_pred_flat, scaler_y_mean, scaler_y_std, max_qpoints, max_bands)\ny_test_true = inverse_transform_y_flat(y_test.reshape(len(y_test), -1), \n                                      scaler_y_mean, scaler_y_std, max_qpoints, max_bands)\n\n# محاسبه R² پیشرفته\nr2_scores = []\nmae_scores = []\nmse_scores = []\n\nfor i in range(len(y_test_true)):\n    r2 = r2_score(y_test_true[i].flatten(), y_pred[i].flatten())\n    mae = np.mean(np.abs(y_test_true[i] - y_pred[i]))\n    mse = np.mean((y_test_true[i] - y_pred[i])**2)\n    \n    r2_scores.append(r2)\n    mae_scores.append(mae)\n    mse_scores.append(mse)\n\nmean_r2 = np.mean(r2_scores)\nstd_r2 = np.std(r2_scores)\nmean_mae = np.mean(mae_scores)\nmean_mse = np.mean(mse_scores)\n\nprint(f\"Advanced Test Results:\")\nprint(f\"R² Score: {mean_r2:.6f} ± {std_r2:.6f}\")\nprint(f\"MAE: {mean_mae:.6f}\")\nprint(f\"MSE: {mean_mse:.6f}\")\n\n# ---------- نمودارهای حرفه‌ای ----------\ndef create_professional_plots():\n    \"\"\"ایجاد نمودارهای حرفه‌ای\"\"\"\n    \n    # 1. نمودار Training/Validation Loss\n    plt.figure(figsize=(15, 12))\n    \n    plt.subplot(2, 2, 1)\n    plt.plot(history.history['loss'], label='Training Loss', linewidth=2, alpha=0.8)\n    plt.plot(history.history['val_loss'], label='Validation Loss', linewidth=2, alpha=0.8)\n    plt.xlabel('Epochs')\n    plt.ylabel('Loss')\n    plt.title('Training and Validation Loss')\n    plt.legend()\n    plt.grid(True, alpha=0.3)\n    plt.yscale('log')\n    \n    # 2. نمودار R² Distribution\n    plt.subplot(2, 2, 2)\n    plt.hist(r2_scores, bins=30, alpha=0.7, color='skyblue', edgecolor='black')\n    plt.axvline(mean_r2, color='red', linestyle='--', linewidth=2, label=f'Mean R²: {mean_r2:.4f}')\n    plt.xlabel('R² Score')\n    plt.ylabel('Frequency')\n    plt.title('Distribution of R² Scores')\n    plt.legend()\n    plt.grid(True, alpha=0.3)\n    \n    # 3. نمودار Phonon Bands (همانند تصویر شما)\n    plt.subplot(2, 2, 3)\n    sample_idx = 0  # نمونه اول برای نمایش\n    \n    # ایجاد colormap حرفه‌ای\n    colors = plt.cm.viridis(np.linspace(0, 1, max_bands))\n    \n    for b in range(max_bands):\n        plt.plot(y_test_true[sample_idx, :, b], color=colors[b], linewidth=2.5, \n                label=f'True Band {b+1}', alpha=0.8)\n        plt.plot(y_pred[sample_idx, :, b], color=colors[b], linewidth=1.5, \n                linestyle='--', label=f'Pred Band {b+1}', alpha=0.8)\n    \n    plt.xlabel('Q-point Index')\n    plt.ylabel('Frequency (THz)')\n    plt.title('Phonon Band Structure - True vs Predicted')\n    plt.legend(bbox_to_anchor=(1.05, 1), loc='upper left')\n    plt.grid(True, alpha=0.3)\n    \n    # 4. نمودار Error Analysis\n    plt.subplot(2, 2, 4)\n    errors = np.abs(y_test_true - y_pred).mean(axis=(1, 2))\n    plt.scatter(range(len(errors)), errors, alpha=0.6, s=50)\n    plt.axhline(np.mean(errors), color='red', linestyle='--', linewidth=2, \n               label=f'Mean Error: {np.mean(errors):.4f}')\n    plt.xlabel('Sample Index')\n    plt.ylabel('Mean Absolute Error')\n    plt.title('Error Distribution Across Samples')\n    plt.legend()\n    plt.grid(True, alpha=0.3)\n    \n    plt.tight_layout()\n    plt.savefig(os.path.join(out_dir, 'professional_analysis.png'), dpi=300, bbox_inches='tight')\n  