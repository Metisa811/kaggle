 GNN را اجرا کنید","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-11-07T11:25:14.33452Z","iopub.execute_input":"2025-11-07T11:25:14.334851Z","iopub.status.idle":"2025-11-07T11:25:15.201169Z","shell.execute_reply.started":"2025-11-07T11:25:14.334833Z","shell.execute_reply":"2025-11-07T11:25:15.20037Z"}},"outputs":[{"execution_count":3,"output_type":"execute_result","data":{"text/plain":"0"},"metadata":{}}],"execution_count":3},{"cell_type":"code","source":"\"\"\"\nSimplified Physics-Informed GNN - Focus on IFCs only\nRemove elastic constants to avoid dimension mismatch issues\n\"\"\"\n\nimport os\nimport numpy as np\nimport tensorflow as tf\nfrom tensorflow import keras\nimport time\n\n# ==========================================\n# Configuration\n# ==========================================\nDATA_DIR = \"./physics_informed_dataset\"\nOUTPUT_DIR = \"./simple_gnn_results\"\nos.makedirs(OUTPUT_DIR, exist_ok=True)\n\nBATCH_SIZE = 8\nEPOCHS = 300\nLR_INITIAL = 5e-4\nPATIENCE = 80\nCUTOFF_RADIUS = 8.0\n\nprint(\"=\"*80)\nprint(\"SIMPLIFIED PHYSICS-INFORMED GNN\")\nprint(\"Focus: Force Constants Prediction Only\")\nprint(\"=\"*80)\n\n# Load dataset\ntrain_data = np.load(os.path.join(DATA_DIR, \"train_data.npy\"), allow_pickle=True)\nval_data = np.load(os.path.join(DATA_DIR, \"val_data.npy\"), allow_pickle=True)\ntest_data = np.load(os.path.join(DATA_DIR, \"test_data.npy\"), allow_pickle=True)\nmetadata = np.load(os.path.join(DATA_DIR, \"metadata.npy\"), allow_pickle=True).item()\n\nprint(f\"✓ Train: {len(train_data)}, Val: {len(val_data)}, Test: {len(test_data)}\")\n\nNODE_FEATURE_DIM = metadata['node_feature_dim']\nprint(f\"✓ Node features: {NODE_FEATURE_DIM}\")\n\n# Normalize IFCs\nprint(\"\\nNormalizing IFCs...\")\nall_samples = list(train_data)\nall_ifcs = np.concatenate([s['force_constants'].flatten() for s in all_samples])\nIFC_MEAN = np.mean(all_ifcs)\nIFC_STD = np.std(all_ifcs)\nprint(f\"IFC mean: {IFC_MEAN:.6f}, std: {IFC_STD:.6f}\")\n\nfor sample in list(train_data) + list(val_data) + list(test_data):\n    sample['force_constants'] = (sample['force_constants'] - IFC_MEAN) / (IFC_STD + 1e-8)\n\nprint(\"✓ IFCs normalized!\")\n\n# ==========================================\n# Graph Construction\n# ==========================================\ndef construct_graph(sample, cutoff=CUTOFF_RADIUS):\n    positions = sample['positions']\n    n_atoms = len(positions)\n    \n    diff = positions[:, np.newaxis, :] - positions[np.newaxis, :, :]\n    distances = np.linalg.norm(diff, axis=-1)\n    \n    edges, edge_vecs, edge_lens = [], [], []\n    for i in range(n_atoms):\n        for j in range(n_atoms):\n            if i != j and distances[i, j] < cutoff:\n                edges.append([i, j])\n                edge_vecs.append(diff[i, j])\n                edge_lens.append(distances[i, j])\n    \n    if len(edges) == 0:\n        for i in range(n_atoms):\n            for j in range(n_atoms):\n                if i != j:\n                    edges.append([i, j])\n                    edge_vecs.append(diff[i, j])\n                    edge_lens.append(distances[i, j])\n    \n    return (np.array(edges, dtype=np.int32),\n            np.array(edge_vecs, dtype=np.float32),\n            np.array(edge_lens, dtype=np.float32).reshape(-1, 1))\n\ndef prepare_batch(samples):\n    node_list, edge_list, edge_vec_list, edge_len_list = [], [], [], []\n    ifc_list, graph_idx_list, n_atoms_list = [], [], []\n    \n    max_atoms = max(s['n_atoms'] for s in samples)\n    \n    node_offset = 0\n    for gid, sample in enumerate(samples):\n        node_list.append(sample['node_features'])\n        \n        edges, edge_vecs, edge_lens = construct_graph(sample)\n        edge_list.append(edges + node_offset)\n        edge_vec_list.append(edge_vecs)\n        edge_len_list.append(edge_lens)\n        \n        ifc = sample['force_constants']\n        n_atoms = sample['n_atoms']\n        pad_size = max_atoms - n_atoms\n        \n        ifc_padded = np.pad(ifc, [[0, pad_size], [0, pad_size], [0, 0], [0, 0]], \n                           mode='constant', constant_values=0)\n        ifc_list.append(ifc_padded)\n        \n        graph_idx_list.append(np.full(n_atoms, gid, dtype=np.int32))\n        n_atoms_list.append(n_atoms)\n        \n        node_offset += n_atoms\n    \n    return (np.vstack(node_list).astype(np.float32),\n            np.vstack(edge_list).astype(np.int32),\n            np.vstack(edge_vec_list).astype(np.float32),\n            np.vstack(edge_len_list).astype(np.float32),\n            np.concatenate(graph_idx_list).astype(np.int32),\n            np.array(n_atoms_list, dtype=np.int32),\n            np.array([len(samples)], dtype=np.int32)), \\\n           np.array(ifc_list, dtype=np.float32)\n\n# ==========================================\n# Simplified Architecture\n# ==========================================\nclass SimpleMessageLayer(keras.layers.Layer):\n    def __init__(self, hidden_dim, **kwargs):\n        super().__init__(**kwargs)\n        self.message_net = keras.Sequential([\n            keras.layers.Dense(hidden_dim, activation='silu'),\n            keras.layers.Dense(hidden_dim)\n        ])\n        self.update_net = keras.Sequential([\n            keras.layers.Dense(hidden_dim, activation='silu'),\n            keras.layers.Dense(hidden_dim)\n        ])\n    \n    def call(self, node_features, edges, edge_lens):\n        sender_idx = edges[:, 0]\n        receiver_idx = edges[:, 1]\n        \n        sender_features = tf.gather(node_features, sender_idx)\n        receiver_features = tf.gather(node_features, receiver_idx)\n        \n        edge_input = tf.concat([sender_features, receiver_features, edge_lens], axis=-1)\n        messages = self.message_net(edge_input)\n        \n        num_nodes = tf.shape(node_features)[0]\n        aggregated = tf.math.unsorted_segment_sum(messages, receiver_idx, num_segments=num_nodes)\n        \n        update_input = tf.concat([node_features, aggregated], axis=-1)\n        updates = self.update_net(update_input)\n        \n        return node_features + updates\n\nclass SimpleIFCHead(keras.layers.Layer):\n    def __init__(self, hidden_dim, max_atoms=8, **kwargs):\n        super().__init__(**kwargs)\n        self.max_atoms = max_atoms\n        \n        self.pair_net = keras.Sequential([\n            keras.layers.Dense(hidden_dim, activation='silu'),\n            keras.layers.Dense(hidden_dim // 2, activation='silu'),\n            keras.layers.Dense(9)\n        ])\n    \n    def call(self, node_features, graph_idx, batch_size):\n        if len(batch_size.shape) > 0:\n            batch_size = batch_size[0]\n        \n        def predict_graph(graph_id):\n            mask = tf.equal(graph_idx, graph_id)\n            graph_features = tf.boolean_mask(node_features, mask)\n            n_nodes = tf.shape(graph_features)[0]\n            \n            feat_i = tf.tile(tf.expand_dims(graph_features, 1), [1, n_nodes, 1])\n            feat_j = tf.tile(tf.expand_dims(graph_features, 0), [n_nodes, 1, 1])\n            \n            pair_features = tf.concat([feat_i, feat_j], axis=-1)\n            pair_flat = tf.reshape(pair_features, [-1, tf.shape(pair_features)[-1]])\n            \n            ifc_flat = self.pair_net(pair_flat)\n            ifc_matrix = tf.reshape(ifc_flat, [n_nodes, n_nodes, 3, 3])\n            \n            # Symmetry\n            ifc_sym = (ifc_matrix + tf.transpose(ifc_matrix, [1, 0, 3, 2])) / 2.0\n            \n            # ASR\n            mean_j = tf.reduce_mean(ifc_sym, axis=1, keepdims=True)\n            ifc_final = ifc_sym - mean_j\n            \n            pad_size = self.max_atoms - n_nodes\n            return tf.pad(ifc_final, [[0, pad_size], [0, pad_size], [0, 0], [0, 0]])\n        \n        graph_ids = tf.range(batch_size, dtype=tf.int32)\n        return tf.map_fn(predict_graph, graph_ids, dtype=tf.float32, parallel_iterations=10)\n\nclass SimplePooling(keras.layers.Layer):\n    def __init__(self, hidden_dim, **kwargs):\n        super().__init__(**kwargs)\n        self.attention = keras.layers.Dense(1)\n    \n    def call(self, node_features, graph_idx):\n        num_graphs = tf.reduce_max(graph_idx) + 1\n        scores = self.attention(node_features)\n        \n        max_scores = tf.math.unsorted_segment_max(scores, graph_idx, num_segments=num_graphs)\n        exp_scores = tf.exp(scores - tf.gather(max_scores, graph_idx))\n        \n        sum_scores = tf.math.unsorted_segment_sum(exp_scores, graph_idx, num_segments=num_graphs)\n        attention_weights = exp_scores / (tf.gather(sum_scores, graph_idx) + 1e-10)\n        \n        weighted = node_features * attention_weights\n        return tf.math.unsorted_segment_sum(weighted, graph_idx, num_segments=num_graphs)\n\n# Build model\ndef build_simple_gnn(hidden_dim=128, n_layers=3, max_atoms=8):\n    nodes = keras.Input(shape=(NODE_FEATURE_DIM,))\n    edges = keras.Input(shape=(2,), dtype=tf.int32)\n    edge_vecs = keras.Input(shape=(3,))\n    edge_lens = keras.Input(shape=(1,))\n    graph_idx = keras.Input(shape=(), dtype=tf.int32)\n    n_atoms = keras.Input(shape=(), dtype=tf.int32)\n    batch_size_input = keras.Input(shape=(1,), dtype=tf.int32)\n    \n    x = keras.layers.Dense(hidden_dim, activation='silu')(nodes)\n    \n    for i in range(n_layers):\n        x = SimpleMessageLayer(hidden_dim)(x, edges, edge_lens)\n        x = keras.layers.Dropout(0.1)(x)\n    \n    ifc_head = SimpleIFCHead(hidden_dim, max_atoms=max_atoms)\n    \n    model = keras.Model(\n        inputs=[nodes, edges, edge_vecs, edge_lens, graph_idx, n_atoms, batch_size_input],\n        outputs={'node_embeddings': x, 'batch_size': batch_size_input[0]}\n    )\n    \n    model.ifc_head = ifc_head\n    return model\n\nmax_atoms = max(s['n_atoms'] for s in list(train_data) + list(val_data) + list(test_data))\nmodel = build_simple_gnn(hidden_dim=128, n_layers=3, max_atoms=max_atoms)\nprint(\"\\n✓ Model built!\")\n\n# Training\noptimizer = keras.optimizers.Adam(learning_rate=LR_INITIAL)\n\ndef compute_masked_mse(targets, preds, n_atoms_array):\n    batch_size = tf.shape(targets)[0]\n    max_atoms = tf.shape(targets)[1]\n    \n    atom_range = tf.expand_dims(tf.range(max_atoms), 0)\n    n_atoms_expanded = tf.expand_dims(n_atoms_array, 1)\n    \n    mask = tf.cast(atom_range < n_atoms_expanded, tf.float32)\n    mask_4d = tf.reshape(mask, [-1, max_atoms, 1, 1, 1]) * tf.reshape(mask, [-1, 1, max_atoms, 1, 1])\n    \n    diff = tf.square(targets - preds) * mask_4d\n    return tf.reduce_sum(diff) / (tf.reduce_sum(mask_4d) + 1e-10)\n\ndef train_step(inputs, targets):\n    nodes, edges, edge_vecs, edge_lens, graph_idx, n_atoms_array, batch_size_array = inputs\n    \n    with tf.GradientTape() as tape:\n        outputs = model([nodes, edges, edge_vecs, edge_lens, graph_idx, n_atoms_array, batch_size_array], \n                       training=True)\n        node_embeddings = outputs['node_embeddings']\n        batch_size = outputs['batch_size']\n        \n        ifc_preds = model.ifc_head(node_embeddings, graph_idx, batch_size)\n        loss = compute_masked_mse(targets, ifc_preds, n_atoms_array)\n    \n    grads = tape.gradient(loss, model.trainable_variables)\n    grads = [tf.clip_by_norm(g, 1.0) if g is not None else g for g in grads]\n    optimizer.apply_gradients(zip(grads, model.trainable_variables))\n    \n    return loss\n\n# Training loop\nprint(\"\\n\" + \"=\"*80)\nprint(\"Training Simple GNN...\")\nprint(\"=\"*80)\n\nhistory = {'train_loss': [], 'val_loss': []}\nbest_val_loss = np.inf\npatience_counter = 0\n\nstart_time = time.time()\n\nfor epoch in range(1, EPOCHS + 1):\n    train_losses = []\n    \n    np.random.shuffle(train_data)\n    for i in range(0, len(train_data), BATCH_SIZE):\n        batch = train_data[i:i+BATCH_SIZE]\n        inputs, targets = prepare_batch(batch)\n        loss = train_step(inputs, targets)\n        train_losses.append(float(loss))\n    \n    val_losses = []\n    for i in range(0, len(val_data), BATCH_SIZE):\n        batch = val_data[i:i+BATCH_SIZE]\n        inputs, targets = prepare_batch(batch)\n        \n        outputs = model(inputs, training=False)\n        ifc_preds = model.ifc_head(outputs['node_embeddings'], inputs[4], outputs['batch_size'])\n        val_loss = compute_masked_mse(targets, ifc_preds, inputs[5])\n        val_losses.append(float(val_loss))\n    \n    train_loss_avg = np.mean(train_losses)\n    val_loss_avg = np.mean(val_losses)\n    \n    history['train_loss'].append(train_loss_avg)\n    history['val_loss'].append(val_loss_avg)\n    \n    if epoch % 10 == 0 or epoch == 1:\n        print(f\"Epoch {epoch:03d} | Train: {train_loss_avg:.6f} | Val: {val_loss_avg:.6f}\")\n    \n    if val_loss_avg < best_val_loss:\n        best_val_loss = val_loss_avg\n        patience_counter = 0\n        model.save_weights(os.path.join(OUTPUT_DIR, \"best_simple_gnn.weights.h5\"))\n        if epoch % 20 == 0:\n            print(f\"  → Best!\")\n    else:\n        patience_counter += 1\n        if patience_counter >= PATIENCE:\n            print(f\"\\n[Early Stopping] at epoch {epoch}\")\n            break\n\ntraining_time = time.time() - start_time\nprint(f\"\\n✓ Training complete! Time: {training_time/60:.1f} min\")\nprint(f\"✓ Best val loss: {best_val_loss:.6f}\")\n\nnp.save(os.path.join(OUTPUT_DIR, \"simple_history.npy\"), history)\n\nprint(\"\\n\" + \"=\"*80)\nprint(\"✅ Simple model trained successfully!\")\nprint(\"=\"*80)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-11-13T07:51:40.456146Z","iopub.execute_input":"2025-11-13T07:51:40.456543Z","iopub.status.idle":"2025-11-13T09:11:17.026124Z","shell.execute_reply.started":"2025-11-13T07:51:40.456514Z","shell.execute_reply":"2025-11-13T09:11:17.025406Z"}},"outputs":[{"name":"stdout","text":"================================================================================\nSIMPLIFIED PHYSICS-INFORMED GNN\nFocus: Force Constants Prediction Only\n===========