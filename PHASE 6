update({'font.size': 12})\n\n# ---------- تنظیم مسیرها در صورت نیاز ----------\ndata_dir = \"/kaggle/input/dataset-features-gpt5\"  # تغییر بده اگر لازم است\nout_dir = \"feature_analysis_plots\"\nos.makedirs(out_dir, exist_ok=True)\n\n# ---------- بارگذاری X و y (اگر از npy استفاده می‌کنی) ----------\n# در صورتی که قبلاً X_train, y_train در حافظه‌ات باشند، این لود را حذف کن\nif os.path.exists(os.path.join(data_dir, \"train_x.npy\")):\n    X_train = np.load(os.path.join(data_dir, \"train_x.npy\"))\n    y_train = np.load(os.path.join(data_dir, \"train_y.npy\"))\nelse:\n    # در صورت استفاده از متغیرهای در حافظه، فرض می‌کنیم X_train, y_train موجودند\n    try:\n        X_train  # just to check existence\n        y_train\n    except NameError:\n        raise RuntimeError(\"X_train/y_train در دسترس نیستند. یا npy ها را در data_dir بگذار یا متغیرها را تعریف کن.\")\n\n# ---------- نام فیچرها (اگر فایل feature_cols.npy موجود باشد از آن استفاده کن) ----------\nfeature_names = None\nfeat_file = os.path.join(data_dir, \"feature_cols.npy\")\nif os.path.exists(feat_file):\n    try:\n        feature_names = list(np.load(feat_file, allow_pickle=True))\n        print(\"Loaded feature names from:\", feat_file)\n    except Exception:\n        feature_names = None\n\nif feature_names is None:\n    feature_names = [f\"feat_{i}\" for i in range(X_train.shape[1])]\nprint(\"Number of features:\", len(feature_names))\n\n# ---------- پردازش y (تشخیص خودکار ابعاد) ----------\n# حالت‌های ممکن:\n# (N, Q, bands)  -> ما از آن دو چیز استخراج می‌کنیم:\n#    y_mean_all: میانگین کامل برای هر نمونه (N,)\n#    y_band_mean: میانگین روی Q برای هر نمونه و هر band -> (N, bands)\n# (N, some_flat) -> fallback: y_mean_all = mean(axis=1), y_band_mean = try reshape if possible else None\n\nif isinstance(y_train, np.ndarray):\n    if y_train.ndim == 3:\n        # معمول‌ترین حالت: (N, Q, bands)\n        y_mean_all = np.mean(y_train, axis=(1,2))          # shape (N,)\n        y_band_mean = np.mean(y_train, axis=1)             # shape (N, bands)\n        n_bands = y_band_mean.shape[1]\n    elif y_train.ndim == 2:\n        # احتمالاً (N, Q*bands) یا (N, bands)\n        # اگر تعداد ستون‌ها با feature count تفاوت زیادی نداشته باشد فرض می‌کنیم (N, bands)\n        # بهترین کار: اگر قبلاً max_qpoints و max_bands رو ذخیره کردی ازش استفاده کن\n        # سعی می‌کنیم اگر امکان reshape به (N, Q, bands) باشه، انجام بدیم؛ در غیر اینصورت treat as (N, bands)\n        N, M = y_train.shape\n        # اگر فایل max_qpoints و max_bands موجود باشد از آن استفاده کن\n        mqf = os.path.join(data_dir, \"max_qpoints.npy\")\n        mbf = os.path.join(data_dir, \"per_atom_feature_len.npy\")  # not bands but try to be robust\n        if os.path.exists(os.path.join(data_dir, \"max_atoms.npy\")) and os.path.exists(os.path.join(data_dir, \"per_atom_feature_len.npy\")):\n            # کاربر قبلا اینها را ذخیره کرده است — اما احتمالاً bands ذخیره نشده؛ بهترین fallback:\n            y_mean_all = np.mean(y_train, axis=1)\n            y_band_mean = y_train  # treat each column as one \"band-like\" target\n            n_bands = y_band_mean.shape[1]\n        else:\n            # ساده ترین fallback\n            y_mean_all = np.mean(y_train, axis=1)\n            y_band_mean = y_train\n            n_bands = y_band_mean.shape[1]\n    else:\n        raise ValueError(\"y_train دارای ابعاد غیرمنتظره است (ndim != 2 or 3). شکل y_train: \" + str(y_train.shape))\nelse:\n    raise ValueError(\"y_train باید numpy array باشد.\")\n\nprint(\"y_mean_all shape:\", y_mean_all.shape)\nprint(\"y_band_mean shape:\", y_band_mean.shape)\n\n# ---------- ساخت DataFrame از X و ستون‌های باند (میانگین روی Q) ----------\n# فرض: feature_names طولش 11 باشه\nX_df = pd.DataFrame(X_train[:, :len(feature_names)], columns=feature_names)\n\n\n\n# اضافه کردن ستون‌های باند میانگین (هر باند یک ستون جدا)\nband_cols = [f\"band_mean_{i}\" for i in range(n_bands)]\nband_df = pd.DataFrame(y_band_mean, columns=band_cols)\ncorr_df = pd.concat([X_df, band_df], axis=1)\n\n# ---------- 1) ماتریس همبستگی کامل (Feature vs Feature + Bands) ----------\ncorr_full = corr_df.corr()\n\nplt.figure(figsize=(14, 12))\nsns.heatmap(corr_full, cmap=\"coolwarm\", center=0)\nplt.title(\"Correlation matrix (features + band means)\")\nplt.tight_layout()\nplt.savefig(os.path.join(out_dir, \"corr_full_heatmap.png\"), dpi=200)\nplt.show()\n\n# ---------- 2) ماتریس همبستگی مختص: features vs band means (ساده و خواناتر) ----------\ncorr_feat_band = corr_full.loc[feature_names, band_cols]  # shape (n_features, n_bands)\nplt.figure(figsize=(12, 8))\nsns.heatmap(corr_feat_band, cmap=\"RdBu_r\", center=0, annot=False)\nplt.title(\"Correlation (features) vs (band means)\")\nplt.xlabel(\"Bands (mean over Q)\")\nplt.ylabel(\"Features\")\nplt.tight_layout()\nplt.savefig(os.path.join(out_dir, \"corr_features_vs_bands.png\"), dpi=200)\nplt.show()\n\n# ---------- 3) Feature importance via RandomForest on aggregated target ----------\n# هدف агрегیت: y_mean_all (یک عدد برای هر نمونه)\nrf = RandomForestRegressor(n_estimators=200, random_state=42, n_jobs=-1)\nrf.fit(X_df, y_mean_all)\nimportances = rf.feature_importances_\nimp_df = pd.DataFrame({\"feature\": feature_names, \"importance\": importances})\nimp_df = imp_df.sort_values(\"importance\", ascending=False).reset_index(drop=True)\n\nplt.figure(figsize=(10, 6))\nsns.barplot(x=\"importance\", y=\"feature\", data=imp_df.head(30))\nplt.title(\"RandomForest feature importances (target = mean frequency per sample)\")\nplt.tight_layout()\nplt.savefig(os.path.join(out_dir, \"rf_feature_importances.png\"), dpi=200)\nplt.show()\n\nprint(\"Top features by RF importance:\")\nprint(imp_df.head(20))\n\n# ---------- 4) Per-band RandomForest importances (train a RF per band, average) ----------\nper_band_importances = []\nfor i, col in enumerate(band_cols):\n    print(f\"Training RF for {col} ...\")\n    rf_i = RandomForestRegressor(n_estimators=150, random_state=42, n_jobs=-1)\n    rf_i.fit(X_df, band_df[col])\n    per_band_importances.append(rf_i.feature_importances_)\n\nper_band_importances = np.array(per_band_importances)  # shape (n_bands, n_features)\nmean_importance_across_bands = per_band_importances.mean(axis=0)\nimp_band_df = pd.DataFrame({\"feature\": feature_names, \"mean_importance\": mean_importance_across_bands})\nimp_band_df = imp_band_df.sort_values(\"mean_importance\", ascending=False).reset_index(drop=True)\n\nplt.figure(figsize=(10, 6))\nsns.barplot(x=\"mean_importance\", y=\"feature\", data=imp_band_df.head(30))\nplt.title(\"Mean feature importances across bands (RandomForest per band)\")\nplt.tight_layout()\nplt.savefig(os.path.join(out_dir, \"rf_perband_mean_importances.png\"), dpi=200)\nplt.show()\n\nprint(\"Top features by mean per-band RF importance:\")\nprint(imp_band_df.head(20))\n\n# ---------- 5) Permutation importance (دقیق‌تر) روی y_mean_all ----------\nprint(\"Computing permutation importance (this may take some time)...\")\nperm = permutation_importance(rf, X_df, y_mean_all, n_repeats=10, random_state=42, n_jobs=-1)\nperm_imp_df = pd.DataFrame({\"feature\": feature_names, \"perm_importance_mean\": perm.importances_mean})\nperm_imp_df = perm_imp_df.sort_values(\"perm_importance_mean\", ascending=False).reset_index(drop=True)\n\nplt.figure(figsize=(10, 6))\nsns.barplot(x=\"perm_importance_mean\", y=\"feature\", data=perm_imp_df.head(30))\nplt.title(\"Permutation importances (target = mean frequency per sample)\")\nplt.tight_layout()\nplt.savefig(os.path.join(out_dir, \"perm_importances.png\"), dpi=200)\nplt.show()\n\nprint(\"Top features by permutation importance:\")\nprint(perm_imp_df.head(20))\n\n# ---------- 6) پیشنهاد حذف: بر اساس میانگین اهمیت (RF per-band mean و perm) ----------\n# Threshold را تنظیم کن (مثلاً حذف هر فیچری که mean_importance < 0.005)\nthreshold = 0.005\nlow_feats_rf_mean = imp_band_df[imp_band_df['mean_importance'] < threshold]['feature'].tolist()\nlow_feats_perm = perm_imp_df[perm_imp_df['perm_importance_mean'] < threshold]['feature'].tolist()\n\nprint(f\"Features with mean per-band RF importance < {threshold}: {low_feats_rf_mean}\")\nprint(f\"Features with permutation importance mean < {threshold}: {low_feats_perm}\")\n\n# پیشنهادی: intersection آن‌ها را به عنوان نامزد حذف در نظر بگیر\ncandidates_to_drop = sorted(set(low_feats_rf_mean).intersection(set(low_feats_perm)))\nprint(\"Candidate features to DROP (intersection):\", candidates_to_drop)\n\n# ذخیره نتایج متا\nimp_df.to_csv(os.path.join(out_dir, \"rf_importances_mean_target.csv\"), index=False)\nimp_band_df.to_csv(os.path.join(out_dir, \"rf_perband_mean_importances.csv\"), index=False)\nperm_imp_df.to_csv(os.path.join(out_dir, \"perm_importances.csv\"), index=False)\n\nprint(\"Saved plots and CSVs into\", out_dir)\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-08-12T07:27:21.341126Z","iopub.execute_input":"2025-08-12T07:27:21.341432Z","iopub.status.idle":"2025-08-12T07:27:37.340783Z","shell.execute_reply.started":"2025-08-12T07:27:21.341407Z","shell.execute_reply":"2025-08-12T07:27:37.340092Z"}},"outputs":[{"name":"stdout","text":"Loaded feature names from: /kaggle/input/dataset-features-gpt5/feature_cols.npy\nNumber of features: 11\ny_mean_all shape: (228,)\ny_band_mean shape: (228, 24)\n","output_type":"stream"},{"name":"stderr","text":"/usr/local/lib/python3.11/dist-packages/matplotlib/colors.py:721: RuntimeWarning: invalid value encountered in less\n  xa[xa < 0] = -1\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 1400x1200 with 2 Axes>","image/png":"\n"},"metadata":{}},{"name":"stderr","text":"/usr/local/lib/python3.11/dist-packages/matplotlib/colors.py:721: RuntimeWarning: invalid value encountered in less\n  xa[xa < 0] = -1\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 1200x800 with 2 Axes>","image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"<Figure size 1000x600 with 1 Axes>","