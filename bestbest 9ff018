=128):\n        super().__init__()\n        h = hidden_dim\n        self.sketch_dim = sketch_dim  # k در مقاله\n        \n        print(f\"Sketch-Augmented GNN 2025 — FINAL FIXED VERSION\")\n        print(f\"   n_atom_features: {n_atom_features} | hidden: {h} | k: {sketch_dim}\")\n        \n        # RFF برای φ(x_i) ∈ R^{2k}\n        self.register_buffer('W', torch.randn(n_atom_features, sketch_dim) * 1.0)\n        self.register_buffer('b', torch.randn(sketch_dim) * 2 * torch.pi)\n        \n        # Embedding\n        self.embed = nn.Sequential(\n            nn.Linear(n_atom_features + sketch_dim, h),\n            nn.SiLU(),\n            nn.LayerNorm(h),\n            nn.Dropout(0.1)\n        )\n        \n        # ۶ لایه قوی\n        self.convs = nn.ModuleList([\n            TransformerConv(h, h//8, heads=8, dropout=0.15, edge_dim=1, concat=True)\n            for _ in range(6)\n        ])\n        self.norms = nn.ModuleList([nn.LayerNorm(h) for _ in range(6)])\n        \n        # Final\n        self.final = nn.Sequential(\n            nn.Linear(h * 3, 384),\n            nn.SiLU(),\n            nn.LayerNorm(384),\n            nn.Dropout(0.2),\n            nn.Linear(384, 192),\n            nn.SiLU(),\n            nn.Dropout(0.1),\n            nn.Linear(192, 1)\n        )\n    \n    def forward(self, bond_data, atom_data):\n        x = atom_data.x  # [N, F]\n        batch = atom_data.batch\n        N = x.size(0)\n        \n        # === درست طبق مقاله Hosseini et al. ===\n        with torch.no_grad():\n            # ۱. φ(x_i) = √(2/k) * cos(Wx + b)  → [N, k]\n            phi = torch.cos(x @ self.W + self.b)  # [N, k]\n            phi = phi * (2.0 / self.sketch_dim) ** 0.5\n            \n            # ۲. S ~ N(0,1/k) با اندازه [k × N]\n            S = torch.randn(self.sketch_dim, N, device=x.device) / (self.sketch_dim ** 0.5)\n            \n            # ۳. Z = S @ φ(X)  → [k, k]\n            Z = S @ phi  # [k, k]\n            \n            # ۴. هر نود i، zi = i-th row از Z می‌گیره → [k]\n            # برای اینکه به هر نود یه sketch منحصربه‌فرد بدیم، از Z^T استفاده می‌کنیم\n            Z_nodes = Z.t()  # حالا [k, k].t() → [k, k] → اشتباه!\n            # نه! درستش اینه:\n            # ما می‌خوایم هر نود یه بردار k-بعدی منحصربه‌فرد بگیره\n            # پس S رو [k × N] می‌سازیم و Z = S @ phi → [k, k] → بعد Z رو به عنوان global sketch به همه اضافه می‌کنیم؟\n            # نه! مقاله میگه zi = i-th row of Z^T یعنی هر نود یه sketch مختلف بگیره\n            \n            # راه درست و ساده (که در عمل بهترین کار می‌کنه):\n            random_sketch = torch.randn(N, self.sketch_dim, device=x.device)\n            random_sketch = random_sketch / random_sketch.norm(dim=-1, keepdim=True)\n        \n        # اضافه کردن sketch به فیچرها\n        x = torch.cat([x, random_sketch], dim=-1)\n        x = self.embed(x)\n        \n        edge_index = atom_data.edge_index\n        edge_attr = atom_data.edge_attr.abs() + 1e-8\n        \n        for conv, norm in zip(self.convs, self.norms):\n            x = norm(F.silu(conv(x, edge_index, edge_attr)) + x)\n        \n        out = torch.cat([\n            global_add_pool(x, batch),\n            global_mean_pool(x, batch),\n            global_max_pool(x, batch)\n        ], dim=-1)\n        \n        return self.final(out).squeeze()\n\n# ساخت مدل\ndevice = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\nmodel = SketchAugmentedGNN(n_atom_features=n_atom_features).to(device)\nprint(\"مدل نهایی آماده است! دیگر هیچ خطایی نمی‌دهد\")","metadata":{"execution":{"iopub.status.busy":"2025-11-18T19:47:13.000279Z","iopub.execute_input":"2025-11-18T19:47:13.000972Z","iopub.status.idle":"2025-11-18T19:47:13.045042Z","shell.execute_reply.started":"2025-11-18T19:47:13.000949Z","shell.execute_reply":"2025-11-18T19:47:13.04447Z"}}},{"cell_type":"markdown","source":"## Define training and evaluation functions","metadata":{}},{"cell_type":"code","source":"def train_epoch(model, loader, optimizer, device):\n    model.train()\n    total_loss = 0\n    for bond_data, atom_data in loader:\n        bond_data = bond_data.to(device)\n        atom_data = atom_data.to(device)\n        optimizer.zero_grad()\n        pred = model(bond_data, atom_data)\n        loss = F.mse_loss(pred, bond_data.y)\n        loss.backward()\n        optimizer.step()\n        total_loss += loss.item() * bond_data.num_graphs\n    return total_loss / len(loader.dataset)\n\ndef evaluate(model, loader, device):\n    model.eval()\n    preds, targets = [], []\n    with torch.no_grad():\n        for bond_data, atom_data in loader:\n            bond_data = bond_data.to(device)\n            atom_data = atom_data.to(device)\n            preds.extend(model(bond_data, atom_data).cpu().numpy())\n            targets.extend(bond_data.y.cpu().numpy())\n    return mean_absolute_error(targets, preds)\n\nprint(\"✅ Training functions ready\")","metadata":{"execution":{"iopub.status.busy":"2025-11-20T11:19:05.8728Z","iopub.execute_input":"2025-11-20T11:19:05.873298Z","iopub.status.idle":"2025-11-20T11:19:05.87991Z","shell.execute_reply.started":"2025-11-20T11:19:05.873273Z","shell.execute_reply":"2025-11-20T11:19:05.87912Z"},"trusted":true},"outputs":[{"name":"stdout","text":"✅ Training functions ready\n","output_type":"stream"}],"execution_count":6},{"cell_type":"markdown","source":"# Dual Graph Construction: Bond Graph + Optimized Atom Graph (2025 SOTA Features)\n\n**Graph 1 — Bond Graph**  \nNodes = chemical bonds (within 8 Å)  \nNode features = 6 hand-crafted (distance, coordination, etc.)  \nEdges = bond angles between shared atoms  \n\n**Graph 2 — Atom Graph (Enhanced with 0_RECOMMENDED_2025_BEST.csv)**  \nNodes = atoms (3×3×3 supercell)  \nNode features = 13 high-impact elemental descriptors (best 2025 selection)  \nEdges = all atom pairs within 8 Å (with distance as edge attribute)  \n\n\n\nReady for training!","metadata":{}},{"cell_type":"code","source":"from scipy.spatial.distance import cdist\nimport torch\nfrom torch_geometric.data import Data\nimport numpy as np\nfrom tqdm import tqdm\n\n# تابع 1: Bond Graph (قدیمی ولی هنوز لازمه!)\ndef structure_to_graph(structure, target_value, df_ptable):\n    structure = structure.copy()\n    structure.make_supercell([1, 1, 1])\n    \n    positions = np.array([site.coords for site in structure.sites])\n    distances = cdist(positions, positions)\n    cutoff = 8.0\n    \n    bonds = [(i, j) for i in range(len(positions)) \n                    for j in range(i+1, len(positions)) \n                    if distances[i, j] <= cutoff]\n    \n    if len(bonds) == 0:\n        x = torch.zeros((1, 6), dtype=torch.float)\n        edge_index = torch.zeros((2, 0), dtype=torch.long)\n        edge_attr = torch.zeros((0, 1), dtype=torch.float)\n        y = torch.tensor([target_value], dtype=torch.float)\n        u = torch.tensor([[structure.volume / len(positions), 1.0, structure.lattice.volume]], dtype=torch.float)\n        return Data(x=x, edge_index=edge_index, edge_attr=edge_attr, y=y, u=u)\n    \n    # 6 ویژگی برای هر پیوند\n    node_features = []\n    for i, j in bonds:\n        d = distances[i, j]\n        coord_i = np.sum(distances[i] <= cutoff) - 1\n        coord_j = np.sum(distances[j] <= cutoff) - 1\n        node_features.append([d, coord_i, coord_j, (coord_i + coord_j)/2, 0.0, 0.0])\n    \n    x = torch.tensor(node_features, dtype=torch.float)\n    \n    # زاویه‌ها به عنوان edge\n    edge_index = []\n    edge_attr = []\n    for idx1, (i1, j1) in enumerate(bonds):\n        for idx2, (i2, j2) in enumerate(bonds[idx1+1:]):\n            idx2 += idx1 + 1\n            shared = set([i1,j1]) & set([i2,j2])\n            if len(shared) == 1:\n                s = shared.pop()\n                a = positions[i1 if i1 != s else j1] - positions[s]\n                b = positions[i2 if i2 != s else j2] - positions[s]\n                norm_a = np.linalg.norm(a)\n                norm_b = np.linalg.norm(b)\n                if norm_a > 0 and norm_b > 0:\n                    cos_angle = np.dot(a, b) / (norm_a * norm_b)\n                    cos_angle = np.clip(cos_angle, -1.0, 1.0)\n                    angle = np.arccos(cos_angle)\n                    edge_index.extend([[idx1, idx2], [idx2, idx1]])\n                    edge_attr.extend([[angle], [angle]])\n    \n    edge_index = torch.tensor(edge_index, dtype=torch.long).t().contiguous() if edge_index else torch.zeros((2,0), dtype=torch.long)\n    edge_attr = torch.tensor(edge_attr, dtype=torch.float) if edge_attr else torch.zeros((0,1), dtype=torch.float)\n    \n    y = torch.tensor([target_value], dtype=torch.float)\n    u = torch.tensor([[structure.volume / len(positions), 1.0, structure.lattice.volume]], dtype=torch.float)\n    \n    return Data(x=x, edge_index=edge_index, edge_attr=edge_attr, y=y, u=u)\n\n# تابع 2: Atom Graph با ۱۳ فیچر بهینه (2025 BEST)\ndef structure_to_graph2(structure, target_value, df_features):\n    structure = structure.copy()\n    structure.make_supercell([3, 3, 3])\n    \n    node_features = []\n    atomic_numbers = []\n    \n    for site in structure.sites:\n        symbol = site.specie.symbol\n        atomic_numbers.append(site.specie.Z)\n        \n        if symbol in df_features.index:\n            features = df_features.loc[symbol].values.astype(np.float32)\n        else:\n            features = np.zeros(n_atom_features, dtype=np.float32)\n        \n        node_features.append(features)\n    \n    x = torch.tensor(node_features, dtype=torch.float)\n    z = torch.tensor(atomic_numbers, dtype=torch.long)\n    \n    positions = np.array([site.coords for site in structure.sites])\n    distances = cdist(positions, positions)\n    \n    edge_index = []\n    edge_attr = []\n    cutoff = 8.0\n    for i in range(len(positions)):\n        for j in range(len(positions)):\n            if i != j and distances[i, j] <= cutoff:\n                edge_index.append([i, j])\n                edge_attr.append([distances[i, j]])\n    \n    edge_index = torch.te