caler_y.fit_transform(y_flat).reshape(num_samples, num_qpoints, num_bands)\n\n# تقسیم سه‌تایی داده‌ها\nX_temp, X_test, y_temp, y_test = train_test_split(X_normalized, y_normalized, test_size=0.2, random_state=42)\nX_train, X_val, y_train, y_val = train_test_split(X_temp, y_temp, test_size=0.2, random_state=42)\n\n# ذخیره داده‌ها\nnp.save(\"train_x.npy\", X_train)\nnp.save(\"val_x.npy\", X_val)\nnp.save(\"test_x.npy\", X_test)\nnp.save(\"train_y.npy\", y_train)\nnp.save(\"val_y.npy\", y_val)\nnp.save(\"test_y.npy\", y_test)\nnp.save(\"scaler_X.npy\", scaler_X.mean_)\nnp.save(\"scaler_X_std.npy\", scaler_X.scale_)\nnp.save(\"scaler_y_mean.npy\", scaler_y.mean_)\nnp.save(\"scaler_y_std.npy\", scaler_y.scale_)\nnp.save(\"max_atoms.npy\", np.array([max_atoms]))\n","metadata":{"_uuid":"8f2839f25d086af736a60e9eeb907d3b93b6e0e5","_cell_guid":"b1076dfc-b9ad-4769-8c92-a6c4dae69d19","trusted":true,"execution":{"iopub.status.busy":"2025-08-02T06:13:36.484529Z","iopub.execute_input":"2025-08-02T06:13:36.484814Z","iopub.status.idle":"2025-08-02T06:36:04.610605Z","shell.execute_reply.started":"2025-08-02T06:13:36.484786Z","shell.execute_reply":"2025-08-02T06:36:04.609845Z"}},"outputs":[{"name":"stdout","text":"حداکثر اتم‌ها: 8, باند: 24, نقاط q: 357\n","output_type":"stream"}],"execution_count":1},{"cell_type":"code","source":"# train_model.py\nimport numpy as np\nimport tensorflow as tf\nfrom sklearn.metrics import r2_score\nimport matplotlib.pyplot as plt\n\n# بارگذاری داده‌ها\nX_train = np.load(\"/kaggle/input/npy-phonon/train_x.npy\")\nX_val = np.load(\"/kaggle/input/npy-phonon/val_x.npy\")\nX_test = np.load(\"/kaggle/input/npy-phonon/test_x.npy\")\ny_train = np.load(\"/kaggle/input/npy-phonon/train_y.npy\")\ny_val = np.load(\"/kaggle/input/npy-phonon/val_y.npy\")\ny_test = np.load(\"/kaggle/input/npy-phonon/test_y.npy\")\nscaler_y_mean = np.load(\"/kaggle/input/npy-phonon/scaler_y_mean.npy\")\nscaler_y_std = np.load(\"/kaggle/input/npy-phonon/scaler_y_std.npy\")\n\ndef inverse_transform_y(y_norm):\n    y_flat = y_norm.reshape(y_norm.shape[0], -1)\n    return (y_flat * scaler_y_std + scaler_y_mean).reshape(y_norm.shape)\n\n# ساخت مدل\ndef build_model(input_shape, output_shape):\n    model = tf.keras.Sequential([\n        tf.keras.layers.Input(shape=input_shape),\n        tf.keras.layers.Reshape((input_shape[0], 1)),\n        tf.keras.layers.Conv1D(16, 3, activation='relu', padding='same'),\n        tf.keras.layers.MaxPooling1D(2),\n        tf.keras.layers.Conv1D(32, 3, activation='relu', padding='same'),\n        tf.keras.layers.MaxPooling1D(2),\n        tf.keras.layers.Conv1D(64, 3, activation='relu', padding='same'),\n        tf.keras.layers.MaxPooling1D(2),\n        tf.keras.layers.Flatten(),\n        tf.keras.layers.Dense(512, activation='relu', kernel_regularizer=tf.keras.regularizers.l2(0.005)),\n        tf.keras.layers.Dense(np.prod(output_shape), activation='linear')\n    ])\n    return model\n\n# ساخت مدل\nmodel = build_model((X_train.shape[1],), y_train.shape[1:])\nmodel.compile(optimizer=tf.keras.optimizers.Adam(1e-4), loss='mse', metrics=['mae'])\n\n# آموزش\nearly_stopping = tf.keras.callbacks.EarlyStopping(monitor='val_loss', patience=50, restore_best_weights=True)\nreduce_lr = tf.keras.callbacks.ReduceLROnPlateau(monitor='val_loss', factor=0.5, patience=5, min_lr=1e-6)\n\nhistory = model.fit(X_train, y_train.reshape(len(y_train), -1),\n                    validation_data=(X_val, y_val.reshape(len(y_val), -1)),\n                    epochs=300, batch_size=16, callbacks=[early_stopping, reduce_lr], verbose=1)\n\n# ارزیابی روی تست\ny_pred_norm = model.predict(X_test).reshape(y_test.shape)\ny_pred = inverse_transform_y(y_pred_norm)\ny_test_true = inverse_transform_y(y_test)\n\nr2_scores = [r2_score(y_test_true[i].flatten(), y_pred[i].flatten()) for i in range(len(y_test))]\nprint(f\"میانگین R² روی تست: {np.mean(r2_scores):.4f}\")\n\n# رسم یکی از نمونه‌ها\nplt.figure(figsize=(10, 6))\nplt.title(\"نمونه ساختار باند پیش‌بینی‌شده\")