{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.11.13","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"nvidiaTeslaT4","dataSources":[{"sourceType":"datasetVersion","sourceId":12765449},{"sourceType":"datasetVersion","sourceId":13020560},{"sourceType":"datasetVersion","sourceId":12764155},{"sourceType":"datasetVersion","sourceId":13050817},{"sourceType":"datasetVersion","sourceId":12081217},{"sourceType":"datasetVersion","sourceId":11821046}],"dockerImageVersionId":31089,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":true}},"nbformat_minor":4,"nbformat":4,"cells":[{"source":"<a href=\"https://www.kaggle.com/code/metisa81/phase-7?scriptVersionId=262377856\" target=\"_blank\"><img align=\"left\" alt=\"Kaggle\" title=\"Open in Kaggle\" src=\"https://kaggle.com/static/images/open-in-kaggle.svg\"></a>","metadata":{},"cell_type":"markdown"},{"cell_type":"markdown","source":"# prepare_data","metadata":{}},{"cell_type":"code","source":"\nimport os\nimport yaml\nimport numpy as np\nimport pandas as pd\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.preprocessing import StandardScaler\nfrom scipy.ndimage import gaussian_filter1d\n\n# مسیرها — تغییر بده اگر لازم است\nfolder = \"/kaggle/input/yaml-data/extracted_bands_C\"\nexcel_path = \"/kaggle/input/npy-phonon-phase7/feature_data_edited.xlsx\"  # فایل اکسل که آپلود کردی\n\n# بارگذاری دیتای عناصر از اکسل\ndf_elem = pd.read_excel(excel_path)\n# استاندارد: ستونی به نام 'symbol' و 'atomic_weight' انتظار می‌رود\nif 'symbol' not in df_elem.columns or 'atomic_weight' not in df_elem.columns:\n    raise ValueError(\"فایل اکسل باید ستون‌های 'symbol' و 'atomic_weight' را داشته باشد.\")\n\n# نرمال‌سازی نام ستون‌ها (trim)\ndf_elem.columns = [c.strip() for c in df_elem.columns]\n\n# ساخت دیکشنری برای نگاشت symbol -> ویژگی‌ها (شامل atomic_weight)\nelem_features = {}\nfeature_cols = [c for c in df_elem.columns if c not in ['symbol']]  # همه ستون‌ها به جز symbol\nfor _, r in df_elem.iterrows():\n    sym = str(r['symbol']).strip()\n    vals = r[feature_cols].fillna(0).values.astype(float)\n    elem_features[sym] = {\n        'features': vals,\n        'atomic_weight': float(r['atomic_weight'])\n    }\n\n# برای جستجوی بر اساس جرم: لیستی از (atomic_weight, symbol)\natomic_weight_list = [(v['atomic_weight'], k) for k, v in elem_features.items()]\natomic_weight_array = np.array([w for w, s in atomic_weight_list])\n\ndef find_symbol_by_mass(mass, tol=0.5):\n    \"\"\"\n    اگر symbol در YAML وجود نداشته باشد:\n    با نزدیک‌ترین atomic_weight در اکسل نگاشت می‌کنیم.\n    tol: اختلاف مجاز (THz یا واحد جرم) — اگر اختلاف بیشتر باشد هشداری چاپ می‌شود.\n    \"\"\"\n    # mass و atomic_weight ها عموماً در واحد amu — فرض می‌کنیم واحد برابر است\n    diffs = np.abs(atomic_weight_array - mass)\n    idx = np.argmin(diffs)\n    best_mass = atomic_weight_array[idx]\n    best_sym = atomic_weight_list[idx][1]\n    if diffs[idx] > tol:\n        print(f\"هشدار: تطبیق جرم {mass} با عنصر {best_sym} اختلاف {diffs[idx]:.3f} دارد.\")\n    return best_sym\n\ndef parse_yaml_files(folder_path):\n    X, y = [], []\n    skipped = 0\n    max_atoms = 0\n    max_bands = 0\n    max_qpoints = 0\n    # یکبار پیمایش برای یافتن ماکزیمم‌ها\n    for file in os.listdir(folder_path):\n        if file.endswith(\".yaml\"):\n            try:\n                with open(os.path.join(folder_path, file), 'r') as f:\n                    data = yaml.safe_load(f)\n                if not data:\n                    continue\n                if 'points' not in data or 'phonon' not in data:\n                    continue\n                n_atoms = len(data['points'])\n                n_qpoints = len(data['phonon'])\n                n_bands = len(data['phonon'][0].get('band', []))\n                max_atoms = max(max_atoms, n_atoms)\n                max_bands = max(max_bands, n_bands)\n                max_qpoints = max(max_qpoints, n_qpoints)\n            except Exception as e:\n                print(f\"skip (counting) {file}: {e}\")\n                continue\n\n    print(f\"حداکثر اتم‌ها: {max_atoms}, باند: {max_bands}, نقاط q: {max_qpoints}\")\n\n    # ساخت اسم فیچرهای اتمی تا ذخیره شود\n    per_atom_feature_len = 3 + 1 + len(feature_cols)  \n    # توضیح: 3 مختصات + 1 جرم + len(feature_cols) ویژگی‌های اکسل برای هر اتم\n\n    for file in os.listdir(folder_path):\n        if file.endswith(\".yaml\"):\n            try:\n                with open(os.path.join(folder_path, file), 'r') as f:\n                    data = yaml.safe_load(f)\n                if not data or 'points' not in data or 'lattice' not in data or 'reciprocal_lattice' not in data or 'phonon' not in data:\n                    skipped += 1\n                    continue\n\n                atom_features_list = []\n                for pt in data['points']:\n                    # تلاش برای پیدا کردن نماد عنصر در YAML\n                    sym = None\n                    for key in ['symbol', 'label', 'element', 'species', 'name']:\n                        if key in pt:\n                            sym = str(pt[key]).strip()\n                            break\n                    mass = float(pt.get('mass', 0.0))\n                    coords = pt.get('coordinates', [0.0, 0.0, 0.0])\n                    # اگر سمبل موجود بود از دیکشنری استفاده کن، در غیر این صورت بر اساس جرم جستجو کن\n                    if sym and sym in elem_features:\n                        elem_feat = elem_features[sym]['features']\n                    else:\n                        # fallback: match by mass\n                        sym_guess = find_symbol_by_mass(mass)\n                        elem_feat = elem_features[sym_guess]['features']\n                    # concat: coords (3) + mass (1) + elem_feat (N)\n                    vec = list(coords) + [mass] + list(elem_feat)\n                    atom_features_list.append(vec)\n\n                atom_features = np.array(atom_features_list, dtype=float)\n                # padding برای تعداد اتم تا max_atoms\n                atom_features = np.pad(atom_features, ((0, max_atoms - atom_features.shape[0]), (0, 0)), 'constant')\n\n                lattice = np.array(data['lattice']).flatten()\n                reciprocal = np.array(data['reciprocal_lattice']).flatten()\n\n                feature_tensor = np.concatenate([\n                    atom_features.flatten(),\n                    lattice,\n                    reciprocal\n                ]).astype(float)\n\n                # خواندن فرکانس‌ها\n                frequencies = []\n                for qpoint in data['phonon']:\n                    bands = [b.get('frequency', 0.0) for b in qpoint.get('band', [])]\n                    frequencies.append(bands)\n                frequencies = np.array(frequencies, dtype=float)\n                frequencies = np.pad(frequencies, ((0, max_qpoints - frequencies.shape[0]), (0, max_bands - frequencies.shape[1])), 'constant')\n\n                X.append(feature_tensor)\n                y.append(frequencies)\n\n            except Exception as e:\n                print(f\"خطا در فایل {file}: {e}\")\n                skipped += 1\n\n    X = np.array(X)\n    y = np.array(y)\n    print(f\"خوانده شد: samples={len(X)}, skipped={skipped}\")\n    return X, y, max_atoms, per_atom_feature_len\n\nif __name__ == \"__main__\":\n    X, y, max_atoms, per_atom_feature_len = parse_yaml_files(folder)\n\n    # صاف کردن فرکانس‌ها در امتداد q-point ها (axis=1 مشابه قبلی)\n    y_smoothed = gaussian_filter1d(y, sigma=0.6, axis=1)\n\n    # نرمال‌سازی ورودی‌ها\n    scaler_X = StandardScaler()\n    X_normalized = scaler_X.fit_transform(X)\n\n    # نرمال‌سازی خروجی‌ها\n    num_samples, num_qpoints, num_bands = y_smoothed.shape\n    y_flat = y_smoothed.reshape(num_samples, -1)\n    scaler_y = StandardScaler()\n    y_normalized = scaler_y.fit_transform(y_flat).reshape(num_samples, num_qpoints, num_bands)\n\n    # تقسیم سه‌تایی داده‌ها\n    X_temp, X_test, y_temp, y_test = train_test_split(X_normalized, y_normalized, test_size=0.2, random_state=42)\n    X_train, X_val, y_train, y_val = train_test_split(X_temp, y_temp, test_size=0.2, random_state=42)\n\n    # ذخیره داده‌ها و پارامترهای scaler\n    np.save(\"train_x_editedfeature.npy\", X_train)\n    np.save(\"val_x_editedfeature.npy\", X_val)\n    np.save(\"test_x_editedfeature.npy\", X_test)\n    np.save(\"train_y_editedfeature.npy\", y_train)\n    np.save(\"val_y_editedfeature.npy\", y_val)\n    np.save(\"test_y_editedfeature.npy\", y_test)\n\n    np.save(\"scaler_X_mean_editedfeature.npy\", scaler_X.mean_)\n    np.save(\"scaler_X_std_editedfeature.npy\", scaler_X.scale_)\n    np.save(\"scaler_y_mean_editedfeature.npy\", scaler_y.mean_)\n    np.save(\"scaler_y_std_editedfeature.npy\", scaler_y.scale_)\n\n    # ذخیره متا دیتا: تعداد اتم‌ها و طول فیچر هر اتم و نام ستون‌های اکسل استفاده‌شده\n    np.save(\"max_atoms_editedfeature.npy\", np.array([max_atoms]))\n    np.save(\"per_atom_feature_len_editedfeature.npy\", np.array([per_atom_feature_len]))\n    np.save(\"feature_cols_editedfeature.npy\", np.array(feature_cols, dtype=object))\n\n    print(\"ذخیره انجام شد.\")\n","metadata":{"_uuid":"8f2839f25d086af736a60e9eeb907d3b93b6e0e5","_cell_guid":"b1076dfc-b9ad-4769-8c92-a6c4dae69d19","trusted":true,"execution":{"iopub.status.busy":"2025-08-14T12:02:50.015376Z","iopub.execute_input":"2025-08-14T12:02:50.015602Z","iopub.status.idle":"2025-08-14T12:29:22.001647Z","shell.execute_reply.started":"2025-08-14T12:02:50.015582Z","shell.execute_reply":"2025-08-14T12:29:22.000753Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# train_model_smooth_light","metadata":{}},{"cell_type":"code","source":"\n\"\"\"\nنسخه سبک‌شده برای جلوگیری از OOM و کاهش زمان هر epoch:\n- مدل کوچکتر (کمتر پارامتر)\n- mixed precision (در صورت داشتن GPU)\n- استفاده از tf.data pipeline (batch + prefetch)\n- loss ترکیبی (MSE + smoothness) حفظ شده\n- پارامترهای پیش‌فرض محافظه‌کار برای batch/epochs\n\"\"\"\n\nimport os\nimport numpy as np\nimport tensorflow as tf\nfrom sklearn.metrics import r2_score\nimport matplotlib.pyplot as plt\nfrom scipy.signal import savgol_filter\n\n# ---------- تنظیم مسیرها ----------\ndata_dir = \"/kaggle/input/npy-phonon-phase7\"  # تغییر بده در صورت نیاز\nout_dir = \"/kaggle/working\"\nos.makedirs(out_dir, exist_ok=True)\n\n# ---------- فعال‌سازی mixed precision (اگر GPU موجود است) ----------\nfrom tensorflow.keras import mixed_precision\ntry:\n    mixed_precision.set_global_policy('mixed_float16')\n    print(\"Mixed precision policy set to:\", mixed_precision.global_policy())\nexcept Exception as e:\n    print(\"Mixed precision unavailable:\", e)\n\n# ---------- بارگذاری ارایه‌ها (اما بدون نگه داشتن همه در حافظه به صورت سنگین) ----------\nX_train = np.load(os.path.join(data_dir, \"train_x_editedfeature.npy\"))\nX_val   = np.load(os.path.join(data_dir, \"val_x_editedfeature.npy\"))\nX_test  = np.load(os.path.join(data_dir, \"test_x_editedfeature.npy\"))\ny_train = np.load(os.path.join(data_dir, \"train_y_editedfeature.npy\"))\ny_val   = np.load(os.path.join(data_dir, \"val_y_editedfeature.npy\"))\ny_test  = np.load(os.path.join(data_dir, \"test_y_editedfeature.npy\"))\n\nscaler_y_mean = np.load(os.path.join(data_dir, \"scaler_y_mean_editedfeature.npy\"))\nscaler_y_std  = np.load(os.path.join(data_dir, \"scaler_y_std_editedfeature.npy\"))\nscaler_X_mean = np.load(os.path.join(data_dir, \"scaler_X_mean_editedfeature.npy\"))\nscaler_X_std  = np.load(os.path.join(data_dir, \"scaler_X_std_editedfeature.npy\"))\n\n# اگر آرایه‌ها خیلی بزرگند و حافظه محدود است، می‌توانیم از mmap لود کنیم:\n# X_train = np.load(..., mmap_mode='r')  # در صورت نیاز فعال کن\n\n# ---------- ابعاد خروجی ----------\nnum_samples, max_qpoints, max_bands = y_train.shape\noutput_flat_dim = int(max_qpoints * max_bands)\n\ndef inverse_transform_y_flat(y_norm_flat):\n    return (y_norm_flat * scaler_y_std + scaler_y_mean).reshape(-1, max_qpoints, max_bands)\n\n# ---------- smoothness loss ----------\ndef smoothness_loss_from_reshaped(y_pred_reshaped):\n    # y_pred_reshaped: (batch, Q, bands)\n    d2 = y_pred_reshaped[:, 2:, :] - 2.0 * y_pred_reshaped[:, 1:-1, :] + y_pred_reshaped[:, :-2, :]\n    return tf.reduce_mean(tf.square(d2))\n\n# ---------- مدل سبک‌تر و امن ----------\ndef swish(x):\n    return tf.nn.swish(x)\n\ndef residual_dense_block(x, units, dropout_rate=0.03, use_bn=False):\n    shortcut = x\n    # projection for dimension match\n    if int(shortcut.shape[-1]) != units:\n        shortcut = tf.keras.layers.Dense(units, activation=None, dtype='float32')(shortcut)\n    x = tf.keras.layers.Dense(units, activation=swish, dtype='float32')(x)\n    if use_bn:\n        x = tf.keras.layers.BatchNormalization()(x)\n    x = tf.keras.layers.Dropout(dropout_rate)(x)\n    x = tf.keras.layers.Add()([shortcut, x])\n    x = tf.keras.layers.Activation(swish)(x)\n    return x\n\ndef build_model_light(input_dim, output_dim):\n    inp = tf.keras.layers.Input(shape=(input_dim,), name=\"input\")\n    x = tf.keras.layers.Dense(256, activation=swish, dtype='float32')(inp)\n    x = residual_dense_block(x, 256, dropout_rate=0.03, use_bn=False)\n    x = residual_dense_block(x, 128, dropout_rate=0.02, use_bn=False)\n    x = tf.keras.layers.Dense(256, activation=swish, dtype='float32')(x)\n    x = tf.keras.layers.Dropout(0.15)(x)\n    out = tf.keras.layers.Dense(output_dim, activation='linear', dtype='float32', name=\"out\")(x)\n    model = tf.keras.Model(inputs=inp, outputs=out)\n    return model\n\n# ---------- hyperparams (قابل تنظیم) ----------\nBATCH_SIZE = 64            # کمتر برای کاهش حافظه؛ در صورتی که GPU بزرگ داری می‌توانی افزایش دهی\nEPOCHS = 300\nLR = 3e-4\nLAMBDA_SMOOTH = 10e-2      # کمتر از نسخهٔ سنگین؛ می‌توانی تنظیم کنی\nPATIENCE = 30\n\n# ---------- tf.data pipeline برای کارایی و مصرف کمتر رم ----------\ndef make_dataset(X, y, batch_size, shuffle=True):\n    # تبدیل به float32 و فلَت کردن y\n    X = X.astype(np.float32)\n    y_flat = y.reshape(len(y), -1).astype(np.float32)\n    ds = tf.data.Dataset.from_tensor_slices((X, y_flat))\n    if shuffle:\n        ds = ds.shuffle(buffer_size=min(10000, len(X)))\n    ds = ds.batch(batch_size, drop_remainder=False).prefetch(tf.data.AUTOTUNE)\n    return ds\n\ntrain_ds = make_dataset(X_train, y_train, BATCH_SIZE, shuffle=True)\nval_ds   = make_dataset(X_val, y_val, BATCH_SIZE, shuffle=False)\n\n# ---------- ساخت مدل و کامپایل با loss ترکیبی ----------\ninput_dim = X_train.shape[1]\nmodel = build_model_light(input_dim, output_flat_dim)\nmodel.summary()\n\nmse = tf.keras.losses.MeanSquaredError()\n\n# custom training step wrapper (برای حفظ mixed precision و محاسبه loss smooth)\noptimizer = tf.keras.optimizers.Adam(learning_rate=LR)\n\n# برای mixed precision: از LossScale استفاده خودکار توسط policy استفاده می‌شود، بنابراین از @tf.function استفاده می‌کنیم.\n@tf.function\ndef train_step(x_batch, y_batch):\n    with tf.GradientTape() as tape:\n        pred = model(x_batch, training=True)  # (batch, output_flat_dim)\n        loss_mse = mse(y_batch, pred)\n        pred_resh = tf.reshape(pred, (-1, max_qpoints, max_bands))\n        loss_smooth = smoothness_loss_from_reshaped(pred_resh)\n        loss = loss_mse + LAMBDA_SMOOTH * loss_smooth\n        # اگر mixed precision فعال است، optimizer خودش scaling را مدیریت می‌کند (policy)\n    grads = tape.gradient(loss, model.trainable_variables)\n    optimizer.apply_gradients(zip(grads, model.trainable_variables))\n    return loss, loss_mse, loss_smooth\n\n@tf.function\ndef val_step(x_batch, y_batch):\n    pred = model(x_batch, training=False)\n    loss_mse = mse(y_batch, pred)\n    pred_resh = tf.reshape(pred, (-1, max_qpoints, max_bands))\n    loss_smooth = smoothness_loss_from_reshaped(pred_resh)\n    loss = loss_mse + LAMBDA_SMOOTH * loss_smooth\n    return loss, loss_mse, loss_smooth\n\n# ---------- چرخهٔ آموزش ساده (می‌تواند جایگزین model.fit شود تا آسان‌تر خطای OOM بررسی شود) ----------\nbest_val = np.inf\npatience_counter = 0\nhistory = {\"train_loss\": [], \"val_loss\": []}\n\nfor epoch in range(1, EPOCHS + 1):\n    # TRAIN\n    train_losses = []\n    for x_batch, y_batch in train_ds:\n        l, lm, ls = train_step(x_batch, y_batch)\n        train_losses.append(l.numpy())\n    train_loss_epoch = float(np.mean(train_losses))\n\n    # VAL\n    val_losses = []\n    for x_batch, y_batch in val_ds:\n        l, lm, ls = val_step(x_batch, y_batch)\n        val_losses.append(l.numpy())\n    val_loss_epoch = float(np.mean(val_losses))\n\n    history[\"train_loss\"].append(train_loss_epoch)\n    history[\"val_loss\"].append(val_loss_epoch)\n\n    print(f\"Epoch {epoch:03d} - train_loss: {train_loss_epoch:.6e}  val_loss: {val_loss_epoch:.6e}\")\n\n    # early stopping ساده\n    if val_loss_epoch < best_val - 1e-12:\n        best_val = val_loss_epoch\n        patience_counter = 0\n        # ذخیره وزن‌ها\n        model.save_weights(os.path.join(out_dir, \"best_model_light.weights.h5\"))\n    else:\n        patience_counter += 1\n        if patience_counter >= PATIENCE:\n            print(f\"Early stopping after {epoch} epochs (no improvement for {PATIENCE} epochs).\")\n            break\n\n# ---------- بارگذاری بهترین وزن و ارزیابی نهایی ----------\nmodel.load_weights(os.path.join(out_dir, \"best_model_light.weights.h5\"))\n\n\n# پیش‌بینی روی تست\nX_test_tensor = X_test.astype(np.float32)\ny_test_flat = y_test.reshape(len(y_test), -1).astype(np.float32)\ny_pred_flat = model.predict(X_test_tensor, batch_size=BATCH_SIZE)\ny_pred = (y_pred_flat * scaler_y_std + scaler_y_mean).reshape(-1, max_qpoints, max_bands)\ny_test_true = (y_test_flat * scaler_y_std + scaler_y_mean).reshape(-1, max_qpoints, max_bands)\n\nr2_scores = [r2_score(y_test_true[i].flatten(), y_pred[i].flatten()) for i in range(len(y_test_true))]\nprint(\"Mean R2:\", np.mean(r2_scores))\nnp.save(os.path.join(out_dir, \"r2_list_light.npy\"), np.array(r2_scores))\n\n# smoothing for one sample and plot\nsample_idx = 0\npred_sample = y_pred[sample_idx]\nwindow_length = 7 if max_qpoints >= 7 else (max_qpoints//2*2+1)\npolyorder = 3\ntry:\n    pred_smooth = np.copy(pred_sample)\n    for b in range(pred_sample.shape[1]):\n        pred_smooth[:, b] = savgol_filter(pred_sample[:, b], window_length=window_length, polyorder=polyorder, mode='interp')\nexcept Exception as e:\n    from scipy.ndimage import gaussian_filter1d\n    pred_smooth = gaussian_filter1d(pred_sample, sigma=0.6, axis=0)\n\nplt.figure(figsize=(10,6))\nfor b in range(pred_sample.shape[1]):\n    plt.plot(pred_sample[:, b], color='C{}'.format(b%10), alpha=0.4)\nfor b in range(pred_smooth.shape[1]):\n    plt.plot(pred_smooth[:, b], color='C{}'.format(b%10), linewidth=1.4)\nplt.title(\"Predicted phonon bands - before & after smoothing (sample 0)\")\nplt.xlabel(\"Q-point\")\nplt.ylabel(\"Frequency (THz)\")\nplt.grid(True)\nplt.savefig(os.path.join(out_dir, \"pred_light_before_after_smooth.png\"))\nplt.show()\n\nprint(\"Saved weights:\", os.path.join(out_dir, \"best_model_light.ckpt\"))\nprint(\"Saved R2 list:\", os.path.join(out_dir, \"r2_list_light.npy\"))\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-08-14T12:36:56.503334Z","iopub.execute_input":"2025-08-14T12:36:56.503901Z","iopub.status.idle":"2025-08-14T12:37:51.873017Z","shell.execute_reply.started":"2025-08-14T12:36:56.503871Z","shell.execute_reply":"2025-08-14T12:37:51.87213Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"import os\nimport numpy as np\nimport pandas as pd\nimport matplotlib.pyplot as plt\nimport seaborn as sns\nfrom sklearn.ensemble import RandomForestRegressor\nfrom sklearn.inspection import permutation_importance\nfrom matplotlib.backends.backend_pdf import PdfPages\n\nplt.rcParams.update({'font.size': 12})\n\n# ---------- تنظیم مسیرها در صورت نیاز ----------\ndata_dir = \"/kaggle/input/npy-phonon-phase7\"  # تغییر بده اگر لازم است\nout_dir = \"feature_analysis_plots\"\nos.makedirs(out_dir, exist_ok=True)\n\n# ---------- بارگذاری X و y (اگر از npy استفاده می‌کنی) ----------\nif os.path.exists(os.path.join(data_dir, \"train_x_editedfeature.npy\")):\n    X_train = np.load(os.path.join(data_dir, \"train_x_editedfeature.npy\"))\n    y_train = np.load(os.path.join(data_dir, \"train_y_editedfeature.npy\"))\nelse:\n    try:\n        X_train\n        y_train\n    except NameError:\n        raise RuntimeError(\"X_train/y_train در دسترس نیستند. یا npy ها را در data_dir بگذار یا متغیرها را تعریف کن.\")\n\n# ---------- نام فیچرها ----------\nfeature_names = None\nfeat_file = os.path.join(data_dir, \"feature_cols_editedfeature.npy\")\nif os.path.exists(feat_file):\n    try:\n        feature_names = list(np.load(feat_file, allow_pickle=True))\n        print(\"Loaded feature names from:\", feat_file)\n    except Exception:\n        feature_names = None\n\nif feature_names is None:\n    feature_names = [f\"feat_{i}\" for i in range(X_train.shape[1])]\nprint(\"Number of features:\", len(feature_names))\n\n# ---------- پردازش y ----------\nif isinstance(y_train, np.ndarray):\n    if y_train.ndim == 3:\n        y_mean_all = np.mean(y_train, axis=(1,2))\n        y_band_mean = np.mean(y_train, axis=1)\n        n_bands = y_band_mean.shape[1]\n    elif y_train.ndim == 2:\n        N, M = y_train.shape\n        mqf = os.path.join(data_dir, \"max_qpoints.npy\")\n        mbf = os.path.join(data_dir, \"per_atom_feature_len_editedfeature.npy\")\n        if os.path.exists(os.path.join(data_dir, \"max_atoms_editedfeature.npy\")) and os.path.exists(os.path.join(data_dir, \"per_atom_feature_len.npy\")):\n            y_mean_all = np.mean(y_train, axis=1)\n            y_band_mean = y_train\n            n_bands = y_band_mean.shape[1]\n        else:\n            y_mean_all = np.mean(y_train, axis=1)\n            y_band_mean = y_train\n            n_bands = y_band_mean.shape[1]\n    else:\n        raise ValueError(\"y_train دارای ابعاد غیرمنتظره است (ndim != 2 or 3). شکل y_train: \" + str(y_train.shape))\nelse:\n    raise ValueError(\"y_train باید numpy array باشد.\")\n\nprint(\"y_mean_all shape:\", y_mean_all.shape)\nprint(\"y_band_mean shape:\", y_band_mean.shape)\n\n# ---------- ساخت DataFrame ----------\nX_df = pd.DataFrame(X_train[:, :len(feature_names)], columns=feature_names)\nband_cols = [f\"band_mean_{i}\" for i in range(n_bands)]\nband_df = pd.DataFrame(y_band_mean, columns=band_cols)\ncorr_df = pd.concat([X_df, band_df], axis=1)\n\n# محاسبه ماتریس همبستگی (این خط اضافه شده برای رفع ارور)\ncorr_full = corr_df.corr()\n\n# ---------- ذخیره تمام نمودارها در یک PDF ----------\nwith PdfPages(os.path.join(out_dir, 'all_plots.pdf')) as pdf:\n    # 1) ماتریس همبستگی کامل\n    plt.figure(figsize=(28, 24))\n    sns.heatmap(corr_full, cmap=\"coolwarm\", center=0)\n    plt.title(\"Correlation matrix (features + band means)\")\n    plt.xticks(rotation=90, ha='right')  # چرخاندن برچسب‌ها برای نمایش کامل\n    plt.yticks(rotation=0)  # تنظیم برچسب‌های عمودی\n    plt.tight_layout()\n    pdf.savefig()\n    plt.close()\n\n    # 2) ماتریس همبستگی مختص\n    corr_feat_band = corr_full.loc[feature_names, band_cols]\n    plt.figure(figsize=(24, 16))\n    sns.heatmap(corr_feat_band, cmap=\"RdBu_r\", center=0, annot=False)\n    plt.title(\"Correlation (features) vs (band means)\")\n    plt.xlabel(\"Bands (mean over Q)\")\n    plt.ylabel(\"Features\")\n    plt.xticks(rotation=90, ha='right')  # چرخاندن برچسب‌ها برای نمایش کامل\n    plt.yticks(rotation=0)\n    plt.tight_layout()\n    pdf.savefig()\n    plt.close()\n\n    # 3) Feature importance via RandomForest\n    rf = RandomForestRegressor(n_estimators=200, random_state=42, n_jobs=-1)\n    rf.fit(X_df, y_mean_all)\n    importances = rf.feature_importances_\n    imp_df = pd.DataFrame({\"feature\": feature_names, \"importance\": importances})\n    imp_df = imp_df.sort_values(\"importance\", ascending=False).reset_index(drop=True)\n\n    plt.figure(figsize=(20, 12))\n    sns.barplot(x=\"importance\", y=\"feature\", data=imp_df.head(30))\n    plt.title(\"RandomForest feature importances (target = mean frequency per sample)\")\n    plt.xticks(rotation=90, ha='right')  # چرخاندن برچسب‌ها برای نمایش کامل\n    plt.tight_layout()\n    pdf.savefig()\n    plt.close()\n\n    print(\"Top features by RF importance:\")\n    print(imp_df.head(69))\n\n    # 4) Per-band RandomForest importances\n    per_band_importances = []\n    for i, col in enumerate(band_cols):\n        print(f\"Training RF for {col} ...\")\n        rf_i = RandomForestRegressor(n_estimators=150, random_state=42, n_jobs=-1)\n        rf_i.fit(X_df, band_df[col])\n        per_band_importances.append(rf_i.feature_importances_)\n\n    per_band_importances = np.array(per_band_importances)\n    mean_importance_across_bands = per_band_importances.mean(axis=0)\n    imp_band_df = pd.DataFrame({\"feature\": feature_names, \"mean_importance\": mean_importance_across_bands})\n    imp_band_df = imp_band_df.sort_values(\"mean_importance\", ascending=False).reset_index(drop=True)\n\n    plt.figure(figsize=(10, 6))\n    sns.barplot(x=\"mean_importance\", y=\"feature\", data=imp_band_df.head(30))\n    plt.title(\"Mean feature importances across bands (RandomForest per band)\")\n    plt.xticks(rotation=90, ha='right')  # چرخاندن برچسب‌ها برای نمایش کامل\n    plt.tight_layout()\n    pdf.savefig()\n    plt.close()\n\n    print(\"Top features by mean per-band RF importance:\")\n    print(imp_band_df.head(69))\n\n    # 5) Permutation importance\n    print(\"Computing permutation importance (this may take some time)...\")\n    perm = permutation_importance(rf, X_df, y_mean_all, n_repeats=10, random_state=42, n_jobs=-1)\n    perm_imp_df = pd.DataFrame({\"feature\": feature_names, \"perm_importance_mean\": perm.importances_mean})\n    perm_imp_df = perm_imp_df.sort_values(\"perm_importance_mean\", ascending=False).reset_index(drop=True)\n\n    plt.figure(figsize=(10, 6))\n    sns.barplot(x=\"perm_importance_mean\", y=\"feature\", data=perm_imp_df.head(30))\n    plt.title(\"Permutation importances (target = mean frequency per sample)\")\n    plt.xticks(rotation=90, ha='right')  # چرخاندن برچسب‌ها برای نمایش کامل\n    plt.tight_layout()\n    pdf.savefig()\n    plt.close()\n\n    print(\"Top features by permutation importance:\")\n    print(perm_imp_df.head(69))\n\n    # 6) پیشنهاد حذف\n    threshold = 0.005\n    low_feats_rf_mean = imp_band_df[imp_band_df['mean_importance'] < threshold]['feature'].tolist()\n    low_feats_perm = perm_imp_df[perm_imp_df['perm_importance_mean'] < threshold]['feature'].tolist()\n\n    print(f\"Features with mean per-band RF importance < {threshold}: {low_feats_rf_mean}\")\n    print(f\"Features with permutation importance mean < {threshold}: {low_feats_perm}\")\n\n    candidates_to_drop = sorted(set(low_feats_rf_mean).intersection(set(low_feats_perm)))\n    print(\"Candidate features to DROP (intersection):\", candidates_to_drop)\n\n# ذخیره نتایج متا\nimp_df.to_csv(os.path.join(out_dir, \"rf_importances_mean_target.csv\"), index=False)\nimp_band_df.to_csv(os.path.join(out_dir, \"rf_perband_mean_importances.csv\"), index=False)\nperm_imp_df.to_csv(os.path.join(out_dir, \"perm_importances.csv\"), index=False)\n\nprint(\"Saved plots into\", os.path.join(out_dir, 'all_plots.pdf'))\nprint(\"Saved CSVs into\", out_dir)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-08-14T12:57:05.403927Z","iopub.execute_input":"2025-08-14T12:57:05.404318Z","iopub.status.idle":"2025-08-14T12:57:27.580207Z","shell.execute_reply.started":"2025-08-14T12:57:05.404288Z","shell.execute_reply":"2025-08-14T12:57:27.579398Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# gpt edited again\n","metadata":{}},{"cell_type":"markdown","source":"## final code in PHASE 7","metadata":{}},{"cell_type":"code","source":"# prepare_data_from_yaml_and_excel.py\nimport os\nimport re\nimport yaml\nimport numpy as np\nimport pandas as pd\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.preprocessing import StandardScaler\nfrom scipy.ndimage import gaussian_filter1d\n\n# -----------------------\n# تنظیم مسیرها (تغییر بده اگر لازم است)\n# -----------------------\nyaml_folder = \"/kaggle/input/yaml-data/extracted_bands_C\"\nexcel_path  = \"/kaggle/input/npy-phonon-phase7/feature_data_edited.xlsx\"   # فایل اکسل جدید با ویژگی‌های بیشتر\nout_dir     = \".\"  # جایی که npyها ذخیره می‌شوند\n\nos.makedirs(out_dir, exist_ok=True)\n\n# -----------------------\n# توابع کمکی\n# -----------------------\ndef _normalize_cols(cols):\n    \"\"\"نام ستون‌ها را یکدست می‌کند (حذف فاصله، حروف کوچک، جایگزینی فاصله با _)\"\"\"\n    normed = []\n    for c in cols:\n        c2 = str(c).strip()\n        c2 = re.sub(r\"\\s+\", \"_\", c2)\n        c2 = c2.replace(\"-\", \"_\").replace(\"/\", \"_\").replace(\".\", \"_\")\n        normed.append(c2.lower())\n    return normed\n\ndef _guess_symbol_col(df):\n    \"\"\"ستون نماد عنصر را پیدا می‌کند: یکی از [symbol, element, species, label, name]\"\"\"\n    candidates = [\"symbol\", \"element\", \"species\", \"label\", \"name\", \"atomic_symbol\"]\n    for c in df.columns:\n        if c in candidates:\n            return c\n    raise ValueError(\"ستون نماد عنصر (symbol/element/...) در اکسل پیدا نشد.\")\n\ndef _guess_mass_like_cols(df):\n    \"\"\"ستون‌های شبیه جرم (برای fallback نگاشت بر اساس جرم)\"\"\"\n    mass_like = []\n    for c in df.columns:\n        if any(k in c for k in [\"atomic_weight\", \"atomic_mass\", \"mass\", \"amu\", \"weight\"]):\n            mass_like.append(c)\n    return mass_like  # ممکن است خالی باشد (اشکالی ندارد)\n\ndef _read_excel_features(excel_path):\n    df = pd.read_excel(excel_path)\n    df.columns = _normalize_cols(df.columns)\n    sym_col = _guess_symbol_col(df)\n\n    # ستونی که احتمالاً جرم است (برای fallback استفاده می‌شود؛ وارد X نمی‌کنیم)\n    mass_cols = _guess_mass_like_cols(df)\n\n    # ویژگی‌های ورودی = تمام ستون‌ها به‌جز symbol و ستون‌های جرم‌گونه\n    feature_cols = [c for c in df.columns if c not in [sym_col] + mass_cols]\n\n    # دیکشنری: symbol -> بردار ویژگی‌ها (به ترتیب feature_cols)\n    elem_features = {}\n    for _, r in df.iterrows():\n        sym = str(r[sym_col]).strip()\n        vals = r[feature_cols].astype(float).fillna(0.0).values\n        elem_features[sym] = vals\n\n    # اگر mass_col داریم، برای نگاشت بر اساس جرم استفاده می‌کنیم\n    mass_map = None\n    if mass_cols:\n        # از اولین ستون جرم استفاده می‌کنیم\n        mcol = mass_cols[0]\n        mass_map = []\n        for _, r in df.iterrows():\n            sym = str(r[sym_col]).strip()\n            try:\n                mval = float(r[mcol])\n            except:\n                mval = np.nan\n            mass_map.append((mval, sym))\n        mass_map = [(m, s) for (m, s) in mass_map if np.isfinite(m)]\n        mass_array = np.array([m for m, _ in mass_map], dtype=float)\n    else:\n        mass_array = None\n\n    return elem_features, feature_cols, mass_map, mass_array\n\ndef _find_symbol_by_mass(mass, mass_map, mass_array, tol=0.5):\n    \"\"\"اگر symbol در YAML نبود و اکسل جرم دارد، نزدیک‌ترین عنصر را با جرم حدس می‌زند.\"\"\"\n    if mass_map is None or mass_array is None or len(mass_array) == 0:\n        return None, None  # امکان نگاشت نداریم\n    diffs = np.abs(mass_array - mass)\n    idx = np.argmin(diffs)\n    best_mass, best_sym = mass_map[idx]\n    return best_sym, float(diffs[idx])\n\n# -----------------------\n# گام 1: خواندن اکسل و آماده‌سازی دیکشنری ویژگی عناصر\n# -----------------------\nelem_features, excel_feature_cols, mass_map, mass_array = _read_excel_features(excel_path)\nprint(f\"[Excel] تعداد ویژگی‌های عنصری استفاده‌شده: {len(excel_feature_cols)}\")\nprint(f\"[Excel] نمونه‌ای از ویژگی‌ها: {excel_feature_cols[:10]}\")\n\n# -----------------------\n# گام 2: یک پاس سریع روی YAML برای تعیین بیشینه‌ها\n# -----------------------\nmax_atoms = 0\nmax_bands = 0\nmax_qpoints = 0\nyaml_files = [f for f in os.listdir(yaml_folder) if f.endswith(\".yaml\")]\n\nfor file in yaml_files:\n    try:\n        with open(os.path.join(yaml_folder, file), \"r\") as f:\n            data = yaml.safe_load(f)\n        if not data or \"points\" not in data or \"phonon\" not in data:\n            continue\n        n_atoms = len(data[\"points\"])\n        n_q = len(data[\"phonon\"])\n        n_b = len(data[\"phonon\"][0].get(\"band\", [])) if n_q > 0 else 0\n        max_atoms = max(max_atoms, n_atoms)\n        max_qpoints = max(max_qpoints, n_q)\n        max_bands = max(max_bands, n_b)\n    except Exception as e:\n        print(f\"[COUNT] skip {file}: {e}\")\n\nprint(f\"[YAML] max_atoms={max_atoms}, max_qpoints={max_qpoints}, max_bands={max_bands}\")\n\n# طول بردار ویژگی هر اتم: 3 مختصات + 1 جرم (از YAML) + ویژگی‌های اکسل\nper_atom_feature_len = 3 + 1 + len(excel_feature_cols)\n\n# -----------------------\n# گام 3: پاس اصلی؛ ساخت X و y\n# -----------------------\nX_list, Y_list = [], []\nmissing_symbol, mass_matched, zero_filled = 0, 0, 0\n\nfor file in yaml_files:\n    try:\n        with open(os.path.join(yaml_folder, file), \"r\") as f:\n            data = yaml.safe_load(f)\n        if not data:\n            continue\n        if \"points\" not in data or \"lattice\" not in data or \"reciprocal_lattice\" not in data or \"phonon\" not in data:\n            continue\n\n        # --- ویژگی‌های هر اتم ---\n        atom_vecs = []\n        for pt in data[\"points\"]:\n            # coords\n            coords = pt.get(\"coordinates\", [0.0, 0.0, 0.0])\n            coords = list(coords) + [0.0] * (3 - len(coords))  # ایمنی\n            coords = coords[:3]\n\n            # mass از YAML\n            mass_yaml = float(pt.get(\"mass\", 0.0))\n\n            # symbol اگر موجود نبود، با جرم حدس می‌زنیم (اگر اکسل جرم داشته باشد)\n            sym = None\n            for key in [\"symbol\", \"label\", \"element\", \"species\", \"name\"]:\n                if key in pt and str(pt[key]).strip():\n                    sym = str(pt[key]).strip()\n                    break\n\n            feat_vec = None\n            if sym and sym in elem_features:\n                feat_vec = elem_features[sym]\n            else:\n                missing_symbol += 1\n                guessed_sym, diff = _find_symbol_by_mass(mass_yaml, mass_map, mass_array, tol=0.5)\n                if guessed_sym and guessed_sym in elem_features:\n                    feat_vec = elem_features[guessed_sym]\n                    mass_matched += 1\n                else:\n                    # اگر نتونست حدس بزنه یا اکسل جرم نداشت، صفر پر می‌کنیم\n                    feat_vec = np.zeros(len(excel_feature_cols), dtype=float)\n                    zero_filled += 1\n\n            vec = np.array(coords + [mass_yaml], dtype=float)\n            vec = np.concatenate([vec, feat_vec.astype(float)], axis=0)  # طول = per_atom_feature_len\n            atom_vecs.append(vec)\n\n        atom_mat = np.array(atom_vecs, dtype=float)\n        # padding روی محور اتم‌ها\n        if atom_mat.shape[0] < max_atoms:\n            pad = np.zeros((max_atoms - atom_mat.shape[0], per_atom_feature_len), dtype=float)\n            atom_mat = np.vstack([atom_mat, pad])\n        elif atom_mat.shape[0] > max_atoms:\n            atom_mat = atom_mat[:max_atoms, :]\n\n        # --- lattice و reciprocal_lattice ---\n        lattice = np.array(data[\"lattice\"], dtype=float).flatten()\n        recip   = np.array(data[\"reciprocal_lattice\"], dtype=float).flatten()\n\n        # --- ساخت بردار ویژگی نهایی نمونه ---\n        feat_tensor = np.concatenate([atom_mat.flatten(), lattice, recip], axis=0).astype(float)\n        X_list.append(feat_tensor)\n\n        # --- فرکانس‌ها (y) ---\n        freqs = []\n        for qpt in data[\"phonon\"]:\n            bands = [b.get(\"frequency\", 0.0) for b in qpt.get(\"band\", [])]\n            freqs.append(bands)\n        freqs = np.array(freqs, dtype=float)\n\n        # پدینگ فرکانس‌ها به (max_qpoints, max_bands)\n        fq_pad = np.zeros((max_qpoints, max_bands), dtype=float)\n        fq_pad[:min(max_qpoints, freqs.shape[0]), :min(max_bands, freqs.shape[1])] = freqs[:max_qpoints, :max_bands]\n        Y_list.append(fq_pad)\n\n    except Exception as e:\n        print(f\"[PARSE] skip {file}: {e}\")\n\nX = np.array(X_list, dtype=float)\ny = np.array(Y_list, dtype=float)\n\nprint(f\"[BUILD] samples={len(X)}, X.shape={X.shape}, y.shape={y.shape}\")\nprint(f\"[INFO] missing_symbol={missing_symbol}, mass_matched={mass_matched}, zero_filled={zero_filled}\")\n\n# -----------------------\n# گام 4: نرم‌سازی ملایم روی محور Q\n# -----------------------\ny_smooth = gaussian_filter1d(y, sigma=0.6, axis=1)\n\n# -----------------------\n# گام 5: نرمال‌سازی و تقسیم داده‌ها\n# -----------------------\n# X\nscaler_X = StandardScaler()\nX_norm = scaler_X.fit_transform(X)\n\n# y را فلت می‌کنیم، نرمال، و بعد دوباره reshape\nn_samples, n_q, n_b = y_smooth.shape\ny_flat = y_smooth.reshape(n_samples, -1)\n\nscaler_y = StandardScaler()\ny_norm_flat = scaler_y.fit_transform(y_flat)\ny_norm = y_norm_flat.reshape(n_samples, n_q, n_b)\n\n# split: 20% تست، از بقیه 20% اعتبارسنجی\nX_tmp, X_test, y_tmp, y_test = train_test_split(X_norm, y_norm, test_size=0.2, random_state=42)\nX_train, X_val,  y_train, y_val = train_test_split(X_tmp, y_tmp, test_size=0.2, random_state=42)\n\n# -----------------------\n# گام 6: ذخیره خروجی‌ها و متادیتا\n# -----------------------\nnp.save(os.path.join(out_dir, \"train_x.npy\"), X_train)\nnp.save(os.path.join(out_dir, \"val_x.npy\"),   X_val)\nnp.save(os.path.join(out_dir, \"test_x.npy\"),  X_test)\n\nnp.save(os.path.join(out_dir, \"train_y.npy\"), y_train)\nnp.save(os.path.join(out_dir, \"val_y.npy\"),   y_val)\nnp.save(os.path.join(out_dir, \"test_y.npy\"),  y_test)\n\nnp.save(os.path.join(out_dir, \"scaler_X_mean.npy\"), scaler_X.mean_)\nnp.save(os.path.join(out_dir, \"scaler_X_std.npy\"),  scaler_X.scale_)\nnp.save(os.path.join(out_dir, \"scaler_y_mean.npy\"), scaler_y.mean_)\nnp.save(os.path.join(out_dir, \"scaler_y_std.npy\"),  scaler_y.scale_)\n\n# متادیتا برای بازتولید featurization\nnp.save(os.path.join(out_dir, \"max_atoms.npy\"),              np.array([max_atoms]))\nnp.save(os.path.join(out_dir, \"per_atom_feature_len.npy\"),   np.array([per_atom_feature_len]))\nnp.save(os.path.join(out_dir, \"excel_feature_cols.npy\"),     np.array(excel_feature_cols, dtype=object))\n\n# ابعاد lattice / reciprocal (برای سازگاری هنگام پیش‌بینی)\nnp.save(os.path.join(out_dir, \"lattice_len.npy\"),            np.array([len(lattice)]))\nnp.save(os.path.join(out_dir, \"reciprocal_len.npy\"),         np.array([len(recip)]))\n\nprint(\"[DONE] ذخیره شد.\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-08-14T13:15:55.747493Z","iopub.execute_input":"2025-08-14T13:15:55.747905Z","iopub.status.idle":"2025-08-14T13:42:27.964021Z","shell.execute_reply.started":"2025-08-14T13:15:55.74788Z","shell.execute_reply":"2025-08-14T13:42:27.963056Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"import os\nimport numpy as np\nimport tensorflow as tf\nfrom sklearn.metrics import r2_score\nimport matplotlib.pyplot as plt\nfrom scipy.signal import savgol_filter\n\n# ---------- مسیرها ----------\ndata_dir = \"/kaggle/input/fanal-dataset\"  # تغییر در صورت نیاز\nout_dir = \"/kaggle/working\"\nos.makedirs(out_dir, exist_ok=True)\n\n# ---------- mixed precision ----------\nfrom tensorflow.keras import mixed_precision\ntry:\n    mixed_precision.set_global_policy('mixed_float16')\n    print(\"Mixed precision policy set to:\", mixed_precision.global_policy())\nexcept Exception as e:\n    print(\"Mixed precision unavailable:\", e)\n\n# ---------- لود داده‌ها ----------\nX_train = np.load(os.path.join(data_dir, \"train_x.npy\"))\nX_val   = np.load(os.path.join(data_dir, \"val_x.npy\"))\nX_test  = np.load(os.path.join(data_dir, \"test_x.npy\"))\ny_train = np.load(os.path.join(data_dir, \"train_y.npy\"))\ny_val   = np.load(os.path.join(data_dir, \"val_y.npy\"))\ny_test  = np.load(os.path.join(data_dir, \"test_y.npy\"))\n\nscaler_y_mean = np.load(os.path.join(data_dir, \"scaler_y_mean.npy\"))\nscaler_y_std  = np.load(os.path.join(data_dir, \"scaler_y_std.npy\"))\nscaler_X_mean = np.load(os.path.join(data_dir, \"scaler_X_mean.npy\"))\nscaler_X_std  = np.load(os.path.join(data_dir, \"scaler_X_std.npy\"))\n\n# ---------- ابعاد ----------\nnum_samples, max_qpoints, max_bands = y_train.shape\noutput_flat_dim = int(max_qpoints * max_bands)\n\n# ---------- smoothness loss ----------\ndef smoothness_loss_from_reshaped(y_pred_reshaped):\n    d2 = y_pred_reshaped[:, 2:, :] - 2.0 * y_pred_reshaped[:, 1:-1, :] + y_pred_reshaped[:, :-2, :]\n    return tf.reduce_mean(tf.square(d2))\n\n# ---------- مدل ----------\ndef swish(x):\n    return tf.nn.swish(x)\n\ndef residual_dense_block(x, units, dropout_rate=0.03, use_bn=False):\n    shortcut = x\n    if int(shortcut.shape[-1]) != units:\n        shortcut = tf.keras.layers.Dense(units, activation=None, dtype='float32')(shortcut)\n    x = tf.keras.layers.Dense(units, activation=swish, dtype='float32')(x)\n    if use_bn:\n        x = tf.keras.layers.BatchNormalization()(x)\n    x = tf.keras.layers.Dropout(dropout_rate)(x)\n    x = tf.keras.layers.Add()([shortcut, x])\n    x = tf.keras.layers.Activation(swish)(x)\n    return x\n\ndef build_model_light(input_dim, output_dim):\n    inp = tf.keras.layers.Input(shape=(input_dim,), name=\"input\")\n    x = tf.keras.layers.Dense(256, activation=swish, dtype='float32')(inp)\n    x = residual_dense_block(x, 256, dropout_rate=0.03, use_bn=False)\n    x = residual_dense_block(x, 128, dropout_rate=0.02, use_bn=False)\n    x = tf.keras.layers.Dense(256, activation=swish, dtype='float32')(x)\n    x = tf.keras.layers.Dropout(0.15)(x)\n    out = tf.keras.layers.Dense(output_dim, activation='linear', dtype='float32', name=\"out\")(x)\n    return tf.keras.Model(inputs=inp, outputs=out)\n\n# ---------- hyperparams ----------\nBATCH_SIZE = 64\nEPOCHS = 250\nLR = 3e-4\nLAMBDA_SMOOTH = 1e-1\nPATIENCE = 30\n\n# ---------- tf.data pipeline ----------\ndef make_dataset(X, y, batch_size, shuffle=True):\n    X = X.astype(np.float32)\n    y_flat = y.reshape(len(y), -1).astype(np.float32)\n    ds = tf.data.Dataset.from_tensor_slices((X, y_flat))\n    if shuffle:\n        ds = ds.shuffle(buffer_size=min(10000, len(X)))\n    return ds.batch(batch_size).prefetch(tf.data.AUTOTUNE)\n\ntrain_ds = make_dataset(X_train, y_train, BATCH_SIZE, shuffle=True)\nval_ds   = make_dataset(X_val, y_val, BATCH_SIZE, shuffle=False)\n\n# ---------- ساخت مدل ----------\ninput_dim = X_train.shape[1]\nmodel = build_model_light(input_dim, output_flat_dim)\nmodel.summary()\n\nmse = tf.keras.losses.MeanSquaredError()\noptimizer = tf.keras.optimizers.Adam(learning_rate=LR)\n\n@tf.function\ndef train_step(x_batch, y_batch):\n    with tf.GradientTape() as tape:\n        pred = model(x_batch, training=True)\n        loss_mse = mse(y_batch, pred)\n        pred_resh = tf.reshape(pred, (-1, max_qpoints, max_bands))\n        loss_smooth = smoothness_loss_from_reshaped(pred_resh)\n        loss = loss_mse + LAMBDA_SMOOTH * loss_smooth\n    grads = tape.gradient(loss, model.trainable_variables)\n    optimizer.apply_gradients(zip(grads, model.trainable_variables))\n    return loss\n\n@tf.function\ndef val_step(x_batch, y_batch):\n    pred = model(x_batch, training=False)\n    loss_mse = mse(y_batch, pred)\n    pred_resh = tf.reshape(pred, (-1, max_qpoints, max_bands))\n    loss_smooth = smoothness_loss_from_reshaped(pred_resh)\n    return loss_mse + LAMBDA_SMOOTH * loss_smooth\n\n# ---------- آموزش ----------\nbest_val = np.inf\npatience_counter = 0\n\nfor epoch in range(1, EPOCHS+1):\n    train_losses = [train_step(xb, yb).numpy() for xb, yb in train_ds]\n    val_losses = [val_step(xb, yb).numpy() for xb, yb in val_ds]\n    train_loss_epoch = np.mean(train_losses)\n    val_loss_epoch = np.mean(val_losses)\n\n    print(f\"Epoch {epoch:03d} | Train Loss: {train_loss_epoch:.6e} | Val Loss: {val_loss_epoch:.6e}\")\n\n    if val_loss_epoch < best_val:\n        best_val = val_loss_epoch\n        patience_counter = 0\n        model.save_weights(os.path.join(out_dir, \"best_model.weights.h5\"))\n    else:\n        patience_counter += 1\n        if patience_counter >= PATIENCE:\n            print(\"Early stopping.\")\n            break\n\n# ---------- ارزیابی ----------\nmodel.load_weights(os.path.join(out_dir, \"best_model.weights.h5\"))\n\ny_test_flat = y_test.reshape(len(y_test), -1).astype(np.float32)\ny_pred_flat = model.predict(X_test.astype(np.float32), batch_size=BATCH_SIZE)\ny_pred = (y_pred_flat * scaler_y_std + scaler_y_mean).reshape(-1, max_qpoints, max_bands)\ny_test_true = (y_test_flat * scaler_y_std + scaler_y_mean).reshape(-1, max_qpoints, max_bands)\n\nr2_scores = [r2_score(y_test_true[i].flatten(), y_pred[i].flatten()) for i in range(len(y_test_true))]\nprint(\"Mean R2:\", np.mean(r2_scores))\nnp.save(os.path.join(out_dir, \"r2_list.npy\"), np.array(r2_scores))\n\n# ---------- رسم نمونه ----------\nsample_idx = 0\npred_sample = y_pred[sample_idx]\nwindow_length = 7 if max_qpoints >= 7 else (max_qpoints//2*2+1)\npolyorder = 3\npred_smooth = np.copy(pred_sample)\nfor b in range(pred_sample.shape[1]):\n    pred_smooth[:, b] = savgol_filter(pred_sample[:, b], window_length=window_length, polyorder=polyorder, mode='interp')\n\nplt.figure(figsize=(10,6))\nfor b in range(pred_sample.shape[1]):\n    plt.plot(pred_sample[:, b], color=f\"C{b%10}\", alpha=0.4)\n    plt.plot(pred_smooth[:, b], color=f\"C{b%10}\", linewidth=1.4)\nplt.title(\"Predicted phonon bands (before & after smoothing)\")\nplt.xlabel(\"Q-point\")\nplt.ylabel(\"Frequency (THz)\")\nplt.grid(True)\nplt.savefig(os.path.joi