 - learning_rate: 2.5000e-05\nEpoch 310/400\n\u001b[1m4/4\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m0s\u001b[0m 12ms/step - loss: 0.0482 - val_loss: 0.0940 - learning_rate: 2.5000e-05\nEpoch 311/400\n\u001b[1m4/4\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m0s\u001b[0m 12ms/step - loss: 0.0513 - val_loss: 0.0941 - learning_rate: 2.5000e-05\n\u001b[1m2/2\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m1s\u001b[0m 556ms/step\nمیانگین R² روی تست: 0.9830\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 1000x600 with 1 Axes>","image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"<Figure size 1000x600 with 1 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"حداقل validation loss در epoch 261: 9.345056e-02\nvalidation loss آخر: 9.407851e-02\ntrain loss آخر: 5.191096e-02\nآیا overfitting داریم؟ ندارد.\nمدل خوب است.\n","output_type":"stream"}],"execution_count":3},{"cell_type":"code","source":"import os\nimport numpy as np\nimport tensorflow as tf\nfrom sklearn.metrics import r2_score\nimport matplotlib.pyplot as plt\nfrom scipy.signal import savgol_filter\nfrom tensorflow.keras import mixed_precision\nfrom tensorflow.keras.callbacks import EarlyStopping, ReduceLROnPlateau, ModelCheckpoint\nfrom tensorflow.keras import regularizers\n\n# ----------------- Paths -----------------\ndata_dir = \"/kaggle/input/fanal-dataset\"  # <- اگر لازم است تغییر بده\nout_dir = \"/kaggle/working\"\nos.makedirs(out_dir, exist_ok=True)\n\n# ----------------- Reproducibility -----------------\nSEED = 42\nnp.random.seed(SEED)\ntf.random.set_seed(SEED)\n\n# ----------------- Mixed Precision -----------------\ntry:\n    mixed_precision.set_global_policy('mixed_float16')\n    print(\"Mixed precision policy:\", mixed_precision.global_policy())\nexcept Exception as e:\n    print(\"Mixed precision unavailable:\", e)\n\n# ----------------- Load Arrays -----------------\nX_train = np.load(os.path.join(data_dir, \"train_x.npy\"))\nX_val   = np.load(os.path.join(data_dir, \"val_x.npy\"))\nX_test  = np.load(os.path.join(data_dir, \"test_x.npy\"))\ny_train = np.load(os.path.join(data_dir, \"train_y.npy\"))\ny_val   = np.load(os.path.join(data_dir, \"val_y.npy\"))\ny_test  = np.load(os.path.join(data_dir, \"test_y.npy\"))\n\nscaler_y_mean = np.load(os.path.join(data_dir, \"scaler_y_mean.npy\"))\nscaler_y_std  = np.load(os.path.join(data_dir, \"scaler_y_std.npy\"))\nscaler_X_mean = np.load(os.path.join(data_dir, \"scaler_X_mean.npy\"))\nscaler_X_std  = np.load(os.path.join(data_dir, \"scaler_X_std.npy\"))\n\n# ----------------- Shapes -----------------\nnum_samples, max_qpoints, max_bands = y_train.shape\noutput_flat_dim = int(max_qpoints * max_bands)\n\ndef inverse_transform_y_flat(y_norm_flat):\n    return (y_norm_flat * scaler_y_std + scaler_y_mean).reshape(-1, max_qpoints, max_bands)\n\n# ----------------- Loss: MSE + Smoothness -----------------\ndef smoothness_loss_from_reshaped(y_pred_reshaped):\n    # y_pred_reshaped: (batch, Q, bands)\n    d2 = y_pred_reshaped[:, 2:, :] - 2.0 * y_pred_reshaped[:, 1:-1, :] + y_pred_reshaped[:, :-2, :]\n    return tf.reduce_mean(tf.square(d2))\n\n# تنظیم وزن اسموثینگ را می‌توانی بعداً کم‌وزیاد کنی\nLAMBDA_SMOOTH = 0.05\n\ndef custom_loss(y_true, y_pred):\n    # y_true, y_pred هر دو فلت هستند (Q*Bands)\n    mse = tf.keras.losses.MeanSquaredError()(y_true, y_pred)\n    pred_resh = tf.reshape(y_pred, (-1, max_qpoints, max_bands))\n    loss_smooth = smoothness_loss_from_reshaped(pred_resh)\n    return mse + LAMBDA_SMOOTH * loss_smooth\n\n# ----------------- Model -----------------\ndef swish(x): return tf.nn.swish(x)\n\nWEIGHT_DECAY = 1e-5  # برای AdamW + L2\n\ndef residual_dense_block(x, units, dropout_rate=0.05, use_bn=True):\n    shortcut = x\n    # Projection اگر ابعاد عوض شد\n    if int(shortcut.shape[-1]) != units:\n        shortcut = tf.keras.layers.Dense(\n            units, activation=None, dtype='float32',\n            kernel_regularizer=regularizers.l2(WEIGHT_DECAY)\n        )(shortcut)\n\n    x = tf.keras.layers.Dense(\n        units, activation=None, dtype='float32',\n        kernel_regularizer=regularizers.l2(WEIGHT_DECAY)\n    )(x)\n    if use_bn:\n        x = tf.keras.layers.BatchNormalization(dtype='float32')(x)\n    x = tf.keras.layers.Activation(swish, dtype='float32')(x)\n\n    x = tf.keras.layers.Dense(\n        units, activation=None, dtype='float32',\n        kernel_regularizer=regularizers.l2(WEIGHT_DECAY)\n    )(x)\n    if use_bn:\n        x = tf.keras.layers.BatchNormalization(dtype='float32')(x)\n    x = tf.keras.layers.Dropout(dropout_rate)(x)\n\n    x = tf.keras.layers.Add()([shortcut, x])\n    x = tf.keras.layers.Activation(swish, dtype='float32')(x)\n    return x\n\ndef build_model_stronger(input_dim, output_dim):\n    inp = tf.keras.layers.Input(shape=(input_dim,), name=\"input\")\n\n    # ورودی را کمی نویزی و نرمال کنیم (به پایداری کمک می‌کند)\n    x = tf.keras.layers.LayerNormalization(dtype='float32')(inp)\n\n    # بدنه‌ی قوی‌تر\n    x = tf.keras.layers.Dense(\n        512, activation=None, dtype='float32',\n        kernel_regularizer=regularizers.l2(WEIGHT_DECAY)\n    )(x)\n    x = tf.keras.layers.BatchNormalization(dtype='float32')(x)\n    x = tf.keras.layers.Activation(swish, dtype='float32')(x)\n    x = tf.keras.layers.Dropout(0.05)(x)\n\n    x = residual_dense_block(x, 512, dropout_rate=0.08, use_bn=True)\n    x = residual_dense_block(x, 256, dropout_rate=0.06, use_bn=True)\n    x = residual_dense_block(x, 256, dropout_rate=0.05, use_bn=True)\n    x = residual_dense_block(x, 128, dropout_rate=0.04, use_bn=True)\n\n    x = tf.keras.layers.Dense(\n        256, activation=swish, dtype='float32',\n        kernel_regularizer=regularizers.l2(WEIGHT_DECAY)\n    )(x)\n    x = tf.keras.layers.Dropout(0.05)(x)\n\n    out = tf.keras.layers.Dense(output_dim, activation='linear', dtype='float32', name=\"out\")(x)\n    return tf.keras.Model(inputs=inp, outputs=out)\n\n# ----------------- Hyperparams -----------------\nBATCH_SIZE     = 64\nEPOCHS         = 400\nINIT_LR        = 3e-4\nPATIENCE       = 35\nAUG_NOISE_STD  = 0.01  # نویز روی X (به مقیاس std نرمال‌شده)\nMAX_CLIP_STD   = 3.0   # کلیپ کردن augmentation به +/- 3 std\n\n# ----------------- Augmentation -----------------\n# نویز گاوسی متناسب با std فیچرها؛ کلیپ به بازهٔ منطقی\nscaler_X_std_tensor = tf.constant(scaler_X_std.astype(np.float32))\n\n@tf.function\ndef augment(x, y):\n    noise = tf.random.normal(tf.shape(x), mean=0.0, stddev=AUG_NOISE_STD * scaler_X_std_tensor, dtype=tf.float32)\n    x_aug = x + noise\n    x_aug = tf.clip_by_value(x_aug, x - MAX_CLIP_STD * scaler_X_std_tensor, x + MAX_CLIP_STD * scaler_X_std_tensor)\n    return x_aug, y\n\n# ----------------- tf.data Pipelines -----------------\ndef make_dataset(X, y, batch_size, shuffle=True, apply_augment=False):\n    X = X.astype(np.float32)\n    y_flat = y.reshape(len(y), -1).astype(np.float32)\n    ds = tf.data.Dataset.from_tensor_slices((X, y_flat))\n    if shuffle:\n        ds = ds.shuffle(buffer_size=min(20000, len(X)), seed=SEED, reshuffle_each_iteration=True)\n    if apply_augment:\n        ds = ds.map(augment, num_parallel_calls=tf.data.AUTOTUNE)\n    ds = ds.batch(batch_size, drop_remainder=False).prefetch(tf.data.AUTOTUNE)\n    return ds\n\ntrain_ds = make_dataset(X_train, y_train, BATCH_SIZE, shuffle=True,  apply_augment=True)\nval_ds   = make_dataset(X_val,   y_val,   BATCH_SIZE, shuffle=False, apply_augment=False)\n\n# ----------------- Build & Compile -----------------\ninput_dim = X_train.shape[1]\nmodel = build_model_stronger(input_dim, output_flat_dim)\nmodel.summary()\n\n# AdamW با weight_decay (با توجه به L2 هم در لایه‌ها داریم)\noptimizer = tf.keras.optimizers.AdamW(learning_rate=INIT_LR, weight_decay=WEIGHT_DECAY)\n\nmodel.compile(optimizer=optimizer, loss=custom_loss)\n\n# ----------------- Callbacks -----------------\nckpt_path = os.path.join(out_dir, \"best_model_light.weights.h5\")\ncallbacks = [\n    ModelCheckpoint(\n        ckpt_path,\n        monitor='val_loss',\n        save_best_only=True,\n        save_weights_only=True,\n        verbose=1\n    ),\n    EarlyStopping(monitor='val_loss', patience=PATIENCE, restore_best_weights=True, verbose=1),\n    ReduceLROnPlateau(monitor='val_loss', factor=0.3, patience=10, min_lr=1e-6, verbose=1)\n]\n\n# ----------------- Train -----------------\nhistory = model.fit(\n    train_ds,\n    validation_data=val_ds,\n    epochs=EPOCHS,\n    callbacks=callbacks,\n    verbose=1\n)\n\n# ذخیره history برای تحلیل‌های بعدی\nnp.save(os.path.join(out_dir, \"history.npy\"), history.history, allow_pickle=True)\n\n# ----------------- Evaluate on Test -----------------\n# بهترین وزن‌ها با ModelCheckpoint/ES restore شده‌اند\ny_pred_flat = model.predict(X_test.astype(np.float32), batch_size=BATCH_SIZE)\ny_pred      = inverse_transform_y_flat(y_pred_flat)\ny_test_true = inverse_transform_y_flat(y_test.reshape(len(y_test), -1).astype(np.float32))\n\nr2_scores = [r2_score(y_test_true[i].flatten(), y_pred[i].flatten()) for i in range(len(y_test_true))]\naverage_r2 = np.mean(r2_scores)\nprint(f\"Test mean R²: {average_r2:.4f}\")\nnp.save(os.path.join(out_dir, \"r2_list_light.npy\"), np.array(r2_scores))\n\n# ----------------- Plot one sample (pred before/after smoothing) -----------------\nsample_idx = 0\npred_sample = y_pred[sample_idx]\nwindow_length = 7 if max_qpoints >= 7 else (max_qpoints//2*2+1)\npolyorder = 3\ntry:\n    pred_smooth = np.copy(pred_sample)\n    for b in range(pred_sample.shape[1]):\n        pred_smooth[:, b] = savgol_filter(pred_sample[:, b], window_length=window_length, polyorder=polyorder, mode='interp')\nexcept Exception:\n    from scipy.ndimage import gaussian_filter1d\n    pred_smooth = gaussian_filter1d(pred_sample, sigma=0.6, axis=0)\n\nplt.figure(figsize=(10,6))\nfor b in range(pred_sample.shape[1]):\n    plt.plot(pred_sample[:, b], color=f'C{b%10}', alpha=0.35)\n    plt.plot(pred_smooth[:, b], color=f'C{b%10}', linewidth=1.2)\nplt.title(\"Predicted phonon bands - before & after smoothing (sample 0)\")\nplt.xlabel(\"Q-point\")\nplt.ylabel(\"Frequency (THz)\")\nplt.grid(True)\nplt.savefig(os.path.join(out_dir, \"pred_light_before_after_smooth.png\"))\nplt.show()\n\n# ----------------- Plot training curves & overfitting check -----------------\nplt.figure(figsize=(10, 6))\nplt.plot(history.history['loss'], label='Training Loss')\nplt.plot(history.history['val_loss'], label='Validation Loss')\nplt.title('Training and Validation Loss')\nplt.xlabel('Epoch')\nplt.ylabel('Loss')\nplt.legend()\nplt.grid(True)\nplt.savefig(os.path.join(out_dir, \"training_loss.png\"))\nplt.show()\n\n# Simple overfitting heuristic (English outputs as requested earlier)\nval_losses = history.history['val_loss']\ntrain_losses = history.history['loss']\nmin_val = float(np.min(val_losses))\nmin_ep = int(np.argmin(val_losses) + 1)\nlast_val = float(val_losses[-1])\nlast_tr  = float(train_losses[-1])\ngap = last_val - last_tr\n\nprint(f\"Min val loss at epoch {min_ep}: {min_val:.6e}\")\nprint(f\"Last val loss: {last_val:.6e} | Last train loss: {last_tr:.6e} | Gap: {gap:.6e}\")\n\nif (last_val > min_val * 1.05) and (min_ep < 0.6 * len(val_losses)):\n    print(\"Model likely overfitting: validation loss increased after an early minimum.\")\nelif last_val <= min_val * 1.01 and last_tr <= last_val * 1.5:\n    print(\"Model looks good: no strong signs of overfitting.\")\nelse:\n    print(\"Borderline: mild overfitting may exist; review curves and possibly adjust regularization/epochs.\")\n\nprint(\"Saved weights:\", ckpt_path)\nprint(\"Saved R2 list:\", os.path.join(out_dir, \"r2_list_light.npy\"))\nprint(\"Saved history:\", os.path.join(out_dir, \"history.npy\"))\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-08-16T07:56:15.906034Z","iopub.execute_input":"2025-08-16T07:56:15.906742Z","iopub.s