f _guess_symbol_col(df):\n    \"\"\"Finds the element symbol column from a list of common candidates.\"\"\"\n    candidates = [\"symbol\", \"element\", \"species\", \"label\", \"name\", \"atomic_symbol\"]\n    for c in df.columns:\n        if c in candidates:\n            return c\n    raise ValueError(\"Element symbol column (symbol/element/...) not found in Excel.\")\n\ndef _guess_mass_like_cols(df):\n    \"\"\"Identifies columns related to atomic mass, to be excluded from features.\"\"\"\n    mass_like = []\n    for c in df.columns:\n        if any(k in c for k in [\"atomic_weight\", \"atomic_mass\", \"mass\", \"amu\", \"weight\"]):\n            mass_like.append(c)\n    return mass_like\n\ndef _read_excel_features(excel_path):\n    \"\"\"Reads the Excel file and creates a feature dictionary for each element.\"\"\"\n    df = pd.read_excel(excel_path)\n    df.columns = _normalize_cols(df.columns)\n    sym_col = _guess_symbol_col(df)\n    mass_cols = _guess_mass_like_cols(df)\n\n    # Input features are all columns except the symbol and mass-related ones.\n    feature_cols = [c for c in df.columns if c not in [sym_col] + mass_cols]\n\n    # Create a dictionary: symbol -> feature_vector\n    elem_features = {}\n    for _, r in df.iterrows():\n        sym = str(r[sym_col]).strip()\n        vals = r[feature_cols].astype(float).fillna(0.0).values\n        elem_features[sym] = vals\n\n    # Create a map for finding elements by mass if symbol is missing in YAML.\n    mass_map = None\n    mass_array = None\n    if mass_cols:\n        mcol = mass_cols[0]\n        mass_map = []\n        for _, r in df.iterrows():\n            sym = str(r[sym_col]).strip()\n            try:\n                mval = float(r[mcol])\n            except:\n                mval = np.nan\n            mass_map.append((mval, sym))\n        mass_map = [(m, s) for (m, s) in mass_map if np.isfinite(m)]\n        mass_array = np.array([m for m, _ in mass_map], dtype=float)\n\n    return elem_features, feature_cols, mass_map, mass_array\n\ndef _find_symbol_by_mass(mass, mass_map, mass_array, tol=0.5):\n    \"\"\"Fallback function: finds the closest element by mass.\"\"\"\n    if mass_map is None or mass_array is None or len(mass_array) == 0:\n        return None, None\n    diffs = np.abs(mass_array - mass)\n    idx = np.argmin(diffs)\n    best_mass, best_sym = mass_map[idx]\n    return best_sym, float(diffs[idx])\n\n# -----------------------\n# Step 1: Read Excel and prepare element feature dictionary.\n# This is done once for efficiency.\n# -----------------------\nelem_features, excel_feature_cols, mass_map, mass_array = _read_excel_features(excel_path)\nprint(f\"[Excel] Number of elemental features used: {len(excel_feature_cols)}\")\nprint(f\"[Excel] Sample features: {excel_feature_cols[:5]}\")\n\n# -----------------------\n# Step 2: First pass on YAML files to determine maximum dimensions for padding.\n# This is crucial for creating uniformly shaped tensors.\n# -----------------------\nmax_atoms = 0\nmax_bands = 0\nmax_qpoints = 0\nyaml_files = [f for f in os.listdir(yaml_folder) if f.endswith(\".yaml\")]\n\nfor file in yaml_files:\n    try:\n        with open(os.path.join(yaml_folder, file), \"r\") as f:\n            data = yaml.safe_load(f)\n        if not data or \"points\" not in data or \"phonon\" not in data:\n            continue\n        n_atoms = len(data[\"points\"])\n        n_q = len(data[\"phonon\"])\n        n_b = len(data[\"phonon\"][0].get(\"band\", [])) if n_q > 0 else 0\n        max_atoms = max(max_atoms, n_atoms)\n        max_qpoints = max(max_qpoints, n_q)\n        max_bands = max(max_bands, n_b)\n    except Exception as e:\n        print(f\"[COUNT] Skipping {file}: {e}\")\n\nprint(f\"[YAML] Max dimensions found: max_atoms={max_atoms}, max_qpoints={max_qpoints}, max_bands={max_bands}\")\n\n# Calculate the length of the feature vector for a single atom.\nper_atom_feature_len = 3 + 1 + len(excel_feature_cols) # 3 coords + 1 mass + excel features\n\n# -----------------------\n# Step 3: Main pass; build the feature matrix (X) and target tensor (y).\n# -----------------------\nX_list, Y_list = [], []\nmissing_symbol, mass_matched, zero_filled = 0, 0, 0\n\nfor file in yaml_files:\n    try:\n        with open(os.path.join(yaml_folder, file), \"r\") as f:\n            data = yaml.safe_load(f)\n        if not data or \"points\" not in data or \"phonon\" not in data:\n            continue\n\n        # --- Part A: Construct feature vector for each atom ---\n        atom_vecs = []\n        for pt in data[\"points\"]:\n            coords = list(pt.get(\"coordinates\", [0.0, 0.0, 0.0]))[:3]\n            mass_yaml = float(pt.get(\"mass\", 0.0))\n\n            sym = None\n            for key in [\"symbol\", \"label\", \"element\", \"species\", \"name\"]:\n                if key in pt and str(pt[key]).strip():\n                    sym = str(pt[key]).strip()\n                    break\n\n            feat_vec = None\n            if sym and sym in elem_features:\n                feat_vec = elem_features[sym]\n            else:\n                missing_symbol += 1\n                guessed_sym, diff = _find_symbol_by_mass(mass_yaml, mass_map, mass_array, tol=0.5)\n                if guessed_sym and guessed_sym in elem_features:\n                    feat_vec = elem_features[guessed_sym]\n                    mass_matched += 1\n                else:\n                    # Fallback: fill with zeros if no match is found.\n                    feat_vec = np.zeros(len(excel_feature_cols), dtype=float)\n                    zero_filled += 1\n\n            # Combine atomic info (coords, mass) with elemental features (from excel)\n            vec = np.concatenate([np.array(coords + [mass_yaml]), feat_vec.astype(float)])\n            atom_vecs.append(vec)\n\n        atom_mat = np.array(atom_vecs, dtype=float)\n        \n        # Pad the atom matrix to max_atoms\n        if atom_mat.shape[0] < max_atoms:\n            pad = np.zeros((max_ato