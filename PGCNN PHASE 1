 torch_geometric.nn import GINEConv, global_mean_pool\nexcept Exception as e:\n    print(\"PyTorch Geometric not found. Trying to install...\")\n    # در کگل ممکنه لازم باشه نسخه‌های سازگار نصب کنید؛\n    # اگر اینترنت بسته است، این بخش را حذف کنید و محیطی که pyg دارد استفاده کنید.\n    !pip -q install torch-geometric torch-scatter torch-sparse torch-cluster -f https://data.pyg.org/whl/torch-2.3.0+cu121.html\n    import torch_geometric\n    from torch_geometric.data import Data, Dataset, DataLoader\n    from torch_geometric.nn import GINEConv, global_mean_pool\n\n# -----------------------\n# مسیرها\n# -----------------------\nDATA_NPY = \"/kaggle/working/graph_dataset/graph_dataset.npy\"     # خروجی بخش A\nSCALER_Y = \"/kaggle/working/graph_dataset/scaler_y.pkl\"          # برای برگشت به مقیاس واقعی اگر خواستی\n\n# -----------------------\n# Dataset کلاس\n# -----------------------\nclass NPGraphDataset(Dataset):\n    def __init__(self, npy_path):\n        super().__init__()\n        self.samples = np.load(npy_path, allow_pickle=True)\n        # ثابت بودن طول y\n        self.y_len = self.samples[0]['y'].shape[0]\n\n    def len(self):\n        return len(self.samples)\n\n    def get(self, idx):\n        s = self.samples[idx].item() if isinstance(self.samples[idx], np.ndarray) else self.samples[idx]\n        x = torch.tensor(s['x'], dtype=torch.float32)                       # (N, Fx)\n        edge_index = torch.tensor(s['edge_index'], dtype=torch.long)        # (2, E)\n        edge_attr = torch.tensor(s['edge_attr'], dtype=torch.float32)       # (E, Fe)\n        pos = torch.tensor(s['pos'], dtype=torch.float32)                   # (N, 3)\n        u = torch.tensor(s['u'], dtype=torch.float32)                       # (Fu,)\n        y = torch.tensor(s['y'], dtype=torch.float32)                       # (T,)\n\n        data = Data(x=x, edge_index=edge_index, edge_attr=edge_attr, pos=pos, y=y)\n        data.u = u\n        return data\n\n# -----------------------\n# واگذاری train/val split\n# -----------------------\nfull_ds = NPGraphDataset(DATA_NPY)\nn_total = len(full_ds)\nn_val = max(1, int(0.2 * n_total))\nn_train = n_total - n_val\n\ngenerator = torch.Generator().manual_seed(42)\ntrain_ds, val_ds = torch.utils.data.random_split(full_ds, [n_train, n_val], generator=generator)\n\nbatch_size = 16\ntrain_loader = DataLoader(train_ds, batch_size=batch_size, shuffle=True)\nval_loader   = DataLoader(val_ds,   batch_size=batch_size, shuffle=False)\n\ndevice = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n\n# -----------------------\n# مدل: GINEConv با edge_attr + الحاق u (گلوبال) به رپ. گراف\n# -----------------------\ndef mlp(channels):\n    layers = []\n    for i in range(len(channels)-1):\n        layers += [nn.Linear(channels[i], channels[i+1]), nn.ReLU()]\n    return nn.Sequential(*layers)\n\nclass GraphRegressor(nn.Module):\n    def __init__(self, in_dim, edge_dim, u_dim, hidden_dim=128, out_dim=1, num_layers=2):\n        super().__init__()\n        \n        self.u_dim = u_dim\n        \n        # لایه اول برای تطبیق ابعاد edge features\n        self.edge_encoder = nn.Linear(edge_dim, hidden_dim)\n        \n        # ساخت لیست از GINEConv ها\n        self.convs = nn.ModuleList()\n        self.convs.append(GINEConv(mlp([in_dim, hidden_dim]), train_eps=True, edge_dim=hidden_dim))\n        for _ in range(num_layers - 1):\n            self.convs.append(GINEConv(mlp([hidden_dim, hidden_dim]), train_eps=True, edge_dim=hidden_dim))\n\n        self.relu = nn.ReLU()\n        \n        # محاسبه بعد ورودی head\n        head_input_dim = hidden_dim + u_dim\n        print(f\"Head input dimension: {head_input_dim}\")\n        \n        self.head = nn.Sequential(\n            nn.Linear(head_input_dim, 128),\n            nn.ReLU(),\n            nn.Linear(128, out_dim)\n        )\n\n    def forward(self, data):\n        x, edge_index, edge_attr, batch = data.x, data.edge_index, data.edge_attr, data.batch\n        u = data.u\n\n        # کدگذاری edge features\n        edge_attr_encoded = self.relu(self.edge_encoder(edge_attr))\n\n        for conv in self.convs:\n            x = self.relu(conv(x, edge_index, edge_attr_encoded))\n\n        g = global_mean_pool(x, batch)\n\n        # پردازش ویژگی global u\n        # u ممکن است به صورت مسطح (flatten) باشد، پس باید آن را reshape کنیم\n        if u.dim() == 1:\n            # محاسبه تعداد نمونه‌ها در batch\n            batch_size = g.size(0)\n            # reshape u به شکل [batch_size, u_dim]\n            u = u.reshape(batch_size, self.u_dim)\n        elif u.size(0) != g.size(0):\n            # اگر ابعاد مطابقت ندارند، reshape کنیم\n            batch_size = g.size(0)\n            u = u.reshape(batch_size, self.u_dim)\n\n        gu = torch.cat([g, u], dim=-1)\n        \n        out = self.head(gu)\n        return out\n\n# گرفتن یک نمونه برای کشف ابعاد\nsample0 = full_ds[0]\nin_node = sample0.x.shape[1]\nin_edge = sample0.edge_attr.shape[1]  # بعد edge features\nin_global = sample0.u.shape[0]  # اگر u یک بردار باشه\nout_dim = sample0.y.shape[0]\n\nprint(f\"Node feature dimension: {in_node}\")\nprint(f\"Edge feature dimension: {in_edge}\")\nprint(f\"Global feature dimension: {in_global}\")\nprint(f\"Output dimension: {out_dim}\")\n\nmodel = GraphRegressor(\n    in_dim=in_node,\n    edge_dim=in_edge,\n    u_dim=in_global,\n    hidden_dim=128,\n    out_dim=out_dim,\n    num_layers=3\n).to(device)\n\n# تست مدل با یک نمونه\nprint(\"Testing model with one sample...\")\ntest_sample = full_ds[0]\ntest_batch = next(iter(DataLoader([test_sample], batch_size=1)))\ntest_batch = test_batch.to(device)\n\ntry:\n    with torch.no_grad():\n        output = model(test_batch)\n        print(f\"Model output shape: {output.shape}\")\n        print(f\"Expected output shape: {test_batch.y.shape}\")\nexcept Exception as e:\n    print(f\"Error in model test: {e}\")\n\n# حالا با یک batch کوچک تست می‌کنیم\nprint(\"Testing model with small batch...\")\nsmall_batch = next(iter(DataLoader(full_ds[:2], batch_size=2)))\nsmall_batch = small_batch.to(device)\n\ntry:\n    with torch.no_grad():\n        output = model(small_batch)\n        print(f\"Model output shape: {output.shape}\")\n        print(f\"Expected output shape: {small_batch.y.shape}\")\nexcept Exception as e:\n    print(f\"Error in small batch test: {e}\")\n    import traceback\n    traceback.print_exc()\n\noptimizer = torch.optim.Adam(model.parameters(), lr=1e-3, weight_decay=1e-5)\n# تغییر loss function برای تطابق با ابعاد\ndef custom_loss_fn(pred, target):\n    # pred shape: [batch_size, out_dim]\n    # target shape: [batch_size * out_dim] (مسطح شده)\n    # باید target را به شکل [batch_size, out_dim] reshape کنیم\n    batch_size = pred.size(0)\n    out_dim = pred.size(1)\n    target_reshaped = target.reshape(batch_size, out_dim)\n    return F.mse_loss(pred, target_reshaped)\n\n# اگر scaler_y خواستی برای برگرداندن به مقیاس واقعی\nwith open(SCALER_Y, \"rb\") as f:\n    scaler_y = pickle.load(f)\n\n# -----------------------\n# آموزش\n# -----------------------\nepochs = 50\ntrain_losses, val_losses = [], []\n\ndef evaluate(loader):\n    model.eval()\n    total, n = 0.0, 0\n    with torch.no_grad():\n        for batch in loader:\n            batch = batch.to(device)\n            pred = model(batch)\n            loss = custom_loss_fn(pred, batch.y)\n            bs = batch.y.shape[0]\n            total += float(loss.item()) * bs\n            n += bs\n    return total / max(1, n)\n\nprint(\"🚀 Training starts...\")\nfor ep in range(1, epochs+1):\n    model.train()\n    running, n = 0.0, 0\n    for batch in tqdm(train_loader, desc=f\"Epoch {ep}/{epochs}\", leave=False):\n        batch = batch.to(device)\n        optimizer.zero_grad()\n        pred = model(batch)\n        loss = custom_loss_fn(pred, batch.y)\n        loss.backward()\n        optimizer.step()\n        bs = batch.y.shape[0]\n        running += float(loss.item()) * bs\n        n += bs\n\n    tr_loss = running / max(1, n)\n    va_loss = evaluate(val_loader)\n    train_losses.append(tr_loss)\n    val_losses.append(va_loss)\n    print(f\"Epoch {ep:02d} | Train: {tr_loss:.6f} | Val: {va_loss:.6f}\")\n\nprint(\"✅ Training finished.\")\n\n# -----------------------\n# نمودار loss ها\n# -----------------------\nplt.figure(figsize=(7,5))\nplt.plot(train_losses, label=\"Train\")\nplt.plot(val_losses, label=\"Val\")\nplt.xlabel(\"Epoch\"); plt.ylabel(\"MSE\"); plt.title(\"Loss Curves\"); plt.legend(); plt.tight_layout()\nplt.show()\n\n# -----------------------\n# رسم پیش‌بینی vs واقعی برای یک نمونه از val\n# -----------------------\nmodel.eval()\none_batch = next(iter(val_loader))\none_batch = one_batch.to(device)\nwith torch.no_grad():\n    y_pred_norm = model(one_batch).cpu().numpy()\ny_true_norm = one_batch.y.cpu().numpy()\n\n# reshape target به شکل صحیح\nbatch_size = y_pred_norm.shape[0]\nout_dim = y_pred_norm.shape[1]\ny_true_norm = y_true_norm.reshape(batch_size, out_dim)\n\n# فقط نمونه‌ی 0 از این batch\npred0 = y_pred_norm[0]\ntrue0 = y_true_norm[0]\n\n# اگر خواستی به واحد واقعی برگردی:\npred0_real = scaler_y.inverse_transform(pred0[None,:])[0]\ntrue0_real = scaler_y.inverse_transform(true0[None,:])[0]\n\n# دو نمودار جدا\nplt.figure(figsize=(12,4))\nplt.subplot(1,2,1)\nplt.plot(true0_real); plt.title(\"واقعی (Sample 0)\")\nplt.subplot(1,2,2)\nplt.plot(pred0_real); plt.title(\"پیش‌بینی‌شده (Sample 0)\")\nplt.tight_layout(); plt.show()\n\n# نمودار روی‌هم\nplt.figure(figsize=(8,5))\nplt.plot(true0_real, label=\"Real\", linewidth=2)\nplt.plot(pred0_real, label=\"Pred\", linestyle=\"--\")\nplt.legend(); plt.title(\"Comparison (Sample 0)\"); plt.tight_layout(); plt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-08-24T18:52:00.02566Z","iopub.execute_input":"2025-08-24T18:52:00.025961Z","iopub.status.idle":"2025-08-24T18:52:09.240949Z","shell.execute_reply.started":"2025-08-24T18:52:00.025938Z","shell.execute_reply":"2025-08-24T18:52:09.240157Z"}},"outputs":[{"name":"std