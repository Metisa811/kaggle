            if idx1 >= idx2: continue\n            shared = set([i1,j1]) & set([i2,j2])\n            if len(shared) == 1:\n                shared_atom = shared.pop()\n                a = positions[i1 if i1 != shared_atom else j1] - positions[shared_atom]\n                b = positions[i2 if i2 != shared_atom else j2] - positions[shared_atom]\n                cos_angle = np.dot(a, b) / (np.linalg.norm(a) * np.linalg.norm(b) + 1e-8)\n                cos_angle = np.clip(cos_angle, -1, 1)\n                angle = np.arccos(cos_angle)\n                edge_index.append([idx1, idx2])\n                edge_index.append([idx2, idx1])\n                edge_attr.extend([[angle], [angle]])\n    \n    edge_index = torch.tensor(edge_index, dtype=torch.long).t().contiguous() if edge_index else torch.zeros((2,0), dtype=torch.long)\n    edge_attr = torch.tensor(edge_attr, dtype=torch.float) if edge_attr else torch.zeros((0,1), dtype=torch.float)\n    \n    y = torch.tensor([target_value], dtype=torch.float)\n    u = torch.tensor([[structure.volume / len(positions), 1, structure.lattice.volume]], dtype=torch.float)\n    \n    return Data(x=x, edge_index=edge_index, edge_attr=edge_attr, y=y, u=u)","metadata":{"execution":{"iopub.status.busy":"2025-11-15T18:39:38.550528Z","iopub.execute_input":"2025-11-15T18:39:38.551035Z","iopub.status.idle":"2025-11-15T18:39:38.558773Z","shell.execute_reply.started":"2025-11-15T18:39:38.551011Z","shell.execute_reply":"2025-11-15T18:39:38.558131Z"}}},{"cell_type":"markdown","source":"## Convert crystal structure to atom graph (nodes=atoms, edges=distances)","metadata":{}},{"cell_type":"markdown","source":"def structure_to_graph2(structure, target_value, df_features):\n    structure = structure.copy()\n    structure.make_supercell([3, 3, 3])\n    \n    node_features = []\n    atomic_numbers = []\n    \n    for site in structure.sites:\n        symbol = site.specie.symbol\n        atomic_numbers.append(site.specie.Z)\n        \n        # فقط فیچرهای عددی رو بگیر\n        if symbol in df_features.index:\n            features = df_features.loc[symbol].values.astype(np.float32)\n        else:\n            features = np.zeros(n_atom_features, dtype=np.float32)\n        \n        node_features.append(features)\n    \n    x = torch.tensor(node_features, dtype=torch.float)\n    # بقیه کد مثل قبل...\n    z = torch.tensor(atomic_numbers, dtype=torch.long)\n    \n    # Positions\n    positions = np.array([site.coords for site in structure.sites])\n    pos = torch.tensor(positions, dtype=torch.float)\n    \n    # Edges with 5 angstrom cutoff in the entire supercell\n    distances = cdist(positions, positions)\n    edge_index = []\n    edge_attr = []\n    \n    cutoff = 8  # angstrom\n    \n    n_atoms = len(positions)\n    for i in range(n_atoms):\n        for j in range(n_atoms):\n            if i != j and distances[i, j] <= cutoff:\n                edge_index.append([i, j])\n                edge_attr.append([distances[i, j]])\n    \n    edge_index = torch.tensor(edge_index, dtype=torch.long).t().contiguous()\n    edge_attr = torch.tensor(edge_attr, dtype=torch.float)\n    \n    # Target and global features\n    y = torch.tensor([target_value], dtype=torch.float)\n    u = torch.tensor([[structure.volume / n_atoms]], dtype=torch.float)\n    \n    return Data(x=x, edge_index=edge_index, edge_attr=edge_attr, y=y, pos=pos, z=z, u=u)\n","metadata":{"execution":{"iopub.status.busy":"2025-11-15T18:41:20.274512Z","iopub.execute_input":"2025-11-15T18:41:20.275094Z","iopub.status.idle":"2025-11-15T18:41:20.284008Z","shell.execute_reply.started":"2025-11-15T18:41:20.275068Z","shell.execute_reply":"2025-11-15T18:41:20.283037Z"}}},{"cell_type":"markdown","source":"### Define dual graph GNN model with custom message passing","metadata":{}},{"cell_type":"code","source":"# Cell 5\nclass CustomMessagePassing(nn.Module):\n    \"\"\"\n    لایه انتقال پیام (Message Passing) با مکانیزم Attention.\n    این لایه شبیه به GATv2 عمل می‌کند اما سبک‌تر است.\n    \"\"\"\n    def __init__(self, hidden_dim):\n        super().__init__()\n        self.hidden_dim = hidden_dim\n        \n        # شبکه تشخیص اهمیت همسایه‌ها (Attention)\n        self.attention_mlp = nn.Sequential(\n            nn.Linear(3 * hidden_dim, hidden_dim),\n            nn.LayerNorm(hidden_dim),\n            nn.SiLU(),\n            nn.Linear(hidden_dim, 1),\n            nn.LeakyReLU(0.2)\n        )\n        \n        # شبکه پردازش پیام\n        self.message_mlp = nn.Sequential(\n            nn.Linear(hidden_dim, hidden_dim),\n            nn.SiLU(),\n            nn.Linear(hidden_dim, hidden_dim), # لایه اضافه برای قدرت بیشتر\n        )\n    \n    def forward(self, x, edge_index, edge_attr):\n        source_nodes = edge_index[0]\n        target_nodes = edge_index[1]\n        \n        neighbor_features = x[source_nodes]\n        target_features = x[target_nodes]\n        \n        # محاسبه امتیاز توجه (Attention Score)\n        # ورودی: فیچر مبدا + فیچر مقصد + فیچر یال\n        attention_input = torch.cat([target_features, neighbor_features, edge_attr], dim=1)\n        attention_scores = self.attention_mlp(attention_input)\n        \n        # نرمال‌سازی امتیازها با Softmax\n        attention_weights = softmax(attention_scores, target_nodes, num_nodes=x.size(0))\n        \n        # ساخت پیام و اعمال وزن\n        messages = neighbor_features * edge_attr # ترکیب اطلاعات همسایه و یال\n        weighted_messages = messages * attention_weights\n        \n        # جمع‌آوری پیام‌ها در نود مقصد\n        aggregated = torch.zeros_like(x)\n        aggregated.index_add_(0, target_nodes, weighted_messages)\n        \n        # پردازش نهایی\n        output = self.message_mlp(aggregated)\n        return output\n\nclass DualGraphGNN(nn.Module):\n    def __init__(self, n_bond_features=6, n_atom_features=7, edge_dim=1, k=64):\n        super().__init__()\n        self.k = k # تعداد فیچرهای تصادفی Sketch\n        hidden = 128 # افزایش سایز لایه مخفی برای قدرت بیشتر\n        \n        print(f\"🏗️ Building DualGraphGNN: Hidden={hidden}, AtomFeats={n_atom_features}, SketchK={k}\")\n\n        # --- بخش ۱: گراف پیوند (Bond Graph) ---\n        self.bond_embedding = nn.Sequential(\n            nn.Linear(n_bond_features, hidden),\n            nn.LayerNorm(hidden),\n            nn.SiLU()\n        )\n        self.bond_edge_embedding = nn.Linear(edge_dim, hidden)\n        \n        self.bond_layers = nn.ModuleList([CustomMessagePassing(hidden) for _ in range(4)])\n        self.bond_norms = nn.ModuleList([nn.LayerNorm(hidden) for _ in range(4)])\n        \n        # --- بخش ۲: گراف اتم (Atom Graph) + Sketch ---\n        # ورودی اتم: فیچرهای اصلی + k فیچر Sketch\n        self.atom_embedding = nn.Sequential(\n            nn.Linear(n_atom_features + k, hidden), \n            nn.LayerNorm(hidden),\n            nn.SiLU()\n        )\n        self.atom_edge_embedding = nn.Linear(edge_dim, hidden)\n        \n        self.atom_layers = nn.ModuleList([CustomMessagePassing(hidden) for _ in range(3)])\n        self.atom_norms = nn.ModuleList([nn.LayerNorm(hidden) for _ in range(3)])\n\n        # --- پارامترهای Sketch (Random Fourier Features) ---\n        # ماتریس W و بردار b برای تصویرسازی تصادفی (ثابت و غیرقابل آموزش)\n        self.register_buffer('W', torch.randn(n_atom_features, k) * 0.5) # مقیاس‌دهی مهم است\n        self.register_buffer('b', torch.rand(k) * 2 * np.pi)\n\n        # --- بخش ۳: ترکیب و خروجی (Readout) ---\n        from torch_geometric.nn import global_mean_pool, global_max_pool\n        \n        # لایه نهایی\n        # ورودی: (Bond_Mean + Bond_Max) + (Atom_Mean + Atom_Max) + Global_Info\n        final_input_dim = (2 * hidden) + (2 * hidden) + hidden//2\n        \n        self.global_mlp = nn.Sequential(nn.Linear(3, hidden // 2), nn.SiLU()) # پردازش فیچرهای سراسری مثل حجم\n        \n        self.output_block = nn.Sequential(\n            nn.Linear(final_input_dim, 256),\n            nn.SiLU(),\n            nn.Dropout(0.2), # جلوگیری از Overfit\n            nn.Linear(256, 128),\n            nn.SiLU(),\n            nn.Linear(128, 1) # خروجی نهایی: فرکانس\n        )\n\n    def forward(self, bond_data, atom_data):\n        # 1. پردازش گراف پیوند\n        x_bond = self.bond_embedding(bond_data.x)\n        e_bond = self.bond_edge_embedding(bond_data.edge_attr)\n        \n        for mp, norm in zip(self.bond_layers, self.bond_norms):\n            res = x_bond\n            x_bond = mp(x_bond, bond_data.edge_index, e_bond)\n            x_bond = norm(x_bond + res) # Residual Connection\n        \n        # پولینگ گراف پیوند\n        bond_pool = torch.cat([\n            global_mean_pool(x_bond, bond_data.batch),\n            global_max_pool(x_bond, bond_data.batch)\n        ], dim=1)\n\n        # 2. پردازش گراف اتم با Sketch\n        x_atom_raw = atom_data.x\n        \n        # === Sketching Algorithm ===\n        # φ(x) = cos(Wx + b)\n        sketch_features = torch.cos(x_atom_raw @ self.W + self.b)\n        # اتصال اسکچ به فیچرهای اصلی\n        x_atom = torch.cat([x_atom_raw, sketch_features], dim=1)\n        \n        x_atom = self.atom_embedding(x_atom)\n        e_atom = self.atom_edge_embedding(atom_data.edge_attr)\n        \n        for mp, norm in zip(self.atom_layers, self.atom_norms):\n            res = x_atom\n            x_atom = mp(x_atom, atom_data.edge_index, e_atom)\n            x_atom = norm(x_atom + res)\n            \n        # پولینگ گراف اتم\n        atom_pool = torch.cat([\n            global_mean_pool(x_atom, atom_data.batch),\n            global_max_pool(x_atom, atom_data.batch)\n        ], dim=1)\n\n        # 3. اطلاعات سراسری (Global)\n        # bond_data.u شامل اطلاعات حجم و تعداد اتم‌هاست\n        global_info = self.global_mlp(bond_data.u)\n\n        # 4. ترکیب نهایی\n        combined = torch.cat([bond_pool, atom_pool, global_info], dim=1)\n        out = self.output_block(combined)\n        \n        return out\n\n# تست اولیه ساخت مدل\ndevice = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n# n_atom_features=7 (از مرحله قبل)\nmodel = DualGraphGNN(n_bond_features=6, n_atom_features=n_atom_features, edge_dim=1, k=64).to(device)\nprint(f\"✅ Model created with {sum(p.numel() for p in model.parameters()):,} parameters.\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-12-06T17:37:14.987613Z","iopub.execute_input":"2025-12-06T17:37:14.988299Z","iopub.status.idle":"2025-12-06T17:37:15.178491Z","shell.execute_reply.started":"2025-12-06T17:37:14.988275Z","shell.execute_reply":"2025-12-06T17:37:15.177632Z"}},"outputs":[{"name":"stdout","text":"🏗️ Building DualGraphGNN: Hidden=128, AtomFeats=7, SketchK=64\n✅ Model created with 772,744 parameters.\n","output_type":"stream"}],"execution_count":4},{"cell_type":"code","source":"# Cell 6\nfrom scipy.spatial.distance import cdist\n\ndef structure_to_bond_graph(structure, target_value=0.0):\n    \"\"\"\n    تبدیل ساختار به گراف پیوند (Bond Graph).\n    نودها = پیوندها\n    یال‌ها = زاویه بین پیوندها\n    \"\"\"\n    s = structure.copy()\n    # سوپرسل نمی‌سازیم یا خیلی کوچک می‌سازیم تا گراف سنگین نشود\n    # s.make_supercell([1, 1, 1]) \n    \n    pos = s.cart_coords\n    # کات‌آف کمتر برای پیوندها (فقط پیوندهای واقعی مهم هستند)\n    cutoff = 4.5 \n    dists = cdist(pos, pos)\n    \n    # پیدا کردن پیوندها (Bonds)\n    # فرمت: (اتم مبدا، اتم مقصد)\n    bonds = []\n    bond_features = []\n    \n    for i in range(len(pos)):\n        for j in range(i+1, len(pos)): # j > i برای جلوگیری از تکرار\n            d = dists[i, j]\n            if d <= cutoff and d > 0.1:\n                # ویژگی‌های نود (که اینجا خود پیوند است)\n                # فاصله، شعاع کووالانسی تقریبی (ساده شده)\n                f = [d, 1.0/d, d**2, 0.0, 0.0, 0.0] \n                bonds.append((i, j))\n                bond_features.append(f)\n                \n    if len(bonds) == 0:\n        # هندل کردن حالت خاص (تک اتم یا بدون پیوند)\n        return Data(x=torch.zeros((1, 6)), edge_index=torch.zeros((2,0), dtype=torch.long), \n                   edge_attr=torch.zeros((0,1)), y=torch.tensor([target_value]), \n                   u=torch.tensor([[0,0,0]]))\n\n    # تبدیل به تنسور\n    x = torch.tensor(bond_features, dtype=torch.float)\n    \n    # ساختن یال‌های گرافِ پیوند (که می‌شوند زاویه‌ها)\n    # دو پیوند اگر یک اتم مشترک داشته باشند، با هم زاویه می‌سازند\n    edge_indices = []\n    edge_attrs = []\n    \n    for idx1, (i1, j1) in enumerate(bonds):\n        for idx2, (i2, j2) in enumerate(bonds):\n            if idx1 == idx2: continue\n            \n            # پیدا کردن اتم مشترک\n            shared = None\n            other1 = None\n            other2 = None\n            \n            if i1 == i2: shared=i1; other1=j1; other2=j2\n            elif i1 == j2: shared=i1; other1=j1; other2=i2\n            elif j1 == i2: shared=j1; other1=i1; other2=j2\n            elif j1 == j2: shared=j1; other1=i1; other2=i2\n            \n            if shared is not None:\n                # محاسبه زاویه با ضرب داخلی بردارها\n                v1 = pos[other1] - pos[shared]\n                v2 = pos[other2] - pos[shared]\n                \n                # نرمال‌سازی\n                l1 = np.linalg.norm(v1)\n                l2 = np.linalg.norm(v2)\n                \n                if l1 > 0 and l2 > 0:\n                    cos_a = np.dot(v1, v2) / (l1 * l2)\n                    cos_a = np.clip(cos_a, -1.0, 1.0)\n                    angle = np.arccos(cos_a)\n                    \n                    edge_indices.append([idx1, idx2])\n                    edge_attrs.append([angle])\n\n    if len(edge_indices) > 0:\n        edge_index = torch.tensor(edge_indices, dtype=torch.long).t().contiguous()\n        edge_attr = torch.tensor(edge_attrs, dtype=torch.float)\n    else:\n        edge_index = torch.zeros((2, 0), dtype=torch.long)\n        edge_attr = torch.zeros((0, 1), dtype=torch.float)\n\n    y = torch.tensor([target_value], dtype=torch.float)\n    \n    # ویژگی‌های سراسری (Global)\n    # حجم، چگالی اتمی، متوسط طول پیوند\n    vol = s.volume\n    density = len(s) / vol\n    mean_bond_len = np.mean([bf[0] for bf in bond_features]) if bond_features else 0\n    u = torch.tensor([[vol, density, mean_bond_len]], dtype=torch.float)\n\n    return Data(x=x, edge_index=edge_index, edge_attr=edge_attr, y=y, u=u)\n\n\ndef structure_to_atom_graph(structure, target_value=0.0):\n    \"\"\"\n    تبدیل ساختار به گراف اتم (Atom Graph).\n    استفاده از دیکشنری فیچرهای آپتیمایز شده.\n    \"\"\"\n    s = structure.copy()\n    # سوپرسل کوچک برای دیدن همسایه‌های دورتر در گراف اتم\n    # s.make_supercell([2, 2, 2]) # این ممکنه رم رو پر کنه، فعلا غیرفعال میکنیم اگر نیاز بود\n    \n    pos = s.cart_coords\n    atomic_numbers = [site.specie.Z for site in s.sites]\n    symbols = [site.specie.symbol for site in s.sites]\n    \n    # 1. ساخت ویژگی‌های نود (Features)\n    node_features = []\n    for sym in symbols:\n        if sym in atom_feature_dict:\n            node_features.append(atom_feature_dict[sym])\n        else:\n            # اگر عنصری ناشناخته بود (نباید اتفاق بیفتد)\n            node_features.append(torch.zeros(n_atom_features))\n            \n    x = torch.stack(node_features) # [N_atoms, n_features]\n    \n    # 2. محاسبه یال‌ها (Edges) با کات‌آف بزرگتر\n    cutoff = 8.0 \n    dists = cdist(pos, pos)\n    \n    edge_indices = []\n    edge_attrs = []\n    \n    for i in range(len(pos)):\n        for j in range(len(pos)):\n            if i == j: continue\n            d = dists[i, j]\n            if d <= cutoff:\n                edge_indices.append([i, j])\n                # فاصله را با تابع گوسین بسط می‌دهیم (RBF) تا مدل بهتر بفهمد\n                edge_attrs.append([d]) \n                \n    if len(edge_indices) > 0:\n        edge_index = torch.tensor(edge_indices, dtype=torch.long).t().contiguous()\n        edge_attr = torch.tensor(edge_attrs, dtype=torch.float)\n    else:\n        edge_index = torch.zeros((2, 0), dtype=torch.long)\n        edge_att