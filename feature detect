ed, x=x_feature, y=y_feature, hue=\"outlier\",\n                palette={False:\"royalblue\", True:\"red\"}, s=40, alpha=0.8)\nplt.title(f\"{x_feature} vs {y_feature} (Outliers in Red)\")\nplt.grid(True, alpha=0.3)\nplt.show()\n\n# --- 6. خوشه‌بندی ---\nscaler = StandardScaler()\nnum_cols = merged.select_dtypes(include=[np.number]).columns\nX = scaler.fit_transform(merged[num_cols].fillna(0))\n\nkmeans = KMeans(n_clusters=4, random_state=0, n_init=10)\nmerged['cluster'] = kmeans.fit_predict(X)\n\n# --- 7. کاهش ابعاد برای دیدن خوشه‌ها ---\npca = PCA(n_components=2)\nreduced = pca.fit_transform(X)\nmerged['PC1'], merged['PC2'] = reduced[:,0], reduced[:,1]\n\nsns.scatterplot(data=merged, x=\"PC1\", y=\"PC2\", hue=\"cluster\", palette=\"tab10\")\nplt.title(\"Clusters of Materials (PCA Projection)\")\nplt.show()\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-11-06T07:44:12.886404Z","iopub.execute_input":"2025-11-06T07:44:12.886908Z","iopub.status.idle":"2025-11-06T07:44:14.524755Z","shell.execute_reply.started":"2025-11-06T07:44:12.886882Z","shell.execute_reply":"2025-11-06T07:44:14.523984Z"}},"outputs":[{"name":"stdout","text":"✅ تعداد مواد نهایی برای تحلیل: 534\n","output_type":"stream"},{"name":"stderr","text":"/usr/local/lib/python3.11/dist-packages/scipy/stats/_stats_py.py:2893: RuntimeWarning: invalid value encountered in less_equal\n  zero = std <= xp.abs(eps * mn)\n/tmp/ipykernel_37/1238751364.py:54: RuntimeWarning: invalid value encountered in greater\n  merged['outlier'] = np.abs(zscore(merged['residual'])) > 2\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 640x480 with 1 Axes>","image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"<Figure size 640x480 with 1 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":2},{"cell_type":"code","source":"\"\"\"\nGNN-based materials analysis pipeline (unsupervised embeddings + clustering + outlier detection)\n\nInputs (Kaggle):\n- /kaggle/input/features-dataset/ptable2.csv\n- /kaggle/input/features-dataset/mechanical_data_fixed.json\n\nOutputs:\n- /kaggle/working/gnn_embeddings.csv  (embeddings + clusters + outlier flag)\n- /kaggle/working/GNN_Materials_Report.pdf (PCA / t-SNE / clusters / outliers plots)\n\nNotes:\n- This code implements a lightweight Graph Convolutional Encoder (GCN) without requiring PyTorch-Geometric.\n- It builds a k-NN graph between materials in the feature space, learns node embeddings by training\n  a graph autoencoder (reconstruct adjacency via inner-product), then clusters embeddings and\n  detects outliers.\n\nRun in Kaggle CPU runtime. Torch is used; if not available install appropriate torch wheel.\n\"\"\"\n\nimport os\nimport re\nimport json\nimport math\nimport time\nimport numpy as np\nimport pandas as pd\nimport matplotlib.pyplot as plt\nimport seaborn as sns\nfrom sklearn.preprocessing import StandardScaler\nfrom sklearn.decomposition import PCA\nfrom sklearn.manifold import TSNE\nfrom sklearn.cluster import KMeans\nfrom sklearn.ensemble import IsolationForest\nfrom sklearn.neighbors import NearestNeighbors\nfrom sklearn.metrics import pairwise_distances\nfrom matplotlib.backends.backend_pdf import PdfPages\n\nimport torch\nimport torch.nn as nn\nimport torch.nn.functional as F\nfrom torch.optim import Adam\n\n# -------------------- Helpers --------------------\n\ndef parse_formula(formula):\n    return re.findall(r'([A-Z][a-z]?)(\\d*)', formula)\n\ndef extract_elements(formula):\n    matches = parse_formula(formula)\n    comp = []\n    for el, n in matches:\n        count = int(n) if n else 1\n        comp.extend([el]*count)\n    return comp\n\n# -------------------- I/O --------------------\nptable_path = \"/kaggle/input/features-dataset/ptable2.csv\"\nmech_json_path = \"/kaggle/input/features-dataset/mechanical_data_fixed.json\"\n\nptable_df = pd.read_csv(ptable_path)\nwith open(mech_json_path, 'r') as f:\n    mech_list = json.load(f)\nmech_df = pd.DataFrame(mech_list)\n\n# normalize element column name\nif 'symbol' in ptable_df.columns:\n    ptable_df = ptable_df.rename(columns={'symbol':'element'})\nptable_df['element'] = ptable_df['element'].astype(str).str.strip()\n\n# Filter numeric columns in periodic table\nnumeric_cols = ptable_df.select_dtypes(include=[np.number]).columns.tolist()\n# remove index-like columns accidentally present\nnumeric_cols = [c for c in numeric_cols if c != 'atomic_number' or c in ptable_df.columns]\n\n# Build per-material averaged element features (weighted by stoichiometry)\nmaterials = []\nrows = []\nfor _, r in mech_df.iterrows():\n    mat = r['material']\n    elems = extract_elements(mat)\n    if len(elems) == 0:\n        continue\n    sub = ptable_df[ptable_df['element'].isin(elems)]\n    if sub.empty:\n        continue\n    # compute weighted average by counts\n    # Build counts dict\n    counts = {}\n    for el in elems:\n        counts[el] = counts.get(el, 0) + 1\n    total = sum(counts.values())\n    # collect numeric columns and average\n    vals = {}\n    for col in numeric_cols:\n        # compute weighted mean\n        s = 0.0\n        for el, cnt in counts.items():\n            row_el = sub[sub['element'] == el]\n            if row_el.shape[0] == 0:\n                s += 0.0\n            else:\n                # take first matching (ptable has one row per element)\n                v = row_el[col].values[0]\n                try:\n                    v = float(v)\n                except:\n                    v = np.nan\n                s += (v if not np.isnan(v) else 0.0) * cnt\n        vals[col] = s/total\n    vals['material'] = mat\n    # append mechanical properties too\n    for k,v in r.items():\n        if k != 'material':\n            vals[k] = v\n    rows.append(vals)\n\nfeatures_df = pd.DataFrame(rows)\nfeatures_df = features_df.dropna(axis=1, how='all')\n\n# choose numeric features for node attributes\nnum_cols = features_df.select_dtypes(include=[np.number]).columns.tolist()\n# remove mechanical target columns from attribute set (keep them as labels/aux)\nmech_cols = ['C11','C12','C13','C33','C44','C66','B_Hill','G_Hill','E_Hill']\nattr_cols = [c for c in num_cols if c not in mech_cols]\n\nprint(f\"Materials: {features_df.shape[0]}, attribute dims: {len(attr_cols)}\")\n\n# build feature matrix X (materials x features)\nX = features_df[attr_cols].fillna(0).values.astype(np.float32)\nscaler = StandardScaler()\nX_scaled = scaler.fit_transform(X)\n\n# -------------------- Build k-NN graph --------------------\nk = 8\nnbrs = NearestNeighbors(n_neighbors=k+1, algorithm='auto').fit(X_scaled)\ndists, indices = nbrs.kneighbors(X_scaled)\n\nn = X_scaled.shape[0]\nadj = np.zeros((n,n), dtype=np.float32)\nfor i in range(n):\n    for j in indices[i,1:]:\n        adj[i,j] = 1.0\n        adj[j,i] = 1.0\n\n# ensure adjacency has self-loops for GCN if desired\nuse_self_loop = True\nif use_self_loop:\n    np.fill_diagonal(adj, 1.0)\n\n# -------------------- PyTorch GCN Autoencoder --------------------\n# Simple GCN layer\nclass GCNLayer(nn.Module):\n    def __init__(self, in_dim, out_dim):\n        super().__init__()\n        self.W = nn.Linear(in_dim, out_dim, bias=False)\n\n    def forward(self, X, A_norm):\n        # A_norm shape [n,n], X [n, in_dim]\n        return A_norm @ self.W(X)\n\nclass GCNEncoder(nn.Module):\n    def __init__(self, in_dim, hid_dim, emb_dim):\n        super().__init__()\n        self.gc1 = GCNLayer(in_dim, hid_dim)\n        self.gc2 = GCNLayer(hid_dim, emb_dim)\n\n    def forward(self, X, A_norm):\n        h = F.relu(self.gc1(X, A_norm))\n        z = self.gc2(h, A_norm)\n        return z\n\n# compute normalized adjacency for GCN: A_hat = D^{-1/2} A D^{-1/2}\nA = adj.copy()\nD = np.sum(A, axis=1)\nD_inv_sqrt = np.diag(1.0/np.sqrt(D + 1e-12))\nA_norm = D_inv_sqrt @ A @ D_inv_sqrt\nA_norm = torch.from_numpy(A_norm).float()\n\nX_t = torch.from_numpy(X_scaled).float()\n\nin_dim = X_t.shape[1]\nhid_dim = 64\nemb_dim = 32\nencoder = GCNEncoder(in_dim, hid_dim, emb_dim)\noptimizer = Adam(encoder.parameters(), lr=1e-3, weight_decay=1e-5)\n\n# Training: reconstruct adjacency via inner product of embeddings\nepochs = 400\n# prepare adjacency positive pairs\nA_tensor = torch.from_numpy(adj)\n\nfor epoch in range(1, epochs+1):\n    encoder.train()\n    optimizer.zero_grad()\n    Z = encoder(X_t, A_norm)  # [n, emb_dim]\n    # reconstruct adjacency\n    recon = torch.sigmoid(Z @ Z.t())\n    loss = F.binary_cross_entropy(recon, A_tensor)\n    loss.backward()\n    optimizer.step()\n    if epoch % 50 == 0 or epoch==1:\n        print(f\"Epoch {epoch}/{epochs}  loss={loss.item():.6f}\")\n\n# extract embeddings\nencoder.eval()\nwith torch.no_grad():\n    Z = encoder(X_t, A_norm).cpu().numpy()\n\n# -------------------- Clustering on embeddings --------------------\nkmeans = KMeans(n_clusters=4, random_state=0, n_init=10)\nclusters = kmeans.fit_predict(Z)\n\n# outlier detection in embedding space\niso = IsolationForest(contamination=0.05, random_state=42)\noutlier_flag = iso.fit_predict(Z)\noutlier_flag = np.where(outlier_flag == -1, 1, 0)  # 1 -> outlier\n\n# attach results to dataframe\nfeatures_df['cluster_gnn'] = clusters\nfeatures_df['is_outlier_gnn'] = outlier_flag\n\n# save embeddings + metadata\nemb_cols = [f'emb_{i}' for i in range(Z.shape[1])]\nemb_df = pd.DataFrame(Z, columns=emb_cols)\nout_df = pd.concat([features_df.reset_index(drop=True), emb_df], axis=1)\nout_df.to_csv('/kaggle/working/gnn_embeddings.csv', index=False)\nprint('Saved embeddings to /kaggle/working/gnn_embeddings.csv')\n\n# -------------------- Visualization and PDF report --------------------\npdf_path = '/kaggle/working/GNN_Materials_Report.pdf'\nsns.set(style='whitegrid')\nwith PdfPages(pdf_path) as pdf:\n    # PCA on embeddings\n    pca = PCA(n_components=2)\n    pca_emb = pca.fit_transform(Z)\n    fig, ax = plt.subplots(figsize=(7,6))\n    sc = ax.scatter(pca_emb[:,0], pca_emb[:,1], c=clusters, cmap='ta