uilding graphs\"):\n    material_name = os.path.basename(poscar_path)\n    graph = build_graph_from_poscar(poscar_path, element_features_dict, cutoff)\n\n    out_path = os.path.join(output_dir, material_name + \".npz\")\n    np.savez(out_path,\n             node_features=graph[\"node_features\"],\n             edge_index=graph[\"edge_index\"],\n             edge_attr=graph[\"edge_attr\"])\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-09-21T15:38:31.559072Z","iopub.execute_input":"2025-09-21T15:38:31.559452Z","iopub.status.idle":"2025-09-21T15:38:31.570947Z","shell.execute_reply.started":"2025-09-21T15:38:31.559428Z","shell.execute_reply":"2025-09-21T15:38:31.570327Z"}},"outputs":[{"name":"stdout","text":"تعداد فایل POSCAR: 0\n","output_type":"stream"},{"name":"stderr","text":"Building graphs: 0it [00:00, ?it/s]\n","output_type":"stream"}],"execution_count":13},{"cell_type":"code","source":"","metadata":{"trusted":true},"outputs":[],"execution_count":null}]}