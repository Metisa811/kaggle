49:01.522838Z"}},"outputs":[{"name":"stdout","text":"Zipped successfully!\n","output_type":"stream"}],"execution_count":3},{"cell_type":"markdown","source":"## *new edition of PG-GNN and modification of its guided physical loss code*","metadata":{}},{"cell_type":"code","source":"# -*- coding: utf-8 -*-\nimport os\nimport numpy as np\nimport tensorflow as tf\nfrom sklearn.metrics import r2_score\nimport matplotlib.pyplot as plt\nimport pickle\nfrom tqdm import tqdm\nimport phonopy\nfrom phonopy.units import VaspToTHz # وارد کردن صحیح فاکتور تبدیل\nfrom scipy.signal import savgol_filter\n\n# -----------------------\n# مسیرها و تنظیمات ثابت\n# -----------------------\nDATA_FILE = \"/kaggle/input/pg-gnn-dataset1/phonopy_gnn_dataset.pkl\"\nOUT_DIR = \"/kaggle/working/pg_gnn_results\"\nos.makedirs(OUT_DIR, exist_ok=True)\n\n# -----------------------\n# هایپرپارامترها\n# -----------------------\nBATCH_SIZE = 4      # می‌توانید برای اجرای سریع‌تر، این عدد را افزایش دهید\nEPOCHS = 100        # برای نتایج بهتر، تعداد эпох‌ها را افزایش دهید\nLEARNING_RATE = 1e-4\nPHYSICS_LOSS_WEIGHT = 0.01 # ضریب اهمیت زیان فیزیکی\n\n# ----------------------------------------------------\n# تابع زیان فیزیکی (قلب مدل Physics-Informed)\n# ----------------------------------------------------\ndef calculate_physical_loss(phonopy_instance, pred_frequencies_thz):\n    \"\"\"\n    زیان فیزیکی را بر اساس معادله دترمینان محاسبه می‌کند.\n    این تابع در NumPy اجرا می‌شود.\n    \"\"\"\n    try:\n        # دریافت ماتریس دینامیکی در نقطه گاما\n        D_matrix = phonopy_instance.get_dynamical_matrix_at_q([0, 0, 0])\n        num_bands = len(phonopy_instance.primitive) * 3\n        identity_matrix = np.eye(num_bands, dtype=np.complex128)\n\n        total_determinant_sq_loss = 0.0\n        \n        for nu_pred in pred_frequencies_thz:\n            # تبدیل فرکانس پیش‌بینی شده (THz) به مقدار ویژه در واحد داخلی ماتریس D\n            eigval_internal = np.sign(nu_pred) * (nu_pred / VaspToTHz) ** 2\n            \n            # ساخت ماتریس M = D - w^2 * I\n            M = D_matrix - eigval_internal * identity_matrix\n            \n            # محاسبه دترمینان و افزودن مربع قدر مطلق آن به زیان\n            det_M = np.linalg.det(M)\n            total_determinant_sq_loss += np.abs(det_M)**2\n\n        # نرمال‌سازی زیان بر اساس تعداد باندها\n        return total_determinant_sq_loss / num_bands\n    except Exception as e:\n        # در صورت بروز هرگونه خطا در Phonopy، یک مقدار زیان بزرگ برگردانده می‌شود\n        tqdm.write(f\"خطا در محاسبه زیان فیزیکی: {e}\")\n        return 1e10 # مقدار ثابت بزرگ برای خطا\n\n# ----------------------------------------------------\n# لفاف‌بندی زیان فیزیکی برای TensorFlow با گرادیان نایب\n# ----------------------------------------------------\nmse_loss_fn = tf.keras.losses.MeanSquaredError()\n\n@tf.custom_gradient\ndef physical_loss_with_proxy_grad(predicted_gamma_freqs, true_gamma_freqs, poscar_path, fc_path, supercell_matrix_pkl):\n    \"\"\"\n    این تابع زیان فیزیکی (که در NumPy است) را در گراف TensorFlow قرار می‌دهد\n    و یک گرادیان نایب (MSE) برای آن تعریف می‌کند.\n    \"\"\"\n    \n    # بخش Forward Pass: اجرای تابع NumPy\n    def forward_pass_wrapper(preds_tensor, poscar_path_tensor, fc_path_tensor, supercell_matrix_pkl_tensor):\n        preds_np = preds_tensor.numpy().flatten()\n        poscar_path = poscar_path_tensor.numpy().decode('utf-8')\n        fc_path = fc_path_tensor.numpy().decode('utf-8')\n        supercell_matrix = pickle.loads(supercell_matrix_pkl_tensor.numpy())\n\n        try:\n            # بارگذاری نمونه Phonopy فقط برای این محاسبه\n            ph_instance = phonopy.load(\n                unitcell_filename=poscar_path,\n                force_constants_filename=fc_path,\n                supercell_matrix=supercell_matrix,\n                is_nac=False, \n                log_level=3) # **تصحیح کلیدی:** افزایش log_level برای ساکت کردن خروجی\n            \n            phy_loss = calculate_physical_loss(ph_instance, preds_np)\n            return np.float32(phy_loss)\n        except Exception as e:\n            tqdm.write(f\"خطا در بارگذاری Phonopy برای {os.path.basename(poscar_path)}: {e}\")\n            return np.float32(1e10) # بازگرداندن زیان بزرگ\n\n    # اجرای تابع NumPy در محیط TensorFlow\n    phy_loss_val = tf.py_function(\n        func=forward_pass_wrapper,\n        inp=[predicted_gamma_freqs, poscar_path, fc_path, supercell_matrix_pkl],\n        Tout=tf.float32\n    )\n\n    # بخش Backward Pass: تعریف گرادیان\n    def grad_fn(dy):\n        # ما نمی‌توانیم گرادیان واقعی را محاسبه کنیم، پس از یک نایب (proxy) استفاده می‌کنیم.\n        with tf.GradientTape() as tape_proxy:\n            tape_proxy.watch(predicted_gamma_freqs)\n            # استفاده از شیء زیان که قبلاً ساخته شده\n            proxy_loss = mse_loss_fn(true_gamma_freqs, predicted_gamma_freqs)\n        \n        proxy_gradient = tape_proxy.gradient(proxy_loss, predicted_gamma_freqs)\n        return (dy * proxy_gradient, None, None, None, None)\n\n    return phy_loss_val, grad_fn\n\n# -----------------------\n# مدل GNN (بدون تغییر)\n# -----------------------\nclass SimpleGNN(tf.keras.Model):\n    def __init__(self, node_dim, output_dim):\n        super(SimpleGNN, self).__init__()\n        self.dense1 = tf.keras.layers.Dense(128, activation='relu')\n        self.dense2 = tf.keras.layers.Dense(128, activation='relu')\n        self.readout = tf.keras.layers.Dense(output_dim)\n\n    def call(self, inputs):\n        node_features = inputs\n        x = self.dense1(node_features)\n        x = self.dense2(x)\n        graph_embedding = tf.reduce_mean(x, axis=1) # Global Mean Pooling\n        return self.readout(graph_embedding)\n\n# -----------------------\n# بارگذاری و آماده‌سازی داده‌ها\n# -----------------------\nprint(\"در حال بارگذاری دیتاست GNN برای Phonopy...\")\nwith open(DATA_FILE, 'rb') as f:\n    dataset = pickle.load(f)\n\n# پیدا کردن فرکانس‌های نقطه گاما برای هر نمونه\nfor sample in dataset:\n    gamma_idx = np.where(np.all(sample['qpoints'] == [0, 0, 0], axis=1))[0]\n    if len(gamma_idx) > 0:\n        sample['gamma_frequencies'] = sample['frequencies'][gamma_idx[0]]\n    else:\n        sample['gamma_frequencies'] = None # علامت‌گذاری نمونه‌های بدون نقطه گاما\n\n# حذف نمونه‌هایی که نقطه گاما ندارند\ndataset = [s for s in dataset if s['gamma_frequencies'] is not None]\n\ntrain_size = int(0.8 * len(dataset))\ntrain_dataset = dataset[:train_size]\ntest_dataset = dataset[train_size:]\nprint(f\"تعداد کل نمونه‌ها: {len(dataset)}. {len(train_dataset)} برای آموزش و {len(test_dataset)} برای تست.\")\n\n# -----------------------\n# ساخت مدل و بهینه‌ساز\n# -----------------------\nNODE_DIM = dataset[0]['node_features'].shape[1]\nOUTPUT_DIM = dataset[0]['gamma_frequencies'].shape[0]\n\nmodel = SimpleGNN(NODE_DIM, OUTPUT_DIM)\n# یک بار فراخوانی برای ساخت وزن‌ها\n_ = model(tf.ones((1, 10, NODE_DIM))) \n\noptimizer = tf.keras.optimizers.Adam(learning_rate=LEARNING_RATE)\n\n# -----------------------\n# حلقه آموزش سفارشی\n# -----------------------\nhistory = {'train_loss': [], 'mse_loss': [], 'phy_loss': []}\nbest_loss = float('inf')\nbest_model_path = os.path.join(OUT_DIR, \"best_pg_gnn_model.weights.h5\")\n\nprint(\"\\nشروع حلقه آموزش سفارشی برای PG-GNN...\")\nfor epoch in range(EPOCHS):\n    total_loss, total_mse, total_phy = 0, 0, 0\n    np.random.shuffle(train_dataset)\n    \n    progress_bar = tqdm(train_dataset, desc=f\"Epoch {epoch+1}/{EPOCHS}\")\n    for sample in progress_bar:\n        with tf.GradientTape() as tape:\n            # آماده‌سازی داده‌های ورودی\n            node_features = tf.expand_dims(sample['node_features'], 0)\n            true_gamma_freqs = tf.expand_dims(sample['gamma_frequencies'], 0)\n            \n            # پیش‌بینی مدل\n            predicted_gamma_freqs = model(node_features, training=True)\n            \n            # محاسبه زیان MSE\n            mse_loss = mse_loss_fn(true_gamma_freqs, predicted_gamma_freqs)\n            \n            # محاسبه زیان فیزیکی\n            physical_loss = physical_loss_with_proxy_grad(\n                predicted_gamma_freqs,\n                true_gamma_freqs,\n                tf.constant(sample['poscar_path']),\n                tf.constant(sample['fc_path']),\n                tf.constant(pickle.dumps(sample['supercell_matrix']))\n            )\n            \n            # ترکیب زیان‌ها\n            combined_loss = mse_loss + PHYSICS_LOSS_WEIGHT * physical_loss\n            \n        # محاسبه و اعمال گرادیان‌ها\n        grads = tape.gradient(combined_loss, model.trainable_variables)\n        optimizer.apply_gradients(zip(grads, model.trainable_variables))\n        \n        total_loss += combined_loss.numpy()\n        total_mse += mse_loss.numpy()\n        total_phy += physical_loss.numpy()\n        \n        progress_bar.set_postfix({\n            'Loss': f'{total_loss/(progress_bar.n+1):.4f}',\n            'MSE': f'{total_mse/(progress_bar.n+1):.4f}',\n            'Phys': f'{total_phy/(progress_bar.n+1):.4f}'\n        })\n\n    avg_loss = total_loss / len(train_dataset)\n    history['train_loss'].append(avg_loss)\n    history['mse_loss'].append(total_mse / len(train_dataset))\n    history['phy_loss'].append(total_phy / len(train_dataset))\n\n    if avg_loss < best_loss:\n        best_loss = avg_loss\n        model.save_weights(best_model_path)\n        tqdm.write(f\"مدل بهتر در epoch {epoch+1} ذخیره شد (Loss: {avg_loss:.4f}).\")\n\nprint(\"\\nآموزش به پایان رسید.\")\n\n# -----------------------\n# ارزیابی و رسم نمودارها\n# -----------------------\nprint(f\"\\nدر حال ارزیابی مدل با وزن‌های ذخیره شده از {best_model_path}...\")\nmodel.load_weights(best_model_path)\n\n# رسم نمودار تاریخچه زیان\nplt.figure(figsize=(12, 7))\nplt.plot(history['train_loss'], label='Total Loss (MSE + Phys)', linewidth=2)\nplt.plot(history['mse_loss'], label='MSE Loss', linestyle='--')\nplt.plot(history['phy_loss'], label=f'Physical Loss (x{PHYSICS_LOSS_WEIGHT})', linestyle=':')\nplt.title('Training Loss History')\nplt.xlabel('Epoch'); plt.ylabel('Loss')\nplt.legend(); plt.grid(True); plt.yscale('log')\nplt.savefig(os.path.join(OUT_DIR, \"loss_history.png\"))\nplt.show()\n\n# (بقیه کدهای ارزیابی و رسم نمودار نوارهای فونونی بدون تغییر باقی می‌مانند)\n# ...\n\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-09-17T11:34:59.083612Z","iopub.execute_input":"2025-09-17T11:34:59.084287Z"}},"outputs":[{"name":"stderr","text":"/tmp/ipykernel_36/3803634778.py:10: DeprecationWarning: phonopy.units.* is deprecated. Use phonopy.physical_units.physical_units instead.\n  from phonopy.units import VaspToTHz # وارد کردن صحیح فاکتور تبدیل\n","output_type":"stream"},{"name":"stdout","text":"در حال بارگذاری دیتاست GNN برای Phonopy...\nتعداد کل نمونه‌ها: 358. 286 برای آموزش و 72 برای تست.\n\nشروع حلقه آموزش سفارشی برای PG-GNN...\n","output_type":"stream"},{"name":"stderr","text":"Epoch 1/100:   0%|          | 0/286 [00:00<?, ?it/s]","output_type":"stream"},{"name":"stdout","text":"Unit cell structure was read from \"/kaggle/input/pgcnndata/all_poscar/all_poscar/Mo2AlN.psc\".\nForce constants were read from \"/kaggle/input/pgcnndata/extracted_force_constant_All/extracted_force_constant_C/Mo2AlN.fc\".\n","output_type":"stream"},{"name":"stderr","text":"/tmp/ipykernel_36/3803634778.py:91: RuntimeWarning: overflow encountered in cast\n  return np.float32(phy_loss)\nEpoch 1/100:   1%|          | 2/286 [00:01<02:20,  2.02it/s, Loss=inf, MSE=980694.0938, Phys=inf]","output_type":"stream"},{"name":"stdout","text":"Unit cell structure was read from \"/kaggle/input/pgcnndata/all_poscar/all_poscar/Hf2PbC.psc\".\nForce constants were read from \"/kaggle/input/pgcnndata/extracted_force_constant_All/extracted_force_constant_C/Hf2PbC.fc\".\nUnit cell structure was read from \"/kaggle/input/pgcnndata/all_poscar/all_poscar/Ta2AlN.psc\".\nForce constants were read from \"/kaggle/input/pgcnndata/extracted_force_constant_All/extracted_force_constant_C/Ta2AlN.fc\".\n","output_type":"stream"},{"name