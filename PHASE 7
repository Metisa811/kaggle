)(x)\n    out = tf.keras.layers.Dense(output_dim, activation='linear', kernel_initializer=\"he_normal\", dtype='float32', name=\"out\")(x)\n    return tf.keras.Model(inputs=inp, outputs=out)\n\n# ---------- هایپرپارامترها ----------\nBATCH_SIZE = 64\nEPOCHS = 250\nLR = 3e-4\n# **IMPROVEMENT**: Further increased lambda to enforce even smoother bands.\nLAMBDA_SMOOTH = 5.0\nPATIENCE = 30\n\n# ---------- پایپ‌لاین داده tf.data ----------\ndef make_dataset(X, y, batch_size, shuffle=True):\n    X = X.astype(np.float32)\n    y_flat = y.reshape(len(y), -1).astype(np.float32)\n    ds = tf.data.Dataset.from_tensor_slices((X, y_flat))\n    if shuffle:\n        ds = ds.shuffle(buffer_size=min(10000, len(X)))\n    return ds.batch(batch_size).prefetch(tf.data.AUTOTUNE)\n\ntrain_ds = make_dataset(X_train, y_train, BATCH_SIZE, shuffle=True)\nval_ds   = make_dataset(X_val, y_val, BATCH_SIZE, shuffle=False)\n\n# ---------- ساخت مدل و بهینه‌ساز ----------\ninput_dim = X_train.shape[1]\nmodel = build_model_with_he_init(input_dim, output_flat_dim)\nmodel.summary()\nmse = tf.keras.losses.MeanSquaredError()\noptimizer = tf.keras.optimizers.Adam(learning_rate=LR)\nprint(\"Using Adam optimizer.\")\n\n# ---------- حلقه‌های آموزش و اعتبارسنجی ----------\n@tf.function\ndef train_step(x_batch, y_batch):\n    with tf.GradientTape() as tape:\n        pred = model(x_batch, training=True)\n        loss_mse = mse(y_batch, pred)\n        pred_resh = tf.reshape(pred, (-1, max_qpoints, max_bands))\n        loss_smooth = smoothness_loss_from_reshaped(pred_resh)\n        loss = loss_mse + LAMBDA_SMOOTH * loss_smooth\n    grads = tape.gradient(loss, model.trainable_variables)\n    optimizer.apply_gradients(zip(grads, model.trainable_variables))\n    return loss\n\n@tf.function\ndef val_step(x_batch, y_batch):\n    pred = model(x_batch, training=False)\n    loss_mse = mse(y_batch, pred)\n    pred_resh = tf.reshape(pred, (-1, max_qpoints, max_bands))\n    loss_smooth = smoothness_loss_from_reshaped(pred_resh)\n    return loss_mse + LAMBDA_SMOOTH * loss_smooth\n\n# ---------- حلقه اصلی آموزش ----------\nbest_val = np.inf\npatience_counter = 0\nhistory = {'train_loss': [], 'val_loss': []}\nbest_model_path = os.path.join(out_dir, \"best_model_final.weights.h5\")\n\nfor epoch in range(1, EPOCHS + 1):\n    train_losses = [train_step(xb, yb).numpy() for xb, yb in train_ds]\n    val_losses = [val_step(xb, yb).numpy() for xb, yb in val_ds]\n    train_loss_epoch = np.mean(train_losses)\n    val_loss_epoch = np.mean(val_losses)\n    history['train_loss'].append(train_loss_epoch)\n    history['val_loss'].append(val_loss_epoch)\n    print(f\"Epoch {epoch:03d} | Train Loss: {train_loss_epoch:.6e} | Val Loss: {val_loss_epoch:.6e}\")\n    if val_loss_epoch < best_val:\n        best_val = val_loss_epoch\n        patience_counter = 0\n        model.save_weights(best_model_path)\n    else:\n        patience_counter += 1\n        if patience_counter >= PATIENCE:\n            print(\"Early stopping triggered.\")\n            break\n\n# ---------- رسم نمودار تاریخچه آموزش ----------\nplt.figure(figsize=(10, 6))\nplt.plot(history['train_loss'], label='Training Loss')\nplt.plot(history['val_loss'], label='Validation Loss')\nplt.title('Training and Validation Loss History')\nplt.xlabel('Epoch')\nplt.ylabel('Loss')\nplt.legend()\nplt.grid(True)\nplt.savefig(os.path.join(out_dir, \"loss_history_final.png\"))\nplt.show()\n\n# ---------- ارزیابی نهایی مدل ----------\nprint(f\"\\nLoading best model from {best_model_path} for evaluation.\")\nmodel.load_weights(best_model_path)\ny_test_flat = y_test.reshape(len(y_test), -1).astype(np.float32)\ny_pred_flat = model.predict(X_test.astype(np.float32), batch_size=BATCH_SIZE)\ny_pred_rescaled = (y_pred_flat * scaler_y_std + scaler_y_mean).reshape(-1, max_qpoints, max_bands)\ny_test_rescaled = (y_test_flat * scaler_y_std + scaler_y_mean).reshape(-1, max_qpoints, max_bands)\n\n# **IMPROVEMENT**: Apply Savitzky-Golay filter post-prediction for final smoothing.\ny_pred_final = np.copy(y_pred_rescaled)\nwindow_length = 11  # Must be an odd integer\npolyorder = 3       # Polynomial order\nfor i in range(len(y_pred_final)):\n    for b in range(max_bands):\n        y_pred_final[i, :, b] = savgol_filter(y_pred_rescaled[i, :, b], window_length, polyorder)\n\nr2_scores = [r2_score(y_test_rescaled[i].flatten(), y_pred_final[i].flatten()) for i in range(len(y_test_rescaled))]\nr2_scores = np.array(r2_scores)\nprint(\"\\n--- R2 Score Analysis (After Post-Processing) ---\")\nprint(f\"Mean R2 Score:   {np.mean(r2_scores):.4f}\")\nprint(f\"Median R2 Score: {np.median(r2_scores):.4f}\")\nprint(f\"Std Dev R2 Score:{np.std(r2_scores):.4f}\")\nprint(f\"Min R2 Score:    {np.min(r2_scores):.4f}\")\nprint(f\"Max R2 Score:    {np.max(r2_scores):.4f}\")\nprint(\"---------------------------------------------------\\n\")\nnp.save(os.path.join(out_dir, \"r2_scores_final.npy\"), r2_scores)\n\n# ---------- رسم هیستوگرام R2 ----------\nplt.figure(figsize=(10, 6))\nplt.hist(r2_scores, bins=30, edgecolor='black', color='skyblue')\nplt.title('Distribution of R2 Scores After Post-Processing')\nplt.xlabel('R2 Score')\nplt.ylabel('Frequency')\nplt.grid(axis='y')\nplt.savefig(os.path.join(out_dir, \"r2_distribution_final.png\"))\nplt.show()\n\n# ---------- رسم نمونه برای مقایسه ----------\nsample_idx = np.random.randint(0, len(y_test_rescaled))\npred_sample = y_pred_final[sample_idx]\ntrue_sample = y_test_rescaled[sample_idx]\nplt.figure(figsize=(12, 7))\ncolors = plt.cm.viridis(np.linspace(0, 1, max_bands))\n\n# **IMPROVEMENT**: Plot each band with a matching color for true and predicted.\nfor b in range(max_bands):\n    # Plot the true band as a solid line\n    plt.plot(true_sample[:, b], color=colors[b], linestyle='-', linewidth=2.5, label=f'True Band {b+1}' if b < 3 else \"\")\n    # Plot the predicted band as a dashed line\n    plt.plot(pred_sample[:, b], color=colors[b], linestyle='--', linewidth=2.5, label=f'Predicted Band {b+1}' if b < 3 else \"\")\n\nplt.title(f\"Band-by-Band Comparison (Sample {sample_idx})\")\nplt.xlabel(\"Q-point index\")\nplt.ylabel(\"Frequency (THz)\")\nplt.grid(True)\nplt.legend()\nplt.savefig(os.path.join(out_dir, \"band_comparison_final.png\"))\nplt.show()\n\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-09-10T15:55:32.095431Z","iopub.execute_input":"2025-09-10T15:55:32.096451Z","iopub.status.idle":"2025-09-10T15:56:49.717885Z","shell.execute_reply.started":"2025-09-10T15:55:32.096417Z","shell.execute_reply":"2025-09-10T15:56:49.716692Z"}},"outputs":[{"name":"stdout","text":"Mixed precision policy set to: <DTypePolicy \"mixed_float16\">\nLoading dataset files...\nDataset loaded successfully.\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"\u001b[1mModel: \"functional_2\"\u001b[0m\n","text/html":"<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\">Model: \"functional_2\"</span>\n</pre>\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"┏━━━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━┓\n┃\u001b[1m \u001b[0m\u001b[1mLayer (type)       \u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1mOutput Shape     \u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1m   Param #\u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1mConnected to     \u001b[0m\u001b[1m \u001b[0m┃\n┡━━━━━━━━━━━━━━━━━━━━━╇━━━━━━━━━━━━━━━━━━━╇━━━━━━━━━━━━╇━━━━━━━━━━━━━━━━━━━┩\n│ input (\u001b[38;5;33mInputLayer\u001b[0m)  │ (\u001b[38;5;45mNone\u001b[0m, \u001b[38;5;34m330\u001b[0m)       │          \u001b[38;5;34m0\u001b[0m │ -                 │\n├─────────────────────┼───────────────────┼────────────┼───────────────────┤\n│ dense_10 (\u001b[38;5;33mDense\u001b[0m)    │ (\u001b[38;5;45mNone\u001b[0m, \u001b[38;5;34m256\u001b[0m)       │     \u001b[38;5;34m84,736\u001b[0m │ input[\u001b[38;5;34