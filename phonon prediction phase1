\n\n                lattice = np.array(data['lattice']).flatten()\n                reciprocal = np.array(data['reciprocal_lattice']).flatten()\n\n                # Shape: (max_atoms, 4) + (9,) + (9,) → (max_atoms, 4), 9, 9\n                feature_tensor = np.concatenate([\n                    atom_features.flatten(),\n                    lattice,\n                    reciprocal\n                ])\n\n                # Frequencies\n                frequencies = []\n                for qpoint in data['phonon']:\n                    bands = [b['frequency'] for b in qpoint.get('band', [])]\n                    frequencies.append(bands)\n                frequencies = np.array(frequencies)\n                frequencies = np.pad(frequencies, ((0, max_qpoints - frequencies.shape[0]), (0, max_bands - frequencies.shape[1])), 'constant')\n\n                X.append(feature_tensor)\n                y.append(frequencies)\n\n            except Exception as e:\n                print(f\"Error in file {file}: {e}\")\n                skipped += 1\n\n    print(f\"✅ Loaded: {len(X)}, Skipped: {skipped}\")\n    return np.array(X), np.array(y), max_atoms\n\n# =======================\n# Step 2: Build Advanced CNN Model\n# =======================\n\n\ndef build_cnn_model(input_shape, output_shape):\n    inputs = tf.keras.Input(shape=input_shape)\n    x = tf.keras.layers.Reshape((input_shape[0], 1))(inputs)\n\n    # Convolutional feature extractor\n    conv_filters = [64, 64, 128, 128, 256, 256]\n    pool_after_layers = [1, 3]  # Only pool after these layers to avoid over-pooling\n\n    for i, filters in enumerate(conv_filters):\n        x = tf.keras.layers.Conv1D(filters, kernel_size=3, padding='same', activation='relu')(x)\n        if i in pool_after_layers:\n            # Check if sequence is long enough to apply pooling\n            if x.shape[1] is not None and x.shape[1] >= 2:\n                x = tf.keras.layers.MaxPooling1D(pool_size=2)(x)\n\n    # Global pooling to flatten\n    x =