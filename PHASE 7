---\nclass SimpleGNN(tf.keras.Model):\n    def __init__(self, node_dim, output_dim):\n        super(SimpleGNN, self).__init__()\n        self.dense1 = tf.keras.layers.Dense(128, activation='relu')\n        self.dense2 = tf.keras.layers.Dense(128, activation='relu')\n        self.readout = tf.keras.layers.Dense(output_dim)\n\n    def call(self, inputs):\n        node_features = inputs\n        x = self.dense1(node_features)\n        x = self.dense2(x)\n        graph_embedding = tf.reduce_mean(x, axis=1)\n        return self.readout(graph_embedding)\n\nmodel = SimpleGNN(NODE_DIM, OUTPUT_DIM)\n_ = model(tf.ones((1, 10, NODE_DIM)))\n\n\n# -----------------------\n# تابع زیان فیزیکی (Physical Loss Function)\n# -----------------------\nmse_loss_fn = tf.keras.losses.MeanSquaredError()\n\ndef calculate_physical_loss(phonopy_instance, q_point, pred_frequencies_thz):\n    try:\n        phonopy_instance.run_qpoints([q_point], with_dynamical_matrices=True)\n        dm_dict = phonopy_instance.get_qpoints_dict()\n        dynamical_matrix = dm_dict['dynamical_matrices'][0]\n        eigvals, eigvecs = np.linalg.eigh(dynamical_matrix)\n        \n        VASP_THZ_TO_RAD_PS = 0.0299792458 * 2 * np.pi\n        pred_eigvals = (pred_frequencies_thz * VASP_THZ_TO_RAD_PS) ** 2\n\n        loss = 0.0\n        num_bands = len(pred_eigvals)\n        identity_matrix = np.identity(dynamical_matrix.shape[0], dtype=np.complex128)\n        \n        for i in range(num_bands):\n            D_eff = dynamical_matrix - pred_eigvals[i] * identity_matrix\n            residual_vector = np.dot(D_eff, eigvecs[:, i])\n            loss += np.linalg.norm(residual_vector)**2\n            \n        return loss / num_bands\n    except Exception as e:\n        print(f\"Phonopy eigenvalue calculation failed: {e}\")\n        return 100.0\n\n@tf.custom_gradient\ndef physical_loss_with_proxy_grad(predicted_frequencies, true_frequencies, qpoints, poscar_path, fc_path, supercell_matrix_pkl):\n    \n    def forward_pass_wrapper(preds_tensor, qpoints_tensor, poscar_path_tensor, fc_path_tensor, supercell_matrix_pkl_tensor):\n        preds_np = preds_tensor.numpy()\n        poscar_path = poscar_path_tensor.numpy().decode('utf-8')\n        fc_path = fc_path_tensor.numpy().decode('utf-8')\n        supercell_matrix = pickle.loads(supercell_matrix_pkl_tensor.numpy())\n        qpoints_np = qpoints_tensor.numpy()\n\n        try:\n            ph_instance = phonopy.load(\n                unitcell_filename=poscar_path,\n                force_constants_filename=fc_path,\n                supercell_matrix=supercell_matrix,\n                is_nac=False, log_level=1)\n        except RuntimeError as e:\n            # This is the expected error for inconsistent data. We skip the sample.\n            print(f\"WARNING: Skipping sample due to Phonopy load error: {e}\")\n            return np.float32(0.0)\n\n        phy_loss = 0.0\n        for i in range(len(qpoints_np)):\n            phy_loss += calculate_physical_loss(ph_instance, qpoints_np[i], preds_np[i])\n        return np.float32(phy_loss / len(qpoints_np))\n\n    phy_loss_val = tf.py_function(\n        func=forward_pass_wrapper, \n        inp=[predicted_frequencies, qpoints, poscar_path, fc_path, supercell_matrix_pkl],\n        Tout=tf.float32\n    )\n\n    def grad_fn(dy):\n        with tf.GradientTape() as tape_proxy:\n            tape_proxy.watch(predicted_frequencies)\n            proxy_loss = mse_loss_fn(true_frequencies, predicted_frequencies)\n        \n        proxy_gradient = tape_proxy.gradient(proxy_loss, predicted_frequencies)\n        \n        # **FIX**: Return one gradient for each of the 6 flattened input tensors.\n        return (dy * proxy_gradient, None, None, None, None, None)\n\n    return phy_loss_val, grad_fn\n\n# -----------------------\n# حلقه آموزش سفارشی\n# -----------------------\noptimizer = tf.keras.optimizers.Adam(learning_rate=LR)\nhistory = {'train_loss': []}\n\nprint(\"\\nStarting custom training loop for PG-GNN...\")\nbest_model_path = os.path.join(out_dir, \"best_pg_gnn_model.weights.h5\")\n\nfor epoch in range(EPOCHS):\n    total_loss, total_mse_loss, total_phy_loss = 0, 0, 0\n    np.random.shuffle(train_dataset_samples)\n    \n    for sample in tqdm(train_dataset_samples, desc=f\"Epoch {epoch+1}/{EPOCHS}\"):\n        with tf.GradientTape() as tape:\n            node_features_tensor = tf.expand_dims(sample['node_features'], 0)\n            predicted_bands_at_gamma = model(node_features_tensor, training=True)\n            predicted_frequencies = tf.tile(predicted_bands_at_gamma, [len(sample['qpoints']), 1])\n            \n            true_frequencies = sample['frequencies']\n            mse_loss = mse_loss_fn(true_frequencies, predicted_frequencies)\n            \n            physical_loss = physical_loss_with_proxy_grad(\n                predicted_frequencies,\n                true_frequencies,\n                sample['qpoints'],\n                tf.constant(sample['poscar_path']),\n                tf.constant(sample['fc_path']),\n                tf.constant(pickle.dumps(sample['supercell_matrix']))\n            )\n            \n            combined_loss = mse_loss + PHYSICS_LOSS_WEIGHT * physical_loss\n            \n        grads = tape.gradient(combined_loss, model.trainable_variables)\n        if grads is not None and all(g is not None for g in grads):\n             optimizer.apply_gradients(zip(grads, model.trainable_variables))\n        \n        total_loss += combined_loss.numpy()\n        total_mse_loss += mse_loss.numpy()\n        total_phy_loss += physical_loss.numpy()\n\n    avg_loss = total_loss / len(train_dataset_samples)\n    avg_mse = total_mse_loss / len(train_dataset_samples)\n    avg_phy = total_phy_loss / len(train_dataset_samples)\n    history['train_loss'].append(avg_loss)\n    print(f\"Epoch {epoch+1} - Avg Loss: {avg_loss:.4f}, Avg MSE: {avg_mse:.4f}, Avg Physical Loss: {avg_phy:.4f}\")\n    model.save_weights(best_model_path) \n\nprint(\"\\nTraining finished.\")\n\n# ... (The rest of the analysis and plotting code remains the same) ...\n# ---------- رسم نمودار تاریخچه آموزش ----------\nplt.figure(figsize=(10, 6))\nplt.plot(history['train_loss'], label='Training Loss')\nplt.title('Training Loss History')\nplt.xlabel('Epoch'); plt.ylabel('Loss')\nplt.legend(); plt.grid(True)\nplt.savefig(os.path.join(out_dir, \"loss_history_pg_gnn.png\"))\nplt.show()\n\n# -----------------------\n# ارزیابی نهایی و پس‌پردازش\n# -----------------------\nprint(f\"\\nEvaluating model with weights from {best_model_path}.\")\ny_pred_final_list = []\ny_test_rescaled_list = []\n\nfor sample in tqdm(test_dataset_samples, desc=\"Evaluating on test set\"):\n    node_features_tensor = tf.expand_dims(sample['node_features'], 0)\n    predicted_bands = model(node_features_tensor, training=False)\n    predicted_frequencies = np.tile(predicted_bands.numpy(), [len(sample['qpoints']), 1])\n    \n    pred_smooth = np.copy(predicted_frequencies)\n    if pred_smooth.shape[0] > 11:\n        for b in range(pred_smooth.shape[1]):\n            pred_smooth[:, b] = savgol_filter(predicted_frequencies[:, b], 11, 3)\n\n    y_pred_final_list.append(pred_smooth)\n    y_test_rescaled_list.append(sample['frequencies'])\n\n# -----------------------\n# تحلیل جامع R²\n# -----------------------\nr2_scores = np.array([r2_score(y_test_rescaled_list[i].flatten(), y_pred_final_list[i].flatten()) for i in range(len(test_dataset_samples))])\nprint(\"\\n--- R2 Score Analysis (Overall per Sample) ---\")\nprint(f\"Mean R2: {np.mean(r2_scores):.4f}, Median R2: {np.median(r2_scores):.4f}, Std Dev: {np.std(r2_scores):.4f}\")\n\ndef plot_band_comparison(sample_idx, y_true_list, y_pred_list, r2_score_val, title_prefix, filename):\n    plt.figure(figsize=(12, 7))\n    true_sample = y_true_list[sample_idx]\n    pred_sample = y_pred_list[sample_idx]\n    max_bands_sample = true_sample.shape[1]\n    colors = plt.cm.viridis(np.linspace(0, 1, max_bands_sample))\n    for b in range(max_bands_sample):\n        plt.plot(true_sample[:, b], color=colors[b], linestyle='-', linewidth=2.5, label=f'True B{b+1}' if b < 2 else None)\n        plt.plot(pred_sample[:, b], color=colors[b], linestyle='--', linewidth=2.5, label=f'Pred B{b+1}' if b < 2 else None)\n    plt.title(f\"{title_prefix} (Sample Index {sample_idx}, R² = {r2_score_val:.3f})\")\n    plt.xlabel(\"Q-point index\"); plt.ylabel(\"Frequency (THz)\"); plt.grid(True)\n    from matplotlib.lines import Line2D\n    legend_elements = [Line2D([0], [0], color='black', lw=2, linestyle='-', label='True'),\n                       Line2D([0], [0], color='black', lw=2, linestyle='--', label='Predicted')]\n    plt.legend(handles=legend_elements)\n    plt.savefig(filename)\n    plt.show()\n\nbest_idx = np.argmax(r2_scores)\nworst_idx = np.argmin(r2_scores)\nprint(f\"Plotting best case (Index {best_idx}, R²={r2_scores[best_idx]:.3f}) and worst case (Index {worst_idx}, R²={r2_scores[worst_idx]:.3f}).\")\nplot_band_comparison(best_idx, y_test_rescaled_list, y_pred_final_list, r2_scores[best_idx], \"Best Prediction\", os.path.join(out_dir, \"best_prediction_pg_gnn.png\"))\nplot_band_comparison(worst_idx, y_test_rescaled_list, y_pred_final_list, r2_scores[worst_idx], \"Worst Prediction\", os.path.join(out_dir, \"worst_prediction_pg_gnn.png\"))\n\n# تحلیل R² به تفکیک هر باند\nprint(\"\\n--- R2 Score Analysis (Per Individual Band) ---\")\nmax_bands_overall = max(s.shape[1] for s in y_test_rescaled_list)\nr2_per_band = [[] for _ in range(max_bands_overall)]\nfor i in range(len(y_test_rescaled_list)):\n    num_bands_sample = y_test_rescaled_list[i].shape[1]\n    for b in range(num_bands_sample):\n        if np.std(y_test_rescaled_list[i][:, b]) > 1e-6:\n            score = r2_score(y_test_rescaled_list[i][:, b], y_pred_final_list[i][:, b])\n            r2_per_band[b].append(score)\n\nmean_r2_per_band = [np.mean(scores) if len(scores) > 0 else -1 for scores in r2_per_band]\nfor b in range(max_bands_overall):\n    if len(r2_per_band[b]) > 0:\n        print(f\"Band {b+1:02d} | Mean R²: {mean_r2_per_band[b]:.4f}\")\n\nplt.figure(figsize=(15, 8))\nvalid_bands_data = [scores for scores in r2_per_band if len(scores) > 0]\nbox = plt.boxplot(valid_bands_data, vert=True, patch_artist=True, labels=[f'B{i+1}' for i in range(len(valid_bands_data))])\ncolors = plt.cm.viridis(np.linspace(0, 1, len(valid_bands_data)))\nfor patch, color in zip(box['boxes'], colors):\n    patch.set_facecolor(color); patch.set_alpha(0.6)\nplt.title('Distribution of R² Scores for Each Phonon Band (PG-GNN)')\nplt.ylabel('R² Score'); plt.xlabel('Band Index')\nplt.grid(axis='y', linestyle='--'); plt.axhline(y=0, color='r', linestyle='--')\nplt.ylim(-1, 1.1)\nplt.savefig(os.path.join(out_dir, \"r2_per_band_distribution_pg_gnn.png\"))\nplt.show()\n\n","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"! pip install phonopy","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-09-17T11:34:47.523198Z","iopub.execute_input":"2025-09-17T11:34:47.523379Z","iopub.status.idle":"2025-09-17T11:34:53.823549Z","shell.execute_reply.started":"2025-09-17T11:34:47.523362Z","shell.execute_reply":"2025-09-17T11:34:53.822759Z"}},"outputs":[{"name":"stdout","text":"Collecting phonopy\n  Downloading phonopy-2.43.2-cp311-cp311-manylinux_2_17_x86_64.manylinux2014_x86_64.whl.metadata (3.3 kB)\nRequirement already satisfied: numpy>=1.17.0 in /usr/local/lib/python3.11/dist-packages (from phonopy) (1.26.4)\nRequirement already satisfied: PyYAML>=5.3 in /usr/local/lib/python3.11/dist-packages (from phonopy) (6.0.2)\nRequirement already satisfied: matplotlib>=2.2.2 in /usr/local/lib/python3.11/dist-packages (from phonopy) (3.7.2)\nRequirement already satisfied: h5py>=3.0 in /usr/local/lib/python3.11/dist-packages (from phonopy) (3.14.0)\nCollecting spglib>=2.3 (from phonopy)\n  Downloading spglib-2.6.0-cp311-cp311-manylinux_2_17_x86_64.manylinux2014_x86_64.whl.metadata (4.2 kB)\nCollecting 