   with open(os.path.join(folder_path, file), 'r') as f:\n                    data = yaml.safe_load(f)\n\n                if 'points' not in data or 'lattice' not in data or 'reciprocal_lattice' not in data or 'phonon' not in data:\n                    skipped += 1\n                    continue\n\n                # Щ…Ш®ШӘШөШ§ШӘ Ш§ШӘЩ…вҖҢЩҮШ§\n                atom_coords = np.array([pt['coordinates'] for pt in data['points']])\n                atom_masses = np.array([pt['mass'] for pt in data['points']])\n\n                # ШіШ§Ш®ШӘ Щ…Ш§ШӘШұЫҢШі ЩҒШ§ШөЩ„ЩҮвҖҢЩҮШ§\n                n_atoms_sample = len(data['points'])\n                distance_matrix = np.zeros((max_atoms, max_atoms))\n                for i in range(n_atoms_sample):\n                    for j in range(n_atoms_sample):\n                        distance_matrix[i, j] = np.linalg.norm(atom_coords[i] - atom_coords[j])\n                distance_matrix = np.pad(distance_matrix, ((0, max_atoms - n_atoms_sample), (0, max_atoms - n_atoms_sample)), 'constant')\n\n                # ЩҶШұЩ…Ш§Щ„вҖҢШіШ§ШІЫҢ Щ…Ш§ШӘШұЫҢШі ЩҒШ§ШөЩ„ЩҮвҖҢЩҮШ§\n                distance_matrix_normalized = (distance_matrix - distance_matrix.min()) / (distance_matrix.max() - distance_matrix.min())\n\n                # Ш§Ш¶Ш§ЩҒЩҮ Ъ©ШұШҜЩҶ Ъ©Ш§ЩҶШ§Щ„ Ш¬ШұЩ… (ШЁЩҮвҖҢШ№ЩҶЩҲШ§ЩҶ ЫҢЩҮ Щ„Ш§ЫҢЩҮ ШұЩҶЪҜЫҢ)\n                mass_matrix = np.zeros((max_atoms, max_atoms))\n                mass_matrix[:n_atoms_sample, :n_atoms_sample] = np.outer(atom_masses, atom_masses) / atom_masses.max()\n                mass_matrix_normalized = (mass_matrix - mass_matrix.min()) / (mass_matrix.max() - mass_matrix.min())\n\n                # ШӘШұЪ©ЫҢШЁ ШЁЩҮвҖҢШ№ЩҶЩҲШ§ЩҶ ШӘШөЩҲЫҢШұ ШЁШ§ 2 Ъ©Ш§ЩҶШ§Щ„\n                image = np.stack([distance_matrix_normalized, mass_matrix_normalized], axis=-1)\n\n                # Ш°Ш®ЫҢШұЩҮ ШӘШөЩҲЫҢШұ (Ш§Ш®ШӘЫҢШ§ШұЫҢ ШЁШұШ§ЫҢ ШЁШұШұШіЫҢ)\n                plt.imsave(f'image_{idx}.png', image[:, :, 0], cmap='viridis')  # ЩҒЩӮШ· Ъ©Ш§ЩҶШ§