it())) for line in lines[8:8 + sum(numbers)]]\n\n    atoms = []\n    for sym, count in zip(symbols, numbers):\n        atoms += [sym] * count\n\n    return PhonopyAtoms(symbols=atoms, scaled_positions=positions, cell=lattice)\n\ndef validate_frequencies(poscar='/kaggle/input/cr2aln-phonon/POSCAR', force_constants_file='/kaggle/input/cr2aln-phonon/FORCE_CONSTANTS', band_yaml='/kaggle/input/cr2aln-phonon/band.yaml', output_file='/kaggle/working/validation_results.txt'):\n    structure = load_structure(poscar)\n    force_constants = read_force_constants(filename=\"/kaggle/input/cr2aln-phonon/FORCE_CONSTANTS\")\n\n\n    \n    phonon = Phonopy(structure, np.eye(3), primitive_matrix=\"auto\")\n    phonon.force_constants = force_constants\n\n\n    qpoints, freqs = read_band_yaml(band_yaml)\n    phonon.run_band_structure([qpoints])\n    dyn_matrices = []\n    results = []\n\n    for i, q in enumerate(qpoints):\n        dynmat = phonon.get_dynamical_matrix_at_q(q)\n        eigenvals = np.linalg.eigvals(dynmat)\n        eig_freqs = np.sqrt(np.abs(eigenvals.real)) * np.sign(eigenvals.real)\n        \n        for j, omega in enumerate(freqs[i]):\n            omega_rad = omega * 2 * np.pi * 1e12  # Convert THz to angular frequency in rad/s\n            matrix = dynmat - (omega_rad**2) * np.identity(len(dynmat))\n            det = np.linalg.det(matrix)\n            close_to_zero = np.isclose(det, 0, atol=1e-3)\n\n            results.append({\n                \"q-point\": q.tolist(),\n                \"mode\": j,\n                \"frequency_THz\": omega,\n                \"determinant\": det,\n                \"is_zero\": close_to_zero\n            })\n\n    with open(output_file, 'w') as f:\n        for r in results:\n            f.write(f\"q = {r['q-point']}, mode = {r['mode']}, freq = {r['frequency_THz']:.4f} THz, det = {r['determinant']:.4e}, zero? {r['is_zero']}\\n\")\n\n    print(f\"نتایج بررسی در فایل {output_file} ذخیره شد.\")\n\nvalidate_frequencies()\n","metadata":{"tru