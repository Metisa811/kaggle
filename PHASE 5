\n                if 'points' not in data or 'lattice' not in data or 'reciprocal_lattice' not in data or 'phonon' not in data:\n                    skipped += 1\n                    continue\n\n                # Щ…Ш®ШӘШөШ§ШӘ Ш§ШӘЩ…вҖҢЩҮШ§\n                atom_coords = np.array([pt['coordinates'] for pt in data['points']])\n                atom_masses = np.array([pt['mass'] for pt in data['points']])\n\n                # ШіШ§Ш®ШӘ Щ…Ш§ШӘШұЫҢШі ЩҒШ§ШөЩ„ЩҮвҖҢЩҮШ§\n                n_atoms_sample = len(data['points'])\n                distance_matrix = np.zeros((max_atoms, max_atoms))\n                for i in range(n_atoms_sample):\n                    for j in range(n_atoms_sample):\n                        distance_matrix[i, j] = np.linalg.norm(atom_coords[i] - atom_coords[j])\n                distance_matrix = np.pad(distance_matrix, ((0, max_atoms - n_atoms_sample), (0, max_atoms - n_atoms_sample)), 'constant')\n\n                # ЩҶШұЩ…Ш§Щ„вҖҢШіШ§ШІЫҢ Щ…Ш§ШӘШұЫҢШі ЩҒШ§ШөЩ„ЩҮвҖҢЩҮШ§\n                distance_matrix_normalized = (distance_matrix - distance_matrix.min()) / (distance_matrix.max() - distance_matrix.min())\n\n                # Ш§Ш¶Ш§ЩҒЩҮ Ъ©ШұШҜЩҶ Ъ©Ш§ЩҶШ§Щ„ Ш¬ШұЩ… (ШЁЩҮвҖҢШ№ЩҶЩҲШ§ЩҶ ЫҢЩҮ Щ„Ш§ЫҢЩҮ ШұЩҶЪҜЫҢ)\n                mass_matrix = np.zeros((max_atoms, max_atoms))\n                mass_matrix[:n_atoms_sample, :n_atoms_sample] = np.outer(atom_masses, atom_masses) / atom_masses.max()\n                mass_matrix_normalized = (mass_matrix - mass_matrix.min()) / (mass_matrix.max() - mass_matrix.min())\n\n                # ШӘШұЪ©ЫҢШЁ ШЁЩҮвҖҢШ№ЩҶЩҲШ§ЩҶ ШӘШөЩҲЫҢШұ ШЁШ§ 2 Ъ©Ш§ЩҶШ§Щ„\n                image = np.stack([distance_matrix_normalized, mass_matrix_normalized], axis=-1)\n\n                # Ш°Ш®ЫҢШұЩҮ ШӘШөЩҲЫҢШұ (Ш§Ш®ШӘЫҢШ§ШұЫҢ ШЁШұШ§ЫҢ ШЁШұШұШіЫҢ)\n                plt.imsave(f'image_{idx}.png', image[:, :, 0], cmap='viridis')  # ЩҒЩӮШ· Ъ©Ш§ЩҶШ§Щ„ ЩҒШ§ШөЩ„ЩҮ ШЁШұШ§ЫҢ ЩҶЩ…Ш§ЫҢШҙ\n\n                X_images.append(image)\n                y.append(data['phonon'])  # ЩҒШұЪ©Ш§ЩҶШівҖҢЩҮШ§\n\n            except Exception as e:\n                print(f\"Ш®Ш·Ш§ ШҜШұ ЩҒШ§ЫҢЩ„ {file}: {e}\")\n                skipped += 1\n\n    print(f\"вң… ШЁШ§ШұЪҜШ°Ш§ШұЫҢ ШҙШҜЩҮ: {len(X_images)}, ШұШҜ ШҙШҜЩҮ: {skipped}\")\n    return np.array(X_images), np.array(y), max_atoms\n\ndef prepare_input(points, lattice, reciprocal, max_atoms, max_qpoints):\n    atom_coords = np.array([pt['coordinates'] for pt in points])\n    atom_masses = np.array([pt['mass'] for pt in points])\n    n_atoms_sample = len(points)\n    distance_matrix = np.zeros((max_atoms, max_atoms))\n    for i in range(n_atoms_sample):\n        for j in range(n_atoms_sample):\n            distance_matrix[i, j] = np.linalg.norm(atom_coords[i] - atom_coords[j])\n    distance_matrix = np.pad(distance_matrix, ((0, max_atoms - n_atoms_sample), (0, 0)), 'constant')\n    distance_matrix_normalized = (distance_matrix - distance_matrix.min()) / (distance_matrix.max() - distance_matrix.min())\n\n    mass_matrix = np.zeros((max_atoms, max_atoms))\n    mass_matrix[:n_atoms_sample, :n_atoms_sample] = np.outer(atom_masses, atom_masses) / atom_masses.max()\n    mass_matrix_normalized = (mass_matrix - mass_mass.min()) / (mass_matrix.max() - mass_matrix.min())\n\n    image = np.stack([distance_matrix_normalized, mass_matrix_normalized], axis=-1)\n    return image.reshape(1, max_atoms, max_atoms, 2)\n\n# Щ…ШіЫҢШұ ШҜШ§ШҜЩҮвҖҢЩҮШ§\nfolder = \"/kaggle/input/yaml-phonopy-data/extracted_bands_C\"\nX_images, y_raw, max_atoms = parse_yaml_files(folder)\n\n# ЩҶШұЩ… Ъ©ШұШҜЩҶ ЩҒШұЪ©Ш§ЩҶШівҖҢЩҮШ§\ny_frequencies = []\nfor sample in y_raw:\n    frequencies = []\n    for qpoint in sample:\n        bands = [b['frequency'] for b in qpoint.get('band', [])]\n        frequencies.append(bands)\n    frequencies = np.array(frequencies)\n    y_frequencies.append(frequencies)\ny = np.array(y_frequencies)\n\n# ЩҶШұЩ… Ъ©ШұШҜЩҶ ЩҒШұЪ©Ш§ЩҶШівҖҢЩҮШ§ ШЁШ§ sigma Ъ©Щ…ШӘШұ\ny_smoothed = gaussian_filter1d(y, sigma=0.5, axis=1, mode='constant')\n\n# ЩҶШұЩ…Ш§Щ„вҖҢШіШ§ШІЫҢ y ШЁШ§ MinMaxScaler\nnum_samples, num_qpoints, num_bands = y_smoothed.shape\ny_flat = y_smoothed.reshape(num_samples, -1)\nscaler_y = MinMaxScaler()\ny_normalized = scaler_y.fit_transform(y_flat).reshape(num_samples, num_qpoints, num_bands)\n\n# ШӘЩӮШіЫҢЩ… ШҜШ§ШҜЩҮвҖҢЩҮШ§\nX_train, X_test, y_train, y_test = train_test_split(X_images, y_normalized, test_size=0.2, random_state=42)\n\n# Ш°Ш®ЫҢШұЩҮ ШҜШ§ШҜЩҮвҖҢЩҮШ§\nnp.save('xdata_train_images.npy', X_train)\nnp.save('ydata_train.npy', y_train)\nnp.save('xdata_test_images.npy', X_test)\nnp.save('ydata_test.npy', y_test)\n\n# Ш°Ш®ЫҢШұЩҮ scalerЩҮШ§ ШЁШ§ joblib\njoblib.dump(scaler_y, 'scaler_y.joblib')\n\n# Ш°Ш®ЫҢШұЩҮ max_atoms\nnp.save('max_atoms.npy', max_atoms)\n\nprint(\"ШҜШ§ШҜЩҮвҖҢЩҮШ§ ЩҲ ШӘШөШ§ЩҲЫҢШұ ШЁШ§ Щ…ЩҲЩҒЩӮЫҢШӘ Ш°Ш®ЫҢШұЩҮ ШҙШҜЩҶШҜ!\")","metadata":{"_uuid":"8f2839f25d086af736a60e9eeb907d3b93b6e0e5","_cell_guid":"b1076dfc-b9ad-4769-8c92-a6c4dae69d19","trusted":true,"execution":{"iopub.status.busy":"2025-05-15T22:44:59.812589Z","iopub.execute_input":"2025-05-15T22:44:59.813325Z","iopub.status.idle":"2025-05-15T22:45:00.626042Z","shell.execute_reply.started":"2025-05-15T22:44:59.813289Z","shell.execute_reply":"2025-05-15T22:45:00.62471Z"}},"outputs":[{"traceback":["\u001b[0;31m---------------------------------------------------------------------------\u001b[0m","\u001b[0;31mFileNotFoundError\u001b[0m                         Traceback (most recent call last)","\u001b[0;32m/tmp/ipykernel_35/3003909222.py\u001b[0m in \u001b[0;36m<cell line: 0>\u001b[0;34m()\u001b[0m\n\u001b[1;32m     98\u001b[0m \u001b[0;31m# Щ…ШіЫҢШұ ШҜШ§ШҜЩҮвҖҢЩҮШ§\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m     99\u001b[0m \u001b[0mfolder\u001b[0m \u001b[0;34m=\u001b[0m \u001b[0;34m\"/kaggle/input/yaml-phonopy-data/extracted_bands_C\"\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0;32m--> 100\u001b[0;31m \u001b[0mX_images\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0my_raw\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0mmax_atoms\u001b[0m \u001b[0;34m=\u001b[0m \u001b[0mparse_yaml_files\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mfolder\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0m\u001b[1;32m    101\u001b[0m \u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m    102\u001b[0m \u001b[0;31m# ЩҶШұЩ… Ъ©ШұШҜЩҶ ЩҒШұЪ©Ш§ЩҶШівҖҢЩҮШ§\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n","\u001b[0;32m/tmp/ipykernel_35/3003909222.py\u001b[0m in \u001b[0;36mparse_yaml_files\u001b[0;34m(folder_path)\u001b[0m\n\u001b[1;32m     16\u001b[0m \u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m     17\u001b[0m     \u001b[0;31m# ЫҢШ§ЩҒШӘЩҶ ШӯШҜШ§Ъ©Ш«Шұ Ш§ЩҶШҜШ§ШІЩҮвҖҢЩҮШ§ ШҜШұ ЩҫШ§Ші Ш§ЩҲЩ„\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0;32m---> 18\u001b[0;31m     \u001b[0;32mfor\u001b[0m \u001b[0mfile\u001b[0m \u001b[0;32min\u001b[0m \u001b[0mos\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mlistdir\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mfolder_path\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m:\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0m\u001b[1;32m     19\u001b[0m         \u001b[0;32mif\u001b[0m \u001b[0mfile\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mendswith\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0;34m\".yaml\"\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m:\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m     20\u001b[0m             \u001b[0;32mtry\u001b[0m\u001b[0;34m:\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n","\u001b[0;31mFileNotFoundError\u001b[0m: [Errno 2] No such file or directory: '/kaggle/input/yaml-phonopy-data/extracted_bands_C'"],"ename":"FileNotFoundError","evalue":"[Errno 2] No such file or directory: '/kaggle/input/yaml-phonopy-data/extracted_bands_C'","output_type":"error"}],"execution_count":1},{"cell_type":"code","source":"import numpy as np\nimport tensorflow as tf\nfrom sklearn.metrics import r2_score\nimport matplotlib.pyplot as plt\nimport joblib  # ШЁШұШ§ЫҢ Щ„ЩҲШҜ scalerЩҮШ§\n\ndef prepare_input(points, lattice, reciprocal, max_atoms, max_qpoints):\n    atom_features = [pt['coordinates'] + [pt['mass']] for pt in points]\n    atom_features = np.array(atom_features)\n    atom_features = np.pad(atom_features, ((0, max_atoms - atom_features.shape[0]), (0, 0)), 'constant')\n    lattice_flat = np.array(lattice).flatten()\n    reciprocal_flat = np.array(reciprocal).flatten()\n    # ЩҒШұШ¶ Щ…ЫҢвҖҢЪ©ЩҶЫҢЩ… qpoints ШЁШұШ§ЫҢ ЩҶЩ…ЩҲЩҶЩҮ Ш¬ШҜЫҢШҜ ШөЩҒШұ Ш§ШіШӘ (ШҜШұ ШөЩҲШұШӘ ЩҲШ¬ЩҲШҜ Ш§Ш·Щ„Ш§Ш№Ш§ШӘ ЩҲШ§ЩӮШ№ЫҢ Ш¬Ш§ЫҢЪҜШІЫҢЩҶ ШҙЩҲШҜ)\n    qpoints = np.zeros((max_qpoints, 3))\n    return np.concatenate([atom_features.flatten(), lattice_flat, reciprocal_flat, qpoints.flatten()]).reshape(1, -1)\n\ndef build_cnn_model(input_shape, output_shape):\n    num_qpoints = 357  # ШӘШ№ШҜШ§ШҜ ЩӮЫҢШ§ШіЫҢвҖҢЩҮШ§\n    model = tf.keras.Sequential([\n        tf.keras.layers.Input(shape=input_shape),\n        tf.keras.layers.Reshape((input_shape[0], 1)),\n        tf.keras.layers.Conv1D(1 * num_qpoints, kernel_size=3, activation='relu', padding='same'),  # 357 ЩҒЫҢЩ„ШӘШұ\n        tf.keras.layers.Conv1D(int(0.5 * num_qpoints), kernel_size=3, activation='relu', padding='same'),  # 178 ЩҒЫҢЩ„ШӘШұ\n        tf.keras.layers.MaxPooling1D(pool_size=2),\n        tf.keras.layers.Flatten(),\n        tf.keras.layers.Dense(1 * num_qpoints, activation='relu', kernel_regularizer=tf.keras.regularizers.l2(0.005)),  # 357 ЩҶЩҲШұЩҲЩҶ\n        tf.keras.layers.Dropout(0.3),\n        tf.keras.layers.Dense(np.prod(output_shape), activation='linear')\n    ])\n    return model\n\n# ШӘШ§ШЁШ№ error_loss (ЩҲШІЩҶвҖҢШҜШ§Шұ ШЁШұШ§ЫҢ ЩҒШұЪ©Ш§ЩҶШівҖҢЩҮШ§ЫҢ ШЁШ§Щ„Ш§)\ndef error_loss(y_true, y_pred):\n    weights = tf.where(y_true > 15.0, 2.0, 1.0)  # ЩҲШІЩҶ 2 ШЁШұШ§ЫҢ ЩҒШұЪ©Ш§ЩҶШівҖҢЩҮШ§ЫҢ > 15 THz\n    return tf.reduce_mean(tf.square(weights * (y_pred - y_true)))\n\n# ШӘШ§ШЁШ№ physics_loss (ЩӮЩҲШ§ЩҶЫҢЩҶ ЩҒЫҢШІЫҢЪ©ЫҢ)\ndef physics_loss(y_pred):\n    # Ш¬ШұЫҢЩ…ЩҮ ШЁШұШ§ЫҢ ЩҒШұЪ©Ш§ЩҶШівҖҢЩҮШ§ЫҢ Щ…ЩҶЩҒЫҢ (Пү вүҘ 0)\n    negative_penalty = tf.reduce_mean(tf.square(tf.minimum(y_pred, 0)))\n    \n    # ШӘЩӮШұЫҢШЁ ШіШ§ШҜЩҮ ШЁШұШ§ЫҢ Ш§Щ…ЩҲШ§Ш¬ ШЁЩ„ЩҲШ®: ШіШ§ШІЪҜШ§ШұЫҢ ШЁШ§ ШӘЩӮШ§ШұЩҶ ЩӮЫҢШ§ШіЫҢ (Ш¬ШұЫҢЩ…ЩҮ ШӘШәЫҢЫҢШұШ§ШӘ ЩҶШ§ЪҜЩҮШ§ЩҶЫҢ)\n    diff_penalty = tf.reduce_mean(tf.square(y_pred[:, 1:] - y_pred[:, :-1]))  # ШӘЩҒШ§ЩҲШӘ Щ…ШӘЩҲШ§Щ„ЫҢ\n    return negative_penalty + 0.1 * diff_penalty  # ЩҲШІЩҶ 0.1 ШЁШұШ§ЫҢ Ш¬ШұЫҢЩ…ЩҮ ШӘЩҒШ§ЩҲШӘ\n\n# ШӘШ§ШЁШ№ loss ШӘШұЪ©ЫҢШЁЫҢ\ndef combined_loss(y_true, y_pred):\n    return error_loss(y_true, y_pred) + 1.0 * physics_loss(y_pred)\n\n# Щ„ЩҲШҜ ШҜШ§ШҜЩҮвҖҢЩҮШ§ ЩҲ scalerЩҮШ§\nX_train = np.load('/kaggle/input/yaml-npy/xdata_train.npy')\ny_train = np.load('/kaggle/input/yaml-npy/ydata_train.npy')\nX_test = np.load('/kaggle/input/yaml-npy/xdata_test.npy')\ny_test = np.load('/kaggle/input/yaml-npy/ydata_test.npy')\nscaler_X = joblib.load('/kaggle/input/yaml-npy/scaler_X.joblib')\nscaler_y = joblib.load('/kaggle/input/yaml-npy/scaler_y.joblib')\nmax_atoms = np.load('/kaggle/input/yaml-npy/max_atoms.npy')  # Щ„ЩҲШҜ max_atoms ШЁШұШ§ЫҢ Ш§ШіШӘЩҒШ§ШҜЩҮ ШҜШұ prepare_input\n\n# Ш§ШЁШ№Ш§ШҜ ШҜШ§ШҜЩҮвҖҢЩҮШ§\nnum_samples, num_qpoints, num_bands = y_test.shape\n\n# ШӘШ№ШұЫҢЩҒ EarlyStopping\nearly_stopping = tf.keras.callbacks.EarlyStopping(monitor='val_loss', patience=50, restore_best_weights=True)\n\n# ШіШ§Ш®ШӘ ЩҲ Ъ©Ш§Щ…ЩҫШ§ЫҢЩ„ Щ…ШҜЩ„\nmodel = build_cnn_model((X_train.shape[1],), y_train.shape[1:])\nmodel.compile(optimizer=tf.keras.optimizers.Adam(learning_rate=0.0001), \n              loss=combined_loss, \n              metrics=['mae'])\n\n# ШӘЩҶШёЫҢЩ…Ш§ШӘ Ш¬ШҜЫҢШҜ ШЁШұШ§ЫҢ ШўЩ…ЩҲШІШҙ\nhistory = model.fit(X_train, y_train.reshape(len(y_train), -1),\n                    validation_split=0.1, epochs=200, batch_size=32, verbose=1,\n                    callbacks=[early_stopping, tf.keras.callbacks.ReduceLROnPlateau(monitor='val_loss', factor=0.5, patience=20, min_lr=1e-6)])\n\n# ЩҫЫҢШҙвҖҢШЁЫҢЩҶЫҢ ШұЩҲЫҢ Щ…Ш¬Щ…ЩҲШ№ЩҮ ШӘШіШӘ\ny_test_pred_normalized = model.predict(X_test).reshape(y_test.shape)\ny_test_pred = scaler_y.inverse_transform(y_test_pred_normalized.reshape(len(y_test), -1)).reshape(y_test.shape)\ny_test_original = scaler_y.inverse_transform(y_test.reshape(len(y_test), -1)).reshape(y_test.shape)\n\n# Щ…ШӯШ§ШіШЁЩҮ Ш§Щ…ШӘЫҢШ§ШІ RВІ\nr2_scores = [r2_score(y_test_original[i].flatten(), y_test_pred[i].flatten()) for i in range(len(y_test))]\naverage_r2 = np.mean(r2_scores)\nprint(f\"Щ…ЫҢШ§ЩҶЪҜЫҢЩҶ RВІ ШҜШұ Щ…Ш¬Щ…ЩҲШ№ЩҮ ШӘШіШӘ: {average_r2:.4f}\")\n\n# Ш°Ш®ЫҢШұЩҮ Щ„ЫҢШіШӘ RВІ\nnp.save('r2_list.npy', r2_scores)\n\n# ШұШіЩ… ЩҶЩ…ЩҲЩҶЩҮ (Щ…ЩӮШ§ЫҢШіЩҮ ЩҲШ§ЩӮШ№ЫҢ ЩҲ ЩҫЫҢШҙвҖҢШЁЫҢЩҶЫҢвҖҢШҙШҜЩҮ ШЁШұШ§ЫҢ ЩҶЩ…ЩҲЩҶЩҮ 0 Ш§ШІ Щ…Ш¬Щ…ЩҲШ№ЩҮ ШӘШіШӘ)\ndef plot_sample_prediction(y_true, y_pred, sample_idx=19):\n    plt.figure(figsize=(12, 6))\n    for band in range(num_bands):\n        plt.plot(y_true[sample_idx, :, band], label=f'True Band {band}', linestyle='-', alpha=0.7)\n        plt.plot(y_pred[sample_idx, :, band], label=f'Predicted Band {band}', linestyle='--', alpha=0.7)\n    plt.axhline(y=17.0, color='r', linestyle=':', label='17 THz Target')\n    plt.xlabel('Q-point Index')\n    plt.ylabel('Frequency (THz)')\n    plt.title('Actual vs Predicted Frequencies for Sample 0 (Test Set)')\n    plt.legend()\n    plt.grid(True)\n    plt.savefig('actual_vs_predicted_sample0_cnn.png')\n    plt.close()\n\n# ШұШіЩ… ШЁШұШ§ЫҢ ЩҶЩ…ЩҲЩҶЩҮ 0 Ш§ШІ Щ…Ш¬Щ…ЩҲШ№ЩҮ ШӘШіШӘ\nplot_sample_prediction(y_test_original, y_test_pred)\n\n# ШұШіЩ… ШӘШ§ШұЫҢШ®ЪҶЩҮ ШўЩ…ЩҲШІШҙ\nplt.figure(figsize=(8, 6))\nplt.plot(history.history['loss'], label='Training Loss')\nplt.plot(history.history['val_loss'], label='Validation Loss')\nplt.xlabel('Epoch')\nplt.ylabel('Loss')\nplt.title('Training and Validation Loss')\nplt.legend()\nplt.grid(True)\nplt.savefig('training_loss_cnn.png')\nplt.close()\n\n# ШўЩ…Ш§ШҜЩҮвҖҢШіШ§ШІЫҢ ЩҲШұЩҲШҜЫҢ ШЁШұШ§ЫҢ Щ…Ш§ШҜЩҮ Ш¬ШҜЫҢШҜ\nsample_points = [\n    {'coordinates': [0.666666666666664, 0.333333333333336, 0.573789318806853], 'mass': 51.996100},\n    {'coordinates': [0.666666666666664, 0.333333333333336, 0.926210681193147], 'mass': 51.996100},\n    {'coordinates': [0.333333333333336, 0.666666666666664, 0.073789318806853], 'mass': 51.996100},\n    {'coordinates': [0.333333333333336, 0.666666666666664, 0.426210681193147], 'mass': 51.996100},\n    {'coordinates': [0.333333333333336, 0.666666666666664, 0.750000000000000], 'mass': 196.966569},\n    {'coordinates': [0.000000000000000, 0.000000000000000, 0.500000000000000], 'mass': 14.006700},\n    {'coordinates': [0.000000000000000, 0.000000000000000, 0.000000000000000], 'mass': 14.006700}\n]\nsample_lattice = [[2.932123524309962, 0.0, 0.0], [-1.466061762154982, 2.539293459086388, 0.0], [0.0, 0.0, 12.890073431300316]]\nsample_reciprocal = [[0.34104975, 0.19690517, 0.0], [0.0, 0.39381033, 0.0], [0.0, 0.0, 0.07757908]]\n\nx_new_raw = prepare_input(sample_points, sample_lattice, sample_reciprocal, max_atoms, num_qpoints)\nx_new_normalized = scaler_X.transform(x_new_raw)\npredicted_normalized = model.predict(x_new_normalized).reshape(y_test.shape[1:])\npredicted = scaler_y.inverse_transform(predicted_normalized.reshape(1, -1)).reshape(y_test.shape[1:])\n\n# ШұШіЩ… ШіШ§Ш®ШӘШ§Шұ ШЁШ§ЩҶШҜ ЩҒЩҲЩҶЩҲЩҶЫҢ ЩҫЫҢШҙвҖҢШЁЫҢЩҶЫҢвҖҢШҙШҜЩҮ\nplt.figure(figsize=(10, 6))\nfor i in range(predicted.shape[1]):\n    plt.plot(predicted[:, i])\nplt.title(\"Predicted Phonon Band Structure\")\nplt.xlabel(\"Q-point index\")\nplt.ylabel(\"Frequency (THz)\")\nplt.grid(True)\nplt.savefig('predicted_phonon_band_structure_5.png')\nplt.close()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-05-15T19:56:48.522725Z","iopub.execute_input":"2025-05-15T19:56:48.52303Z","iopub.status.idle":"2025-05-15T20:29:01.864707Z","shell.execute_reply.started":"2025-05-15T19:56:48.523003Z","shell.execute_reply":"2025-05-15T20:29:01.863688Z"}},"outputs":[{"name":"stderr","text":"2025-05-15 19:56:50.832774: E external/local_xla/xla/s