":[{"name":"stdout","text":"Optimized feature table loaded!\n   → 7 features per atom (was ~76 before)\n   → Features: ['atomic_weight', 'atomic_radius', 'atomic_radius_rahm', 'covalent_radius_cordero', 'vdw_radius', 'atomic_volume', 'lattice_constant']\nn_atom_features = 7  ← این عدد خیلی مهمه!\n","output_type":"stream"}],"execution_count":3},{"cell_type":"code","source":"def get_cartesian_positions(structure: Structure):\n    \"\"\"\n    Returns cartesian coordinates as torch tensor [N, 3]\n    \"\"\"\n    pos = torch.tensor(\n        structure.cart_coords,\n        dtype=torch.float32\n    )\n    return pos\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-12-25T09:57:28.059064Z","iopub.execute_input":"2025-12-25T09:57:28.05962Z","iopub.status.idle":"2025-12-25T09:57:28.064839Z","shell.execute_reply.started":"2025-12-25T09:57:28.059595Z","shell.execute_reply":"2025-12-25T09:57:28.064151Z"}},"outputs":[],"execution_count":4},{"cell_type":"code","source":"def build_edge_index(pos, cutoff=5.0):\n    \"\"\"\n    Build edge_index based on distance cutoff\n    \"\"\"\n    dist = torch.cdist(pos, pos)\n    mask = (dist < cutoff) & (dist > 1e-6)\n\n    edge_index = mask.nonzero(as_tuple=False).t()\n    return edge_index\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-12-25T09:57:29.338463Z","iopub.execute_input":"2025-12-25T09:57:29.339095Z","iopub.status.idle":"2025-12-25T09:57:29.343196Z","shell.execute_reply.started":"2025-12-25T09:57:29.339066Z","shell.execute_reply":"2025-12-25T09:57:29.342476Z"}},"outputs":[],"execution_count":5},{"cell_type":"code","source":"def compute_direction_only_edge_features(pos, edge_index):\n    \"\"\"\n    Direction-only edge features:\n    - unit vector components (dx, dy, dz)\n    - |dz|  → out-of-plane strength\n    - sqrt(dx^2 + dy^2) → in-plane strength\n    \"\"\"\n\n    src, dst = edge_index\n    vec = pos[dst] - pos[src]          # [E, 3]\n    norm = torch.norm(vec, dim=1, keepdim=True) + 1e-8\n    unit_vec = vec / norm               # normalize\n\n    dx = unit_vec[:, 0:1]\n    dy = unit_vec[:, 1:2]\n    dz = unit_vec[:, 2:3]\n\n    in_plane = torch.sqrt(dx**2 + dy**2)\n    out_of_plane = torch.abs(dz)\n\n    edge_attr = torch.cat(\n        [dx, dy, dz, in_plane, out_of_plane],\n        dim=1\n    )\n\n    return edge_attr  # shape: [E, 5]\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-12-25T09:57:29.618292Z","iopub.execute_input":"2025-12-25T09:57:29.618855Z","iopub.status.idle":"2025-12-25T09:57:29.624123Z","shell.execute_reply.started":"2025-12-25T09:57:29.618833Z","shell.execute_reply":"2025-12-25T09:57:29.62336Z"}},"outputs":[],"execution_count":6},{"cell_type":"code","source":"def build_graph_data(structure, node_features, cutoff=5.0):\n    pos = get_cartesian_positions(structure)\n    edge_index = build_edge_index(pos, cutoff=cutoff)\n    edge_attr = compute_direction_only_edge_features(pos, edge_index)\n\n    data = Data(\n        x=node_features,     # [N, n_atom_features]\n        pos=pos,\n        edge_index=edge_index,\n        edge_attr=edge_attr\n    )\n\n    return data\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-12-25T09:57:35.151567Z","iopub.execute_input":"2025-12-25T09:57:35.151878Z","iopub.status.idle":"2025-12-25T09:57:35.15646Z","shell.execute_reply.started":"2025-12-25T09:57:35.151855Z","shell.execute_reply":"2025-12-25T09:57:35.155803Z"}},"outputs":[],"execution_count":7},{"cell_type":"code","source":"","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### Define dual graph GNN model with custom message passing","metadata":{}},{"cell_type":"code","source":"from pymatgen.core.periodic_table import Element\n\n# Lookup سریع برای عدد اتمی و جرم اتمی\ndef get_atomic_info(symbol):\n    el = Element(symbol)\n    return el.Z, float(el.atomic_mass)\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-12-25T09:57:37.183002Z","iopub.execute_input":"2025-12-25T09:57:37.18369Z","iopub.status.idle":"2025-12-25T09:57:37.187575Z","shell.execute_reply.started":"2025-12-25T09:57:37.183664Z","shell.execute_reply":"2025-12-25T09:57:37.186837Z"}},"outputs":[],"execution_count":8},{"cell_type":"code","source":"class DualGraphGNN(nn.Module):\n    def __init__(self, n_atom_features, hidden_dim):\n        super().__init__()\n\n        self.embedding = nn.Linear(n_atom_features, hidden_dim)\n\n        # --- Directional graph ---\n        self.conv_dir = TransformerConv(\n            in_channels=hidden_dim,\n            out_channels=hidden_dim,\n            heads=4,\n            edge_dim=3,\n            concat=False\n        )\n\n        # --- Distance graph ---\n        self.conv_dist = TransformerConv(\n            in_channels=hidden_dim,\n            out_channels=hidden_dim,\n            heads=4,\n            edge_dim=1,   # یا 2\n            concat=False\n        )\n\n        self.norm = nn.LayerNorm(hidden_dim)\n\n        # Fusion\n        self.fusion = nn.Linear(2 * hidden_dim, hidden_dim)\n\n        self.readout = nn.Sequential(\n            nn.Linear(hidden_dim, hidden_dim),\n            nn.SiLU(),\n            nn.Linear(hidden_dim, 1)\n        )\n\n    def forward(self, data):\n        x = self.embedding(data.x)\n\n        # --- message passing ---\n        x_dir = self.conv_dir(x, data.edge_index, data.edge_attr_dir)\n        x_dist = self.conv_dist(x, data.edge_index, data.edge_attr_dist)\n\n        # --- fusion ---\n        x = torch.cat([x_dir, x_dist], dim=-1)\n        x = self.fusion(x)\n        x = self.norm(x)\n        x = F.silu(x)\n\n        # --- pooling ---\n        x = global_add_pool(x, data.batch)\n\n        return self.readout(x).squeeze()\n","metadata":{"execution":{"iopub.status.busy":"2025-12-25T10:24:13.258465Z","iopub.execute_input":"2025-12-25T10:24:13.259226Z","iopub.status.idle":"2025-12-25T10:24:13.265595Z","shell.execute_reply.started":"2025-12-25T10:24:13.259199Z","shell.execute_reply":"2025-12-25T10:24:13.265039Z"},"trusted":true},"outputs":[],"execution_count":52},{"cell_type":"code","source":"from scipy.spatial.distance import cdist\nimport numpy as np\nimport torch\nfrom torch_geometric.data import Data\n\ndef structure_to_graph(structure, target_value, df_ptable):\n    structure = structure.copy()\n    structure.make_supercell([1, 1, 1])\n\n    # -------------------------\n    # اطلاعات پایه\n    # -------------------------\n    positions = np.array([site.coords for site in structure.sites])\n    symbols   = [site.specie.symbol for site in structure.sites]\n\n    Z_list = []\n    mass_list = []\n    for s in symbols:\n        Z, m = get_atomic_info(s)\n        Z_list.append(Z)\n        mass_list.append(m)\n\n    Z_list = np.array(Z_list, dtype=np.float32)\n    mass_list = np.array(mass_list, dtype=np.float32)\n\n    distances = cdist(positions, positions)\n    cutoff = 8.0\n\n    bonds = [\n        (i, j)\n        for i in range(len(positions))\n        for j in range(i + 1, len(positions))\n        if distances[i, j] <= cutoff\n    ]\n\n    # -------------------------\n    # fallback (rare case)\n    # -------------------------\n    if len(bonds) == 0:\n        x = torch.zeros((1, 9), dtype=torch.float)\n        edge_index = torch.zeros((2, 0), dtype=torch.long)\n        edge_attr = torch.zeros((0, 1), dtype=torch.float)\n        y = torch.tensor([target_value], dtype=torch.float)\n        u = torch.tensor(\n            [[structure.volume / len(positions), 1.0, structure.lattice.volume]],\n            dtype=torch.float\n        )\n        return Data(x=x, edge_index=edge_index, edge_attr=edge_attr, y=y, u=u)\n\n    # =====================================================\n    # Bond node features (۹ فیچر فیزیکی)\n    # =====================================================\n    node_features = []\n\n    for i, j in bonds:\n        d = distances[i, j]\n\n        Zi, Zj = Z_list[i], Z_list[j]\n        mi, mj = mass_list[i], mass_list[j]\n\n        coord_i = np.sum(distances[i] <= cutoff) - 1\n        coord_j = np.sum(distances[j] <= cutoff) - 1\n\n        # ---------- فیزیک phonon ----------\n        mu_reduced = (mi * mj) / (mi + mj + 1e-8)\n        \n        k_proxy_raw = (Zi * Zj) / (d**2 + 1e-6)\n        \n        k_proxy = np.log(k_proxy_raw + 1.0)\n        mu_log = np.log(mu_reduced + 1.0)\n        k_over_mu = k_proxy - mu_log\n\n\n        node_features.append([\n            d,\n            coord_i,\n            coord_j,\n            0.5 * (coord_i + coord_j),\n            Zi,\n            Zj,\n            mu_log,\n            k_proxy,\n            k_over_mu\n        ])\n\n    x = torch.tensor(node_features, dtype=torch.float)\n\n    # =====================================================\n    # Angle edges (همان نسخه قبلی)\n    # =====================================================\n    edge_index = []\n    edge_attr = []\n\n    for idx1, (i1, j1) in enumerate(bonds):\n        for idx2, (i2, j2) in enumerate(bonds[idx1 + 1:], start=idx1 + 1):\n            shared = set([i1, j1]) & set([i2, j2])\n            if len(shared) == 1:\n                s = shared.pop()\n                a = positions[i1 if i1 != s else j1] - positions[s]\n                b = positions[i2 if i2 != s else j2] - positions[s]\n\n                na = np.linalg.norm(a)\n                nb = np.linalg.norm(b)\n\n                if na > 0 and nb > 0:\n                    cos_angle = np.dot(a, b) / (na * nb)\n                    cos_angle = np.clip(cos_angle, -1.0, 1.0)\n                    angle = np.arccos(cos_angle)\n\n                    edge_index.extend([[idx1, idx2], [idx2, idx1]])\n                    edge_attr.extend([[angle], [angle]])\n\n    edge_index = (\n        torch.tensor(edge_index, dtype=torch.long).t().contiguous()\n        if edge_index else torch.zeros((2, 0), dtype=torch.long)\n    )\n    edge_attr = (\n        torch.tensor(edge_attr, dtype=torch.float)\n        if edge_attr else torch.zeros((