53], 'mass': 51.996100},\n    {'coordinates': [0.333333333333336, 0.666666666666664, 0.426210681193147], 'mass': 51.996100},\n    {'coordinates': [0.333333333333336, 0.666666666666664, 0.750000000000000], 'mass': 196.966569},\n    {'coordinates': [0.666666666666664, 0.333333333333336, 0.250000000000000], 'mass': 196.966569},\n    {'coordinates': [0.000000000000000, 0.000000000000000, 0.500000000000000], 'mass': 14.006700},\n    {'coordinates': [0.000000000000000, 0.000000000000000, 0.000000000000000], 'mass': 14.006700}\n]\nsample_lattice = [[2.932123524309962, 0.0, 0.0], [-1.466061762154982, 2.539293459086388, 0.0], [0.0, 0.0, 12.890073431300316]]\nsample_reciprocal = [[0.34104975, 0.19690517, 0.0], [0.0, 0.39381033, 0.0], [0.0, 0.0, 0.07757908]]\n\nx_new = prepare_input(sample_points, sample_lattice, sample_reciprocal, max_atoms)\npredicted = model.predict(x_new).reshape(y.shape[1:])\n\n# =======================\n# Step 5: Calculate and Store Errors\n# =======================\n\n\n# به‌روزرسانی تابع خطا\ndef calculate_errors(y_true, y_pred):\n    y_true_flat = y_true.flatten()\n    y_pred_flat = y_pred.flatten()\n    \n    mae = np.mean(np.abs(y_true_flat - y_pred_flat))\n    mse = np.mean((y_true_flat - y_pred_flat) ** 2)\n    rmse = np.sqrt(mse)\n    \n    non_zero_mask = y_true_flat != 0\n    mape = np.mean(np.abs((y_true_flat[non_zero_mask] - y_pred_flat[non_zero_mask]) / y_true_flat[non_zero_mask])) * 100 if np.any(non_zero_mask) else np.nan\n\n    r2 = r2_score(y_true_flat, y_pred_flat)  # ← محاسبه R²\n\n    return {\n        'MAE': mae,\n        'MSE': mse,\n        'RMSE': rmse,\n        'MAPE': mape,\n        'R2': r2  # ← اضافه شد\n    }\n\n# لیست خطاها برای کل تست‌ست\ny_test_pred = model.predict(X_test)\nerrors_list = []\nr2_list = []\n\n\nfor i in range(len(y_test)):\n    errors = calculate_errors(y_test[i], y_test_pred[i])\n    errors_list.append(errors)\n    r2_list.append(errors['R2'])  # ← R² هر نمونه\n\n# میانگین خطاها\naggregate_errors = {\n    'MAE': np.mean([e['MAE'] for e in errors_list]),\n    'MSE': np.mean([e['MSE'] for e in errors_list]),\n    'RMSE': np.mean([e['RMSE'] for e in errors_list]),\n    'MAPE': np.nanmean([e['MAPE'] for e in errors_list]),\n    'R2': np.mean(r2_list)  # ← میانگین R²\n}\n\n# چاپ نتایج\nprint(\"\\n=== Aggregate Errors on Test Set ===\")\nfor metric, value in aggregate_errors.items():\n    print(f\"{metric}: {value:.4f}\")\n\n# ذخیره لیست R² برای استفاده بعدی\nnp.save('r2_list.npy', r2_list)\n\n\n# Plot predicted phonon band structure\nplt.figure(figsize=(10, 6))\nfor i in range(predicted.shape[1]):\n    plt.plot(predicted[:, i])\nplt.title(\"Predicted Phonon Band Structure\")\nplt.xlabel(\"Q-point index\")\nplt.ylabel(\"Frequency (THz)\")\nplt.grid(True)\n#plt.savefig('phonon_band_structure.png')\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-04-22T21:10:43.59516Z","iopub.execute_input":"2025-04-22T21:10:43.595513Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"","metadata":{"trusted":true},"outputs":[],"execution_count":null}]}