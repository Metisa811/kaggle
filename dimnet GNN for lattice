{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"pygments_lexer":"ipython3","nbconvert_exporter":"python","version":"3.6.4","file_extension":".py","codemirror_mode":{"name":"ipython","version":3},"name":"python","mimetype":"text/x-python"},"kaggle":{"accelerator":"none","dataSources":[{"sourceType":"datasetVersion","sourceId":13099679}],"dockerImageVersionId":31089,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":false}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"code","source":"import torch\nimport torch.nn as nn\nimport torch.nn.functional as F\nfrom torch.utils.data import Dataset, DataLoader\n\nimport numpy as np\nfrom ase.io import read\nfrom phonopy import Phonopy\nfrom phonopy.structure.cells import get_supercell\nfrom phonopy.interface.calculator import read_force_constants\n\n# ---------- بخش 1: خواندن داده ----------\nclass PhononDataset(Dataset):\n    def __init__(self, poscar_path, force_constants_path, cutoff=5.0):\n        # ساختار بلوری (ASE atoms)\n        self.atoms = read(poscar_path)\n        self.natoms = len(self.atoms)\n\n        # نیروی هدف: از force constants و جابجایی‌ها محاسبه می‌شود\n        self.force_constants = read_force_constants(force_constants_path)\n\n        # گراف: همسایه‌ها و زوایا\n        self.cutoff = cutoff\n        self.edges, self.triplets = self.build_graph()\n\n    def build_graph(self):\n        edges = []\n        triplets = []\n        cell = self.atoms.get_cell()\n        positions = self.atoms.get_positions()\n\n        for i, ri in enumerate(positions):\n            for j, rj in enumerate(positions):\n                if i == j: \n                    continue\n                # کوتاهترین بردار تصویر\n                dr = self.atoms.get_distance(i, j, mic=True, vector=True)\n                d = np.linalg.norm(dr)\n                if d <= self.cutoff:\n                    edges.append((i, j, dr))\n\n        # triplets (k->j->i)\n        for j in range(self.natoms):\n            nbrs = [e for e in edges if e[0] == j]  # همسایه‌هایی که به j ختم می‌شوند\n            for (i1, j1, dr1) in nbrs:\n                for (i2, j2, dr2) in nbrs:\n                    if i1 != i2:\n                        angle = self.calc_angle(dr1, dr2)\n                        triplets.append((i2, j, i1, angle))\n        return edges, triplets\n\n    def calc_angle(self, v1, v2):\n        cos = np.dot(v1, v2) / (np.linalg.norm(v1)*np.linalg.norm(v2))\n        return np.arccos(np.clip(cos, -1.0, 1.0))\n\n    def __len__(self):\n        return len(self.edges)\n\n    def __getitem__(self, idx):\n        i, j, dr = self.edges[idx]\n        # ورودی: نوع اتم، فاصله\n        # خروجی: نیروها (TODO: بر اساس دیتای واقعی بساز)\n        return {\n            \"i\": i, \"j\": j, \"dr\": dr,\n            \"target_force\": np.zeros(3)  # TODO\n        }\n\n# ---------- بخش 2: Basis functions ----------\ndef radial_bessel(d, nmax=16, cutoff=5.0):\n    # پایه‌های بسل شعاعی (ارتوگونال)\n    res = []\n    for n in range(1, nmax+1):\n        res.append(np.sin(n*np.pi*d/cutoff)/d)\n    return np.array(res)\n\ndef spherical_bessel_angle(d, angle, nrad=6, nang=7, cutoff=5.0):\n    # ترکیب ساده بسل+Legendre (ساده‌شده)\n    res = []\n    for n in range(1, nrad+1):\n        for l in range(nang):\n            res.append((np.sin(n*np.pi*d/cutoff)/d) * np.cos(l*angle))\n    return np.array(res)\n\n# ---------- بخش 3: مدل DimeNet ساده‌شده ----------\nclass SimpleDimeNet(nn.Module):\n    def __init__(self, emb_size=128, num_radial=16, num_spherical=7):\n        super().__init__()\n        self.emb_size = emb_size\n        self.lin_in = nn.Linear(num_radial, emb_size)\n        self.interaction = nn.Sequential(\n            nn.Linear(emb_size, emb_size),\n            nn.SiLU(),\n            nn.Linear(emb_size, emb_size),\n        )\n        self.lin_out = nn.Linear(emb_size, 3)  # پیش‌بینی نیرو روی بردار 3D\n\n    def forward(self, rbf):\n        h = self.lin_in(rbf)\n        h = self.interaction(h)\n        return self.lin_out(h)\n\n# ---------- بخش 4: آموزش ----------\ndef train_model(dataset, model, nepochs=50, batch_size=32, lr=1e-3):\n    loader = DataLoader(dataset, batch_size=batch_size, shuffle=True)\n    opt = torch.optim.Adam(model.parameters(), lr=lr)\n\n    train_losses, val_losses = [], []\n    for epoch in range(nepochs):\n        model.train()\n        epoch_loss = 0\n        for batch in loader:\n            dr = np.linalg.norm(batch[\"dr\"].numpy(), axis=1)\n            rbf = np.array([radial_bessel(d) for d in dr])\n            rbf = torch.tensor(rbf, dtype=torch.float32)\n\n            target = torch.tensor(batch[\"target_force\"], dtype=torch.float32)\n\n            pred = model(rbf)\n            loss = F.mse_loss(pred, target)\n\n            opt.zero_grad()\n            loss.backward()\n            opt.step()\n\n            epoch_loss += loss.item()\n        train_losses.append(epoch_loss/len(loader))\n\n        print(f\"Epoch {epoch}: loss={train_losses[-1]:.4f}\")\n\n    return train_losses, val_losses\n\n# ---------- بخش 5: رسم نمودار ----------\nimport matplotlib.pyplot as plt\n\ndef plot_losses(train_losses, val_losses):\n    plt.plot(train_losses, label=\"Train\")\n    plt.plot(val_losses, label=\"Validation\")\n    plt.legend()\n    plt.xlabel(\"Epoch\")\n    plt.ylabel(\"Loss\")\n    plt.show()\n\ndef plot_phonon_band(structure, force_constants, force_constants_pred):\n    # ساخت phonopy object واقعی vs پیش‌بینی\n    phonon_real = Phonopy(structure, supercell_matrix=[[2,0,0],[0,2,0],[0,0,2]])\n    phonon_real.set_force_constants(force_constants)\n\n    phonon_pred = Phonopy(structure, supercell_matrix=[[2,0,0],[0,2,0],[0,0,2]])\n    phonon_pred.set_force_constants(force_constants_pred)\n\n    qpts, bands = phonon_real.get_band_structure()\n    qpts2, bands_pred = phonon_pred.get_band_structure()\n\n    for br, bp in zip(bands, bands_pred):\n        plt.plot(qpts, br, \"b-\", label=\"DFT\")\n        plt.plot(qpts2, bp, \"r--\", label=\"ML\")\n    plt.legend()\n    plt.show()\n","metadata":{"_uuid":"8f2839f25d086af736a60e9eeb907d3b93b6e0e5","_cell_guid":"b1076dfc-b9ad-4769-8c92-a6c4dae69d19","trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"","metadata":{"trusted":true},"outputs":[],"execution_count":null}]}