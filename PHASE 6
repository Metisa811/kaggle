15/15\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m0s\u001b[0m 7ms/step - loss: 0.2292 - mae: 0.3396 - val_loss: 0.2083 - val_mae: 0.3151 - learning_rate: 2.5000e-05\nEpoch 200/200\n\u001b[1m15/15\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m0s\u001b[0m 7ms/step - loss: 0.2090 - mae: 0.3132 - val_loss: 0.2031 - val_mae: 0.3100 - learning_rate: 2.5000e-05\n\u001b[1m3/3\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m1s\u001b[0m 186ms/step\nمیانگین R² روی تست: 0.9719\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 1000x600 with 1 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":4},{"cell_type":"code","source":"# train_model_smooth.py\n\"\"\"\nنسخه پیشرفتهٔ آموزش مدل فونون:\n- Residual Dense blocks\n- Swish activation\n- Loss = MSE + lambda_smooth * smoothness_loss (مشتق دوم روی محور Q)\n- پس از پیش‌بینی، اعمال Savitzky-Golay برای نرم‌سازی\n\"\"\"\n\nimport os\nimport numpy as np\nimport tensorflow as tf\nfrom sklearn.metrics import r2_score\nimport matplotlib.pyplot as plt\nfrom scipy.signal import savgol_filter\n\n# تنظیم مسیر داده‌ها (تغییر بده در صورت نیاز)\ndata_dir = \"/kaggle/input/dataset-features-gpt5\"  # مسیر حاوی .npy ها (یا مسیر محلی خودت)\nout_dir = \"/kaggle/working\"            # مسیر خروجی‌ها (مدل، نمودار، r2)\nos.makedirs(out_dir, exist_ok=True)\n\n# بارگذاری داده‌ها\nX_train = np.load(os.path.join(data_dir, \"train_x.npy\"))\nX_val   = np.load(os.path.join(data_dir, \"val_x.npy\"))\nX_test  = np.load(os.path.join(data_dir, \"test_x.npy\"))\ny_train = np.load(os.path.join(data_dir, \"train_y.npy\"))\ny_val   = np.load(os.path.join(data_dir, \"val_y.npy\"))\ny_test  = np.load(os.path.join(data_dir, \"test_y.npy\"))\n\nscaler_y_mean = np.load(os.path.join(data_dir, \"scaler_y_mean.npy\"))\nscaler_y_std  = np.load(os.path.join(data_dir, \"scaler_y_std.npy\"))\nscaler_X_mean = np.load(os.path.join(data_dir, \"scaler_X_mean.npy\"))\nscaler_X_std  = np.load(os.path.join(data_dir, \"scaler_X_std.npy\"))\n\n# تعیین ابعاد خروجی از y\nnum_samples, max_qpoints, max_bands = y_train.shape\noutput_flat_dim = int(max_qpoints * max_bands)\n\n# تابع کمکی: بازگردانی y از نرمالایز\ndef inverse_transform_y_flat(y_norm_flat):\n    # y_norm_flat shape: (N, output_flat_dim)\n    return (y_norm_flat * scaler_y_std + scaler_y_mean).reshape(-1, max_qpoints, max_bands)\n\n# تابع smoothness loss: میانگین مربع مشتق دوم نسبت به Q\ndef smoothness_loss_from_reshaped(y_pred_reshaped):\n    # y_pred_reshaped: (batch, Q, bands)\n    # second finite difference along axis=1 (Q-axis)\n    # d2 = y[i+2] - 2*y[i+1] + y[i]\n    d2 = y_pred_reshaped[:, 2:, :] - 2.0 * y_pred_reshaped[:, 1:-1, :] + y_pred_reshaped[:, :-2, :]\n    return tf.reduce_mean(tf.square(d2))\n\n# ساخت مدل با residual blocks و swish\ndef swish(x): \n    return tf.nn.swish(x)\n\ndef residual_dense_block(x, units, dropout_rate=0.0):\n    shortcut = x\n    # اگر ابعاد shortcut با units یکی نیست، با Dense تبدیلش کن\n    if shortcut.shape[-1] != units:\n        shortcut = tf.keras.layers.Dense(units, activation=None)(shortcut)\n    \n    x = tf.keras.layers.Dense(units, activation='swish')(x)\n    x = tf.keras.layers.BatchNormalization()(x)\n    x = tf.keras.layers.Dropout(dropout_rate)(x)\n    x = tf.keras.layers.Dense(units, activation=None)(x)\n    x = tf.keras.layers.BatchNormalization()(x)\n    \n    x = tf.keras.layers.Add()([shortcut, x])\n    x = tf.keras.layers.Activation('swish')(x)\n    return x\n\ndef build_model(input_dim, output_dim):\n    inp = tf.keras.layers.Input(shape=(input_dim,), name=\"input\")\n    x = tf.keras.layers.Dense(1024, activation=swish)(inp)\n    x = tf.keras.layers.BatchNormalization()(x)\n\n    # 3 residual-dense blocks\n    x = residual_dense_block(x, 1024, dropout_rate=0.06)\n    x = residual_dense_block(x, 768, dropout_rate=0.05)\n    x = residual_dense_block(x, 512, dropout_rate=0.04)\n\n    x = tf.keras.layers.Dense(512, activation=swish)(x)\n    x = tf.keras.layers.Dropout(0.2)(x)\n    out = tf.keras.layers.Dense(output_dim, activation='linear', name=\"out\")(x)\n\n    model = tf.keras.Model(inputs=inp, outputs=out)\n    return model\n\n# ساخت مدل\ninput_dim = X_train.shape[1]\nmodel = build_model(input_dim, output_flat_dim)\nmodel.summary()\n\n# سفارشی‌سازی loss: MSE + lambda_smooth * smoothness_loss\nlambda_smooth = 1e-2   # مقدار قابل تنظیم؛ از 1e-3 تا 1e-1 تست کن\n\n# تابع loss سفارشی با استفاده از y_true, y_pred\nmse = tf.keras.losses.MeanSquaredError()\n\n@tf.function\ndef combined_loss(y_true, y_pred):\n    # y_true, y_pred: شکل (batch, output_flat_dim)\n    loss_mse = mse(y_true, y_pred)\n    # reshape to (batch, Q, bands)\n    y_pred_resh = tf.reshape(y_pred, (-1, max_qpoints, max_bands))\n    loss_smooth = smoothness_loss_from_reshaped(y_pred_resh)\n    return loss_mse + lambda_smooth * loss_smooth\n\n# کامپایل مدل (استفاده از optimizer با weight decay از طریق AdamW)\ntry:\n    # TF 2.11+ has AdamW in tfa or tf.keras.optimizers.experimental.AdamW\n    opt = tf.keras.optimizers.Adam(learning_rate=1e-4)\nexcept:\n    opt = tf.keras.optimizers.Adam(learning_rate=1e-4)\n\nmodel.compile(optimizer=opt, loss=combined_loss, metrics=[tf.keras.metrics.MeanAbsoluteError()])\n\n# callbacks\nearly_stopping = tf.keras.callbacks.EarlyStopping(monitor='val_loss', patience=80, restore_best_weights=True)\nreduce_lr = tf.keras.callbacks.ReduceLROnPlateau(monitor='val_loss', factor=0.5, patience=10, min_lr=1e-7, verbose=1)\ncheckpoint = tf.keras.callbacks.ModelCheckpoint(os.path.join(out_dir, \"best_model.h5\"), monitor='val_loss', save_best_only=True)\n\n# آماده‌سازی داده‌ها برای آموزش (flatten y)\ny_train_flat = y_train.reshape(len(y_train), -1)\ny_val_flat   = y_val.reshape(len(y_val), -1)\n\n# آموزش\nhistory = model.fit(\n    X_train, y_train_flat,\n    validation_data=(X_val, y_val_flat),\n    epochs=1000,\n    batch_size=16,\n    callbacks=[early_stopping, reduce_lr, checkpoint],\n    verbose=1\n)\n\n# بارگذاری بهترین مدل و پیش‌بینی روی تست\nmodel.load_weights(os.path.join(out_dir, \"best_model.h5\"))\ny_pred_norm_flat = model.predict(X_test, batch_size=32)\ny_pred_norm = y_pred_norm_flat.reshape(len(X_test), max_qpoints, max_bands)\n\n# inverse transform\ny_test_true = inverse_transform_y_flat(y_test.reshape(len(y_test), -1))\ny_pred = inverse_transform_y_flat(y_pred_norm_flat)\n\n# محاسبه R2 برای هر نمونه\nr2_scores = [r2_score(y_test_true[i].flatten(), y_pred[i].flatten()) for i in range(len(y_test_true))]\nprint(f\"میانگین R² روی تست: {np.mean(r2_scores):.6f}\")\nnp.save(os.path.join(out_dir, \"r2_list.npy\"), np.array(r2_scores))\n\n# نمونه رسم یک مورد قبل از فیلتر و بعد از فیلتر\nsample_idx = 0\npred_sample = y_pred[sample_idx]  # shape (Q, bands)\n\n# Savitzky-Golay smoothing (پارامترها قابل تغییرند)\nwindow_length = 9 if max_qpoints >= 9 else (max_qpoints // 2 * 2 + 1)  # باید فرد باشد\npolyorder = 3\npred_smooth = np.copy(pred_sample)\nfor b in range(pred_sample.shape[1]):\n    try:\n        pred_smooth[:, b] = savgol_filter(pred_sample[:, b], window_length=window_length, polyorder=polyorder, mode='interp')\n    except Exception as e:\n        # اگر نتوانست، از Gaussian ساده استفاده کن\n        from scipy.ndimage import gaussian_filter1d\n        pred_smooth[:, b] = gaussian_filter1d(pred_sample[:, b], sigma=0.6)\n\n# رسم\nplt.figure(figsize=(10, 6))\nplt.title(f\"Predicted phonon bands (sample {sample_idx}) — before & after smoothing\")\nfor b in range(pred_sample.shape[1]):\n    plt.plot(pred_sample[:, b], color='C{}'.format(b%10), alpha=0.5)\nfor b in range(pred_smooth.shape[1]):\n    plt.plot(pred_smooth[:, b], color='C{}'.format(b%10), linewidth=1.5)\nplt.xlabel(\"Q-point\")\nplt.ylabel(\"Frequency (THz)\")\nplt.grid(True)\nplt.savefig(os.path.join(out_dir, \"pred_before_after_smooth.png\"))\nplt.show()\n\nprint(\"ذخیره مدل: \", os.path.join(out_dir, \"best_model.h5\"))\nprint(\"ذخیره لیست R2: \", os.path.join(out_dir, \"r2_list.npy\"))\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-08-10T18:00:35.055433Z","iopub.execute_input":"2025-08-10T18:00:35.055775Z","iopub.status.idle":"2025-08-10T18:10:16.542819Z","shell.execute_reply.started":"2025-08-10T18:00:35.055732Z","shell.execute_reply":"2025-08-10T18:10:16.54167Z"}},"outputs":[{"name":"stderr","text":"2025-08-10 18:00:37.168875: E external/local_xla/xla/stream_executor/cuda/cuda_fft.cc:477] Unable to register cuFFT factory: Attempting to register factory for plugin cuFFT when one has already been registered\nWARNING: All log messages before absl::InitializeLog() is called are written to STDERR\nE0000 00:00:1754848837.435730      36 cuda_dnn.cc:8310] Unable to register cuDNN factory: Attempting to register factory for plugin cuDNN when one has already been registered\nE0000 00:00:1754848837.510376      36 cuda_blas.cc:1418] Unable to register cuBLAS factory: Attempting to register factory for plugin cuBLAS when one has already been registered\nI0000 00:00:1754848853.993171      36 gpu_device.cc:2022] Created device /job:localhost/replica:0/task:0/device:GPU:0 with 15513 MB memory:  -> device: 0, name: Tesla P100-PCIE-16GB, pci bus id: 0000:00:04.0, compute capability: 6.0\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"\u001b[1mModel: \"functional\"\u001b[0m\n","text/html":"<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\">Model: \"functional\"</span>\n</pre>\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"┏━━━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━┓\n┃\u001b[1m \u001b[0m\u001b[1mLayer (type)       \u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1mOutput Shape     \u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1m   Param #\u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1mConnect