ent/...) در اکسل پیدا نشد.\")\n\ndef _guess_mass_like_cols(df):\n    \"\"\"ستون‌های شبیه جرم (برای fallback نگاشت بر اساس جرم)\"\"\"\n    mass_like = []\n    for c in df.columns:\n        if any(k in c for k in [\"atomic_weight\", \"atomic_mass\", \"mass\", \"amu\", \"weight\"]):\n            mass_like.append(c)\n    return mass_like  # ممکن است خالی باشد (اشکالی ندارد)\n\ndef _read_excel_features(excel_path):\n    df = pd.read_excel(excel_path)\n    df.columns = _normalize_cols(df.columns)\n    sym_col = _guess_symbol_col(df)\n\n    # ستونی که احتمالاً جرم است (برای fallback استفاده می‌شود؛ وارد X نمی‌کنیم)\n    mass_cols = _guess_mass_like_cols(df)\n\n    # ویژگی‌های ورودی = تمام ستون‌ها به‌جز symbol و ستون‌های جرم‌گونه\n    feature_cols = [c for c in df.columns if c not in [sym_col] + mass_cols]\n\n    # دیکشنری: symbol -> بردار ویژگی‌ها (به ترتیب feature_cols)\n    elem_features = {}\n    for _, r in df.iterrows():\n        sym = str(r[sym_col]).strip()\n        vals = r[feature_cols].astype(float).fillna(0.0).values\n        elem_features[sym] = vals\n\n    # اگر mass_col داریم، برای نگاشت بر اساس جرم استفاده می‌کنیم\n    mass_map = None\n    if mass_cols:\n        # از اولین ستون جرم استفاده می‌کنیم\n        mcol = mass_cols[0]\n        mass_map = []\n        for _, r in df.iterrows():\n            sym = str(r[sym_col]).strip()\n            try:\n                mval = float(r[mcol])\n            except:\n                mval = np.nan\n            mass_map.append((mval, sym))\n        mass_map = [(m, s) for (m, s) in mass_map if np.isfinite(m)]\n        mass_array = np.array([m for m, _ in mass_map], dtype=float)\n    else:\n        mass_array = None\n\n    return elem_features, feature_cols, mass_map, mass_array\n\ndef _find_symbol_by_mass(mass, mass_map, mass_array, tol=0.5):\n    \"\"\"اگر symbol در YAML نبود و اکسل جرم دارد، نزدیک‌ترین عنصر را با جرم حدس می‌زند.\"\"\"\n    if mass_map is None or mass_array is None or len(mass_array) == 0:\n        return None, None  # امکان نگاشت نداریم\n    diffs = np.abs(mass_array - mass)\n    idx = np.argmin(diffs)\n    best_mass, best_sym = mass_map[idx]\n    return best_sym, float(diffs[idx])\n\n# -----------------------\n# گام 1: خواندن اکسل و آماده‌سازی دیکشنری ویژگی عناصر\n# -----------------------\nelem_features, excel_feature_cols, mass_map, mass_array = _read_excel_features(excel_path)\nprint(f\"[Excel] تعداد ویژگی‌های عنصری استفاده‌شده: {len(excel_feature_cols)}\")\nprint(f\"[Excel] نمونه‌ای از ویژگی‌ها: {excel_feature_cols[:10]}\")\n\n# -----------------------\n# گام 2: یک پاس سریع روی YAML برای تعیین بیشینه‌ها\n# -----------------------\nmax_atoms = 0\nmax_bands = 0\nmax_qpoints = 0\nyaml_files = [f for f in os.listdir(yaml_folder) if f.endswith(\".yaml\")]\n\nfor file in yaml_files:\n    try:\n        with open(os.path.join(yaml_folder, file), \"r\") as f:\n            data = yaml.safe_load(f)\n        if not data or \"points\" not in data or \"phonon\" not in data:\n            continue\n        n_atoms = len(data[\"points\"])\n        n_q = len(data[\"phonon\"])\n        n_b = len(data[\"phonon\"][0].get(\"band\", [])) if n_q > 0 else 0\n        max_atoms = max(max_atoms, n_atoms)\n        max_qpoints = max(max_qpoints, n_q)\n        max_bands = max(max_bands, n_b)\n    except Exception as e:\n        print(f\"[COUNT] skip {file}: {e}\")\n\nprint(f\"[YAML] max_atoms={max_atoms}, max_qpoints={max_qpoints}, max_bands={max_bands}\")\n\n# طول بردار ویژگی هر اتم: 3 مختصات + 1 جرم (از YAML) + ویژگی‌های اکسل\nper_atom_feature_len = 3 + 1 + len(excel_feature_cols)\n\n# -----------------------\n# گام 3: پاس اصلی؛ ساخت X و y\n# -----------------------\nX_list, Y_list = [], []\nmissing_symbol, mass_matched, zero_filled = 0, 0, 0\n\nfor file in yaml_files:\n    try:\n        with open(os.path.join(yaml_folder, file), \"r\") as f:\n            data = yaml.safe_load(f)\n        if not data:\n            continue\n        if \"points\" not in data or \"lattice\" not in data or \"reciprocal_lattice\" not in data or \"phonon\" not in data:\n            continue\n\n        # --- ویژگی‌های هر اتم ---\n        atom_vecs = []\n        for pt in data[\"points\"]:\n            # coords\n            coords = pt.get(\"coordinates\", [0.0, 0.0, 0.0])\n            coords = list(coords) + [0.0] * (3 - len(coords))  # ایمنی\n            coords = coords[:3]\n\n            # mass از YAML\n            mass_yaml = float(pt.get(\"mass\", 0.0))\n\n            # symbol اگر موجود نبود، با جرم حدس می‌زنیم (اگر اکسل جرم داشته باشد)\n            sym = None\n            for key in [\"symbol\", \"label\", \"element\", \"species\", \"name\"]:\n                if key in pt and str(pt[key]).strip():\n                    sym = str(pt[key]).strip()\n                    break\n\n            feat_vec = None\n            if sym and sym in elem_features:\n                feat_vec = elem_features[sym]\n            else:\n                missing_symbol += 1\n                guessed_sym, diff = _find_symbol_by_mass(mass_yaml, mass_map, mass_array, tol=0.5)\n                if guessed_sym and guessed_sym in elem_features:\n                    feat_vec = elem_features[guessed_sym]\n                    mass_matched += 1\n                else:\n                    # اگر نتونست حدس بزنه یا اکسل جرم نداشت، صفر پر می‌کنیم\n                    feat_vec = np.zeros(len(excel_feature_cols), dtype=float)\n                    zero_filled += 1\n\n            vec = np.array(coords + [mass_yaml], dtype=float)\n            vec = np.concatenate([vec, feat_vec.astype(float)], axis=0)  # طول = per_atom_feature_len\n            atom_vecs.append(vec)\n\n        atom_mat = np.array(atom_vecs, dtype=float)\n        # padding روی محور اتم‌ها\n        if atom_mat.shape[0] < max_atoms:\n            pad = np.zeros((max_atoms - atom_mat.shape[0], per_atom_feature_len), dtype=float)\n            atom_mat = np.vstack([atom_mat, pad])\n        elif atom_mat.shape[0] > max_atoms:\n            atom_mat = atom_mat[:max_atoms, :]\n\n        # --- lattice و reciprocal_lattice ---\n        lattice = np.array(data[\"lattice\"], dtype=float).flatten()\n        recip   = np.array(data[\"reciprocal_lattice\"], dtype=float).flatten()\n\n        # --- ساخت بردار ویژگی نهایی نمونه ---\n        feat_tensor = np.concatenate([atom_mat.flatten(), lattice, recip], axis=0).astype(float)\n        X_list.append(feat_tensor)\n\n        # --- فرکانس‌ها (y) ---\n        freqs = []\n        for qpt in data[\"phonon\"]:\n            bands = [b.get(\"frequency\", 0.0) for b in qpt.get(\"band\", [])]\n            freqs.append(bands)\n        freqs = np.array(freqs, dtype=float)\n\n        # پدینگ فرکانس‌ها به (max_qpoints, max_bands)\n        fq_pad = np.zeros((max_qpoints, max_bands), dtype=float)\n        fq_pad[:min(max_qpoints, freqs.shape[0]), :min(max_bands, freqs.shape[1])] = freqs[:max_qpoints, :max_bands]\n        Y_list.append(fq_pad)\n\n    except Exception as e:\n        print(f\"[PARSE] skip {file}: {e}\")\n\nX = np.array(X_list, dtype=float)\ny = np.array(Y_list, dtype=float)\n\nprint(f\"[BUILD] samples={len(X)}, X.shape={X.shape}, y.shape={y.shape}\")\nprint(f\"[INFO] missing_symbol={missing_symbol}, mass_matched={mass_matched}, zero_filled={zero_filled}\")\n\n# -----------------------\n# گام 4: نرم‌سازی ملایم روی محور Q\n# -----------------------\ny_smooth = gaussian_filter1d(y, sigma=0.6, axis=1)\n\n# -----------------------\n# گام 5: نرمال‌سازی و تقسیم داده‌ها\n# -----------------------\n# X\nscaler_X = StandardScaler()\nX_norm = scaler_X.fit_transform(X)\n\n# y را فلت می‌کنیم، نرمال، و بعد دوباره reshape\nn_samples, n_q, n_b = y_smooth.shape\ny_flat = y_smooth.reshape(n_samples, -1)\n\nscaler_y = StandardScaler()\ny_norm_flat = scaler_y.fit_transform(y_flat)\ny_norm = y_norm_flat.reshape(n_samples, n_q, n_b)\n\n# split: 20% تست، از بقیه 20% اعتبارسنجی\nX_tmp, X_test, y_tmp, y_test = train_test_split(X_norm, y_norm, test_size=0.2, random_state=42)\nX_train, X_val,  y_train, y_val = train_test_split(X_tmp, y_tmp, test_size=0.2, random_state=42)\n\n# -----------------------\n# گام 6: ذخیره خروجی‌ها و متادیتا\n# -----------------------\nnp.save(os.path.join(out_dir, \"train_x.npy\"), X_train)\nnp.save(os.path.join(out_dir, \"val_x.npy\"),   X_val)\nnp.save(os.path.join(out_dir, \"test_x.npy\"),  X_test)\n\nnp.save(os.path.join(out_dir, \"train_y.npy\"), y_train)\nnp.save(os.path.join(out_dir, \"val_y.npy\"),   y_val)\nnp.save(os.path.join(out_dir, \"test_y.npy\"),  y_test)\n\nnp.save(os.path.join(out_dir, \"scaler_X_mean.npy\"), scaler_X.mean_)\nnp.save(os.path.join(out_dir, \"scaler_X_std.npy\"),  scaler_X.scale_)\nnp.save(os.path.join(out_dir, \"scaler_y_mean.npy\"), scaler_y.mean_)\nnp.save(os.path.join(out_dir, \"scaler_y_std.npy\"),  scaler_y.scale_)\n\n# متادیتا برای بازتولید featurization\nnp.save(os.path.join(out_dir, \"max_atoms.npy\"),              np.array([max_atoms]))\nnp.save(os.path.join(out_dir, \"per_atom_feature_len.npy\"),   np.array([per_atom_feature_len]))\nnp.save(os.path.join(out_dir, \"excel_feature_cols.npy\"),     np.array(excel_feature_cols, dtype=object))\n\n# ابعاد lattice / reciprocal (برای سازگاری هنگام پیش‌بینی)\nnp.save(os.path.join(out_dir, \"lattice_len.npy\"),            np.array([len(lattice)]))\nnp.save(os.path.join(out_dir, \"reciprocal_len.npy\"),         np.array([len(recip)]))\n\nprint(\"[DONE] ذخیره شد.\")\n","metadata":{"_uuid":"8f2839f25d086af736a60e9eeb907d3b93b6e0e5","_cell_guid":"b1076dfc-b9ad-4769-8c92-a6c4dae69d19","trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"import os\nimport numpy as np\nimport tensorflow as tf\nfrom sklearn.metrics import r2_score\nimport matplotlib.pyplot as plt\nfrom scipy.signal import savgol_filter\n\n# ---------- مسیرها ----------\ndata_dir = \"/kaggle/working\"  # تغییر در صورت نیاز\nout_dir = \"/kaggle/working\"\nos.makedirs(out_dir, exist_ok=True)\n\n# ---------- mixed precision ----------\nfrom tensorflow.keras import mixed_precision\ntry:\n    mixed_precision.set_global_policy('mixed_float16')\n    print(\"Mixed precision policy set to:\", mixed_precision.global_policy())\nexcept Exception as e:\n    print(\"Mixed precision unavailable:\", e)\n\n# ---------- لود داده‌ها ----------\nX_train = np.load(os.path.join(data_dir, \"train_x.npy\"))\nX_val   = np.load(os.path.join(data_dir, \"val_x.npy\"))\nX_test  = np.load(os.path.join(data_dir, \"test_x.npy\"))\ny_train = np.load(os.path.join(data_dir, \"train_y.npy\"))\ny_val   = np.load(os.path.join(data_dir, \"val_y.npy\"))\ny_test  = np.load(os.path.join(data_dir, \"test_y.npy\"))\n\nscaler_y_mean = np.load(os.path.join(data_dir, \"scaler_y_mean.npy\"))\nscaler_y_std  = np.load(os.path.join(data_dir, \"scaler_y_std.npy\"))\nscaler_X_mean = np.load(os.path.join(data_dir, \"scaler_X_mean.npy\"))\nscaler_X_std  = np.load(os.path.join(data_dir, \"scaler_X_std.npy\"))\n\n# ---------- ابعاد ----------\nnum_samples, max_qpoints, max_bands = y_train.shape\noutput_flat_dim = int(max_qpoints * max_bands)\n\n# ---------- smoothness loss ----------\ndef smoothness_loss_from_reshaped(y_pred_reshaped):\n    d2 = y_pred_reshaped[:, 2:, :] - 2.0 * y_pred_reshaped[:, 1:-1, :] + y_pred_reshaped[:, :-2, :]\n    return tf.reduce_mean(tf.square(d2))\n\n# ---------- مدل ----------\ndef swish(x):\n    return tf.nn.swish(x)\n\ndef residual_dense_block(x, units, dropout_rate=0.03, use_bn=False):\n    shortcut = x\n    if int(shortcut.shape[-1]) != units:\n        shortcut = tf.keras.layers.Dense(units, activation=None, dtype='float32')(shortcut)\n    x = tf.keras.layers.Dense(units, activation=swish, dtype='float32')(x)\n    if use_bn:\n        x = tf.keras.layers.BatchNormalization()(x)\n    x = tf.keras.layers.Dropout(dropout_rate)(x)\n    x = tf.keras.layers.Add()([shortcut, x])\n    x = tf.keras.layers.Activation(swish)(x)\n    return x\n\ndef build_model_light(input_dim, output_dim):\n    inp = tf.keras.layers.Input(shape=(input_dim,), name=\"input\")\n    x = tf.keras.layers.Dense(256, activation=swish, dtype='float32')(inp)\n    x = residual_dense_block(x, 256, dropout_rate=0.03, use_bn=False)\n    x = residual_dense_block(x, 128, dropout_rate=0.02, use_bn=False)\n    x = tf.keras.layers.Dense(256, activation=swish, dtype='float32')(x)\n    x = tf.keras.layers.Dropout(0.15)(x)\n    out = tf.keras.layers.Dense(output_dim, activation='linear', dtype='float32', name=\"out\")(x)\n    return tf.keras.Model(inputs=inp, outputs=out)\n\n# ---------- hyperparams ----------\nBATCH_SIZE = 64\nEPOCHS = 250\nLR = 3e-4\nLAMBDA_SMOOTH = 1e-1\nPATIENCE = 30\n\n# ---------- tf.data pipeline ----------\ndef make_dataset(X, y, batch_size, shuffle=True):\n    X = X.astype(np.float32)\n    y_flat = y.reshape(len(y), -1).astype(np.float32)\n    ds = tf.data.Dataset.from_tensor_slices((X, y_flat))\n    if shuffle:\n        ds = ds.shuffle(buffer_size=min(10000, len(X)))\n    return ds.batch(batch_size).prefetch(tf.data.AUTOTUNE)\n\ntrain_ds = make_dataset(X_train, y_train, BATCH_SIZE, shuffle=True)\nval_ds   = make_dataset(X_val, y_val, BATCH_SIZE, shuffle=False)\n\n# ---------- ساخت مدل ----------\ninput_dim = X_train.shape[1]\nmodel = build_model_light(input_dim, output_flat_dim)\nmodel.summary()\n\nmse = tf.keras.losses.MeanSquaredError()\noptimizer = tf.keras.optimizers.Adam(learning_rate=LR)\n\n@tf.function\ndef train_step(x_batch, y_batch):\n    with tf.GradientTape() as tape:\n        pred = model(x_batch, training=True)\n        loss_mse = mse(y_batch, pred)\n        pred_resh = tf.reshape(pred, (-1, max_qpoints, max_bands))\n        loss_smooth = smoothness_loss_from_reshaped(pred_resh)\n        loss = loss_mse + LAMBDA_SMOOTH * loss_smooth\n    grads = tape.gradient(loss, model.trainable_variables)\n    optimizer.apply_gradients(zip(grads, model.trainable_variables))\n    return loss\n\n@tf.function\ndef val_step(x_batch, y_batch):\n    pred = model(x_batch, training=False)\n    loss_mse = mse(y_batch, pred)\n    pred_resh = tf.reshape(pred, (-1, max_qpoints, max_bands))\n    loss_smooth = smoothness_loss_from_reshaped(pred_resh)\n    return loss_mse + LAMBDA_SMOOTH * loss_smooth\n\n# ---------- آموزش ----------\nbest_val = np.inf\npatience_counter = 0\n\nfor epoch in range(1, EPOCHS+1):\n    train_losses = [train_step(xb, yb).numpy() for xb, yb in train_ds]\n    val_losses = [val_step(xb, yb).numpy() for xb, yb in val_ds]\n    train_loss_epoch = np.mean(train_losses)\n    val_loss_epoch = np.mean(val_losses)\n\n    print(f\"Epoch {epoch:03d} | Train Loss: {train_loss_epoch:.6e} | Val Loss: {val_loss_epoch:.6e}\")\n\n    if val_loss_epoch < best_val:\n        best_val = val_loss_epoch\n        patience_counter = 0\n        model.save_weights(os.path.join(out_dir, \"best_model.weights.h5\"))\n    else:\n        patience_counter += 1\n        if patience_counter >= PATIENCE:\n            print(\"Early stopping.\")\n            break\n\n# ---------- ارزیابی ----------\nmodel.load_weights(os.path.join(out_dir, \"best_model.weights.h5\"))\n\ny_test_flat = y_test.reshape(len(y_test), -1).astype(np.float32)\ny_pred_flat = model.predict(X_test.astype(np.float32), batch_size=BATCH_SIZE)\ny_pred = (y_pred_flat * scaler_y_std + scaler_y_mean).reshape(-1, max_qpoints, max_bands)\ny_test_true = (y_test_flat * scaler_y_std + scaler_y_mean).reshape(-1, max_qpoints, max_bands)\n\nr2_scores = [r2_score(y_test_true[i].flatten(), y_pred[i].flatten()) for i in range(len(y_test_true))]\nprint(\"Mean R2:\", np.mean(r2_scores))\nnp.save(os.path.join(out_dir, \"r2_list.npy\"), np.array(r2_scores))\n\n# ---------- رسم نمونه ----------\nsample_idx = 0\npred_sample = y_pred[sample_idx]\nwindow_length = 7 if max_qpoints >= 7 else (max_qpoints//2*2+1)\npolyorder = 3\npred_smooth = np.copy(pred_sample)\nfor b in range(pred_sample.shape[1]):\n    pred_smooth[:, b] = savgol_filter(pred_sample[:, b], window_length=window_length, polyorder=polyorder, mode='interp')\n\nplt.figure(figsize=(10,6))\nfor b in range(pred_sample.shape[1]):\n    plt.plot(pred_sample[:, b], color=f\"C{b%10}\", alpha=0.4)\n    plt.plot(pred_smooth[:, b], color=f\"C{b%10}\", linewidth=1.4)\nplt.title(\"Predicted phonon bands (before & after smoothing)\")\nplt.xlabel(\"Q-point\")\nplt.ylabel(\"Frequency (THz)\")\nplt.grid(True)\nplt.savefig(os.path.join(out_dir, \"pred_before_after_smooth.png\"))\nplt.show()\n\n\n\n","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"import os\nimport numpy as np\nimport tensorflow as tf\nfrom sklearn.metrics import r2_score\nimport matplotlib.pyplot as plt\nfrom scipy.signal import savgol_filter\nfrom tensorflow.keras import mixed_precision\nfrom tensorflow.keras.callbacks import EarlyStopping, ReduceLROnPlateau\n\n# ---------- تنظیم مسیرها ----------\ndata_dir = \"/kaggle/input/fanal-dataset\"  # تغییر بده در صورت نیاز\nout_dir = \"/kaggle/working\"\nos.makedirs(out_dir, exist_ok=True)\n\n# ---------- فعال‌سازی mixed precision (اگر GPU موجود است) ----------\ntry:\n    mixed_precision.set_global_policy('mixed_float16')\n    print(\"Mixed precision policy set to:\", mixed_precision.global_policy())\nexcept Exception as e:\n    print(\"Mixed precision unavailable:\", e)\n\n# ---------- بارگذاری ارایه‌ها ----------\nX_train = np.load(os.path.join(data_dir, \"train_x.npy\"))\nX_val   = np.load(os.path.join(data_dir, \"val_x.npy\"))\nX_test  = np.load(os.path.join(data_dir, \"test_x.npy\"))\ny_train = np.load(os.path.join(data_dir, \"train_y.npy\"))\ny_val   = np.load(os.path.join(data_dir, \"val_y.npy\"))\ny_test  = np.load(os.path.join(data_dir, \"test_y.npy\"))\n\nscaler_y_mean = np.load(os.path.join(data_dir, \"scaler_y_mean.npy\"))\nscaler_y_std  = np.load(os.path.join(data_dir, \"scaler_y_std.npy\"))\nscaler_X_mean = np.load(os.path.join(data_dir, \"scaler_X_mean.npy\"))\nscaler_X_std  = np.load(os.path.join(data_dir, \"scaler_X_std.npy\"))\n\n# ---------- ابعاد خروجی ----------\nnum_samples, max_qpoints, max_bands = y_train.shape\noutput_flat_dim = int(max_qpoints * max_bands)\n\ndef inverse_transform_y_flat(y_norm_flat):\n    return (y_norm_flat * scaler_y_std + scaler_y_mean).reshape(-1, max_qpoints, max_bands)\n\n# ---------- smoothness loss ----------\ndef smoothness_loss_from_reshaped(y_pred_reshaped):\n    d2 = y_pred_reshaped[:, 2:, :] - 2.0 * y_pred_reshaped[:, 1:-1, :] + y_pred_reshaped[:, :-2, :]\n    return tf.reduce_mean(tf.square(d2))\n\ndef custom_loss(y_true, y_pred):\n    mse = tf.keras.losses.MeanSquaredError()(y_true, y_pred)\n    pred_resh = tf.reshape(y_pred, (-1, max_qpoints, max_bands))\n    loss_smooth = smoothness_loss_from_reshaped(pred_resh)\n    return mse + LAMBDA_SMOOTH * loss_smooth\n\n# ---------- مدل سبک‌تر و امن ----------\ndef swish(x):\n    return tf.nn.swish(x)\n\ndef residual_dense_block(x, units, dropout_rate=0.03, use_bn=False):\n    shortcut = x\n    if int(shortcut.shape[-1]) != units:\n        shortcut = tf.keras.layers.Dense(units, activation=None, dtype='float32')(shortcut)\n    x = tf.keras.layers.Dense(units, activation=swish, dtype='float32')(x)\n    if use_bn:\n        x = tf.keras.layers.BatchNormalization()(x)\n    x = tf.keras.layers.Dropout(dropout_rate)(x)\n    x = tf.keras.layers.Add()([shortcut, x])\n    x = tf.keras.layers.Activation(swish)(x)\n    return x\n\ndef build_model_light(input_dim, output_dim):\n    inp = tf.keras.layers.Input(shape=(input_dim,), name=\"input\")\n    x = tf.keras.layers.Dense(256, activation=swish, dtype='float32')(inp)\n    x = residual_dense_block(x, 256, dropout_rate=0.03, use_bn=False)\n    x = residual_dense_block(x, 128, dropout_rate=0.02, use_bn=False)\n    x = tf.keras.layers.Dense(256, activation=swish, dtype='float32')(x)\n    x = tf.keras.layers.Dropout(0.15)(x)\n    out = tf.keras.layers.Dense(output_dim, activation='linear', dtype='float32', name=\"out\")(x)\n    return tf.keras.Model(inputs=inp, outputs=out)\n\n# ---------- hyperparams (قابل تنظیم) ----------\nBATCH_SIZE = 64\nEPOCHS = 300\nLR = 3e-4\nLAMBDA_SMOOTH = 0.05  # کاهش داده شده برای تعادل با augmentation\nPATIENCE = 30\nAUG_NOISE_STD = 0.005  # کاهش شدت نویز برای جلوگیری از کاهش دقت\n\n# ---------- تبدیل scaler_X_std به تنسور برای استفاده در augmentation ----------\nscaler_X_std_tensor = tf.constant(scaler_X_std.astype(np.float32))\n\n# ---------- تابع augmentation ----------\n@tf.function\ndef augment(x, y):\n    noise = tf.random.normal(shape=tf.shape(x), mean=0.0, stddev=AUG_NOISE_STD * scaler_X_std_tensor, dtype=tf.float32)\n    x_aug = x + noise\n    x_aug = tf.clip_by_value(x_aug, x - 3 * scaler_X_std_tensor, x + 3 * scaler_X_std_tensor)\n    return x_aug, y\n\n# ---------- tf.data pipeline ----------\ndef make_dataset(X, y, batch_size, shuffle=True, apply_augment=False):\n    X = X.astype(np.float32)\n    y_flat = y.reshape(len(y), -1).astype(np.float32)\n    ds = tf.data.Dataset.from_tensor_slices((X, y_flat))\n    if shuffle:\n        ds = ds.shuffle(buffer_size=min(10000, len(X)))\n    if apply_augment:\n        ds = ds.map(augment, num_parallel_calls=tf.data.AUTOTUNE)\n    return ds.batch(batch_size, drop_remainder=False).prefetch(tf.data.AUTOTUNE)\n\ntrain_ds = make_dataset(X_train, y_train, BATCH_SIZE, shuffle=True, apply_augment=True)\nval_ds   = make_dataset(X_val, y_val, BATCH_SIZE, shuffle=False, apply_augment=False)\n\n# ---------- ساخت مدل و کامپایل ----------\ninput_dim = X_train.shape[1]\nmodel = build_model_light(input_dim, output_flat_dim)\nmodel.summary()\n\n# ---------- تنظیم callbacks ----------\nearly_stopping = EarlyStopping(monitor='val_loss', patience=PATIENCE, restore_best_weights=True)\nreduce_lr = ReduceLROnPlateau(monitor='val_loss', factor=0.2, patience=10, min_lr=1e-6)\n\n# ---------- کامپایل و آموزش مدل با model.fit ----------\nmodel.compile(optimizer=tf.keras.optimizers.Adam(learning_rate=LR), loss=custom_loss)\n\nhistory = model.fit(\n    train_ds,\n    validation_data=val_ds,\n    epochs=EPOCHS,\n    callbacks=[early_stopping, reduce_lr],\n    verbose=1\n)\n\n# ذخیره history\nnp.save(os.path.join(out_dir, \"history.npy\"), history.history)\n\n# ---------- ارزیابی روی تست ----------\ny_pred_flat = model.predict(X_test.astype(np.float32), batch_size=BATCH_SIZE)\ny_pred = inverse_transform_y_flat(y_pred_flat)\ny_test_true = inverse_transform_y_flat(y_test.reshape(len(y_test), -1).astype(np.float32))\n\nr2_scores = [r2_score(y_test_true[i].flatten(), y_pred[i].flatten()) for i in range(len(y_test_true))]\naverage_r2 = np.mean(r2_scores)\nprint(f\"میانگین R² روی تست: {average_r2:.4f}\")\nnp.save(os.path.join(out_dir, \"r2_list_light.npy\"), np.array(r2_scores))\n\n# ---------- رسم نمونه پیش‌بینی ----------\nsample_idx = 0\npred_sample = y_pred[sample_idx]\nwindow_length = 7 if max_qpoints >= 7 else (max_qpoints//2*2+1)\npolyorder = 3\ntry:\n    pred_smooth = np.copy(pred_sample)\n    for b in range(pred_sample.shape[1]):\n        pred_smooth[:, b] = savgol_filter(pred_sample[:, b], window_length=window_length, polyorder=polyorder, mode='interp')\nexcept Exception as e:\n    from scipy.ndimage import gaussian_filter1d\n    pred_smooth = gaussian_filter1d(pred_sample, sigma=0.6, axis=0)\n\nplt.figure(figsize=(10,6))\nfor b in range(pred_sample.shape[1]):\n    plt.plot(pred_sample[:, b], color=f'C{b%10}', alpha=0.4)\n    plt.plot(pred_smooth[:, b], color=f'C{b%10}', linewidth=1.4)\nplt.title(\"Predicted phonon bands - before & after smoothing (sample 0)\")\nplt.xlabel(\"Q-point\")\nplt.ylabel(\"Frequency (THz)\")\nplt.grid(True)\nplt.savefig(os.path.join(out_dir, \"pred_light_before_after_smooth.png\"))\nplt.show()\n\n# ---------- رسم تاریخچه تلفات و بررسی اوورفیتینگ ----------\nplt.figure(figsize=(10, 6))\nplt.plot(history.history['loss'], label='Training Loss', marker='o', color='blue')\nplt.plot(history.history['val_loss'], label='Validation Loss', marker='o', color='orange')\nplt.title('Training and Validation Loss')\nplt.xlabel('Epoch')\nplt.ylabel('Loss')\nplt.legend()\nplt.grid(True)\nplt.savefig(os.path.join(out_dir, \"training_loss.png\"))\nplt.show()\n\n# بررسی اوورفیتینگ\nthreshold = 0.01  # قابل تنظیم بر اساس مقیاس loss\nmin_val_loss = min(history.history['val_loss'])\nmin_val_epoch = history.history['val_loss'].index(min_val_loss) + 1\nlast_val_loss = history.history['val_loss'][-1]\nlast_train_loss = history.history['loss'][-1]\n\nif last_val_loss > min_val_loss + threshold and min_val_epoch < len(history.history['val_loss']) * 0.6:\n    overfitting_status = f\"دارد (overfitting مشاهده می‌شود، چون validation loss بعد از epoch {min_val_epoch} افزایش پیدا کرده).\"\n    model_status = \"مدل خوب نیست، overfitting دارد. پیشنهاد: از regularization قوی‌تر (مثل dropout بیشتر یا L2)، data augmentation ملایم‌تر، یا early stopping زودهنگام‌تر استفاده کن.\"\nelif last_val_loss <= min_val_loss + threshold and last_train_loss < last_val_loss * 1.5:\n    overfitting_status = \"ندارد (overfitting مشاهده نمی‌شود، lossها همگرا هستند).\"\n    model_status = \"مدل خوب است، overfitting ندارد و می‌توان استفاده کرد.\"\nelse:\n    overfitting_status = \"شاید (وضعیت متوسط، val loss کمی بالاتر است اما افزایش شدیدی ندارد).\"\n    model_status = \"مدل متوسط است، ممکن است کمی overfitting داشته باشد. پیشنهاد: داده‌های validation و test رو بیشتر بررسی کن یا تعداد epochها رو کاهش بده.\"\n\nprint(f\"حداقل validation loss در epoch {min_val_epoch}: {min_val_loss:.6e}\")\nprint(f\"validation loss آخر: {last_val_loss:.6e}\")\nprint(f\"train loss آخر: {last_train_loss:.6e}\")\nprint(f\"آیا overfitting داریم؟ {overfitting_status}\")\nprint(model_status)\n\nprint(\"Saved weights:\", os.path.join(out_dir, \"best_model_light.weights.h5\"))\nprint(\"Saved R2 list:\", os.path.join(out_dir, \"r2_list_light.npy\"))\nprint(\"Saved history:\", os.path.join(out_dir, \"history.npy\"))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-08-14T15:06:54.613095Z","iopub.execute_input":"2025-08-14T15:06:54.613302Z","iopub.status.idle":"2025-08-14T15:07:33.270714Z","shell.execute_reply.started":"2025-08-14T15:06:54.6132