 0) and i > 0:\n            continue\n        phonopy_output = phonopy_obj.get_frequencies(q)\n        true_frequencies = phonopy_output[1]\n        predicted_frequencies = sorted(y_pred[i])\n        total_loss += np.mean((true_frequencies - predicted_frequencies) ** 2)\n        num_calculations += 1\n    return total_loss / num_calculations if num_calculations > 0 else 0.0\n\n# --- ۴) ساخت مدل و بهینه‌ساز ---\ninput_shape = (X_train_raw.shape[1],)\noutput_shape = y_train_raw.shape[1:]\nmodel = build_cnn_model(input_shape, output_shape)\n\noptimizer = tf.keras.optimizers.Adam(learning_rate=1e-4)\nmse_loss_fn = tf.keras.losses.MeanSquaredError()\n\nepochs = 30\nbatch_size = 32\nphysics_loss_weight = 0.5\n\n# --- ۵) آماده‌سازی tf.data با ایندکس‌ها (برای اتصال به train_dataset اصلی) ---\ntrain_indices = np.arange(len(train_dataset), dtype=np.int32)\n\ntrain_dataset_tf = (\n    tf.data.Dataset\n    .from_tensor_slices((X_train_normalized, y_train_normalized, train_indices))\n    .shuffle(buffer_size=len(train_dataset), reshuffle_each_iteration=True)\n    .batch(batch_size, drop_remainder=False)\n    .prefetch(tf.data.AUTOTUNE)\n)\n\nval_dataset_tf = (\n    tf.data.Dataset\n    .from_tensor_slices((X_val, y_val))\n    .batch(batch_size, drop_remainder=False)\n    .prefetch(tf.data.AUTOTUNE)\n)\n\nnum_train_batches = math.ceil(len(train_dataset) / batch_size)\nnum_val_batches = math.ceil(len(X_val) / batch_size)\n\n# --- ۶) حلقه آموزش ---\ntrain_losses, val_losses = [], []\n\nprint(\"\\n--- شروع فرآیند آموزش ---\")\nfor epoch in range(epochs):\n    start_time = time.time()\n    print(f\"\\nEpoch {epoch + 1}/{epochs}\")\n    epoch_total_loss = 0.0\n\n    # --- Train ---\n    for step, (X_batch, y_true_batch, idx_batch) in enumerate(tqdm(train_dataset_tf, desc=\"Training\", leave=False)):\n        with tf.GradientTape() as tape:\n            y_pred_batch_norm = model(X_batch, training=True)\n            standard_loss = mse_loss_fn(y_true_batch, y_pred_batch_norm)\n\n            # Physics loss: نصف نمونه‌های batch و qpoints یکی در میان\n            physics_loss = 0.0\n            idx_np = idx_batch.numpy()\n            k = max(1, len(idx_np) // 2)  # نصف batch\n            for j in range(k):\n                sample_idx = int(idx_np[j])\n                sample = train_dataset[sample_idx]\n\n                # unscale خروجی همین نمونه\n                y_pred_sample_flat = tf.reshape(y_pred_batch_norm[j], (1, -1))\n                y_pred_sample_unscaled = scaler_y.inverse_transform(\n                    y_pred_sample_flat.numpy()\n                ).reshape(output_shape)\n\n                # qpoints کم‌تراکم‌تر\n                q_sub = sample['qpoints'][::2]\n\n                def loss_func(y_p_numpy):\n                    return np.float32(\n                        calculate_physics_loss_for_sample(\n                            y_p_numpy, sample['phonopy_obj'], q_sub\n                        )\n                    )\n\n                p_loss = tf.py_function(func=loss_func,\n                                        inp=[y_pred_sample_unscaled],\n                                        Tout=tf.float32)\n                physics_loss += p_loss\n\n            physics_loss = physics_loss / float(k)\n            total_loss = standard_loss + physics_loss_weight * physics_loss\n\n        grads = tape.gradient(total_loss, model.trainable_variables)\n        optimizer.apply_gradients(zip(grads, model.trainable_variables))\n        epoch_total_loss += float(total_loss.numpy())\n\n    train_loss_avg = epoch_total_loss / num_train_batches\n    train_losses.append(train_loss_avg)\n\n    # --- Validation (بدون physics loss برای سرعت) ---\n    val_total_loss = 0.0\n    for X_batch, y_true_batch in val_dataset_tf:\n        y_pred_batch_norm = model(X_batch, training=False)\n        val_total_loss += float(mse_loss_fn(y_true_batch, y_pred_batch_norm).numpy())\n    val_loss_avg = val_total_loss / num_val_batches\n    val_losses.append(val_loss_avg)\n\n    elapsed = time.time() - start_time\n    print(f\"Train Loss: {train_loss_avg:.6f} | Val Loss: {val_loss_avg:.6f} | زمان Epoch: {elapsed:.2f} s\")\n\nprint(\"\\n--- آموزش به پایان رسید ---\")\n\n# --- ۷) رسم نمودار Training و Validation loss ---\nplt.figure(figsize=(8, 5))\nplt.plot(train_losses, label=\"Training Loss\")\nplt.plot(val_losses, label=\"Validation Loss\")\nplt.xlabel(\"Epoch\")\nplt.ylabel(\"Loss\")\nplt.legend()\nplt.title(\"Training & Validation Loss\")\nplt.tight_layout()\nplt.show()\n\n# --- ۸) رسم نتایج پیش‌بینی در برابر واقعی (یک نمونه) ---\nsample_idx = 0\nX_test_raw = np.array([d['X'] for d in test_dataset])\ny_test_raw = np.array([d['y'] for d in test_dataset])\nX_test = scaler_X.transform(X_test_raw)\n\nprint(\"در حال پیش‌بینی روی تست...\")\ny_pred_norm = model.predict(X_test, verbose=0)\ny_pred_unscaled = scaler_y.inverse_transform(\n    y_pred_norm.reshape(len(y_pred_norm), -1)\n).reshape(y_test_raw.shape)\n\ntrue_freqs = y_test_raw[sample_idx]\npred_freqs = y_pred_unscaled[sample_idx]\n\n# دو نمودار جداگانه\nplt.figure(figsize=(12, 4))\nplt.subplot(1, 2, 1)\nplt.plot(true_freqs, label=\"Real Frequencies\")\nplt.title(\"واقعی\")\nplt.subplot(1, 2, 2)\nplt.plot(pred_freqs, label=\"Predicted Frequencies\")\nplt.title(\"پیش‌بینی‌شده\")\nplt.tight_layout()\nplt.show()\n\n# نمودار روی‌هم\nplt.figure(figsize=(8, 5))\nplt.plot(true_freqs, label=\"Real\", linewidth=2)\nplt.plot(pred_freqs, label=\"Predicted\", linestyle=\"--\")\nplt.legend()\nplt.title(\"مقایسه واقعی و پیش‌بینی‌شده\")\nplt.tight_layout()\nplt.show()\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-08-23T08:01:04.864497Z","iopub.execute_input":"2025-08-23T08:01:04.864767Z","iopub.status.idle":"2025-08-23T09:43:09.420815Z","shell.execute_reply.started":"2025-08-23T08:01:04.864745Z","shell.execute_reply":"2025-08-23T09:43:09.419972Z"}},"outputs":[{"name":"stdout","text":"در حال بارگذاری داده‌های پردازش‌شده...\n✅ داده‌ها و Scaler ها با موفقیت بارگذاری شدند.\n\n--- شروع 