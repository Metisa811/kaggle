t_data = None\n        for point in data.get('phonon', []):\n            if np.allclose(point['q-position'], [0, 0, 0]):\n                gamma_point_data = point\n                break\n        \n        if not gamma_point_data:\n            return \"ERROR\", f\"نقطه گاما (q=[0,0,0]) در فایل {yaml_path} یافت نشد.\"\n            \n        yaml_freqs = [band['frequency'] for band in gamma_point_data['band']]\n        print(f\"-> {len(yaml_freqs)} فرکانس از فایل yaml خوانده شد.\")\n    except Exception as e:\n        return \"ERROR\", f\"خطا در خواندن یا پردازش فایل yaml: {e}\"\n\n    # --- مرحله ۳: بارگذاری و محاسبه با Phonopy ---\n    try:\n        ph = phonopy.load(unitcell_filename=psc_path,\n                          force_constants_filename=fc_path,\n                          supercell_matrix=supercell_matrix,\n                          is_nac=False)\n        \n        D_matrix = ph.get_dynamical_matrix_at_q([0, 0, 0])\n        num_bands = len(ph.primitive) * 3\n        identity_matrix = np.eye(num_bands, dtype=complex)\n        \n        if num_bands != len(yaml_freqs):\n            return \"ERROR\", \"تعداد باندها در ساختار ({num_bands}) و فایل yaml ({len(yaml_freqs)}) ناهماهنگ است.\"\n\n    except Exception as e:\n        return \"ERROR\", f\"خطا در هنگام بارگذاری داده‌ها با Phonopy: {e}\"\n\n    # --- مرحله ۴: صحت‌سنجی دترمینان ---\n    determinants = []\n    for nu_yaml in yaml_freqs:\n        eigval_internal = np.sign(nu_yaml) * (nu_yaml / VaspToTHz) ** 2\n        M = D_matrix - eigval_internal * identity_matrix\n        abs_det_M = np.abs(np.linalg.det(M))\n        determinants.append(abs_det_M)\n\n    # یک آستانه برای بررسی صفر بودن تعریف می‌کنیم\n    threshold = 1e-10\n    if all(d < threshold for d in determinants):\n        return \"SUCCESS\", \"تایید شد. تمام دترمینان‌ها نزدیک به صفر هستند.\"\n    else:\n        max_det = max(determinants)\n        return \"FAILED\", f\"تایید نشد. حداکثر دترمینان ({max_det:.2e}) از آستانه بزرگتر است.\"\n\n\nif __name__ == '__main__':\n    # --- تنظیمات اصلی ---\n    # مسیرهای پایه دیتاست شما بر اساس ورودی شما تنظیم شده است\n    base_paths = {\n        'psc': \"/kaggle/input/pgcnndata/all_poscar/all_poscar/\",\n        'fc': \"/kaggle/input/pgcnndata/extracted_force_constant_All/extracted_force_constant_C/\",\n        'yaml': \"/kaggle/input/pgcnndata/extracted_bands_C/extracted_bands_C/\"\n    }\n    \n    # **مرحله جدید:** پیدا کردن خودکار تمام مواد از پوشه psc\n    print(\"در حال اسکن پوشه برای پیدا کردن مواد...\")\n    try:\n        # تمام فایل‌هایی که با .psc تمام می‌شوند را لیست کن\n        all_files = os.listdir(base_paths['psc'])\n        psc_files = [f for f in all_files if f.endswith('.psc')]\n        # نام ماده را از نام فایل استخراج کن (حذف .psc)\n        material_ids = sorted([os.path.splitext(f)[0] for f in psc_files])\n        print(f\"-> {len(material_ids)} ماده برای بررسی پیدا شد.\")\n    except FileNotFoundError:\n        print(f\"خطا: پوشه {base_paths['psc']} یافت نشد. لطفاً مسیر را بررسی کنید.\")\n        material_ids = [] # لیست خالی تا برنامه متوقف نشود\n    \n    # ماتریس ابرسلول که برای محاسبات استفاده شده است\n    supercell_matrix = [[3, 0, 0], [0, 3, 0], [0, 0, 1]]\n\n    # --- اجرای پردازش ---\n    results = {}\n    # می‌توانید برای تست، لیست را به تعداد کمی از مواد محدود کنید: material_ids[:5]\n    for material in material_ids:\n        status, message = verify_material(material, base_paths, supercell_matrix)\n        results[material] = (status, message)\n        print(f\"نتیجه: {status} - {message}\")\n\n    # --- نمایش خلاصه نهایی ---\n    print(\"\\n\\n====================== خلاصه نتایج ======================\")\n    successful_materials = [m for m, (s, _) in results.items() if s == 'SUCCESS']\n    failed_materials = [m for m, (s, _) in results.items() if s == 'FAILED']\n    error_materials = [m for m, (s, _) in results.items() if s == 'ERROR']\n\n    print(f\"\\n✅ مواد تایید شده ({len(successful_materials)}):\")\n    print(\", \".join(successful_materials) if successful_materials else \"هیچکدام\")\n\n    print(f\"\\n❌ مواد تایید نشده ({len(failed_materials)}):\")\n    for m in failed_materials:\n        print(f\"  - {m}: {results[m][1]}\")\n    if not failed_materials: print(\"هیچکدام\")\n        \n    print(f\"\\n⚠️ مواد دارای خطا ({len(error_materials)}):\")\n    for m in error_materials:\n        print(f\"  - {m}: {results[m][1]}\")\n    if not error_materials: print(\"هیچکدام\")\n    print(\"==========================================================\")\n\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-09-17T08:23:49.153296Z","iopub.execute_input":"2025-09-17T08:23:49.153664Z","iopub.status.idle":"2025-09-17T08:38:18.19987Z","shell.execute_reply.started":"2025-09-17T08:23:49.153637Z","shell.execute_reply":"2025-09-17T08:38:18.198128Z"}},"outputs":[{"name":"stdout","text":"در حال اسکن پوشه برای پیدا کردن مواد...\n-> 374 ماده برای بررسی پیدا شد.\n\n--- بررسی ماده: Cr2AlC ---\n-> 24 فرکانس از فایل yaml خوانده شد.\nنتیجه: SUCCESS - تایید شد. تمام دترمینان‌ها نزدیک به صفر هستند.\n\n--- بررسی ماده: Cr2AlN ---\n-> 24 فرکانس از فایل yaml خوانده شد.\nنتیجه: SUCCESS - تایید شد. تمام دترمینان‌ها نزدیک به صفر هستند.\n\n--- بررسی ماده: Cr2AsC ---\n-> 24 فرکانس از فایل yaml خوانده شد.\nنتیجه: SUCCESS - تایید شد. تمام دترمینان‌ها نزدیک به صفر هستند.\n\n--- بررسی ماده: Cr2AsN ---\n-> 24 فرکانس از فایل yaml خوانده شد.\nنتیجه: SUCCESS - تایید شد. تمام دترمینان‌ها نزدیک به صفر هستند.\n\n--- بررسی ماده: Cr2AuC ---\n-> 24 فرکانس از فایل yaml خوانده شد.\nنتیجه: SUCCESS - تایید شد. تمام دترمینان‌ها نزدیک به صفر هستند.\n\n--- بررسی ماده: Cr2AuN ---\n-> 24 فرکانس از فایل yaml خوانده شد.\nنتیجه: SUCCESS - تایید شد. تمام دترمینان‌ها نزدیک به صفر هستند.\n\n--- بررسی ماده: Cr2BiC ---\n-> 24 فرکانس از فایل yaml خوانده شد.\nنتیجه: SUCCESS - تایید شد. تمام دترمینان‌ها نزدیک به صفر هستند.\n\n--- بررسی ماده: Cr2BiN ---\n-> 24 فرکانس از فایل yaml خوانده شد.\nنتیجه: SUCCESS - تایید شد. تمام دترمینان‌ها نزدیک به صفر هست