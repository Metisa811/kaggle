he future behavior, set `pd.set_option('future.no_silent_downcasting', True)`\n  vals = r[feature_cols].fillna(0).values.astype(float)\n/tmp/ipykernel_36/3516693164.py:28: FutureWarning: Downcasting object dtype arrays on .fillna, .ffill, .bfill is deprecated and will change in a future version. Call result.infer_objects(copy=False) instead. To opt-in to the future behavior, set `pd.set_option('future.no_silent_downcasting', True)`\n  vals = r[feature_cols].fillna(0).values.astype(float)\n","output_type":"stream"},{"name":"stdout","text":"حداکثر اتم‌ها: 8, باند: 24, نقاط q: 357\nخوانده شد: samples=358, skipped=0\nذخیره انجام شد.\n","output_type":"stream"}],"execution_count":8},{"cell_type":"code","source":"# train_model.py\nimport numpy as np\nimport tensorflow as tf\nfrom sklearn.metrics import r2_score\nimport matplotlib.pyplot as plt\nimport os\n\n# مسیر بارگذاری — تنظیم کن اگر نیاز بود\ndata_dir = \"/kaggle/input/dataset-features-gpt5\"  # یا مسیر محلی جایی که npy هات رو ذخیره کردی\n\ndef load_arrays(prefix_dir):\n    X_train = np.load(os.path.join(prefix_dir, \"train_x.npy\"))\n    X_val = np.load(os.path.join(prefix_dir, \"val_x.npy\"))\n    X_test = np.load(os.path.join(prefix_dir, \"test_x.npy\"))\n    y_train = np.load(os.path.join(prefix_dir, \"train_y.npy\"))\n    y_val = np.load(os.path.join(prefix_dir, \"val_y.npy\"))\n    y_test = np.load(os.path.join(prefix_dir, \"test_y.npy\"))\n    scaler_y_mean = np.load(os.path.join(prefix_dir, \"scaler_y_mean.npy\"))\n    scaler_y_std = np.load(os.path.join(prefix_dir, \"scaler_y_std.npy\"))\n    return X_train, X_val, X_test, y_train, y_val, y_test, scaler_y_mean, scaler_y_std\n\nX_train, X_val, X_test, y_train, y_val, y_test, scaler_y_mean, scaler_y_std = load_arrays(data_dir)\n\ndef inverse_transform_y(y_norm):\n    y_flat = y_norm.reshape(y_norm.shape[0], -1)\n    return (y_flat * scaler_y_std + scaler_y_mean).reshape(y_norm.shape)\n\n# ورودی مدل:\ninput_dim = X_train.shape[1]\noutput_shape = y_train.shape[1:]  # (num_qpoints, num_bands)\noutput_flat_dim = int(np.prod(output_shape))\n\ndef build_model(input_dim, output_flat_dim):\n    \"\"\"یک معماری ساده ولی موثر: conv1d روی بردار ورودی (reshaped) + dense\"\"\"\n    inp = tf.keras.layers.Input(shape=(input_dim,))\n    x = tf.keras.layers.Reshape((input_dim, 1))(inp)\n\n    # چند لایه Conv1D کوتاه با BatchNorm و Dropout\n    x = tf.keras.layers.Conv1D(32, 5, activation='relu', padding='same')(x)\n    x = tf.keras.layers.BatchNormalization()(x)\n    x = tf.keras.layers.MaxPooling1D(2)(x)\n\n    x = tf.keras.layers.Conv1D(64, 5, activation='relu', padding='same')(x)\n    x = tf.keras.layers.BatchNormalization()(x)\n    x = tf.keras.layers.MaxPooling1D(2)(x)\n\n    x = tf.keras.layers.Conv1D(128, 3, activation='relu', padding='same')(x)\n    x = tf.keras.layers.BatchNormalization()(x)\n    x = tf.keras.layers.GlobalAveragePooling1D()(x)\n\n    x = tf.keras.layers.Dense(512, activation='relu', kernel_regularizer=tf.keras.regularizers.l2(1e-4))(x)\n    x = tf.keras.layers.Dropout(0.3)(x)\n    x = tf.keras.layers.Dense(256, activation='relu')(x)\n    out = tf.keras.layers.Dense(output_flat_dim, activation='linear')(x)\n\n    model = tf.keras.Model(inputs=inp, outputs=out)\n    return model\n\nmodel = build_model(input_dim, output_flat_dim)\nmodel.compile(optimizer=tf.keras.optimizers.Adam(1e-4), loss='mse', metrics=['mae'])\nmodel.summary()\n\n# callbacks\nearly_stopping = tf.keras.callbacks.EarlyStopping(monitor='val_loss', patience=50, restore_best_weights=True)\nreduce_lr = tf.keras.callbacks.ReduceLROnPlateau(monitor='val_loss', factor=0.5, patience=7, min_lr=1e-6)\ncheckpoint = tf.keras.callbacks.ModelCheckpoint(\"best_model.h5\", monitor='val_loss', save_best_only=True)\n\n# آماده‌سازی برچسب‌ها (flatten)\ny_train_flat = y_train.reshape(len(y_train), -1)\ny_val_flat = y_val.reshape(len(y_val), -1)\n\nhistory = model.fit(X_train, y_train_flat,\n                    validation_data=(X_val, y_val_flat),\n                    epochs=200,\n                    batch_size=16,\n                    callbacks=[early_stopping, reduce_lr, checkpoint],\n                    verbose=1)\n\n# بارگذاری بهترین مدل و پیش‌بینی\nmodel.load_weights(\"best_model.h5\")\ny_pred_norm_flat = model.predict(X_test)\ny_pred_norm = y_pred_norm_flat.reshape(y_test.shape)\n\n# inverse transform\ny_pred = inverse_transform_y(y_pred_norm)\ny_test_true = inverse_transform_y(y_test)\n\n# R2 per sample\nr2_scores = [r2_score(y_test_true[i].flatten(), y_pred[i].flatten()) for i in range(len(y_test))]\nprint(f\"میانگین R² روی تست: {np.mean(r2_scores):.4f}\")\n\n# رسم مثال اول (تمام باندها)\nplt.figure(figsize=(10, 6))\nplt.title(\"نمونه ساختار باند پیش‌بینی‌شده (نمونه اول از تست)\")\nfor b in range(y_pred.shape[2]):\n    plt.plot(y_pred[0, :, b], label=f\"band {b+1}\")\nplt.xlabel(\"Q-point\")\nplt.ylabel(\"Frequency (THz)\")\nplt.grid(True)\nplt.legend(ncol=2, fontsize='small')\nplt.savefig('/kaggle/working/predicted_phonon_bands_gpt5.png')\nplt.show()\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-08-09T21:11:37.879943Z","iopub.execute_input":"2025-08-09T21:11:37.880718Z","iopub.status.idle":"2025-08-09T21:12:24.985691Z","shell.execute_reply.started":"2025-08-09T21:11:37.880692Z","shell.execute_reply":"2025-08-09T21:12:24.984784Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"\u001b[1mModel: \"functional_1\"\u001b[0m\n","text/html":"<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\">Model: \"functional_1\"</span>\n</pre>\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┓\n┃\u001b[1m \u001b[0m\u001b[1mLayer (type)                   \u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1mOutput Shape          \u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1m     