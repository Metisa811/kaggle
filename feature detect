ier'].map({1:'Normal', -1:'Outlier'})\n\n# ---------- 8. رسم و ذخیره در PDF ----------\npdf_path = \"PCA_tSNE_Cluster_Analysis.pdf\"\nsns.set(style=\"white\", context=\"notebook\")\n\nwith PdfPages(pdf_path) as pdf:\n    # --- PCA Plot ---\n    plt.figure(figsize=(7,6))\n    sns.scatterplot(data=merged_df, x='PCA1', y='PCA2', hue='B_Hill',\n                    palette='coolwarm', s=45, edgecolor='black', alpha=0.8)\n    plt.title(\"PCA: Feature Space Colored by Bulk Modulus (B_Hill)\")\n    plt.grid(True, alpha=0.3)\n    plt.tight_layout()\n    pdf.savefig(); plt.close()\n\n    # --- t-SNE Plot ---\n    plt.figure(figsize=(7,6))\n    sns.scatterplot(data=merged_df, x='TSNE1', y='TSNE2', hue='B_Hill',\n                    palette='coolwarm', s=45, edgecolor='black', alpha=0.8)\n    plt.title(\"t-SNE: Feature Space Colored by Bulk Modulus (B_Hill)\")\n    plt.grid(True, alpha=0.3)\n    plt.tight_layout()\n    pdf.savefig(); plt.close()\n\n    # --- Outlier Highlight ---\n    plt.figure(figsize=(7,6))\n    sns.scatterplot(data=merged_df, x='TSNE1', y='TSNE2', hue='is_outlier',\n                    palette={'Normal':'royalblue','Outlier':'red'},\n                    s=55, edgecolor='black', alpha=0.9)\n    plt.title(\"t-SNE: Outlier Detection via Isolation Forest\")\n    plt.grid(True, alpha=0.3)\n    plt.tight_layout()\n    pdf.savefig(); plt.close()\n\nprint(f\"✅ تمام نمودارها در فایل PDF ذخیره شدند:\\n📄 {pdf_path}\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-11-06T06:40:40.90068Z","iopub.execute_input":"2025-11-06T06:40:40.900872Z","iopub.status.idle":"2025-11-06T06:40:45.342644Z","shell.execute_reply.started":"2025-11-06T06:40:40.900856Z","shell.execute_reply":"2025-11-06T06:40:45.341963Z"}},"outputs":[{"name":"stdout","text":"✅ تعداد مواد نهایی برای تحلیل: 534\n✅ تمام نمودارها در فایل PDF ذخیره شدند:\n📄 PCA_tSNE_Cluster_Analysis.pdf\n","output_type":"stream"}],"execution_count":1},{"cell_type":"code","source":"import pandas as pd\nimport 