025-08-09T19:40:07.358023Z","iopub.execute_input":"2025-08-09T19:40:07.358348Z","iopub.status.idle":"2025-08-09T19:40:07.364034Z","shell.execute_reply.started":"2025-08-09T19:40:07.358326Z","shell.execute_reply":"2025-08-09T19:40:07.36313Z"}},"outputs":[{"traceback":["\u001b[0;36m  File \u001b[0;32m\"/tmp/ipykernel_36/3555250408.py\"\u001b[0;36m, line \u001b[0;32m1\u001b[0m\n\u001b[0;31m    phas 2 chatgpt 5\u001b[0m\n\u001b[0m         ^\u001b[0m\n\u001b[0;31mSyntaxError\u001b[0m\u001b[0;31m:\u001b[0m invalid syntax\n"],"ename":"SyntaxError","evalue":"invalid syntax (3555250408.py, line 1)","output_type":"error"}],"execution_count":3},{"cell_type":"markdown","source":"phas 2 chatgpt 5","metadata":{}},{"cell_type":"code","source":"# prepare_data.py\nimport os\nimport yaml\nimport numpy as np\nimport pandas as pd\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.preprocessing import StandardScaler\nfrom scipy.ndimage import gaussian_filter1d\n\n# مسیرها — تغییر بده اگر لازم است\nfolder = \"/kaggle/input/yaml-data/extracted_bands_C\"\nexcel_path = \"/kaggle/input/npy-phonon/points.xlsx\"  # فایل اکسل که آپلود کردی\n\n# بارگذاری دیتای عناصر از اکسل\ndf_elem = pd.read_excel(excel_path)\n# استاندارد: ستونی به نام 'symbol' و 'atomic_weight' انتظار می‌رود\nif 'symbol' not in df_elem.columns or 'atomic_weight' not in df_elem.columns:\n    raise ValueError(\"فایل اکسل باید ستون‌های 'symbol' و 'atomic_weight' را داشته باشد.\")\n\n# نرمال‌سازی نام ستون‌ها (trim)\ndf_elem.columns = [c.strip() for c in df_elem.columns]\n\n# ساخت دیکشنری برای نگاشت symbol -> ویژگی‌ها (شامل atomic_weight)\nelem_features = {}\nfeature_cols = [c for c in df_elem.columns if c not in ['symbol']]  # همه ستون‌ها به جز symbol\nfor _, r in df_elem.iterrows():\n    sym = str(r['symbol']).strip()\n    vals = r[feature_cols].fillna(0).values.astype(float)\n    elem_features[sym] = {\n        'features': vals,\n        'atomic_weight': float(r['atomic_weight'])\n    }\n\n# برای جستجوی بر اساس جرم: لیستی از (atomic_weight, symbol)\natomic_weight_list = [(v['atomic_weight'], k) for k, v in elem_features.items()]\natomic_weight_array = np.array([w for w, s in atomic_weight_list])\n\ndef find_symbol_by_mass(mass, tol=0.5):\n    \"\"\"\n    اگر symbol در YAML وجود نداشته باشد:\n    با نزدیک‌ترین atomic_weight در اکسل نگاشت می‌کنیم.\n    tol: اختلاف مجاز (THz یا واحد جرم) — اگر اختلاف بیشتر باشد هشداری چاپ می‌شود.\n    \"\"\"\n    # mass و atomic_weight ها عموماً در واحد amu — فرض می‌کنیم واحد برابر است\n    diffs = np.abs(atomic_weight_array - mass)\n    idx = np.argmin(diffs)\n    best_mass = atomic_weight_array[idx]\n    best_sym = atomic_weight_list[idx][1]\n    if diffs[idx] > tol:\n        print(f\"هشدار: تطبیق جرم {mass} با عنصر {best_sym} اختلاف {diffs[idx]:.3f} دارد.\")\n    return best_sym\n\ndef parse_yaml_files(folder_path):\n    X, y = [], []\n    skipped = 0\n    max_atoms = 0\n    max_bands = 0\n    max_qpoints = 0\n    # یکبار پیمایش برای یافتن ماکزیمم‌ها\n    for file in os.listdir(folder_path):\n        if file.endswith(\".yaml\"):\n            try:\n                with open(os.path.join(folder_path, file), 'r') as f:\n                    data = yaml.safe_load(f)\n                if not data:\n                    continue\n                if 'points' not in data or 'phonon' not in data:\n                    continue\n                n_atoms = len(data['points'])\n                n_qpoints = len(data['phonon'])\n                n_bands = len(data['phonon'][0].get('band', []))\n                max_atoms = max(max_atoms, n_atoms)\n                max_bands = max(max_bands, n_bands)\n                max_qpoints = max(max_qpoints, n_qpoints)\n            except Exception as e:\n                print(f\"skip (counting) {file}: {e}\")\n                continue\n\n    print(f\"حداکثر اتم‌ها: {max_atoms}, باند: {max_bands}, نقاط q: {max_qpoints}\")\n\n    # ساخت اسم فیچرهای اتمی تا ذخیره شود\n    per_atom_feature_len = 3 + 1 + len(feature_cols)  \n    # توضیح: 3 مختصات + 1 جرم + len(feature_cols) ویژگی‌های اکسل برای هر اتم\n\n    for file in os.listdir(folder_path):\n        if file.endswith(\".yaml\"):\n            try:\n                with open(os.path.join(folder_path, file), 'r') as f:\n                    data = yaml.safe_load(f)\n                if not data or 'points' not in data or 'lattice' not in data or 'reciprocal_lattice' not in data or 'phonon' not in data:\n                    skipped += 1\n                    continue\n\n                atom_features_list = []\n                for pt in data['points']:\n                    # تلاش برای پیدا کردن نماد عنصر در YAML\n                    sym = None\n                    for key in ['symbol', 'label', 'element', 'species', 'name']:\n                        if key in pt:\n                            sym = str(pt[key]).strip()\n                            break\n                    mass = float(pt.get('mass', 0.0))\n                    coords = pt.get('coordinates', [0.0, 0.0, 0.0])\n                    # اگر سمبل موجود بود از دیکشنری استفاده کن، در غیر این صورت بر اساس جرم جستجو کن\n                    if sym and sym in elem_features:\n                        elem_feat = elem_features[sym]['features']\n                    else:\n                        # fallback: match by mass\n                        sym_guess = find_symbol_by_mass(mass)\n                        elem_feat = elem_features[sym_guess]['features']\n                    # concat: coords (3) + mass (1) + elem_feat (N)\n                    vec = list(coords) + [mass] + list(elem_feat)\n                    atom_features_list.append(vec)\n\n                atom_features = np.array(atom_features_list, dtype=float)\n                # padding برای تعداد اتم تا max_atoms\n                atom_features = np.pad(atom_features, ((0, max_atoms - atom_features.shape[0]), (0, 0)), 'constant')\n\n                lattice = np.array(data['lattice']).flatten()\n                reciprocal = np.array(data['reciprocal_lattice']).flatten()\n\n                feature_tensor = np.concatenate([\n                    atom_features.flatten(),\n                    lattice,\n                    reciprocal\n                ]).astype(float)\n\n                # خواندن فرکانس‌ها\n                frequencies = []\n                for qpoint in data['phonon']:\n                    bands = [b.get('frequency', 0.0) for b in qpoint.get('band', [])]\n                    frequencies.append(bands)\n                frequencies = np.array(frequencies, dtype=float)\n                frequencies = np.pad(frequencies, ((0, max_qpoints - frequencies.shape[0]), (0, max_bands - frequencies.shape[1])), 'constant')\n\n                X.append(feature_tensor)\n                y.append(frequencies)\n\n            except Exception as e:\n                print(f\"خطا در فایل {file}: {e}\")\n                skipped += 1\n\n    X = np.array(X)\n    y = np.array(y)\n    print(f\"خوانده شد: samples={len(X)}, skipped={skipped}\")\n    return X, y, max_atoms, per_atom_feature_len\n\nif __name__ == \"__main__\":\n    X, y, max_atoms, per_atom_feature_len = parse_yaml_files(folder)\n\n    # صاف کردن فرکانس‌ها در امتداد q-point ها (axis=1 مشابه قبلی)\n    y_smoothed = gaussian_filter1d(y, sigma=0.6, axis=1)\n\n    # نرمال‌سازی ورودی‌ها\n    scaler_X = StandardScaler()\n    X_normalized = scaler_X.fit_transform(X)\n\n    # نرمال‌سازی خروجی‌ها\n    num_samples, num_qpoints, num_bands = y_smoothed.shape\n    y_flat = y_smoothed.reshape(num_samples, -1)\n    scaler_y = StandardScaler()\n    y_normalized = scaler_y.fit_transform(y_flat).reshape(num_samples, num_qpoints, num_bands)\n\n    # تقسیم سه‌تایی داده‌ها\n    X_temp, X_test, y_temp, y_test = train_test_split(X_normalized, y_normalized, test_size=0.2, random_state=42)\n    X_train, X_val, y_train, y_val = train_test_split(X_temp, y_temp, test_size=0.2, random_state=42)\n\n    # ذخیره داده‌ها و پارامترهای scaler\n    np.save(\"train_x.npy\", X_train)\n    np.save(