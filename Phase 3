.mean(lattice)\n    \n    # شبکه متقابل\n    reciprocal_start = lattice_end\n    reciprocal_end = reciprocal_start + num_reciprocal_features\n    reciprocal = X[i, reciprocal_start:reciprocal_end]\n    features_dict['mean_reciprocal'][i] = np.mean(reciprocal)\n    \n    # قیاسی‌ها\n    qposition_start = reciprocal_end\n    qposition_end = qposition_start + num_qpoints_features\n    qpositions = X[i, qposition_start:qposition_end].reshape(num_qpoints, 3)\n    features_dict['mean_qposition'][i] = np.mean(qpositions)\n\n# تبدیل به DataFrame\nX_features_df = pd.DataFrame(features_dict)\n\n# 2. آماده‌سازی داده‌های y: میانگین فرکانس‌ها برای هر باند\n# y یک آرایه با ابعاد (num_samples, num_qpoints, num_bands) است\nmean_frequencies_per_band = np.mean(y, axis=1)  # میانگین روی قیاسی‌ها → (num_samples, num_bands)\ny_df = pd.DataFrame(mean_frequencies_per_band, columns=[f'Band_{i}' for i in range(num_bands)])\n\n# 3. محاسبه ماتریس همبستگی\n# ترکیب X و y در یک DataFrame\ncombined_df = pd.concat([X_features_df, y_df], axis=1)\n\n# محاسبه همبستگی Pearson\ncorrelation_matrix = combined_df.corr()\n\n# استخراج همبستگی بین ویژگی‌های X و باندهای y\ncorrelation_matrix = correlation_matrix.loc[X_features_df.columns, y_df.columns]\n\n# 4. رسم ماتریس همبستگی با heatmap\nplt.figure(figsize=(12, 8))\nsns.heatmap(correlation_matrix, annot=True, cmap='coolwarm', vmin=-1, vmax=1, center=0)\nplt.title('Correlation Matrix: Input Features vs Phonon Bands')\nplt.xlabel('Phonon Bands')\nplt.ylabel('Input Features')\nplt.xticks(rotation=45)\nplt.yticks(rotation=0)\nplt.tight_layout()\n\n# ذخیره نمودار\nplt.savefig('correlation_matrix.png')\nplt.close()\n\n# گزارش ویژگی‌های با بیشترین همبستگی\nprint(\"ویژگی‌هایی با بیشترین همبستگی (مثبت یا منفی) با هر باند:\")\nfor band in y_df.columns:\n    max_corr_feature = correlation_matrix[band].idxmax()\n    max_corr_value = correlation_matrix[band].max()\n    min_corr_feature = correlation_matrix[band].idxmin()\n    min_corr_value = correlation_matrix[band].m