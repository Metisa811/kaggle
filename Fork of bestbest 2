      ])\n\n                edge_index.append([i, j])\n                edge_attr.append(edge_feature)\n\n    edge_index = torch.tensor(edge_index, dtype=torch.long).t().contiguous()\n    edge_attr = torch.tensor(edge_attr, dtype=torch.float)\n\n    y = torch.tensor([target_value], dtype=torch.float)\n\n    return Data(\n        x=x,\n        edge_index=edge_index,\n        edge_attr=edge_attr,\n        y=y,\n        pos=torch.tensor(positions, dtype=torch.float)\n    )\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-12-25T09:58:43.018525Z","iopub.execute_input":"2025-12-25T09:58:43.01918Z","iopub.status.idle":"2025-12-25T09:58:43.027401Z","shell.execute_reply.started":"2025-12-25T09:58:43.019153Z","shell.execute_reply":"2025-12-25T09:58:43.026718Z"}},"outputs":[],"execution_count":22},{"cell_type":"code","source":"import torch\nimport torch.nn as nn\nimport torch.nn.functional as F\nfrom torch_geometric.nn import TransformerConv, global_mean_pool, global_max_pool\n\nclass PhononDirectionMassGNN(nn.Module):\n    def __init__(self, n_atom_features, hidden_dim=96):\n        super().__init__()\n\n        self.embedding = nn.Sequential(\n            nn.Linear(n_atom_features, hidden_dim),\n            nn.LayerNorm(hidden_dim),\n            nn.SiLU()\n        )\n\n        self.conv1 = TransformerConv(\n            in_channels=hidden_dim,\n            out_channels=hidden_dim,\n            heads=4,\n            edge_dim=5,\n            dropout=0.1,\n            beta=True\n        )\n\n        self.conv2 = TransformerConv(\n            in_channels=hidden_dim * 4,\n            out_channels=hidden_dim,\n            heads=1,\n            edge_dim=5,\n            dropout=0.1,\n            beta=True\n        )\n\n        self.norm1 = nn.LayerNorm(hidden_dim * 4)\n        self.norm2 = nn.LayerNorm(hidden_dim)\n\n        self.mlp = nn.Sequential(\n            nn.Linear(hidden_dim * 2, 128),\n            nn.SiLU(),\n            nn.Linear(128, 64),\n            nn.SiLU(),\n            nn.Linear(64, 1)\n        )\n\n    def forward(self, data):\n        x, edge_index, edge_attr, batch = (\n            data.x,\n            data.edge_index,\n            data.edge_attr,\n            data.batch\n        )\n\n        x = self.embedding(x)\n\n        x = self.conv1(x, edge_index, edge_attr)\n        x = self.norm1(x)\n        x = F.silu(x)\n\n        x = self.conv2(x, edge_index, edge_attr)\n        x = self.norm2(x)\n        x = F.silu(x)\n\n        x_mean = global_mean_pool(x, batch)\n        x_max  = global_max_pool(x, batch)\n\n        out = self.mlp(torch.cat([x_mean, x_max], dim=1))\n        return out.squeeze()\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-12-25T09:58:48.513704Z","iopub.execute_input":"2025-12-25T09:58:48.514266Z","iopub.status.idle":"2025-12-25T09:58:48.52174Z","shell.execute_reply.started":"2025-12-25T09:58:48.514242Z","shell.execute_reply":"2025-12-25T09:58:48.521049Z"}},"outputs":[],"execution_count":23},{"cell_type":"code","source":"","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-12-25T09:58:50.853023Z","iopub.execute_input":"2025-12-25T09:58:50.853827Z","iopub.status.idle":"2025-12-25T09:58:50.879011Z","shell.execute_reply.started":"2025-12-25T09:58:50.853798Z","shell.execute_reply":"2025-12-25T09:58:50.878038Z"}},"outputs":[{"traceback":["\u001b[0;31m---------------------------------------------------------------------------\u001b[0m","\u001b[0;31mIndexError\u001b[0m                                Traceback (most recent call last)","\u001b[0;32m/tmp/ipykernel_38/334107040.py\u001b[0m in \u001b[0;36m<cell line: 0>\u001b[0;34m()\u001b[0m\n\u001b[1;32m      6\u001b[0m ).to(device)\n\u001b[1;32m      7\u001b[0m \u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0;32m----> 8\u001b[0;31m \u001b[0msample\u001b[0m \u001b[0;34m=\u001b[0m \u001b[0mtrain_atom_graphs\u001b[0m\u001b[0;34m[\u001b[0m\u001b[0;36m0\u001b[0m\u001b[0;34m]\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mto\u001b[0m