ource":"\"\"\"\nComplete Physics-Informed Dataset Preparation\nCreates unified dataset with Force Constants for eSEN-style training\n\"\"\"\n\nimport os\nimport numpy as np\nimport pandas as pd\nfrom pathlib import Path\nimport re\nfrom tqdm import tqdm\n\n# ==========================================\n# Configuration\n# ==========================================\nPGCNN_DIR = \"/kaggle/input/pgcnndata\"\nFC_DIR = os.path.join(PGCNN_DIR, \"extracted_force_constant_All/extracted_force_constant_C\")\nPOSCAR_DIR = os.path.join(PGCNN_DIR, \"all_poscar/all_poscar\")\n\nFEATURES_DIR = \"/kaggle/input/features-dataset/\"\nEXCEL_FILE = os.path.join(FEATURES_DIR, \"ptable2.csv\")\nELASTIC_FILE = os.path.join(FEATURES_DIR, \"mechanical_data_fixed.json\")\n\nOUTPUT_DIR = \"./physics_informed_dataset\"\nos.makedirs(OUTPUT_DIR, exist_ok=True)\n\nprint(\"=\"*80)\nprint(\"PHYSICS-INFORMED DATASET PREPARATION FOR MAX PHASES\")\nprint(\"Target: Force Constants → Phonon Prediction with MAE < 0.01 THz\")\nprint(\"=\"*80)\n\n# ==========================================\n# CORRECT Force Constants Parser\n# ==========================================\ndef parse_force_constants(fc_path):\n    \"\"\"\n    Parse Phonopy FORCE_CONSTANTS file.\n    \n    Format:\n    Line 0: n_atoms n_dim\n    Line 1: i j (atom pair, 1-indexed)\n    Lines 2-4: 3x3 force constant matrix\n    ...\n    \"\"\"\n    with open(fc_path, 'r') as f:\n        lines = [l.strip() for l in f.readlines() if l.strip()]\n    \n    # Parse header\n    first_line = lines[0].split()\n    n_atoms = int(first_line[0])\n    \n    # Initialize IFCs array\n    ifcs = np.zeros((n_atoms, n_atoms, 3, 3), dtype=np.float64)\n    \n    line_idx = 1\n    while line_idx < len(lines):\n        # Read atom pair indices\n        parts = lines[line_idx].split()\n        \n        if len(parts) == 2:\n            try:\n                i = int(parts[0]) - 1  # Convert to 0-indexed\n                j = int(parts[1]) - 1\n                line_idx += 1\n                \n                # Read 3x3 matrix\n                for row in range(3):\n                    if line_idx < len(lines):\n                        values = list(map(float, lines[line_idx].split()))\n                        if len(values) >= 3:\n                            ifcs[i, j, row, :] = values[:3]\n                        line_idx += 1\n                    else:\n                        break\n                        \n            except (ValueError, IndexError) as e:\n                line_idx += 1\n        else:\n            line_idx += 1\n    \n    return n_atoms, ifcs\n\n# ==========================================\n# POSCAR Parser\n# ==========================================\ndef parse_poscar(poscar_path):\n    \"\"\"Parse POSCAR/CONTCAR file.\"\"\"\n    with open(poscar_path, 'r') as f:\n        lines = f.readlines()\n    \n    comment = lines[0].strip()\n    scaling = float(lines[1].strip())\n    \n    # Lattice vectors\n    lattice = np.array([list(map(float, lines[i].split())) for i in range(2, 5)])\n    lattice *= scaling\n    \n    # Elements and counts\n    line5 = lines[5].strip().split()\n    line6 = lines[6].strip().split()\n    \n    if line5[0].isalpha():\n        elements = line5\n        counts = list(map(int, line6))\n        coord_line = 7\n    else:\n        counts = list(map(int, line5))\n        elements = [f\"X{i}\" for i in range(len(counts))]\n        coord_line = 6\n    \n    # Coordinate type\n    coord_type = lines[coord_line].strip()[0].upper()\n    \n    # Positions\n    n_atoms = sum(counts)\n    positions = []\n    for i in range(coord_line + 1, min(coord_line + 1 + n_atoms, len(lines))):\n        pos = list(map(float, lines[i].split()[:3]))\n        positions.append(pos)\n    \n    positions = np.array(positions)\n    \n    # Convert to Cartesian if Direct\n    if coord_type == 'D':\n        positions = positions @ lattice\n    \n    # Create element list for each atom\n    atom_elements = []\n    for elem, count in zip(elements, counts):\n        atom_elements.extend([elem] * count)\n    \n    return {\n        'comment': comment,\n        'lattice': lattice.astype(np.float32),\n        'elements': elements,\n        'counts': counts,\n        'n_atoms': n_atoms,\n        'positions': positions.astype(np.float32),\n        'atom_elements': atom_elements,\n        'volume': float(np.abs(np.linalg.det(lattice)))\n    }\n\n# ==========================================\n# Utility Functions\n# ==========================================\ndef extract_formula(filename):\n    \"\"\"Extract chemical formula from filename.\"\"\"\n    name = Path(filename).stem\n    for suffix in ['.fc', '.psc', '_POSCAR', '-POSCAR']:\n        name = name.replace(suffix, '')\n    return name\n\n# ==========================================\n# Load Atomic Features from CSV\n# ==========================================\nprint(\"\\n\" + \"─\"*80)\nprint(\"Step 1: Loading Atomic Features from CSV\")\nprint(\"─\"*80)\n\ndf_atomic = pd.read_csv(EXCEL_FILE)\nprint(f\"✓ Loaded {len(df_atomic)} elements with {len(df_atomic.columns)} columns\")\n\n# Display first few rows to understand structure\nprint(f\"\\nFirst 3 rows:\")\nprint(df_atomic.head(3))\n\nprint(f\"\\nColumn data types:\")\nprint(df_atomic.dtypes)\n\n# Identify element column (usually 'symbol', 'element', or 'Symbol')\nelement_col = None\nfor col in ['symbol', 'Symbol', 'element', 'Element', 'Atom']:\n    if col in df_atomic.columns:\n        element_col = col\n        break\n\nif element_col is None:\n    # Assume first column is element\n    element_col = df_atomic.columns[0]\n    print(f\"\\n⚠ Element column not found, using first column: '{element_col}'\")\nelse:\n    print(f\"\\n✓ Element column: '{element_col}'\")\n\n# Extract only numeric features\nfeature_cols_numeric = df_atomic.select_dtypes(include=[np.number]).columns.tolist()\n\n# Remove element column if it's numeric (atomic number)\nif element_col in feature_cols_numeric:\n    feature_cols_numeric.remove(element_col)\n\nprint(f\"✓ Numeric features: {len(feature_cols_numeric)}\")\nprint(f\"  Sample features: {feature_cols_numeric[:10]}\")\n\n# Create element → features mapping\nelement_features = {}\nfor _, row in df_atomic.iterrows():\n    elem = str(row[element_col]).strip()  # Convert to string and strip whitespace\n    features = row[feature_cols_numeric].values.astype(np.float32)\n    # Handle NaN values\n    features = np.nan_to_num(features, nan=0.0, posinf=0.0, neginf=0.0)\n    element_features[elem] = features\n\nfeature_dim = len(features)\nprint(f\"✓ Feature dimension: {feature_dim}\")\nprint(f\"✓ Created feature lookup for {len(element_features)} elements\")\nprint(f\"  Sample elements: {list(element_features.keys())[:10]}\")\n\n# ==========================================\n# Load Elastic Constants from JSON\n# ==========================================\nprint(\"\\n\" + \"─\"*80)\nprint(\"Step 2: Loading Elastic Constants from JSON\")\nprint(\"─\"*80)\n\nimport json\n\nwith open(ELASTIC_FILE, 'r') as f:\n    elastic_json = json.load(f)\n\nprint(f\"✓ Loaded {len(elastic_json)} materials from JSON\")\n\n# Check structure of first entry\nif elastic_json:\n    print(f\"\\nSample entry:\")\n    print(json.dumps(elastic_json[0], indent=2))\n\n# Create elastic data dictionary\nelastic_data = {}\nfor entry in elastic_json:\n    material = entry.get('material', entry.get('Material', entry.get('formula', '')))\n    \n    # Extract elastic constants (check different possible keys)\n    c11 = float(entry.get('C11', entry.get('c11', 0)))\n    c12 = float(entry.get('C12', entry.get('c12', 0)))\n    c13 = float(entry.get('C13', entry.get('c13', 0)))\n    c33 = float(entry.get('C33', entry.get('c33', 0)))\n    c44 = float(entry.get('C44', entry.get('c44', 0)))\n    c66 = float(entry.get('C66', entry.get('c66', 0)))\n    \n    # Store as array (6 components for hexagonal symmetry)\n    elastic_data[material] = np.array([c11, c12, c13, c33, c44, c66], dtype=np.float32)\n\nprint(f\"✓ Processed elastic constants for {len(elastic_data)} materials\")\nprint(f\"  Sample materials: {list(elastic_data.keys())[:5]}\")\nprint(f\"  Elastic dimension: 6 (C11, C12, C13, C33, C44, C66)\")\n\nELASTIC_DIM = 6\n\n# ==========================================\n# Process Dataset\n# ==========================================\nprint(\"\\n\" + \"─\"*80)\nprint(\"Step 3: Processing and Matching Datasets\")\nprint(\"─\"*80)\n\nfc_files = list(Path(FC_DIR).glob(\"*.fc\"))\nposcar_files = list(Path(POSCAR_DIR).glob(\"*.psc\"))\n\nprint(f\"Found: {len(fc_files)} FC files, {len(poscar_files)} POSCAR files\")\n\n# Create mappings\nfc_dict = {extract_formula(f.name): f for f in fc_files}\nposcar_dict = {extract_formula(f.name): f for f in poscar_files}\n\n# Find common materials\ncommon_formulas = sorted(set(fc_dict.keys()) & set(poscar_dict.keys()))\nprint(f\"✓ Common materials: {len(common_formulas)}\")\n\n# Count with elastic data\nwith_elastic = sum(1 for f in common_formulas if f in elastic_data)\nprint(f\"✓ With elastic constants: {with_elastic}\")\n\n# ==========================================\n# Create Unified Dataset\n# ==========================================\nprint(\"\\n\" + \"─\"*80)\nprint(\"Step 4: Creating Unified Dataset\")\nprint(\"─\"*80)\n\ndataset = []\nfailed = []\n\nfor formula in tqdm(common_formulas, desc=\"Processing\"):\n    try:\n        # Load POSCAR\n        poscar = parse_poscar(poscar_dict[formula])\n        \n        # Load Force Constants\n        n_atoms, ifcs = parse_force_constants(fc_dict[formula])\n        \n        # Verify consistency\n        if n_atoms != poscar['n_atoms']:\n            failed.append((formula, f\"Mismatch: FC={n_atoms}, POSCAR={poscar['n_atoms']}\"))\n            continue\n        \n        # Get atomic features\n        node_features = []\n        for elem in poscar['atom_elements']:\n            if elem in element_features:\n                node_features.append(element_features[elem])\n            else:\n                node_features.append(np.zeros(feature_dim, dtype=np.float32))\n        \n        node_features = np.array(node_features, dtype=np.float32)\n        \n        # Get elastic constants\n        if formula in elastic_data:\n            elastic_vec = elastic_data[formula]\n            has_elastic = True\n        else:\n            elastic_vec = np.zeros(5, dtype=np.float32)\n            has_elastic = False\n        \n        # Store sample\n        sample = {\n            'formula': formula,\n            'n_atoms': n_atoms,\n            'lattice': poscar['lattice'],\n            'positions': poscar['positions'],\n            'elements': poscar['atom_elements'],\n            'node_features': node_features,\n            'force_constants': ifcs.astype(np.float32),\n            'elastic_constants': elastic_vec,\n            'has_elastic': has_elastic,\n            'volume': poscar['volume']\n        }\n        \n        dataset.append(sample)\n        \n    except Exception as e:\n        failed.append((formula, str(e)))\n\nprint(f\"\\n✓ Successfully processed: {len(dataset)} samples\")\nprint(f\"✗ Failed: {len(failed)} samples\")\n\nif len(dataset) == 0:\n    print(\"\\n⚠ ERROR: No samples were successfully processed!\")\n    print(\"Showing first 5 failures:\")\n    for formula, reason in failed[:5]:\n        print(f\"  - {formula}: {reason}\")\n    raise ValueError(\"Dataset is empty!\")\n\nif failed and len(failed) <= 10:\n    print(\"\\nFailed samples:\")\n    for formula, reason in failed:\n        print(f\"  - {formula}: {reason}\")\n\n# ==========================================\n# Dataset Statistics\n# ==========================================\nprint(\"\\n\" + \"=\"*80)\nprint(\"DATASET STATISTICS\")\nprint(\"=\"*80)\n\nn_atoms_list = [s['n_atoms'] for s in dataset]\nifc_stats = {\n    'min': [s['force_constants'].min() for s in dataset],\n    'max': [s['force_constants'].max() for s in dataset],\n    'mean': [s['force_constants'].mean() for s in dataset],\n    'std': [s['force_constants'].std() for s in dataset]\n}\n\nprint(f\"\\nDataset Summary:\")\nprint(f\"  • Total samples: {len(dataset)}\")\nprint(f\"  • Atoms per structure: {min(n_atoms_list)} - {max(n_atoms_list)} (median: {np.median(n_atoms_list):.0f})\")\nprint(f\"  • With elastic constants: {sum(s['has_elastic'] for s in dataset)}\")\n\nprint(f\"\\nForce Constants Statistics:\")\nprint(f\"  • Range: [{min(ifc_stats['min']):.6f}, {max(ifc_stats['max']):.6f}] eV/Å²\")\nprint(f\"  • Mean: {np.mean(ifc_stats['mean']):.8f} ± {np.std(ifc_stats['mean']):.8f}\")\nprint(f\"  • Std: {np.mean(ifc_stats['std']):.6f}\")\n\nprint(f\"\\nFeature Dimensions:\")\nprint(f\"  • Node features: {dataset[0]['node_features'].shape}\")\nprint(f\"  • Force constants: {dataset[0]['force_constants'].shape}\")\nprint(f\"  • Elastic constants: {dataset[0]['elastic_constants'].shape}\")\n\n# Check symmetry of force constants\nsample_fc = dataset[0]['force_constants']\nsymmetry_error = np.abs(sample_fc - sample_fc.transpose(1, 0, 3, 2)).max()\nprint(f\"\\nPhysical Validation (sample):\")\nprint(f\"  • Symmetry error: {symmetry_error:.2e} (should be ~0)\")\n\nasr_error = np.abs(sample_fc.sum(axis=1)).max()\nprint(f\"  • ASR error: {asr_error:.2e} (acoustic sum rule)\")\n\n# ==========================================\n# Train/Val/Test Split\n# ==========================================\nprint(\"\\n\" + \"─\"*80)\nprint(\"Step 5: Creating Train/Val/Test Split\")\nprint(\"─\"*80)\n\nn_total = len(dataset)\nn_train = int(0.8 * n_total)\nn_val = int(0.1 * n_total)\nn_test = n_total - n_train - n_val\n\n# Shuffle\nnp.random.seed(42)\nindices = np.random.permutation(n_total)\ntrain_idx = indices[:n_train]\nval_idx = indices[n_train:n_train+n_val]\ntest_idx = indices[n_train+n_val:]\n\ntrain_data = [dataset[i] for i in train_idx]\nval_data = [dataset[i] for i in val_idx]\ntest_data = [dataset[i] for i in test_idx]\n\nprint(f\"Split sizes:\")\nprint(f\"  • Trai