how loss and overfiting","metadata":{}},{"cell_type":"code","source":"import os\nimport numpy as np\nimport tensorflow as tf\nfrom sklearn.metrics import r2_score\nimport matplotlib.pyplot as plt\nfrom scipy.signal import savgol_filter\n\n# ---------- مسیرها ----------\ndata_dir = \"/kaggle/input/fanal-dataset\"  # تغییر در صورت نیاز\nout_dir = \"/kaggle/working\"\nos.makedirs(out_dir, exist_ok=True)\n\n# ---------- mixed precision ----------\nfrom tensorflow.keras import mixed_precision\ntry:\n    mixed_precision.set_global_policy('mixed_float16')\n    print(\"Mixed precision policy set to:\", mixed_precision.global_policy())\nexcept Exception as e:\n    print(\"Mixed precision unavailable:\", e)\n\n# ---------- لود داده‌ها ----------\nX_train = np.load(os.path.join(data_dir, \"train_x.npy\"))\nX_val   = np.load(os.path.join(data_dir, \"val_x.npy\"))\nX_test  = np.load(os.path.join(data_dir, \"test_x.npy\"))\ny_train = np.load(os.path.join(data_dir, \"train_y.npy\"))\ny_val   = np.load(os.path.join(data_dir, \"val_y.npy\"))\ny_test  = np.load(os.path.join(data_dir, \"test_y.npy\"))\n\nscaler_y_mean = np.load(os.path.join(data_dir, \"scaler_y_mean.npy\"))\nscaler_y_std  = np.load(os.path.join(data_dir, \"scaler_y_std.npy\"))\nscaler_X_mean = np.load(os.path.join(data_dir, \"scaler_X_mean.npy\"))\nscaler_X_std  = np.load(os.path.join(data_dir, \"scaler_X_std.npy\"))\n\n# ---------- ابعاد ----------\nnum_samples, max_qpoints, max_bands = y_train.shape\noutput_flat_dim = int(max_qpoints * max_bands)\n\n# ---------- smoothness loss ----------\ndef smoothness_loss_from_reshaped(y_pred_reshaped):\n    d2 = y_pred_reshaped[:, 2:, :] - 2.0 * y_pred_reshaped[:, 1:-1, :] + y_pred_reshaped[:, :-2, :]\n    return tf.reduce_mean(tf.square(d2))\n\n# ---------- مدل ----------\ndef swish(x):\n    return tf.nn.swish(x)\n\ndef residual_dense_block(x, units, dropout_rate=0.03, use_bn=False):\n    shortcut = x\n    if int(shortcut.shape[-1]) != units:\n        shortcut = tf.keras.layers.Dense(units, activation=None, dtype='float32')(shortcut)\n    x = tf.keras.layers.Dense(units, activation=swish, dtype='float32')(x)\n    if use_bn:\n        x = tf.keras.layers.BatchNormalization()(x)\n    x = tf.keras.layers.Dropout(dropout_rate)(x)\n    x = tf.keras.layers.Add()([shortcut, x])\n    x = tf.keras.layers.Activation(swish)(x)\n    return x\n\ndef build_model_light(input_dim, output_dim):\n    inp = tf.keras.layers.Input(shape=(input_dim,), name=\"input\")\n    x = tf.keras.layers.Dense(256, activation=swish, dtype='float32')(inp)\n    x = residual_dense_block(x, 256, dropout_rate=0.03, use_bn=False)\n    x = residual_dense_block(x, 128, dropout_rate=0.02, use_bn=False)\n    x = tf.keras.layers.Dense(256, activation=swish, dtype='float32')(x)\n    x = tf.keras.layers.Dropout(0.15)(x)\n    out = tf.keras.layers.Dense(output_dim, activation='linear', dtype='float32', name=\"out\")(x)\n    return tf.keras.Model(inputs=inp, outputs=out)\n\n# ---------- hyperparams ----------\nBATCH_SIZE = 64\nEPOCHS = 250\nLR = 3e-4\nLAMBDA_SMOOTH = 1e-1\nPATIENCE = 30\n\n# ---------- tf.data pipeline ----------\ndef make_dataset(X, y, batch_size, shuffle=True):\n    X = X.astype(np.float32)\n    y_flat = y.reshape(len(y), -1).astype(np.float32)\n    ds = tf.data.Dataset.from_tensor_slices((X, y_flat))\n    if shuffle:\n        ds = ds.shuffle(buffer_size=min(10000, len(X)))\n    return ds.batch(batch_size).prefetch(tf.data.AUTOTUNE)\n\ntrain_ds = make_dataset(X_train, y_train, BATCH_SIZE, shuffle=True)\nval_ds   = make_dataset(X_val, y_val, BATCH_SIZE, shuffle=False)\n\n# ---------- ساخت مدل ----------\ninput_dim = X_train.shape[1]\nmodel = build_model_light(input_dim, output_flat_dim)\nmodel.summary()\n\nmse = tf.keras.losses.MeanSquaredError()\noptimizer = tf.keras.optimizers.Adam(learning_rate=LR)\n\n@tf.function\ndef train_step(x_batch, y_batch):\n    with tf.GradientTape() as tape:\n        pred = model(x_batch, training=True)\n        loss_mse = mse(y_batch, pred)\n        pred_resh = tf.reshape(pred, (-1, max_qpoints, max_bands))\n        loss_smooth = smoothness_loss_from_reshaped(pred_resh)\n        loss = loss_mse + LAMBDA_SMOOTH * loss_smooth\n    grads = tape.gradient(loss, model.trainable_variables)\n    optimizer.apply_gradients(zip(grads, model.trainable_variables))\n    return loss\n\n@tf.function\ndef val_step(x_batch, y_batch):\n    pred = model(x_batch, training=False)\n    loss_mse = mse(y_batch, pred)\n    pred_resh = tf.reshape(pred, (-1, max_qpoints, max_bands))\n    loss_smooth = smoothness_loss_from_reshaped(pred_resh)\n    return loss_mse + LAMBDA_SMOOTH * loss_smooth\n\n# ---------- آموزش ----------\nbest_val = np.inf\npatience_counter = 0\n\nfor epoch in range(1, EPOCHS+1):\n    train_losses = [train_step(xb, yb).numpy() for xb, yb in train_ds]\n    val_losses = [val_step(xb, yb).numpy() for xb, yb in val_ds]\n    train_loss_epoch = np.mean(train_losses)\n    val_loss_epoch = np.mean(val_losses)\n\n    print(f\"Epoch {epoch:03d} | Train Loss: {train_loss_epoch:.6e} | Val Loss: {val_loss_epoch:.6e}\")\n\n    if val_loss_epoch < best_val:\n        best_val = val_loss_epoch\n        patience_counter = 0\n        model.save_weights(os.path.join(out_dir, \"best_model.weights.h5\"))\n    else:\n        patience_counter += 1\n        if patience_counter >= PATIENCE:\n            print(\"Early stopping.\")\n            break\n\n# ---------- ارزیابی ----------\nmodel.load_weights(os.path.join(out_dir, \"best_model.weights.h5\"))\n\ny_test_flat = y_test.reshape(len(y_test), -1).astype(np.float32)\ny_pred_flat = model.predict(X_test.astype(np.float32), batch_size=BATCH_SIZE)\ny_pred = (y_pred_flat * scaler_y_std + scaler_y_mean).reshape(-1, max_qpoints, max_bands)\ny_test_true = (y_test_flat * scaler_y_std + scaler_y_mean).reshape(-1, max_qpoints, max_bands)\n\nr2_scores = [r2_score(y_test_true[i].flatten(), y_pred[i].flatten()) for i in range(len(y_test_true))]\nprint(\"Mean R2:\", np.mean(r2_scores))\nnp.save(os.path.join(out_dir, \"r2_list.npy\"), np.array(r2_scores))\n\n# ---------- رسم نمونه ----------\nsample_idx = 0\npred_sample = y_pred[sample_idx]\nwindow_length = 7 if max_qpoints >= 7 else (max_qpoints//2*2+1)\npolyorder = 3\npred_smooth = np.copy(pred_sample)\nfor b in range(pred_sample.shape[1]):\n    pred_smooth[:, b] = savgol_filter(pred_sample[:, b], window_length=window_length, polyorder=polyorder, mode='interp')\n\nplt.figure(figsize=(10,6))\nfor b in range(pred_sample.shape[1]):\n    plt.plot(pred_sample[:, b], color=f\"C{b%10}\", alpha=0.4)\n    plt.plot(pred_smooth[:, b], color=f\"C{b%10}\", linewidth=1.4)\nplt.title(\"Predicted phonon bands (before & after smoothing)\")\nplt.xlabel(\"Q-point\")\nplt.ylabel(\"Frequency (THz)\")\nplt.grid(True)\nplt.savefig(os.path.join(out_dir, \"pred_before_after_smooth.png\"))\nplt.show()\n\n\n\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-09-10T12:49:17.240382Z","iopub.execute_input":"2025-09-10T12:49:17.240697Z","iopub.status.idle":"2025-09-10T12:49:53.806989Z","shell.execute_reply.started":"2025-09-10T12:49:17.240674Z","shell.execute_reply":"2025-09-10T12:49:53.80603Z"}},"outputs":[{"name":"stdout","text":"Mixed precision policy set to: <DTypePolicy \"mixed_float16\">\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"\u001b[1mModel: \"functional_6\"\u001b[0m\n","text/html":"<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\">Model: \"functional_6\"</span>\n</pre>\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"┏━━━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━┓\n┃\u001b[1m \u001b[0m\u001b[1mLayer (type)       \u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1mOutput Shape     \u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1m   Param #\u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[