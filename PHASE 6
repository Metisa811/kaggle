er1d\n\n# بارگذاری داده‌های اکسل\nexcel_file = \"/kaggle/input/npy-phonon/points.xlsx\"\ndf_elements = pd.read_excel(excel_file, sheet_name=\"Sheet1\")\nelement_features = df_elements.set_index('symbol').to_dict('index')\n\nfolder = \"/kaggle/input/yaml-data/extracted_bands_C\"\n\ndef parse_yaml_files(folder_path):\n    X, y = [], []\n    skipped = 0\n    max_atoms = 0\n    max_bands = 0\n    max_qpoints = 0\n\n    # یافتن حداکثر اندازه‌ها\n    for file in os.listdir(folder_path):\n        if file.endswith(\".yaml\"):\n            try:\n                with open(os.path.join(folder_path, file), 'r') as f:\n                    data = yaml.safe_load(f)\n                n_atoms = len(data['points'])\n                n_qpoints = len(data['phonon'])\n                n_bands = len(data['phonon'][0]['band'])\n                max_atoms = max(max_atoms, n_atoms)\n                max_bands = max(max_bands, n_bands)\n                max_qpoints = max(max_qpoints, n_qpoints)\n            except:\n                continue\n\n    print(f\"حداکثر اتم‌ها: {max_atoms}, باند: {max_bands}, نقاط q: {max_qpoints}\")\n\n    for file in os.listdir(folder_path):\n        if file.endswith(\".yaml\"):\n            try:\n                with open(os.path.join(folder_path, file), 'r') as f:\n                    data = yaml.safe_load(f)\n\n                if 'points' not in data or 'lattice' not in data or 'reciprocal_lattice' not in data or 'phonon' not in data:\n                    skipped += 1\n                    continue\n\n                # استخراج ویژگی‌های اتمی از اکسل\n                atom_features = []\n                for pt in data['points']:\n                    symbol = pt.get('symbol', 'H')  # فرض بر اینکه symbol وجود دارد\n                    element_data = element_features.get(symbol, {\n                        'atomic_radius': 0, 'density': 0, 'boiling_point': 0, 'lattice_constant': 0,\n                        'melting_point': 0, 'group_id': 0, 'period': 0, 'valance_main': 0,\n                        'covalent_radius_pyykko': 0, 'atomic_weight': 0, 'magp_electronegativity': 0\n                    })\n                    features = pt['coordinates'] + [pt['mass']] + [\n                        element_data['atomic_radius'], element_data['density'], element_data['boiling_point'],\n                        element_data['lattice_constant'], element_data['melting_point'], element_data['group_id'],\n                        element_data['period'], element_data['valance_main'], element_data['covalent_radius_pyykko'],\n                        element_data['atomic_weight'], element_data['magp_electronegativity']\n                    ]\n                    atom_features.append(features)\n                atom_features = np.array(atom_features)\n                atom_features = np.pad(atom_features, ((0, max_atoms - atom_features.shape[0]), (0, 0)), 'constant')\n\n                lattice = np.array(data['lattice']).flatten()\n                reciprocal = np.array(data['reciprocal_lattice']).flatten()\n\n                feature_tensor = np.concatenate([\n                    atom_features.flatten(),\n                    lattice,\n                    reciprocal\n                ])\n\n                frequencies = []\n                for qpoint in data['phonon']:\n                    bands = [b['frequency'] for b in qpoint.get('band', [])]\n                    frequencies.append(bands)\n                frequencies = np.array(frequencies)\n                frequencies = np.pad(frequencies, ((0, max_qpoints - frequencies.shape[0]), (0, max_bands - frequencies.shape[1])), 'constant')\n\n                X.append(feature_tensor)\n                y.append(frequencies)\n\n            except Exception as e:\n                print(f\"خطا در فایل {file}: {e}\")\n                skipped += 1\n\n    print(f\"✅ بارگذاری شده: {len(X)}, رد شده: {skipped}\")\n    if len(X) == 0:\n        raise ValueError(\"هیچ داده‌ای بارگذاری نشد! لطفاً مسیر داده‌ها یا ساختار فایل‌ها را بررسی کنید.\")\n    return np.array(X), np.array(y), max_atoms\n\n# اجرای آماده‌سازی\nX, y, max_atoms = parse_yaml_files(folder)\n\n# صاف کردن فرکانس‌ها\ny_smoothed = gaussian_filter1d(y, sigma=0.6, axis=1)\n\n# نرمال‌سازی ورودی‌ها\nscaler_X = StandardScaler()\nX_normalized = scaler_X.fit_transform(X)\n\n# نرمال‌سازی خروجی‌ها\nnum_samples, num_qpoints, num_bands = y_smoothed.shape\ny_flat = y_smoothed.reshape(num_samples, -1)\nscaler_y = StandardScaler()\ny_normalized = scaler_y.fit_transform(y_flat).reshape(num_samples, num_qpoints, num_bands)\n\n# تقسیم سه‌تایی داده‌ها\nX_temp, X_test, y_temp, y_test = train_test_split(X_normalized, y_normalized, test_size=0.2, random_state=42)\nX_train, X_val, y_train, y_val = train_test_split(X_temp, y_temp, test_size=0.2, random_state=42)\n\n\n\n# ذخیره داده‌ها\nnp.save(\"train_xfeatures.npy\", X_train)\nnp.save(\"val_xfeatures.npy\", X_val)\nnp.save(\"test_xfeatures.npy\", X_test)\nnp.save(\"train_yfeatures.npy\", y_train)\nnp.save(\"val_yfeatures.npy\", y_val)\nnp.save(\"test_yfeatures.npy\", y_test)\nnp.save(\"scaler_X_meanfeatures.npy\", scaler_X.mean_)\nnp.save(\"scaler_X_scalefeatures.npy\", scaler_X.scale_)\nnp.save(\"scaler_y_meanfeatures.npy\", scaler_y.mean_)\nnp.save(\"scaler_y_scalefeatures.npy\", scaler_y.scale_)  # اصلاح قطعی به scale_\nnp.save(\"max_atomsfeatures.npy\", np.array([max_atoms]))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-08-09T06:29:49.39167Z","iopub.execute_input":"2025-08-09T06:29:49.391909Z","iopub.status.idle":"2025-08-09T06:52:04.124665Z","shell.execute_reply.started":"2025-08-09T06:29:49.391872Z","shell.execute_reply":"2025-08-09T06:52:04.123985Z"}},"outputs":[{"name":"stdout","text":"حداکثر اتم‌ها: 8, باند: 24, نقاط q: 357\n✅ بارگذاری شده: 358, رد شده: 0\n","output_type":"stream"}],"execution_count":1},{"cell_type":"code","source":"import numpy as np\nimport tensorflow as tf\nfrom sklearn.metrics import r2_score\nimport matplotlib.pyplot as plt\n\n# بارگذاری داده‌ها\nX_train = np.load(\"/kaggle/input/npy-phonon/train_xfeatures.npy\")\nX_val = np.load(\"/kaggle/input/npy-phonon/val_xfeatures.npy\")\nX_test = np.load(\"/kaggle/input/npy-phonon/test_xfeatures.npy\")\ny_train = np.load(\"/kaggle/input/npy-phonon/train_yfeatures.npy\")\ny_val = np.load(\"/kaggle/input/npy-phonon/val_yfeatures.npy\")\ny_test = np.load(\"/kaggle/input/npy-phonon/test_yfeatures.npy\")\nscaler_y_mean = np.load(\"/kaggle/input/npy-phonon/scaler_y_meanfeatures.npy\")\nscaler_y_scale = np.load(\"/kaggle/input/npy-phonon/scaler_y_scalefeatures.npy\")\n\ndef inverse_transform_y(y_norm):\n    y_flat = y_norm.reshape(y_norm.shape[0], -1)\n    return (y_flat * scaler_y_scale + scaler_y_mean).reshape(y_norm.shape)\n\n# ساخت مدل\ndef build_model(input_shape, output_shape):\n    model = tf.keras.Sequential([\n        tf.keras.layers.Input(shape=input_shape),\n        tf.keras.layers.Reshape((input_shape[0], 1)),  # تبدیل به فرمت مناسب برای CNN 1D\n        tf.keras.layers.Conv1D(64, 3, activation='relu', padding='same'),\n        tf.keras.layers.MaxPooling1D(2),\n        tf.keras.layers.Conv1D(128, 3, activation='relu', padding='same'),\n        tf.keras.layers.MaxPooling1D(2),\n        tf.keras.layers.Conv1D(256, 3, activation='relu', padding='same'),\n        tf.keras.layers.MaxPooling1D(2),\n        tf.keras.layers.Flatten(),\n        tf.keras.layers.Dense(1024, activation='relu', kernel_regularizer=tf.keras.regularizers.l2(0.01)),\n        tf.keras.layers.Dropout(0.3),\n        tf.keras.layers.Dense(np.prod(output_shape), activation='linear')\n    ])\n    model.compile(optimizer=tf.keras.optimizers.Adam(learning_rate=1e-4), loss='mse', metrics=['mae'])\n    return model\n\n# ساخت و آموزش مدل\nmodel = build_model((X_train.shape[1],), y_train.shape[1:])\nearly_stopping = tf.keras.callbacks.EarlyStopping(monitor='val_loss', patience=50, restore_best_weights=True)\nreduce_lr = tf.keras.callbacks.ReduceLROnPlateau(monitor='val_loss', factor=0.5, patience=10, min_lr=1e-6)\n\nhistory = model.fit(X_train, y_train.reshape(len(y_train), -1),\n                    validation_data=(X_val, y_val.reshape(len(y_val), -1)),\n                    epochs=300, batch_size=32, callbacks=[early_stopping, reduce_lr], verbose=1)\n\n# ارزیابی روی تست\ny_pred_norm = model.predict(X_test).reshape(y_test.shape)\ny_pred = inverse_transform_y(y_pred_norm)\ny_test_true = inverse_transform_y(y_test)\n\nr2_scores = [r2_score(y_test_true[i].flatten(), y_pred[i].flatten()) for i in range(len(y_test))]\naverage_r2 = np.mean(r2_scores)\nprint(f\"میانگین R² روی تست: {average_r2:.4f}\")\n\n# رسم تاریخچه تلفات\nplt.figure(figsize=(10, 6))\nplt.plot(history.history['loss'], label='Training Loss')\nplt.plot(history.history['val_loss'], label='Validation Loss')\nplt.title('Training and Validation Loss')\nplt.xlabel('Epoch')\nplt.ylabel('Loss')\nplt.legend()\nplt.grid(True)\nplt.savefig('training_loss.png')\nplt.show()\n\n# ذخیره مدل\nmodel.save('phonon_model.h5')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-08-09T06:54:55.387783Z","iopub.execute_input":"2025-08-09T06:54:55.388388Z","iopub.status.idle":"2025-08-09T06:56:05.214402Z","shell.execute_reply.started":"2025-08-09T06:54:55.388358Z","shell.execute_reply":"2025-08-09T06:56:05.213823Z"}},"outputs":[{"name":"stderr","text":"2025-08-09 06:54:57.171438: E external/local_xla/xla/stream_executor/cuda/cuda_fft.cc:477] Unable to register cuFFT factory: Attempting to register factory for plugin cuFFT when one has already been registered\nWARNING: All log messages before absl::InitializeLog() is called are written to STDERR\nE0000 00:00:1754722497.367702      36 cuda_dnn.cc:8310] Unable to register cuDNN factory: Attempting to register factory for plugin cuDNN when one has already been registered\nE0000 00:00:1754722497.450145      36 cuda_blas.cc:1418] Unable to register cuBLAS factory: Attempting to register factory for plugin cuBLAS when one has already been registered\nI0000 00:00:1754722509.396890