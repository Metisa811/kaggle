oin(data_dir, \"train_x.npy\"))\nX_val   = np.load(os.path.join(data_dir, \"val_x.npy\"))\nX_test  = np.load(os.path.join(data_dir, \"test_x.npy\"))\ny_train = np.load(os.path.join(data_dir, \"train_y.npy\"))\ny_val   = np.load(os.path.join(data_dir, \"val_y.npy\"))\ny_test  = np.load(os.path.join(data_dir, \"test_y.npy\"))\n\nscaler_y_mean = np.load(os.path.join(data_dir, \"scaler_y_mean.npy\"))\nscaler_y_std  = np.load(os.path.join(data_dir, \"scaler_y_std.npy\"))\nscaler_X_mean = np.load(os.path.join(data_dir, \"scaler_X_mean.npy\"))\nscaler_X_std  = np.load(os.path.join(data_dir, \"scaler_X_std.npy\"))\n\n# اگر آرایه‌ها خیلی بزرگند و حافظه محدود است، می‌توانیم از mmap لود کنیم:\n# X_train = np.load(..., mmap_mode='r')  # در صورت نیاز فعال کن\n\n# ---------- ابعاد خروجی ----------\nnum_samples, max_qpoints, max_bands = y_train.shape\noutput_flat_dim = int(max_qpoints * max_bands)\n\ndef inverse_transform_y_flat(y_norm_flat):\n    return (y_norm_flat * scaler_y_std + scaler_y_mean).reshape(-1, max_qpoints, max_bands)\n\n# ---------- smoothness loss ----------\ndef smoothness_loss_from_reshaped(y_pred_reshaped):\n    # y_pred_reshaped: (batch, Q, bands)\n    d2 = y_pred_reshaped[:, 2:, :] - 2.0 * y_pred_reshaped[:, 1:-1, :] + y_pred_reshaped[:, :-2, :]\n    return tf.reduce_mean(tf.square(d2))\n\n# ---------- مدل سبک‌تر و امن ----------\ndef swish(x):\n    return tf.nn.swish(x)\n\ndef residual_dense_block(x, units, dropout_rate=0.03, use_bn=False):\n    shortcut = x\n    # projection for dimension match\n    if int(shortcut.shape[-1]) != units:\n        shortcut = tf.keras.layers.Dense(units, activation=None, dtype='float32')(shortcut)\n    x = tf.keras.layers.Dense(units, activation=swish, dtype='float32')(x)\n    if use_bn:\n        x = tf.keras.layers.BatchNormalization()(x)\n    x = tf.keras.layers.Dropout(dropout_rate)(x)\n    x = tf.keras.layers.Add()([shortcut, x])\n    x = tf.keras.layers.Activation(swish)(x)\n    return x\n\ndef build_model_light(input_dim, output_dim):\n    inp = tf.keras.layers.Input(shape=(input_dim,), name=\"input\")\n    x = tf.keras.layers.Dense(256, activation=swish, dtype='float32')(inp)\n    x = residual_dense_block(x, 256, dropout_rate=0.03, use_bn=False)\n    x = residual_dense_block(x, 128, dropout_rate=0.02, use_bn=False)\n    x = tf.keras.layers.Dense(256, activation=swish, dtype='float32')(x)\n    x = tf.keras.layers.Dropout(0.15)(x)\n    out = tf.keras.layers.Dense(output_dim, activation='linear', dtype='float32', name=\"out\")(x)\n    model = tf.keras.Model(inputs=inp, outputs=out)\n    return model\n\n# ---------- hyperparams (قابل تنظیم) ----------\nBATCH_SIZE = 8            # کمتر برای کاهش حافظه؛ در صورتی که GPU بزرگ داری می‌توانی افزایش دهی\nEPOCHS = 300\nLR = 3e-4\nLAMBDA_SMOOTH = 5e-3      # کمتر از نسخهٔ سنگین؛ می‌توانی تنظیم کنی\nPATIENCE = 30\n\n# ---------- tf.data pipeline برای کارایی و مصرف کمتر رم ----------\ndef make_dataset(X, y, batch_size, shuffle=True):\n    # تبدیل به float32 و فلَت کردن y\n    X = X.astype(np.float32)\n    y_flat = y.reshape(len(y), -1).astype(np.float32)\n    ds = tf.data.Dataset.from_tensor_slices((X, y_flat))\n    if shuffle:\n        ds = ds.shuffle(buffer_size=min(10000, len(X)))\n    ds = ds.batch(batch_size, drop_remainder=False).prefetch(tf.data.AUTOTUNE)\n    return ds\n\ntrain_ds = make_dataset(X_train, y_train, BATCH_SIZE, shuffle=True)\nval_ds   = make_dataset(X_val, y_val, BATCH_SIZE, shuffle=False)\n\n# ---------- ساخت مدل و کامپایل با loss ترکیبی ----------\ninput_dim = X_train.shape[1]\nmodel = build_model_light(input_dim, output_flat_dim)\nmodel.summary()\n\nmse = tf.keras.losses.MeanSquaredError()\n\n# custom training step wrapper (برای حفظ mixed precision و محاسبه loss smooth)\noptimizer = tf.keras.optimizers.Adam(learning_rate=LR)\n\n# برای mixed precision: از LossScale استفاده خودکار توسط policy استفاده می‌شود، بنابراین از @tf.function استفاده می‌کنیم.\n@tf.function\ndef train_step(x_batch, y_batch):\n    with tf.GradientTape() as tape:\n        pred = model(x_batch, training=True)  # (batch, output_flat_dim)\n        loss_mse = mse(y_batch, pred)\n        pred_resh = tf.reshape(pred, (-1, max_qpoints, max_bands))\n        loss_smooth = smoothness_loss_from_reshaped(pred_resh)\n        loss = loss_mse + LAMBDA_SMOOTH * loss_smooth\n        # اگر mixed precision فعال است، optimizer خودش scaling را مدیریت می‌کند (policy)\n    grads = tape.gradient(loss, model.trainable_variables)\n    optimizer.apply_gradients(zip(grads, model.trainable_variables))\n    return loss, loss_mse, loss_smooth\n\n@tf.function\ndef val_step(x_batch, y_batch):\n    pred = model(x_batch, training=False)\n    loss_mse = mse(y_batch, pred)\n    pred_resh = tf.reshape(pred, (-1, max_qpoints, max_bands))\n    loss_smooth = smoothness_loss_from_reshaped(pred_resh)\n    loss = loss_mse + LAMBDA_SMOOTH * loss_smooth\n    return loss, loss_mse, loss_smooth\n\n# ---------- چرخهٔ آموزش ساده (می‌تواند جایگزین model.fit شود تا آسان‌تر خطای OOM بررسی شود) ----------\nbest_val = np.inf\npatience_counter = 0\nhistory = {\"train_loss\": [], \"val_loss\": []}\n\nfor epoch in range(1, EPOCHS + 1):\n    # TRAIN\n    train_losses = []\n    for x_batch, y_batch in train_ds:\n        l, lm, ls = train_step(x_batch, y_batch)\n        train_losses.append(l.numpy())\n    train_loss_epoch = float(np.mean(train_losses))\n\n    # VAL\n    val_losses = []\n    for x_batch, y_batch in val_ds:\n        l, lm, ls = val_step(x_batch, y_batch)\n        val_losses.append(l.numpy())\n    val_loss_epoch = float(np.mean(val_losses))\n\n    history[\"train_loss\"].append(train_loss_epoch)\n    history[\"val_loss\"].append(val_loss_epoch)\n\n    print(f\"Epoch {epoch:03d} - train_loss: {train_loss_epoch:.6e}  val_loss: {val_loss_epoch:.6e}\")\n\n    # early stopping ساده\n    if val_loss_epoch < best_val - 1e-12:\n        best_val = val_loss_epoch\n        patience_counter = 0\n        # ذخیره وزن‌ها\n        model.save_weights(os.path.join(out_dir, \"best_model_light.weights.h5\"))\n    else:\n        patience_counter += 1\n        if patience_counter >= PATIENCE:\n            print(f\"Early stopping after {epoch} epochs (no improvement for {PATIENCE} epochs).\")\n            break\n\n# ---------- بارگذاری بهترین وزن و ارزیابی نهایی ----------\nmodel.load_weights(os.path.join(out_dir, \"best_model_light.weights.h5\"))\n\n\n# پیش‌بینی روی تست\nX_test_tensor = X_test.astype(np.float32)\ny_test_flat = y_test.reshape(len(y_test), -1).astype(np.float32)\ny_pred_flat = model.predict(X_test_tensor, batch_size=BATCH_SIZE)\ny_pred = (y_pred_flat * scaler_y_std + scaler_y_mean).reshape(-1, max_qpoints, max_bands)\ny_test_true = (y_test_flat * scaler_y_std + scaler_y_mean).reshape(-1, max_qpoints, max_bands)\n\nr2_scores = [r2_score(y_test_true[i].flatten(), y_pred[i].flatten()) for i in range(len(y_test_true))]\nprint(\"Mean R2:\", np.mean(r2_scores))\nnp.save(os.path.join(out_dir, \"r2_list_light.npy\"), np.array(r2_scores))\n\n# smoothing for one sample and plot\nsample_idx = 0\npred_sample = y_pred[sample_idx]\nwindow_length = 7 if max_qpoints >= 7 else (max_qpoints//2*2+1)\npolyorder = 3\ntry:\n    pred_smooth = np.copy(pred_sample)\n    for b in range(pred_sample.shape[1]):\n        pred_smooth[:, b] = savgol_filter(pred_sample[:, b], window_length=window_length, polyorder=polyorder, mode='interp')\nexcept Exception as e:\n    from scipy.ndimage import gaussian_filter1d\n    pred_smooth = gaussian_filter1d(pred_sample, sigma=0.6, axis=0)\n\nplt.figure(figsize=(10,6))\nfor b in range(pred_sample.shape[1]):\n    plt.plot(pred_sample[:, b], color='C{}'.format(b%10), alpha=0.4)\nfor b in range(pred_smooth.shape[1]):\n    plt.plot(pred_smooth[:, b], color='C{}'.format(b%10), linewidth=1.4)\nplt.title(\"Predicted phonon bands - before & after smoothing (sample 0)\")\nplt.xlabel(\"Q-point\")\nplt.ylabel(\"Frequency (THz)\")\nplt.grid(True)\nplt.savefig(os.path.join(out_dir, \"pred_light_before_after_smooth.png\"))\nplt.show(